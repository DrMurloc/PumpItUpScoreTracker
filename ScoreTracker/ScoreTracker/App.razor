@using System.Globalization
@using Microsoft.AspNetCore.Localization
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Theming
@inject ShellModelFactory ShellFactory
@inject StaticHeadResolver HeadResolver
@inject IWebHostEnvironment Env

@* The document root, rendered statically: the shell paints as real HTML and the app boots into
   the content region under it (docs/design/static-shell.md). Nothing here prerenders. *@
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
    <link href="/css/charts.css" rel="stylesheet" />
    @* The active palette's --mix-* tokens. Server-side: the shell paints before any circuit, and
       MudThemeProvider's own vars only arrive with one. *@
    <style>@((MarkupString)MixThemes.CssVariablesFor(_shell.ThemeMix))</style>
    @* A real head for readers that run no JS, resolved from the route (StaticHeadResolver):
       chart routes get their name, description and jacket; unmatched routes get the bare site
       title and no meta. Blazor removes the title on boot and HeadOutlet takes over, so
       <PageTitle> keeps working unchanged. *@
    <title>@(_head?.Title ?? L["PIU Scores"].Value)</title>
    @if (_head != null)
    {
        <meta name="description" content="@_head.Description" />
        <meta property="og:title" content="@_head.Title" />
        <meta property="og:description" content="@_head.Description" />
        <meta property="og:type" content="website" />
        @if (_head.OgImage != null)
        {
            <meta property="og:image" content="@_head.OgImage" />
        }
        @if (_head.Canonical != null)
        {
            <link rel="canonical" href="@_head.Canonical" />
            <script type="application/ld+json">@((MarkupString)JsonLd(_head))</script>
        }
    }
    @* Interactive, and not prerendered — matching every <PageTitle> in the app. Static, it would
       only ever see static components and every page's title would read "PIU Scores". *@
    <HeadOutlet @rendermode="RenderModes.Interactive" />
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "d2n3fzq6v8");
    </script>
    <style>
        .apexcharts-legend-text {
            color: #ffffff !important
        }

        .apexcharts-tooltip-text-y-value {
            color: #000000 !important;
        }

        .apexcharts-tooltip-text-y-label {
            color: #000000 !important;
        }

        .apexcharts-text tspan {
            fill: #FFFFFF
        }
    </style>
</head>
@* Enhanced navigation off: blazor.web.js turns it on by default, and it fetches and patches the
   DOM instead of loading a page — which the dock's scroll watcher, ApexCharts and Clarity have
   never been asked to survive. The attribute is read through closest(), so one here covers every
   link. Turning it on is its own change, with its own field test. *@
<body data-enhance-nav="false" class="@MixThemes.CssClassFor(_shell.ThemeMix)">
@* Ahead of every island, deliberately. There is one popover provider per circuit and roots
   activate in render order, so an island that asks for a popover before this rendered would get
   "Missing <MudPopoverProvider />". *@
<MudProviders @rendermode="RenderModes.Interactive" ThemeMix="_shell.ThemeMix" />

<header class="shell-appbar">
    <ShellNav Model="_shell" />
    <span class="shell-spacer"></span>
    <AppBarSearch @rendermode="RenderModes.Interactive" Mix="_shell.CurrentMix" />
    <ShellMixMenu Model="_shell" />
    <ShellUserMenu Model="_shell" />
</header>
<ShellMoreSheet Model="_shell" />
<ShellSearchSheet Model="_shell" />
<ShellBottomNav Model="_shell" />
@* Renders nothing; it drives the hidden pulse dot the shell put in the avatar. *@
<ShellImportPulse @rendermode="RenderModes.Interactive" />
@* Renders nothing; it seeds the circuit's ShellContext with the request-resolved mix
   before any page root initializes (roots activate in document order). *@
<ShellMixSeed @rendermode="RenderModes.Interactive" CurrentMix="_shell.CurrentMix" />

<main class="shell-main">
    @* Static: pages declare their own circuits (@rendermode RenderModes.Interactive) and
       every navigation is a full document load. A page converts to static SSR by deleting
       its own line (docs/design/seo-friendly-site.md §7). *@
    <Routes />
</main>

<div id="blazor-error-ui">
    @if (Env.IsDevelopment())
    {
        <text>An unhandled exception has occurred. See browser dev tools for details.</text>
    }
    else
    {
        <text>An error has occurred. This application may no longer respond until reloaded.</text>
    }
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

<script src="_framework/blazor.web.js"></script>
<script src="_content/MudBlazor/MudBlazor.min.js"></script>
<script src="/js/page-dock.js"></script>
<script src="/js/nav.js"></script>
<script src="/js/dashboard-grid.js"></script>
<script src="/js/credential-storage.js"></script>
</body>
</html>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = null!;

    private ShellViewModel _shell = null!;
    private StaticHeadModel? _head;

    // MusicRecording JSON-LD for chart pages — enough for a rich result to name the song and
    // link its image. System.Text.Json escapes the values, so a song title can't break out.
    private static string JsonLd(StaticHeadModel head)
    {
        return System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "MusicRecording",
            ["name"] = head.Title,
            ["description"] = head.Description,
            ["url"] = head.Canonical,
            ["image"] = head.OgImage
        });
    }

    // Resolved here rather than in OnInitializedAsync: an async init renders once at its first
    // await, before it has assigned anything. A page can show a spinner through that render —
    // the document cannot, because every line of it reads the model.
    public override async Task SetParametersAsync(ParameterView parameters)
    {
        parameters.SetParameterProperties(this);
        await Resolve();
        await base.SetParametersAsync(ParameterView.Empty);
    }

    private async Task Resolve()
    {
        _shell = await ShellFactory.BuildAsync(HttpContext);
        _head = await HeadResolver.Resolve(HttpContext.Request.Path, _shell.CurrentMix,
            HttpContext.RequestAborted);
        // Only when it is missing or stale: an unconditional Set-Cookie makes every response
        // uncacheable, and explicit changes already go through /Culture/Set.
        var resolved = CookieRequestCultureProvider.MakeCookieValue(
            new RequestCulture(CultureInfo.CurrentCulture, CultureInfo.CurrentUICulture));
        if (HttpContext.Request.Cookies[CookieRequestCultureProvider.DefaultCookieName] != resolved)
            HttpContext.Response.Cookies.Append(CookieRequestCultureProvider.DefaultCookieName, resolved);
    }
}
