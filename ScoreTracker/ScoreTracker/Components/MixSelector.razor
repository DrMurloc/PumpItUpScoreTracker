@using ScoreTracker.SharedKernel.Enums
@namespace ScoreTracker.Web.Components

@* The mix picker's option list (docs/design/legacy-mixes.md): the primary trio up
   front, and the 28 legacy mixes grouped into the collections the community actually
   thinks in (owner call: a flat list of 28 was unusable). Tapping a collection expands
   its mixes in place — click, not hover, so the same interaction works on the phone
   bottom-nav path. Renders MudMenuItems — embed inside a MudMenu (the app-bar pill). *@

@foreach (var mix in Primary)
{
    <MudMenuItem OnClick="() => Select(mix)">@mix.GetName()</MudMenuItem>
}
@if (!_showLegacy)
{
    <MudMenuItem AutoClose="false" OnClick="() => _showLegacy = true" Icon="@Icons.Material.Filled.History">@L["More Mixes"]</MudMenuItem>
}
else
{
    <MudDivider/>
    @foreach (var collection in Collections)
    {
        var isOpen = _openCollection == collection.Label;
        <MudMenuItem AutoClose="false" OnClick="() => ToggleCollection(collection.Label)"
                     Icon="@(isOpen ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)">@L[collection.Label]</MudMenuItem>
        @if (isOpen)
        {
            @foreach (var mix in collection.Mixes)
            {
                <MudMenuItem OnClick="() => Select(mix)" Style="padding-left: 40px;">@mix.GetName()</MudMenuItem>
            }
        }
    }
}

@code {
    private bool _showLegacy;
    private string? _openCollection;

    [Parameter] public EventCallback<MixEnum> OnSelected { get; set; }

    private static readonly MixEnum[] Primary = Enum.GetValues<MixEnum>()
        .Where(m => m.IsPrimary())
        .OrderByDescending(m => m.DisplayOrder())
        .ToArray();

    // Newest collection first; newest mix first within each — matching the picker's
    // recency ordering everywhere else. Labels are localization keys (proper nouns
    // pass through unchanged in most locales).
    private static readonly (string Label, MixEnum[] Mixes)[] Collections =
    {
        ("Prime", new[] { MixEnum.Prime2, MixEnum.Prime }),
        ("Fiesta", new[] { MixEnum.Fiesta2, MixEnum.FiestaEx, MixEnum.Fiesta }),
        ("NX", new[] { MixEnum.NxAbsolute, MixEnum.Nx2, MixEnum.Nx }),
        ("Exceed / Zero", new[] { MixEnum.Zero, MixEnum.Exceed2, MixEnum.Exceed }),
        ("Premiere / Prex", new[]
        {
            MixEnum.Prex3, MixEnum.Premiere3, MixEnum.Prex2, MixEnum.Premiere2,
            MixEnum.Rebirth, MixEnum.Prex, MixEnum.Premiere
        }),
        ("Classic", new[]
        {
            MixEnum.Extra, MixEnum.PerfectCollection, MixEnum.Collection,
            MixEnum.ObgSeasonEvolution, MixEnum.ThirdObg, MixEnum.SecondUltimateRemix, MixEnum.FirstDanceFloor
        }),
        ("American", new[] { MixEnum.Infinity, MixEnum.Pro2, MixEnum.Pro })
    };

    private void ToggleCollection(string label)
    {
        _openCollection = _openCollection == label ? null : label;
    }

    private async Task Select(MixEnum mix)
    {
        _showLegacy = false;
        _openCollection = null;
        await OnSelected.InvokeAsync(mix);
    }
}
