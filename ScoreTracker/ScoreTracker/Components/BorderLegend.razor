@namespace ScoreTracker.Web.Components

@* The card border language, printed (rule 8: color never travels alone). *@
<div class="border-legend">
    <span class="border-legend-item">
        <span class="border-legend-swatch tier-chart-card-pass"></span>@L["Passed"]
    </span>
    <span class="border-legend-item">
        <span class="border-legend-swatch tier-chart-card-todo"></span>@L["To Do"]
    </span>
    <span class="border-legend-item">
        <span class="border-legend-swatch tier-chart-card-other-mix"></span>@L["Passed in another mix"]
    </span>
</div>
