@namespace ScoreTracker.Web.Components
@using ScoreTracker.Domain.Models
@using ScoreTracker.Domain.Records
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Web.Services.Theming

@* Leaderboard for one chart: EVERY entry, your row highlighted in place — the MaxPlaces cap
   died with the challenges-hub overhaul (weekly-charts-overhaul.md M6); the dialog scrolls
   instead, and pagination stays a future lever. Shared by the Weekly/Daily widgets and the
   challenges page — the caller passes the entries and a sort direction (Limbo Day ranks the
   LOWEST passing score first). Trust ladder (M5): ✔ imported · 📷 photo proof (opens the
   image) · blank for a bare self-report. *@
<MudDialog Visible="Visible" VisibleChanged="VisibleChanged" Options="DialogSizing" Class="weekly-lb-dialog">
    <TitleContent>
        @if (Chart != null)
        {
            <div class="weekly-lb-title">
                <DifficultyBubble Chart="Chart" Small="true"></DifficultyBubble>
                <MudText Typo="Typo.h6">@Chart.Song.Name</MudText>
            </div>
        }
    </TitleContent>
    <DialogContent>
        @if (!_loaded)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary"/>
        }
        else if (!_rows.Any())
        {
            <MudText Typo="Typo.body2">@L["No entries yet."]</MudText>
        }
        else
        {
            @foreach (var row in _rows)
            {
                <div class="weekly-lb-row @(row.IsMe ? "weekly-lb-me" : CommunityUserIds?.Contains(row.Entry.UserId) == true ? "weekly-lb-community" : "")">
                    <span class="weekly-lb-place" style="@ThemeScales.RarityStyle(row.Percentile)">
                        #@row.Place
                    </span>
                    <span class="weekly-lb-user">
                        @if (_users.TryGetValue(row.Entry.UserId, out var user))
                        {
                            <UserLabel User="user"></UserLabel>
                        }
                        @if (OfficialUserIds?.Contains(row.Entry.UserId) == true)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small"
                                     Class="weekly-lb-verified" title="@L["Verified from official import"]"/>
                        }
                        else if (row.Entry.PhotoUrl != null)
                        {
                            @* The optional-photo trust tier: self-reported, proof attached — the
                               icon opens the image (M3: photos exist for disputed legitimacy). *@
                            <MudIconButton Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Small"
                                           Class="weekly-lb-photo" Href="@row.Entry.PhotoUrl.ToString()"
                                           Target="_blank" title="@L["Photo proof"]"/>
                        }
                    </span>
                    <ScoreBreakdown Score="row.Entry.Score" Plate="row.Entry.Plate"
                                    IsBroken="row.Entry.IsBroken" OneLine="true" ShowScore="true">
                    </ScoreBreakdown>
                </div>
            }
            <MudLink Href="/WeeklyCharts" Typo="Typo.caption">@L["See Leaderboards"]</MudLink>
        }
    </DialogContent>
    <DialogActions>
        @if (OfficialUserIds != null)
        {
            <MudText Typo="Typo.caption" Class="weekly-lb-legend">✔ @L["Imported"] · 📷 @L["Photo proof"]</MudText>
        }
        <MudSpacer/>
        <MudButton OnClick="() => VisibleChanged.InvokeAsync(false)">@L["Close"]</MudButton>
    </DialogActions>
</MudDialog>

@inject ICurrentUserAccessor CurrentUser
@inject IUserRepository Users

@code {

    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public Chart? Chart { get; set; }
    [Parameter] public IEnumerable<WeeklyTournamentEntry> Entries { get; set; } = Array.Empty<WeeklyTournamentEntry>();

    /// <summary>Limbo Day inverts the board: passing runs only, lowest score first.</summary>
    [Parameter] public bool Ascending { get; set; }

    /// <summary>
    ///     User ids whose ranked score came from an official import — the ✔ tier. Null hides the
    ///     trust ladder entirely (boards that don't track provenance); a self-reported row with a
    ///     photo renders the 📷 tier from its <c>PhotoUrl</c>, and a bare one renders nothing.
    /// </summary>
    [Parameter] public IReadOnlySet<Guid>? OfficialUserIds { get; set; }

    /// <summary>Optional: user ids in a community you share — their rows glow green.</summary>
    [Parameter] public IReadOnlySet<Guid>? CommunityUserIds { get; set; }

    private static readonly DialogOptions DialogSizing = new()
        { FullWidth = true, MaxWidth = MaxWidth.ExtraSmall, CloseOnEscapeKey = true };

    private sealed record LeaderboardRow(int Place, double Percentile, WeeklyTournamentEntry Entry, bool IsMe);

    private bool _loaded;
    private string? _loadedFor;
    private List<LeaderboardRow> _rows = new();
    private IDictionary<Guid, User> _users = new Dictionary<Guid, User>();

    protected override async Task OnParametersSetAsync()
    {
        if (!Visible || Chart == null) return;
        var signature = $"{Chart.Id}|{Ascending}|{Entries.Count()}";
        if (signature == _loadedFor) return;
        _loadedFor = signature;
        _loaded = false;

        var forChart = Entries.Where(e => e.ChartId == Chart.Id);
        var ordered = (Ascending
                ? forChart.Where(e => !e.IsBroken).OrderBy(e => (int)e.Score)
                : forChart.OrderBy(e => e.IsBroken).ThenByDescending(e => (int)e.Score))
            .ToArray();

        var me = CurrentUser.IsLoggedIn ? CurrentUser.User.Id : (Guid?)null;
        _rows = ordered
            .Select((e, i) => new LeaderboardRow(i + 1, ordered.Length <= 0 ? 0 : 1.0 - (double)(i + 1) / ordered.Length, e,
                e.UserId == me))
            .ToList();

        var users = await Users.GetUsers(_rows.Select(r => r.Entry.UserId).Distinct().ToArray());
        _users = users.ToDictionary(u => u.Id);
        _loaded = true;
    }

}
