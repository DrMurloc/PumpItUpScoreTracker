@using System.ComponentModel.DataAnnotations
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Web.Services.Theming
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType
@namespace ScoreTracker.Web.Components
@inject ChartScoringLevels ScoringLevels
@if (Chart != null || (Type != null && Level != null))
{
    @* MudTooltip renders a popover, which throws in static SSR (no provider in the static
       tree). The tooltip is a hover affordance, so a static render drops it and keeps the
       bubble; in a circuit it comes back. *@
    @if (RendererInfo.IsInteractive)
    {
        <MudTooltip ShowOnFocus="true" Placement="Placement.Right">
            <ChildContent>@Bubble</ChildContent>
            <TooltipContent>
                @if (Chart != null)
                {
                    <MudText Typo="Typo.caption">@Chart.Song.Name @(UseLegacyChip ? ChipText : Chart.DifficultyString)</MudText><br/>
                    @if (UseLegacyChip && Chart.Slot != null)
                    {
                        <MudText Typo="Typo.caption">@Chart.Mix.GetName() @L["scale"] — @L["not comparable to modern levels"]</MudText><br/>
                    }
                    <MudText Typo="Typo.caption">@Chart.StepArtist</MudText><br/>
                    <MudText Typo="Typo.caption">@ScoringLevelString</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption">@DiffString</MudText>
                }
            </TooltipContent>
        </MudTooltip>
    }
    else
    {
        @Bubble
    }
}
@code {
    private RenderFragment Bubble => UseLegacyChip
        ? @<span tabindex="0" class="legacy-chip" style="border-color:@ThemeScales.SlotColor(Chart?.Slot);color:@ThemeScales.SlotColor(Chart?.Slot);font-size:@(Small ? ".62rem" : ".78rem");">@ChipText</span>
        @* Legacy chips are deliberately rendered, not image bubbles: pre-Exceed slots have no
           official art, and looking different from the modern bubbles IS the message — these
           numbers live on a different scale (docs/design/legacy-mixes.md). *@
        : @<MudImage tabindex="0" Src="@DifficultyBubblePath" Height="Height ?? (Small ? 22 : 35)" Alt="@DiffString" ObjectFit="ObjectFit.ScaleDown"></MudImage>;

    private double? _scoringLevel;
    private string ScoringLevelString => _scoringLevel == null ? "" : $"{_scoringLevel:0.0}";

    protected override async Task OnParametersSetAsync()
    {
        _scoringLevel = Chart == null ? null : await ScoringLevels.GetScoringLevel(Chart.Id);
    }

    [Parameter]
    public Chart? Chart { get; set; }

    // Chart-less mode (owner 2026-07-13): render a modern bubble straight from a type + level
    // (+ mix) when there's no full Chart — e.g. a folder label. No legacy/slot handling here.
    [Parameter]
    public ChartType? Type { get; set; }

    [Parameter]
    public DifficultyLevel? Level { get; set; }

    [Parameter]
    public MixEnum? Mix { get; set; }

    [Parameter]
    public bool Small { get; set; } = false;

    [Parameter]
    public int? Height { get; set; }

    private ChartType? EffectiveType => Chart?.Type ?? Type;
    private MixEnum? EffectiveMix => Chart?.Mix ?? Mix;

    private string DiffString => Chart?.DifficultyString
                                 ?? (Type != null && Level != null
                                     ? $"{Type.Value.GetShortHand()}{(int)Level.Value}"
                                     : string.Empty);

    // Chip cases: pre-Exceed slots, Half-Double (no bubble art exists in any set),
    // and legacy co-ops that carry a real difficulty next to their player count. The
    // chart-less path only ever hits the Half-Double case.
    private bool UseLegacyChip =>
        (Chart != null &&
         (Chart.Slot != null ||
          Chart.Type == ChartType.HalfDouble ||
          (Chart.Type == ChartType.CoOp && Chart.Mix.UsesLegacyScoring() && Chart.Level != Chart.PlayerCount)))
        || (Chart == null && Type == ChartType.HalfDouble);

    private string ChipText => Chart != null
        ? Chart.Slot != null
            ? $"{Chart.Slot.Value.GetName().ToUpperInvariant()} {Chart.Level}"
            : Chart.Type == ChartType.CoOp
                ? $"CO-OP ×{Chart.PlayerCount} · {Chart.Level}"
                : $"HDB {Chart.Level}"
        : Level != null
            ? $"HDB {(int)Level.Value}"
            : DiffString;

    // Modern mixes keep their per-mix bubble art; every numbered legacy mix
    // (Exceed → Prime 2, Infinity, Pro) reuses the XX image set — same S/D notation,
    // zero new assets. SP/DP predate per-mix art and were always served flat.
    public string DifficultyBubblePath =>
        EffectiveType == ChartType.DoublePerformance || EffectiveType == ChartType.SinglePerformance ||
        EffectiveMix == MixEnum.XX || EffectiveMix?.UsesLegacyScoring() == true
            ? $"https://piuimages.arroweclip.se/difficulty/{DiffString.ToLower()}.png"
            : $"https://piuimages.arroweclip.se/difficulty/{EffectiveMix}/{DiffString.ToLower()}.png";

}
