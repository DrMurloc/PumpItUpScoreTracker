@using ScoreTracker.ChartIntelligence.Contracts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Web.Services
@namespace ScoreTracker.Web.Components

@* One card on the similar-charts shelf (docs/design/chart-similarity.md, mock approved
   2026-07-15). Two jobs that fight each other: it must be a real <a href> so crawlers
   follow it — the shelf IS the internal-link mesh — and it must let you watch, because
   "this chart is similar" is only half an answer. A <button> cannot live inside an <a>,
   so the play control is a SIBLING overlaid on the art, never a child of the link.
   The art is 16:9 because that is the shape of a video: the iframe drops into the art's
   exact box, so watching costs no reflow and the grid never jumps. A square jacket would
   have to grow or letterbox, and either shoves every card below it down the page.
   Nothing loads until asked — six embeds on page load would outweigh the rest of it. *@
<div class="chart-card">
    @if (_playing && VideoUrl != null)
    {
        <div class="chart-card-link">
            <span class="chart-card-art chart-card-art-playing">
                <iframe class="chart-card-video" src="@($"{VideoUrl}?autoplay=1")" allow="autoplay; encrypted-media"
                        allowfullscreen title="@Chart.Song.Name"></iframe>
                <span class="chart-card-bubble"><DifficultyBubble Chart="Chart" Small="true"></DifficultyBubble></span>
            </span>
            @Body()
        </div>
        <button type="button" class="chart-card-close" @onclick="() => _playing = false"
                aria-label="@L["Close video"]">✕</button>
    }
    else
    {
        <a class="chart-card-link" href="@Href">
            <span class="chart-card-art">
                <SongImage Song="Chart.Song" Height="128"></SongImage>
                <span class="chart-card-bubble"><DifficultyBubble Chart="Chart" Small="true"></DifficultyBubble></span>
            </span>
            @Body()
        </a>
        @if (VideoUrl != null)
        {
            <span class="chart-card-playzone">
                <button type="button" class="chart-card-play" @onclick="() => _playing = true"
                        aria-label="@L["Watch {0}", Chart.Song.Name]"></button>
            </span>
        }
    }
</div>

@code {
    [Parameter, EditorRequired]
    public Chart Chart { get; set; } = default!;

    [Parameter, EditorRequired]
    public ChartSimilarityRecord Record { get; set; } = default!;

    /// <summary>The anchor's NPS, so the intensity chip can say what it is comparing to.</summary>
    [Parameter]
    public decimal? AnchorNps { get; set; }

    [Parameter]
    public decimal? Nps { get; set; }

    /// <summary>Null when the chart has no video banked — the play affordance is then absent, not dead.</summary>
    [Parameter]
    public string? VideoUrl { get; set; }

    private bool _playing;

    private string Href => $"/Chart/{Chart.Id}";

    /// <summary>
    ///     Shared with the playing state so the card's text never moves when the art
    ///     becomes a video — only the art's contents change.
    /// </summary>
    private RenderFragment Body() =>
        @<span class="chart-card-body">
            <span class="chart-card-title">
                <h3>@Chart.Song.Name</h3>
                <span class="chart-card-pct">@((int)Math.Round(Record.Score * 100))%</span>
            </span>
            <span class="chart-card-meta">
                @if (Chart.StepArtist != null && Chart.StepArtist.ToString() != "Unknown")
                {
                    <em>@Chart.StepArtist</em><i>·</i>
                }
                @Chart.OriginalMix.GetName()
                @if (Chart.Song.Bpm != null || Nps != null)
                {
                    <br/>
                    @if (Chart.Song.Bpm != null)
                    {
                        <text>@L["{0} BPM", Chart.Song.Bpm.Value.ToString()]</text>
                    }
                    @if (Chart.Song.Bpm != null && Nps != null)
                    {
                        <i>·</i>
                    }
                    @if (Nps != null)
                    {
                        <text>@L["{0} NPS", Nps.Value.ToString("0.0")]</text>
                    }
                }
            </span>
            @if (Reasons.Count > 0 || IntensityReason != null)
            {
                <span class="chart-card-wl">@L["Matched on"]</span>
                <span class="chart-card-why">
                    @foreach (var reason in Reasons)
                    {
                        <b>@reason.Label<var>@reason.Value</var></b>
                    }
                    @if (IntensityReason != null)
                    {
                        <b class="chart-card-why-intensity">@L["NPS"]<var>@IntensityReason</var></b>
                    }
                </span>
            }
        </span>;

    /// <summary>
    ///     What the pair actually matched on, named — never "skills match", which reads as
    ///     broken. The value is the coverage the two charts SHARE, so "Brackets 50%" says
    ///     both are at least half brackets.
    /// </summary>
    internal IReadOnlyList<(string Label, string Value)> Reasons =>
        Record.SharedBadges
            .Where(b => b.Coverage >= MinimumReasonCoverage)
            .Take(MaximumReasons)
            .Select(b => (L[SimilarityBadgeLabels.For(b.Badge)].ToString(),
                $"{(int)Math.Round(b.Coverage * 100)}%"))
            .ToArray();

    /// <summary>
    ///     Intensity's own chip, in its own colour: a different KIND of reason, and it must
    ///     not read as a skill. Both NPS values are needed to say anything honest — "NPS" on
    ///     its own is a label, "10.7 → 11.9" is a fact the reader can judge.
    /// </summary>
    internal string? IntensityReason =>
        AnchorNps != null && Nps != null ? $"{AnchorNps.Value:0.0} → {Nps.Value:0.0}" : null;

    internal const double MinimumReasonCoverage = 0.15;
    internal const int MaximumReasons = 3;
}
