@using ScoreTracker.ScoreLedger.Contracts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.SharedKernel.ValueTypes
@namespace ScoreTracker.Web.Components
<div class="d-flex align-center gap-2 mt-6 mb-1">
    <MudText Typo="Typo.h6">@L["Score Journal"]</MudText>
    <MudSpacer/>
    <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download"
               Href="@ExportUrl" Target="_blank" data-testid="export-journal">
        @L["Export CSV"]
    </MudButton>
</div>
<MudSimpleTable Dense="true" Hover="true" data-testid="journal-table">
    <thead>
    <tr>
        <th>@L["When"]</th>
        <th>@L["Chart"]</th>
        <th style="text-align:right">@L["Score"]</th>
        <th>@L["Result"]</th>
        <th>@L["Source"]</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var row in Rows)
    {
        var chart = Charts.GetValueOrDefault(row.ChartId);
        <tr>
            <td>@row.OccurredAt.ToLocalTime().ToString("g")</td>
            <td>
                @if (chart != null)
                {
                    <DifficultyBubble Chart="chart" Small="true"></DifficultyBubble>
                    <MudLink Href="@($"/Chart/{chart.Id}")">@chart.Song.Name</MudLink>
                }
            </td>
            <td style="text-align:right">@(row.Score?.ToString("N0") ?? "—")</td>
            <td>
                <ClassificationChip Classification="row.Classification"></ClassificationChip>
                @if (row.Score != null)
                {
                    <ScoreBreakdown Score="PhoenixScore.From(row.Score.Value)" IsBroken="row.IsBroken"
                                    Plate="PhoenixPlateHelperMethods.TryParse(row.Plate)"></ScoreBreakdown>
                }
            </td>
            <td><MudText Typo="Typo.caption">@row.Source</MudText></td>
        </tr>
    }
    </tbody>
</MudSimpleTable>

@code {
    [Parameter] [EditorRequired] public IReadOnlyList<RecentSessionsPage.ScoreEventRecord> Rows { get; set; } = null!;
    [Parameter] public IReadOnlyDictionary<Guid, Chart> Charts { get; set; } = new Dictionary<Guid, Chart>();
    [Parameter] [EditorRequired] public string ExportUrl { get; set; } = string.Empty;
}
