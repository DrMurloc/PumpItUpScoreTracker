@namespace ScoreTracker.Web.Components
@using ScoreTracker.Domain.Models
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Services.Theming
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType
@inject ICurrentUserAccessor CurrentUser

@* The randomizer's settings surface (docs/design/randomizer-overhaul.md, field-test
   round 2): range sliders are the front door; Advanced Filters is a stack of opt-in
   sections that stay collapsed until enabled. Basic and advanced never fight — while a
   Dynamic Weights section owns a chart type, its basic control disables; opting out
   (tap-again confirmed) snaps the data back to the slider's contiguous range. Mix is a
   property of the settings, defaulting to the site mix. The page owns the drawer
   chrome and the live match-count footer. *@
<div class="rand-settings">
    <div class="rand-settings-row">
        <MudSelect T="MixEnum" Value="Mix" ValueChanged="SetMix" Label="@L["Mix"]" Dense="true"
                   Variant="Variant.Outlined" Margin="Margin.Dense">
            @foreach (var mix in MixThemes.ThemedMixes)
            {
                <MudSelectItem T="MixEnum" Value="mix">@mix.GetName()</MudSelectItem>
            }
        </MudSelect>
    </div>

    <div class="rand-settings-row">
        <span class="rand-settings-label">@L["Cards per draw"]</span>
        <div class="rand-count-presets">
            @foreach (var preset in CountPresets)
            {
                <button type="button" class="rand-count-preset @(Settings.Count == preset ? "on" : null)"
                        @onclick="() => SetCount(preset)">@preset</button>
            }
            <MudNumericField T="int" Min="1" Max="30" Value="Settings.Count" ValueChanged="SetCount"
                             Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true"
                             Class="rand-count-custom" aria-label="@L["Cards per draw"]"></MudNumericField>
        </div>
        @if (MinimumsTotal > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Warning">@L["{0} Charts From Minimums", MinimumsTotal]</MudText>
        }
    </div>

    <div class="rand-settings-row">
        <div class="rand-type-head">
            <span class="rand-settings-label">@L["Singles"]</span>
            @if (IsOpen(AdvSection.SinglesWeights))
            {
                <MudText Typo="Typo.caption" Class="rand-owned-note">@L["Managed by Dynamic Weights"]</MudText>
            }
            else
            {
                <MudSwitch T="bool" Color="Color.Primary" Value="SinglesOn" ValueChanged="ToggleSingles"
                           aria-label="@L["Singles"]"></MudSwitch>
            }
        </div>
        <LevelRangeSlider Label="@L["Singles"].ToString()" Prefix="S" Min="MinLevel" Max="MaxLevel"
                          ValueMin="SinglesRange.min" ValueMax="SinglesRange.max"
                          Disabled="@(!SinglesOn || IsOpen(AdvSection.SinglesWeights))"
                          ValueMinChanged="v => SetSinglesRange(v, SinglesRange.max)"
                          ValueMaxChanged="v => SetSinglesRange(SinglesRange.min, v)"></LevelRangeSlider>
    </div>

    <div class="rand-settings-row">
        <div class="rand-type-head">
            <span class="rand-settings-label">@L["Doubles"]</span>
            @if (IsOpen(AdvSection.DoublesWeights))
            {
                <MudText Typo="Typo.caption" Class="rand-owned-note">@L["Managed by Dynamic Weights"]</MudText>
            }
            else
            {
                <MudSwitch T="bool" Color="Color.Primary" Value="DoublesOn" ValueChanged="ToggleDoubles"
                           aria-label="@L["Doubles"]"></MudSwitch>
            }
        </div>
        <LevelRangeSlider Label="@L["Doubles"].ToString()" Prefix="D" Min="MinLevel" Max="MaxLevel"
                          ValueMin="DoublesRange.min" ValueMax="DoublesRange.max"
                          Disabled="@(!DoublesOn || IsOpen(AdvSection.DoublesWeights))"
                          ValueMinChanged="v => SetDoublesRange(v, DoublesRange.max)"
                          ValueMaxChanged="v => SetDoublesRange(DoublesRange.min, v)"></LevelRangeSlider>
    </div>

    <div class="rand-settings-row">
        <div class="rand-type-head">
            <span class="rand-settings-label">@L["Co-Op"]</span>
            @if (IsOpen(AdvSection.CoOpWeights))
            {
                <MudText Typo="Typo.caption" Class="rand-owned-note">@L["Managed by Dynamic Weights"]</MudText>
            }
        </div>
        <div class="rand-coop-chips">
            @foreach (var players in Settings.PlayerCountWeights.Keys.OrderBy(k => k))
            {
                var count = players;
                <button type="button" disabled="@IsOpen(AdvSection.CoOpWeights)"
                        class="rand-coop-chip @(Settings.PlayerCountWeights[count] > 0 ? "on" : null)"
                        @onclick="() => ToggleCoOp(count)">×@count</button>
            }
        </div>
    </div>

    <MudSwitch T="bool" Color="Color.Primary" Label="@L["Allow Repeat Charts"]" Value="Settings.AllowRepeats"
               ValueChanged="SetAllowRepeats"></MudSwitch>

    <div class="rand-settings-row">
        <button type="button" class="rand-advanced-toggle" @onclick="() => _showAdvanced = !_showAdvanced"
                aria-expanded="@_showAdvanced">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small"></MudIcon>
            @L["Advanced Filters"]
            <MudIcon Icon="@(_showAdvanced ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                     Size="Size.Small" Class="rand-advanced-caret"></MudIcon>
        </button>
        @if (_showAdvanced)
        {
            <div class="rand-advanced-body">
                @Section(AdvSection.SinglesWeights, L["Dynamic Singles Weights"],
                    @<FolderWeightList Weights="Settings.LevelWeights" Type="ChartType.Single" Changed="Notify"></FolderWeightList>)

                @Section(AdvSection.DoublesWeights, L["Dynamic Doubles Weights"],
                    @<FolderWeightList Weights="Settings.DoubleLevelWeights" Type="ChartType.Double" Changed="Notify"></FolderWeightList>)

                @Section(AdvSection.CoOpWeights, L["Dynamic Co-Op Weights"],
                    @<div class="rand-section-body">
                        <FolderWeightList Weights="Settings.PlayerCountWeights" Type="ChartType.CoOp" Changed="Notify"></FolderWeightList>
                        <div class="rand-coop-bounds">
                            <MudNumericField T="double?" Value="Settings.MinCoOpLevel" ValueChanged="SetMinCoOpLevel"
                                             Label="@L["Min CoOp Scoring Level"]" Clearable="true" Min="0"
                                             Max="Settings.MaxCoOpLevel ?? DifficultyLevel.Max" Variant="Variant.Outlined"
                                             Margin="Margin.Dense"></MudNumericField>
                            <MudNumericField T="double?" Value="Settings.MaxCoOpLevel" ValueChanged="SetMaxCoOpLevel"
                                             Label="@L["Max CoOp Scoring Level"]" Clearable="true"
                                             Min="Settings.MinCoOpLevel ?? 0" Max="DifficultyLevel.Max"
                                             Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                        </div>
                    </div>)

                @Section(AdvSection.SongTypes, L["Song Types"],
                    @<div class="rand-section-body">
                        @foreach (var songType in Settings.SongTypeWeights.Keys)
                        {
                            var captured = songType;
                            <MudSwitch T="bool" Color="Color.Primary" Label="@L[captured.ToString()]"
                                       Value="Settings.SongTypeWeights[captured] > 0"
                                       ValueChanged="v => SetSongType(captured, v)"></MudSwitch>
                        }
                    </div>)

                @Section(AdvSection.Minimums, L["Minimum Counts"], MinimumsBody)

                @if (CurrentUser.IsLoggedIn)
                {
                    @Section(AdvSection.PersonalScores, L["Filter By Personal Scores"], PersonalScoresBody)
                }

                <div class="rand-plain-rows">
                    <MudSwitch T="bool" Color="Color.Primary" Label="@L["Use Scoring Level"]"
                               Value="Settings.UseScoringLevels" ValueChanged="SetUseScoringLevels"></MudSwitch>
                    <MudSelect T="RandomSettings.ResultsOrdering" Value="Settings.Ordering" ValueChanged="SetOrdering"
                               Label="@L["Results Order"]" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var option in Enum.GetValues<RandomSettings.ResultsOrdering>())
                        {
                            <MudSelectItem T="RandomSettings.ResultsOrdering" Value="option">@L[option.ToString()]</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
        }
    </div>
</div>

@code {

    private static readonly int[] CountPresets = { 3, 5, 7, 10 };

    private enum AdvSection
    {
        SinglesWeights,
        DoublesWeights,
        CoOpWeights,
        SongTypes,
        Minimums,
        PersonalScores
    }

    private bool _showAdvanced;
    private readonly HashSet<AdvSection> _opened = new();
    private AdvSection? _confirmingOff;
    private RandomSettings? _derivedFor;

    private string _minimumType = "Chart Type";
    private int _bucketSize = 1;
    private IReadOnlyCollection<string> _newCustomBuckets = new List<string>();

    [Parameter] public RandomSettings Settings { get; set; } = new();

    [Parameter] public MixEnum Mix { get; set; } = MixEnum.Phoenix;

    [Parameter] public EventCallback<MixEnum> MixChanged { get; set; }

    /// <summary>Raised after any change — the page debounces the live match count off it.</summary>
    [Parameter] public EventCallback SettingsChanged { get; set; }

    private static int MinLevel => (int)DifficultyLevel.Min;
    private static int MaxLevel => (int)DifficultyLevel.Max;

    // Score filters ride Phoenix scoring (PhoenixLetterGrade, Phoenix records); older
    // scales don't translate (legacy-mixes design).
    private bool PlayerFiltersAvailable => Mix is MixEnum.Phoenix or MixEnum.Phoenix2;

    private bool SinglesOn => Settings.LevelWeights.Any(kv => kv.Value > 0);
    private bool DoublesOn => Settings.DoubleLevelWeights.Any(kv => kv.Value > 0);

    private (int min, int max) SinglesRange => RangeOf(Settings.LevelWeights);
    private (int min, int max) DoublesRange => RangeOf(Settings.DoubleLevelWeights);

    private int MinimumsTotal => Settings.CustomMinimums.Sum(kv => kv.Value)
                                 + Settings.ChartTypeLevelMinimums.Sum(kv => kv.Value ?? 0)
                                 + Settings.LevelMinimums.Sum(kv => kv.Value ?? 0)
                                 + Settings.ChartTypeMinimums.Sum(kv => kv.Value ?? 0);

    protected override void OnParametersSet()
    {
        // Re-derive which sections are lit whenever a different settings object arrives
        // (saved-settings load, reset) — the data says which sections it needs.
        if (ReferenceEquals(_derivedFor, Settings)) return;

        _derivedFor = Settings;
        _confirmingOff = null;
        _opened.Clear();
        if (IsDynamic(Settings.LevelWeights)) _opened.Add(AdvSection.SinglesWeights);
        if (IsDynamic(Settings.DoubleLevelWeights)) _opened.Add(AdvSection.DoublesWeights);
        if (IsDynamic(Settings.PlayerCountWeights) || Settings.MinCoOpLevel != null || Settings.MaxCoOpLevel != null)
            _opened.Add(AdvSection.CoOpWeights);
        // Some-but-not-all zeroed = a deliberate filter; all-zero is the meaningless
        // fresh state (the page normalizes it to all-1) and derives nothing.
        if (Settings.SongTypeWeights.Any(kv => kv.Value == 0) && Settings.SongTypeWeights.Any(kv => kv.Value > 0))
            _opened.Add(AdvSection.SongTypes);
        if (MinimumsTotal > 0) _opened.Add(AdvSection.Minimums);
        if (Settings.ClearStatus != null || Settings.LetterGrades.Any()) _opened.Add(AdvSection.PersonalScores);
        if (_opened.Any()) _showAdvanced = true;
    }

    // Dynamic = anything the slider can't express: gaps in the run or weights above 1.
    private static bool IsDynamic(IDictionary<int, int> weights)
    {
        var active = weights.Where(kv => kv.Value > 0).ToArray();
        if (!active.Any()) return false;
        if (active.Any(kv => kv.Value > 1)) return true;

        var keys = active.Select(kv => kv.Key).ToArray();
        return keys.Max() - keys.Min() + 1 != keys.Length;
    }

    private bool IsOpen(AdvSection section)
    {
        return _opened.Contains(section);
    }

    private RenderFragment Section(AdvSection section, string title, RenderFragment body)
    {
        return @<div class="rand-adv-section">
                   <div class="rand-adv-section-head">
                       <MudSwitch T="bool" Color="Color.Primary" Value="IsOpen(section)"
                                  ValueChanged="on => ToggleSection(section, on)" Label="@title"></MudSwitch>
                       @if (_confirmingOff == section)
                       {
                           <MudText Typo="Typo.caption" Color="Color.Warning">@L["Tap again to turn off and clear"]</MudText>
                       }
                   </div>
                   @if (IsOpen(section))
                   {
                       <div class="rand-adv-section-content">@body</div>
                   }
               </div>;
    }

    private async Task ToggleSection(AdvSection section, bool on)
    {
        if (on)
        {
            _confirmingOff = null;
            _opened.Add(section);
            await Notify();
            return;
        }

        // Opting out clears the section's config — destructive, so it takes two taps.
        if (_confirmingOff != section)
        {
            _confirmingOff = section;
            return;
        }

        _confirmingOff = null;
        _opened.Remove(section);
        ClearSection(section);
        await Notify();
    }

    private void ClearSection(AdvSection section)
    {
        switch (section)
        {
            case AdvSection.SinglesWeights:
                SnapToRange(Settings.LevelWeights);
                break;
            case AdvSection.DoublesWeights:
                SnapToRange(Settings.DoubleLevelWeights);
                break;
            case AdvSection.CoOpWeights:
                foreach (var key in Settings.PlayerCountWeights.Keys.ToArray())
                    Settings.PlayerCountWeights[key] = Settings.PlayerCountWeights[key] > 0 ? 1 : 0;
                Settings.MinCoOpLevel = null;
                Settings.MaxCoOpLevel = null;
                break;
            case AdvSection.SongTypes:
                foreach (var key in Settings.SongTypeWeights.Keys.ToArray()) Settings.SongTypeWeights[key] = 1;
                break;
            case AdvSection.Minimums:
                Settings.ClearChartTypeMinimums();
                Settings.ClearLevelMinimums();
                Settings.ClearChartTypeLevelMinimums();
                Settings.ClearCustomMinimums();
                break;
            case AdvSection.PersonalScores:
                Settings.ClearStatus = null;
                Settings.LetterGrades.Clear();
                break;
        }
    }

    // Back to what the slider can express: the active span as a contiguous run of 1s.
    private static void SnapToRange(IDictionary<int, int> weights)
    {
        var (min, max) = RangeOf(weights);
        WriteRange(weights, min, max);
    }

    private static (int min, int max) RangeOf(IDictionary<int, int> weights)
    {
        var active = weights.Where(kv => kv.Value > 0).Select(kv => kv.Key).ToArray();
        // The dormant default range a re-enabled switch comes back to.
        return active.Length == 0 ? (15, 18) : (active.Min(), active.Max());
    }

    private static void WriteRange(IDictionary<int, int> weights, int min, int max)
    {
        foreach (var key in weights.Keys.ToArray()) weights[key] = key >= min && key <= max ? 1 : 0;
    }

    private async Task Notify()
    {
        await SettingsChanged.InvokeAsync();
    }

    private async Task SetMix(MixEnum mix)
    {
        Mix = mix;
        if (!PlayerFiltersAvailable)
        {
            Settings.ClearStatus = null;
            Settings.LetterGrades.Clear();
            _opened.Remove(AdvSection.PersonalScores);
        }

        await MixChanged.InvokeAsync(mix);
        await Notify();
    }

    private async Task SetCount(int count)
    {
        Settings.Count = count;
        await Notify();
    }

    private async Task ToggleSingles(bool on)
    {
        if (on) WriteRange(Settings.LevelWeights, 15, 18);
        else foreach (var key in Settings.LevelWeights.Keys.ToArray()) Settings.LevelWeights[key] = 0;
        await Notify();
    }

    private async Task ToggleDoubles(bool on)
    {
        if (on) WriteRange(Settings.DoubleLevelWeights, 15, 18);
        else foreach (var key in Settings.DoubleLevelWeights.Keys.ToArray()) Settings.DoubleLevelWeights[key] = 0;
        await Notify();
    }

    private async Task SetSinglesRange(int min, int max)
    {
        WriteRange(Settings.LevelWeights, min, max);
        await Notify();
    }

    private async Task SetDoublesRange(int min, int max)
    {
        WriteRange(Settings.DoubleLevelWeights, min, max);
        await Notify();
    }

    private async Task ToggleCoOp(int players)
    {
        Settings.PlayerCountWeights[players] = Settings.PlayerCountWeights[players] > 0 ? 0 : 1;
        await Notify();
    }

    private async Task SetSongType(SongType type, bool on)
    {
        Settings.SongTypeWeights[type] = on ? 1 : 0;
        await Notify();
    }

    private async Task SetMinCoOpLevel(double? value)
    {
        Settings.MinCoOpLevel = value;
        await Notify();
    }

    private async Task SetMaxCoOpLevel(double? value)
    {
        Settings.MaxCoOpLevel = value;
        await Notify();
    }

    private async Task SetUseScoringLevels(bool on)
    {
        Settings.UseScoringLevels = on;
        await Notify();
    }

    private async Task SetOrdering(RandomSettings.ResultsOrdering ordering)
    {
        Settings.Ordering = ordering;
        await Notify();
    }

    private async Task SetAllowRepeats(bool allow)
    {
        Settings.AllowRepeats = allow;
        await Notify();
    }

    private async Task ToggleGrade(PhoenixLetterGrade grade)
    {
        if (!Settings.LetterGrades.Remove(grade)) Settings.LetterGrades.Add(grade);
        await Notify();
    }

    private async Task SetClearStatus(bool? status)
    {
        Settings.ClearStatus = status;
        await Notify();
    }

    private async Task SetChartTypeMinimum(ChartType type, int? minimum)
    {
        Settings.ClearLevelMinimums();
        Settings.ClearChartTypeLevelMinimums();
        Settings.ClearCustomMinimums();
        Settings.ChartTypeMinimums[type] = minimum;
        await Notify();
    }

    private async Task SetLevelMinimum(int level, int? minimum)
    {
        Settings.ClearChartTypeMinimums();
        Settings.ClearChartTypeLevelMinimums();
        Settings.ClearCustomMinimums();
        Settings.LevelMinimums[level] = minimum;
        await Notify();
    }

    private async Task SetChartTypeLevelMinimum(string shortHand, int? minimum)
    {
        Settings.ClearChartTypeMinimums();
        Settings.ClearLevelMinimums();
        Settings.ClearCustomMinimums();
        Settings.ChartTypeLevelMinimums[shortHand] = minimum;
        await Notify();
    }

    private async Task AddBucket()
    {
        Settings.ClearChartTypeMinimums();
        Settings.ClearLevelMinimums();
        Settings.ClearChartTypeLevelMinimums();
        Settings.CustomMinimums[string.Join(",", _newCustomBuckets)] = _bucketSize;
        _bucketSize = 1;
        _newCustomBuckets = new List<string>();
        await Notify();
    }

    private async Task RemoveBucket(string key)
    {
        Settings.CustomMinimums.Remove(key);
        await Notify();
    }

    private RenderFragment PersonalScoresBody => @<div class="rand-section-body @(PlayerFiltersAvailable ? null : "rand-settings-gated")">
        @if (PlayerFiltersAvailable)
        {
            <div class="rand-my-results">
                <button type="button" class="rand-seg @(Settings.ClearStatus == null ? "on" : null)"
                        @onclick="() => SetClearStatus(null)">@L["Any"]</button>
                <button type="button" class="rand-seg @(Settings.ClearStatus == false ? "on" : null)"
                        @onclick="() => SetClearStatus(false)">@L["Not Passed"]</button>
                <button type="button" class="rand-seg @(Settings.ClearStatus == true ? "on" : null)"
                        @onclick="() => SetClearStatus(true)">@L["Passed"]</button>
            </div>
            <div class="rand-grade-chips">
                @for (var grade = PhoenixLetterGrade.A; grade <= PhoenixLetterGrade.SSSPlus; grade++)
                {
                    var letterGrade = grade;
                    <button type="button" class="rand-grade-chip @(Settings.LetterGrades.Contains(letterGrade) ? "on" : null)"
                            @onclick="() => ToggleGrade(letterGrade)">@letterGrade.GetName()</button>
                }
            </div>
        }
        else
        {
            <MudText Typo="Typo.caption" Class="rand-gated-reason">@L["Score filters need Phoenix scoring — not available for this mix yet"]</MudText>
        }
    </div>;

    private RenderFragment MinimumsBody => @<div class="rand-section-body">
        <MudRadioGroup T="string" Value="_minimumType" ValueChanged="v => _minimumType = v">
            <MudRadio Value="@("Chart Type")" Color="Color.Primary">@L["Chart Type"]</MudRadio>
            <MudRadio Value="@("Difficulty")" Color="Color.Primary">@L["Difficulty Level"]</MudRadio>
            <MudRadio Value="@("Chart Type Difficulty")" Color="Color.Primary">@L["Chart Type"] + @L["Difficulty Level"]</MudRadio>
            <MudRadio Value="@("Buckets")" Color="Color.Primary">@L["Buckets"]</MudRadio>
        </MudRadioGroup>
        <MudGrid>
            @if (_minimumType == "Chart Type")
            {
                @foreach (var kv in Settings.ChartTypeMinimums.Where(kv => (kv.Key == ChartType.Single ? Settings.LevelWeights :
                              kv.Key == ChartType.Double ? Settings.DoubleLevelWeights : Settings.PlayerCountWeights)
                              .Any(g => g.Value > 0)))
                {
                    <MudItem xs="4">
                        <MudNumericField T="int?" Min="0" Value="Settings.ChartTypeMinimums[kv.Key]"
                                         ValueChanged="v => SetChartTypeMinimum(kv.Key, v)" Label="@kv.Key.ToString()"
                                         Clearable="true" HideSpinButtons="true"></MudNumericField>
                    </MudItem>
                }
            }
            else if (_minimumType == "Difficulty")
            {
                @foreach (var kv in Settings.LevelMinimums.Where(k => Settings.LevelWeights[k.Key] > 0 || Settings.DoubleLevelWeights[k.Key] > 0))
                {
                    <MudItem xs="4">
                        <MudNumericField T="int?" Min="0" Value="Settings.LevelMinimums[kv.Key]"
                                         ValueChanged="v => SetLevelMinimum(kv.Key, v)" Label="@kv.Key.ToString()"
                                         Clearable="true" HideSpinButtons="true"></MudNumericField>
                    </MudItem>
                }
            }
            else if (_minimumType == "Chart Type Difficulty")
            {
                @foreach (var kv in Settings.LevelWeights.Where(kv => kv.Value > 0).Select(kv => $"S{kv.Key}")
                              .Concat(Settings.DoubleLevelWeights.Where(kv => kv.Value > 0).Select(kv => $"D{kv.Key}"))
                              .Concat(Settings.PlayerCountWeights.Where(kv => kv.Value > 0).Select(kv => $"CoOp{kv.Key}")))
                {
                    var captured = kv;
                    <MudItem xs="4" sm="3">
                        <MudNumericField T="int?" Min="0" Value="Settings.ChartTypeLevelMinimums[captured]"
                                         ValueChanged="v => SetChartTypeLevelMinimum(captured, v)" Label="@captured"
                                         Clearable="true" HideSpinButtons="true"></MudNumericField>
                    </MudItem>
                }
            }
            else if (_minimumType == "Buckets")
            {
                @foreach (var kv in Settings.CustomMinimums)
                {
                    var captured = kv.Key;
                    <MudItem xs="8">
                        @foreach (var level in LevelBucket.From(captured).GetDifficulties())
                        {
                            <MudChip T="string" Color="@(level.Item1 == ChartType.Single ? Color.Error : level.Item1 == ChartType.Double ? Color.Success : Color.Warning)"
                                     Value="@($"{level.Item1.ToString()[0]}{level.Item2}")"></MudChip>
                        }
                    </MudItem>
                    <MudItem xs="2">
                        @($"x{kv.Value}")
                    </MudItem>
                    <MudItem xs="2">
                        <MudIconButton Color="Color.Error" Icon="@Icons.Material.Filled.Delete"
                                       OnClick="() => RemoveBucket(captured)" aria-label="@L["Remove"]"></MudIconButton>
                    </MudItem>
                }
                <MudItem xs="12" sm="8">
                    <MudChipSet @bind-SelectedValues="_newCustomBuckets" CheckMark="true" SelectedColor="Color.Info"
                                SelectionMode="SelectionMode.MultiSelection">
                        @foreach (var single in Settings.LevelWeights.Where(w => w.Value > 0))
                        {
                            <MudChip Color="Color.Error" Value="@($"S{single.Key}")"></MudChip>
                        }
                        @foreach (var d in Settings.DoubleLevelWeights.Where(w => w.Value > 0))
                        {
                            <MudChip Color="Color.Success" Value="@($"D{d.Key}")"></MudChip>
                        }
                        @foreach (var d in Settings.PlayerCountWeights.Where(w => w.Value > 0))
                        {
                            <MudChip Color="Color.Warning" Value="@($"C{d.Key}")"></MudChip>
                        }
                    </MudChipSet>
                </MudItem>
                <MudItem xs="4" sm="2">
                    <MudNumericField T="int" Min="1" @bind-Value="_bucketSize" Label="@L["Bucket Size"]"
                                     Clearable="false" HideSpinButtons="true"></MudNumericField>
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddBucket">@L["Add"]</MudButton>
                </MudItem>
            }
        </MudGrid>
    </div>;
}
