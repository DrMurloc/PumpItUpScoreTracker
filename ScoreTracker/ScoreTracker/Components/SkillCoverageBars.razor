@using ScoreTracker.Catalog.Contracts
@using ScoreTracker.SharedKernel.Enums
@namespace ScoreTracker.Web.Components

@* The mapped-skill coverage bars — extracted from ChartDetailsDialog (one concept, one
   component) so the chart page and the dialog can never drift. Category tints ride the
   --skillcat-* token group; null coverage = a whole-chart quality (full bar, no number). *@
@if (Chips != null && Chips.Count > 0)
{
    <div class="chart-details-skill-bars">
        @foreach (var chip in Chips.Take(Take))
        {
            var percent = chip.SegmentFraction == null
                ? (int?)null
                : (int)Math.Round(chip.SegmentFraction.Value * 100);
            <div class="chart-details-skill-bar skillcat-@(chip.Skill.GetPrimaryCategory().ToString().ToLowerInvariant())">
                <span class="chart-details-skill-bar-label">@chip.Skill.GetName()</span>
                <span class="chart-details-skill-bar-track"><span class="chart-details-skill-bar-fill" style="width:@(percent ?? 100)%"></span></span>
                <span class="chart-details-skill-bar-value">@(percent == null ? "" : $"{percent}%")</span>
            </div>
        }
    </div>
    @if (ShowNote)
    {
        <MudText Typo="Typo.caption" Class="chart-details-skill-note">@L["Share of chart sections featuring each skill"]</MudText>
    }
}

<style>
    .chart-details-skill-bars {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 4px 16px;
        margin: 2px 0 8px;
    }

    .chart-details-skill-bar {
        display: grid;
        grid-template-columns: 92px 1fr 38px;
        align-items: center;
        gap: 8px;
        font-size: .75rem;
    }

    .chart-details-skill-bar-label {
        color: color-mix(in srgb, var(--skill-chip) 60%, var(--mix-ink));
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chart-details-skill-bar-track {
        height: 5px;
        border-radius: 3px;
        background: color-mix(in srgb, var(--skill-chip) 14%, transparent);
        overflow: hidden;
    }

    .chart-details-skill-bar-fill {
        display: block;
        height: 100%;
        border-radius: 3px;
        background: var(--skill-chip);
    }

    .chart-details-skill-bar-value {
        text-align: right;
        color: var(--mix-ink-muted);
        font-variant-numeric: tabular-nums;
    }

    .chart-details-skill-note {
        display: block;
        color: var(--mud-palette-text-secondary);
        margin-top: 2px;
    }
</style>

@code {
    [Parameter]
    public IReadOnlyList<ChartSkillChipRecord>? Chips { get; set; }

    [Parameter]
    public int Take { get; set; } = 6;

    [Parameter]
    public bool ShowNote { get; set; } = true;
}
