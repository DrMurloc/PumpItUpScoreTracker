@using ScoreTracker.ChartIntelligence.Contracts
@using ScoreTracker.SharedKernel.Enums
@namespace ScoreTracker.Web.Components

@* One verdict facet → one localized sentence (docs/design/chart-verdicts.md): the engine
   ships facts, this component is where they become words — the hero headline and every
   evidence-graph caption render through it so facet phrasing can never fork. *@
@if (Facet is PassVsScoreVerdict passVsScore)
{
    @L["{0} — {1}.", L[PassPhrase(passVsScore.PassTier)], L[ScorePhrase(passVsScore.ScoreTier)]]
}
else if (Facet is LetterWallVerdict wall)
{
    @L["Most clears stall below {0} — the steepest step on this board.", wall.WallGrade.GetName()]
}
else if (Facet is YieldKneeVerdict knee)
{
    @L["Scores open up around competitive level {0}.", knee.KneeLevel]
}
else if (Facet is StyleFingerprintVerdict style)
{
    @(style.TopSkills.Count > 1
        ? L["Dominated by {0} and {1}.", style.TopSkills[0].Skill.GetName(), style.TopSkills[1].Skill.GetName()]
        : L["Dominated by {0}.", style.TopSkills[0].Skill.GetName()])
    @if (style.IsSustained)
    {
        <text> </text>@L["Sustained — it holds you under tension for most of its runtime."]
    }
}
else if (Facet is FirstPassBandVerdict band)
{
    @L["First passes cluster between competitive levels {0} and {1}.", band.LowerLevel, band.UpperLevel]
}
@* PlateResidualVerdict deliberately has no sentence. It used to claim "a kill-spot
   signature" / "smooth attrition"; plates mostly restate scores, so neither is something
   a plate can know. The facet survives only as the verdict card's shape chip, which
   describes the distribution without reading anything into it. *@
else if (Facet is HistoryVerdict history)
{
    @L["Debuted in {0}.", history.DebutMix.GetName()]
}
else if (Facet is PopulationVerdict population)
{
    @L["{0} scores tracked · {1}% pass rate", population.ScoresTracked,
        (int)Math.Round(population.PassRate * 100)]
}

@code {
    [Parameter]
    public ChartVerdictFacet? Facet { get; set; }

    private static string PassPhrase(TierListCategory category)
    {
        return category switch
        {
            TierListCategory.Overrated => "Plays a level easier than its label",
            TierListCategory.VeryEasy => "Very easy to pass for its level",
            TierListCategory.Easy => "Easy to pass for its level",
            TierListCategory.Medium => "Fairly rated to pass",
            TierListCategory.Hard => "Hard to pass for its level",
            TierListCategory.VeryHard => "Very hard to pass for its level",
            TierListCategory.Underrated => "Plays a level harder than its label",
            _ => "Fairly rated to pass"
        };
    }

    private static string ScorePhrase(TierListCategory category)
    {
        return category switch
        {
            TierListCategory.Overrated or TierListCategory.VeryEasy or TierListCategory.Easy =>
                "generous to score once you're through",
            TierListCategory.Hard or TierListCategory.VeryHard or TierListCategory.Underrated =>
                "stingy to score even when passed",
            _ => "scores about as expected"
        };
    }
}
