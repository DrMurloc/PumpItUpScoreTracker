@namespace ScoreTracker.Web.Components
@using ScoreTracker.Domain.Models
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Domain.Records

@* The tier list's chart card (Comfortable density). Border language is owner-locked
   (design doc §4): solid success = passed, dashed info-blue = To-Do, dashed success =
   passed in another mix; precedence passed > To-Do > other-mix. Hue always pairs with
   the dash pattern or a printed value (rule 8). *@
<div class="tier-chart-card @StateClass" title="@StateTitle">
    <div class="tier-chart-card-jacket" style="background-image:url(&quot;@Chart.Song.ImagePath&quot;)">
        <div class="tier-chart-card-bubble">
            <DifficultyBubble Chart="Chart" Small="true"></DifficultyBubble>
        </div>
    </div>
    <div class="tier-chart-card-body">
        @if (ShowName)
        {
            <MudTooltip Text="@Chart.Song.Name.ToString()" ShowOnFocus="true">
                <MudText Typo="Typo.subtitle1" Class="tier-chart-card-name">@Chart.Song.Name</MudText>
            </MudTooltip>
        }
        @if (Score?.Score != null)
        {
            <ScoreBreakdown Score="Score.Score.Value" IsBroken="Score.IsBroken" OneLine="true" ShowScore="true"
                            Plate="Score.Plate" Ranking="Ranking"></ScoreBreakdown>
        }
    </div>
    <div class="tier-chart-card-actions">
        @if (ShowToDo)
        {
            <MudTooltip Text="@(IsToDo ? L["Remove from ToDo List"] : L["Add to ToDo List"])">
                <MudIconButton Size="Size.Small"
                               Icon="@(IsToDo ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)"
                               Color="@(IsToDo ? Color.Info : Color.Default)"
                               OnClick="() => OnToDo.InvokeAsync(Chart.Id)"
                               aria-label="@L["To Do"]"></MudIconButton>
            </MudTooltip>
        }
        <MudSpacer></MudSpacer>
        <MudIconButton Size="Size.Small" Icon="@Icons.Custom.Brands.YouTube"
                       OnClick="() => OnVideo.InvokeAsync(Chart.Id)" aria-label="@L["Video"]"></MudIconButton>
    </div>
</div>

@code {

    [Parameter] public Chart Chart { get; set; } = null!;

    [Parameter] public RecordedPhoenixScore? Score { get; set; }

    [Parameter] public ScoreRankingRecord? Ranking { get; set; }

    [Parameter] public bool Passed { get; set; }

    [Parameter] public bool IsToDo { get; set; }

    [Parameter] public bool PassedInAnotherMix { get; set; }

    [Parameter] public bool ShowName { get; set; } = true;

    [Parameter] public bool ShowToDo { get; set; } = true;

    [Parameter] public EventCallback<Guid> OnToDo { get; set; }

    [Parameter] public EventCallback<Guid> OnVideo { get; set; }

    private string StateClass => Passed ? "tier-chart-card-pass" :
        IsToDo ? "tier-chart-card-todo" :
        PassedInAnotherMix ? "tier-chart-card-other-mix" : string.Empty;

    private string? StateTitle => Passed ? L["Passed"] :
        IsToDo ? L["To Do"] :
        PassedInAnotherMix ? L["Passed in another mix"] : null;
}
