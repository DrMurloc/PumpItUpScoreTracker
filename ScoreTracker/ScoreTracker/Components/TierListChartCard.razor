@namespace ScoreTracker.Web.Components
@using ScoreTracker.Domain.Models
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Domain.Records
@using ScoreTracker.Web.Enums

@* The tier list's chart card. Border language is owner-locked (design doc §4): solid
   success = passed, dashed info-blue = To-Do, dashed success = passed in another mix;
   precedence passed > To-Do > other-mix. Hue always pairs with the dash pattern or a
   printed value (rule 8). Compact is the jacket "sticker sheet" (rule 5); Table
   density is the page's job, not the card's. *@
@if (Density == UiDensity.Compact)
{
    <MudTooltip Text="@CompactTooltip" ShowOnFocus="true">
        <div class="tier-chart-card tier-chart-card-compact @StateClass" role="button" tabindex="0"
             @onclick="() => OnOpen.InvokeAsync(Chart.Id)">
            <div class="tier-chart-card-jacket tier-chart-card-compact-jacket"
                 style="background-image:url(&quot;@Chart.Song.ImagePath&quot;)">
                <div class="tier-chart-card-bubble">
                    <DifficultyBubble Chart="Chart" Height="18"></DifficultyBubble>
                </div>
                @if (Score?.Score != null)
                {
                    <div class="tier-chart-card-compact-grade">
                        <LetterGradeIcon Grade="Score.Score.Value.LetterGrade" IsBroken="Score.IsBroken" Height="16"></LetterGradeIcon>
                    </div>
                }
            </div>
        </div>
    </MudTooltip>
}
else
{
<div class="tier-chart-card @StateClass" title="@StateTitle">
    <div class="tier-chart-card-jacket" role="button" tabindex="0"
         @onclick="() => OnOpen.InvokeAsync(Chart.Id)"
         style="background-image:url(&quot;@Chart.Song.ImagePath&quot;)">
        <div class="tier-chart-card-bubble">
            <DifficultyBubble Chart="Chart" Small="true"></DifficultyBubble>
        </div>
    </div>
    <div class="tier-chart-card-body">
        @if (ShowName)
        {
            <MudTooltip Text="@Chart.Song.Name.ToString()" ShowOnFocus="true">
                <MudText Typo="Typo.subtitle1" Class="tier-chart-card-name">@Chart.Song.Name</MudText>
            </MudTooltip>
        }
        @if (Score?.Score != null)
        {
            <ScoreBreakdown Score="Score.Score.Value" IsBroken="Score.IsBroken" OneLine="true" ShowScore="true"
                            Plate="Score.Plate" Ranking="Ranking"></ScoreBreakdown>
        }
    </div>
    <div class="tier-chart-card-actions">
        @if (ShowToDo)
        {
            <MudTooltip Text="@(IsToDo ? L["Remove from ToDo List"] : L["Add to ToDo List"])">
                <MudIconButton Size="Size.Small"
                               Icon="@(IsToDo ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)"
                               Color="@(IsToDo ? Color.Info : Color.Default)"
                               OnClick="() => OnToDo.InvokeAsync(Chart.Id)"
                               aria-label="@L["To Do"]"></MudIconButton>
            </MudTooltip>
        }
        <MudSpacer></MudSpacer>
        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Info"
                       OnClick="() => OnOpen.InvokeAsync(Chart.Id)" aria-label="@L["Details"]"></MudIconButton>
    </div>
</div>
}

@code {

    [Parameter] public Chart Chart { get; set; } = null!;

    [Parameter] public RecordedPhoenixScore? Score { get; set; }

    [Parameter] public ScoreRankingRecord? Ranking { get; set; }

    [Parameter] public bool Passed { get; set; }

    [Parameter] public bool IsToDo { get; set; }

    [Parameter] public bool PassedInAnotherMix { get; set; }

    [Parameter] public bool ShowName { get; set; } = true;

    [Parameter] public bool ShowToDo { get; set; } = true;

    [Parameter] public UiDensity Density { get; set; } = UiDensity.Comfortable;

    [Parameter] public EventCallback<Guid> OnToDo { get; set; }

    [Parameter] public EventCallback<Guid> OnOpen { get; set; }

    private string StateClass => Passed ? "tier-chart-card-pass" :
        IsToDo ? "tier-chart-card-todo" :
        PassedInAnotherMix ? "tier-chart-card-other-mix" : string.Empty;

    private string? StateTitle => Passed ? L["Passed"] :
        IsToDo ? L["To Do"] :
        PassedInAnotherMix ? L["Passed in another mix"] : null;

    // Compact hides the name, so the tooltip carries the identity (rule 7: no
    // truncation without a tooltip).
    private string CompactTooltip => StateTitle == null
        ? $"{Chart.Song.Name} {Chart.DifficultyString}"
        : $"{Chart.Song.Name} {Chart.DifficultyString} — {StateTitle}";
}
