@using System.ComponentModel.DataAnnotations
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Domain.Models
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.ValueTypes
@using Align = MudBlazor.Align
@namespace ScoreTracker.Web.Components

@* MudTooltip renders a popover, which throws in static SSR (no provider in the static tree).
   The tooltips carry hover text only, so a static render drops them and keeps the flag and
   name; in a circuit they come back. *@
@if (User != null)
{
    @if (!string.IsNullOrWhiteSpace(_countryImage) && User.Country != null)
    {
        @if (RendererInfo.IsInteractive)
        {
            <MudTooltip Text="@User.Country.Value.ToString()">
                <MudImage Height="15" ObjectFit="ObjectFit.ScaleDown" Src="@_countryImage"></MudImage>
            </MudTooltip>
        }
        else
        {
            <MudImage Height="15" ObjectFit="ObjectFit.ScaleDown" Src="@_countryImage"></MudImage>
        }
    }
    @if (RendererInfo.IsInteractive)
    {
        <MudTooltip Text="@Tooltip">
            @User.Name
        </MudTooltip>
    }
    else
    {
        @User.Name
    }
}
@inject IUserRepository Users
@code {
    [Parameter]
    [Required]
    public User? User { get; set; }

    private string _countryImage = string.Empty;
    private Name? _loadedCountry;

    private string Tooltip => User == null ? "" :
        User.GameTag == null ? "" :
            User.Name=="CLEARALL18SORQUIT" ? L["Wouldn't You Like To Know"].Value : User.GameTag.Value;

    // Rendered in reused positions (board dialogs swap their row sets in place), so the flag
    // follows the CURRENT user: reload when the country changes, clear when it goes away.
    protected override async Task OnParametersSetAsync()
    {
        var country = User?.Country;
        if (Nullable.Equals(country, _loadedCountry)) return;
        _loadedCountry = country;
        // The port is nullable — a country without a flag image just renders no flag.
        _countryImage = country == null
            ? string.Empty
            : (await Users.GetCountryImage(country.Value))?.ToString() ?? string.Empty;
    }
}
