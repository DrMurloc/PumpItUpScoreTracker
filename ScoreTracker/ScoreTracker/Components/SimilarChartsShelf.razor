@using MediatR
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.ChartIntelligence.Contracts
@using ScoreTracker.ChartIntelligence.Contracts.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Web.Services
@namespace ScoreTracker.Web.Components
@inject IMediator Mediator
@inject NavigationManager NavManager

@* The similarity graph's shelf (docs/design/chart-similarity.md): jacket cards naming
   the badges each pair actually shares. Doubles as the internal link mesh — static
   content at Stage 3. *@
@if (_loaded)
{
    @if (_entries.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="chart-shelf-empty">@L["Not enough data yet to name similar charts — the graph rebuilds nightly."]</MudText>
    }
    else
    {
        <div class="chart-shelf">
            @foreach (var entry in _entries)
            {
                <a class="chart-shelf-card" href="@($"/Chart/{entry.Chart.Id}")">
                    <div class="chart-shelf-art">
                        <SongImage Song="entry.Chart.Song" Height="96"></SongImage>
                        <span class="chart-shelf-bubble"><DifficultyBubble Chart="entry.Chart" Small="true"></DifficultyBubble></span>
                    </div>
                    <div class="chart-shelf-name">@entry.Chart.Song.Name</div>
                    <div class="chart-shelf-why">
                        @foreach (var reason in entry.Reasons)
                        {
                            <span>@reason</span>
                        }
                    </div>
                    <div class="chart-shelf-match">
                        <span class="chart-shelf-match-bar"><i style="width:@((int)(entry.Record.Score * 100))%"></i></span>
                        <span class="chart-shelf-match-value">@entry.Record.Score.ToString("0.00")</span>
                    </div>
                </a>
            }
        </div>
    }
}

@code {
    /// <summary>
    ///     What counts as a real match. A render-time constant by design: the graph stores
    ///     its top 20 floor-free, so moving this bar is a redeploy rather than a rebuild,
    ///     and the rows below it are the near-misses rather than rows that never existed.
    ///     Pending calibration against a real score distribution.
    /// </summary>
    internal const double ScoreFloor = 0.55;

    /// <summary>
    ///     Below this shared coverage a badge is a trace both charts happen to brush past,
    ///     not something they have in common worth saying out loud.
    /// </summary>
    internal const double MinimumReasonCoverage = 0.15;

    internal const int MaximumReasons = 3;

    [Parameter]
    public Guid ChartId { get; set; }

    [Parameter]
    public MixEnum Mix { get; set; } = MixEnum.Phoenix;

    private bool _loaded;
    private IReadOnlyList<(ChartSimilarityRecord Record, Chart Chart, IReadOnlyList<string> Reasons)> _entries =
        Array.Empty<(ChartSimilarityRecord, Chart, IReadOnlyList<string>)>();

    protected override async Task OnParametersSetAsync()
    {
        var edges = await Mediator.Send(new GetSimilarChartsQuery(ChartId, Mix));
        if (edges.Count == 0)
        {
            _entries = Array.Empty<(ChartSimilarityRecord, Chart, IReadOnlyList<string>)>();
            _loaded = true;
            return;
        }

        var charts = (await Mediator.Send(new GetChartsQuery(Mix, ChartIds: edges.Select(e => e.ChartId))))
            .ToDictionary(c => c.Id);
        // The graph hands over its whole tail; the bar is ours to apply.
        _entries = edges
            .Where(e => e.Score >= ScoreFloor && charts.ContainsKey(e.ChartId))
            .Select(e => (e, charts[e.ChartId], Reasons(e)))
            .ToArray();
        _loaded = true;
    }

    /// <summary>
    ///     What the pair actually matched on, strongest overlap first — never "skills
    ///     match", which reads as broken. The percentage is the coverage the two charts
    ///     *share*, so "Brackets 50%" says both are at least half brackets. A badge whose
    ///     shared coverage is a rounding error is not a reason, so the chips can come back
    ///     empty; that is honest, and the score bar still says how close the pair is.
    /// </summary>
    internal IReadOnlyList<string> Reasons(ChartSimilarityRecord record)
    {
        return record.SharedBadges
            .Where(b => b.Coverage >= MinimumReasonCoverage)
            .Take(MaximumReasons)
            .Select(b => L["{0} {1}%", L[SimilarityBadgeLabels.For(b.Badge)], (int)Math.Round(b.Coverage * 100)]
                .ToString())
            .ToArray();
    }
}
