@using MediatR
@using ScoreTracker.Catalog.Contracts
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.ChartIntelligence.Contracts
@using ScoreTracker.ChartIntelligence.Contracts.Queries
@using ScoreTracker.Domain.Records
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Services
@namespace ScoreTracker.Web.Components
@inject IMediator Mediator
@inject ICurrentUserAccessor CurrentUser
@inject ChartScoringLevels ScoringLevels

@* The similarity graph's shelf (docs/design/chart-similarity.md): cards naming the badges
   each pair actually shares. Doubles as the internal link mesh.
   Three questions, three mechanisms — the shelf is where the last two land. Similarity is
   precalculated and never re-scored here; DIFFICULTY is the ordering, applied per viewer at
   read time; METADATA is the filters, which reduce the target list and recompute live
   (filtering the stored top-20 would return nothing — those twenty are the nearest charts
   overall, so any filter worth applying excludes all of them).
   The static-list/island split rides with P3: prerendering is off permanently and there is
   no render-mode infrastructure on this branch yet, so today the whole page is one
   circuit and the cards are already real <a href>s. *@
@if (_loaded)
{
    <div class="chart-shelf-controls">
        <div class="chart-shelf-sort" role="group" aria-label="@L["Order by"]">
            @foreach (var option in SortOptions)
            {
                <button type="button" aria-pressed="@(_sort == option ? "true" : "false")" disabled="@_sorting"
                        @onclick="() => SetSort(option)">@L[Label(option)]</button>
            }
        </div>
        @* Personalization is a property of the difficulty question, not a fourth answer to
           it — so it rides orthogonal to the lens rather than doubling the buttons, and it
           has nothing to modify when nothing is being ordered. *@
        @if (_sort != ShelfSort.None)
        {
            <label class="chart-shelf-personal"
                   title="@(CanPersonalize ? null : L["Sign in to order by your own tier lists"].ToString())">
                <input type="checkbox" checked="@_personalized" disabled="@(!CanPersonalize || _sorting)"
                       @onchange="OnPersonalizedChanged"/>
                <span>@L["Personalized"]</span>
            </label>
        }
        @* Every option is derived from the anchor, so a filter is one click and can never
           be typed into nonsense. Filters narrow what we COMPARE AGAINST and rescore —
           they never sieve the stored top-20, which are the nearest charts overall and so
           would survive nothing worth filtering by. *@
        @if (_anchor != null)
        {
            <MudMenu Dense="true" Disabled="_sorting" Class="chart-shelf-addfilter"
                     StartIcon="@Icons.Material.Filled.FilterList" Label="@L["Filter"]"
                     Variant="Variant.Outlined" Size="Size.Small">
                @if (_anchor.StepArtist is { } artist && artist.ToString() != "Unknown")
                {
                    <MudMenuItem OnClick="() => FilterByArtist(artist)">@L["By {0}", artist]</MudMenuItem>
                }
                @if (BpmBand is { } band)
                {
                    <MudMenuItem OnClick="() => FilterByBpm(band.Min, band.Max)">
                        @L["{0}–{1} BPM", (int)band.Min, (int)band.Max]
                    </MudMenuItem>
                }
                @foreach (var level in ReachableLevels)
                {
                    var target = level;
                    <MudMenuItem OnClick="() => FilterByLevel(target)">
                        @L["Only {0}", $"{_anchor.Type.GetShortHand()}{target}"]
                    </MudMenuItem>
                }
            </MudMenu>
        }
        <span class="chart-shelf-hint">
            @if (_sorting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="chart-shelf-spinner"></MudProgressCircular>
                @L["Reordering…"]
            }
            else
            {
                @L[Hint]
            }
        </span>
    </div>
    @if (_filter != null)
    {
        <div class="chart-shelf-filters">
            <span class="chart-shelf-fchip">
                @L[_filter.Label]<span>@_filter.Value</span>
                <button type="button" @onclick="ClearFilter" aria-label="@L["Remove filter"]">×</button>
            </span>
        </div>
    }

    @if (_matches.Count == 0 && _nearMisses.Count == 0)
    {
        @* Two different nothings. A filter that narrowed to zero has to say what it
           searched; a chart the crawl never covered has nothing to report a reach over. *@
        <MudText Typo="Typo.body2" Class="chart-shelf-empty">
            @(_filter != null
                ? Reach(none: true)
                : L["Not enough data yet to name similar charts — the graph rebuilds nightly."].ToString())
        </MudText>
    }
    else
    {
        @if (_matches.Count == 0)
        {
            @* Never an empty box: the tail is stored precisely so there is always something
               honest to show. *@
            <MudText Typo="Typo.body2" Class="chart-shelf-empty">@L["No significant matches — here's the closest we could find."]</MudText>
        }
        <div class="chart-shelf">
            @foreach (var entry in _matches.Count == 0 ? _nearMisses : _matches)
            {
                @Card(entry)
            }
        </div>
        @if (_filter != null || _compared != null)
        {
            <p class="chart-shelf-reach">@Reach(none: _matches.Count == 0)</p>
        }
        @if (_matches.Count > 0 && _nearMisses.Count > 0)
        {
            <details class="chart-shelf-nearmiss">
                <summary>@L["Didn't quite make the cut ({0})", _nearMisses.Count]</summary>
                <div class="chart-shelf">
                    @foreach (var entry in _nearMisses)
                    {
                        @Card(entry)
                    }
                </div>
            </details>
        }
    }
}

@code {
    /// <summary>
    ///     What counts as a real match. A render-time constant by design: the graph stores
    ///     its top 20 floor-free, so moving this bar is a redeploy rather than a rebuild,
    ///     and the rows below it are the near-misses rather than rows that never existed.
    ///     Pending calibration against a real score distribution.
    /// </summary>
    internal const double ScoreFloor = 0.55;

    /// <summary>How many near-misses are worth curiosity before it turns into a list of everything.</summary>
    internal const int NearMissCount = 10;

    /// <summary>
    ///     Which difficulty question the shelf is ordered by. Pass and Score are genuinely
    ///     different — a chart can be a wall to clear and generous to score, or the reverse
    ///     — and personalization is a modifier on either, not a third lens.
    /// </summary>
    internal enum ShelfSort
    {
        /// <summary>The match order itself — the only option that shows it. Every difficulty sort reorders away from it.</summary>
        None,
        PassDifficulty,
        ScoreDifficulty
    }

    private static readonly ShelfSort[] SortOptions =
        { ShelfSort.None, ShelfSort.PassDifficulty, ShelfSort.ScoreDifficulty };

    [Parameter]
    public Guid ChartId { get; set; }

    [Parameter]
    public MixEnum Mix { get; set; } = MixEnum.Phoenix;

    private sealed record Entry(ChartSimilarityRecord Record, Chart Chart, ChartIntensityFacts? Intensity,
        string? VideoUrl);

    private sealed record ActiveFilter(string Label, string Value);

    private bool _loaded;
    private Guid _loadedFor;
    private ChartIntensityFacts? _anchorIntensity;
    private Chart? _anchor;
    private ShelfSort _sort = ShelfSort.PassDifficulty;
    private bool _personalized;
    private bool _sorting;
    private ActiveFilter? _filter;
    private int? _compared;
    private IReadOnlyList<Entry> _all = Array.Empty<Entry>();
    private IReadOnlyList<Entry> _matches = Array.Empty<Entry>();
    private IReadOnlyList<Entry> _nearMisses = Array.Empty<Entry>();

    // VideoUrl needs the @: it is a string parameter, and Blazor reads an unprefixed value
    // on one of those as literal text rather than an expression — silently, and only for
    // strings, which is why every other parameter here is fine without it.
    // VideoUrl needs the @: it is a string parameter, and Blazor reads an unprefixed value
    // on one of those as literal text rather than an expression — silently, and only for
    // strings, which is why every other parameter here is fine without it.
    private RenderFragment Card(Entry entry) =>
        @<SimilarChartCard Chart="entry.Chart" Record="entry.Record" Intensity="entry.Intensity"
                           AnchorIntensity="_anchorIntensity" VideoUrl="@entry.VideoUrl"
                           @key="entry.Chart.Id"></SimilarChartCard>;

    /// <summary>Only the personal lists need an account; the community ones are always there.</summary>
    private bool CanPersonalize => CurrentUser.IsLoggedIn;

    // The verdict card at the top of this page already names these two — same words, same
    // key, so the shelf cannot end up disagreeing with the hero in translation.
    private static string Label(ShelfSort sort) => sort switch
    {
        ShelfSort.None => "No sorting",
        ShelfSort.PassDifficulty => "Pass Difficulty",
        _ => "Score Difficulty"
    };

    private string Hint => _sort switch
    {
        ShelfSort.None => "Strongest match first — no difficulty applied",
        ShelfSort.PassDifficulty => _personalized
            ? "Easiest to clear first, from your Pass tier list"
            : "Easiest to clear first, from the community Pass tier list",
        _ => _personalized
            ? "Easiest to score first, from your Score tier list"
            : "Easiest to score first, by scoring level"
    };

    /// <summary>
    ///     What was searched, so "1 match" reads as a narrow filter rather than a broken
    ///     feature. Only meaningful once a filter has actually narrowed something.
    /// </summary>
    private string Reach(bool none)
    {
        var compared = _compared ?? _all.Count;
        var scope = _filter != null ? $"{L[_filter.Label]} {_filter.Value}" : L["within 2 levels"].ToString();
        return none
            ? L["Compared {0} charts ({1}) — none cleared the bar.", compared, scope].ToString()
            : L["Compared {0} charts ({1}) — {2} matches.", compared, scope, _matches.Count].ToString();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ChartId == _loadedFor) return;
        _loadedFor = ChartId;
        _filter = null;
        _compared = null;
        _sort = ShelfSort.PassDifficulty;
        _personalized = false;
        await Load(await Mediator.Send(new GetSimilarChartsQuery(ChartId, Mix)));
    }

    private async Task Load(IReadOnlyList<ChartSimilarityRecord> edges)
    {
        if (edges.Count == 0)
        {
            _all = _matches = _nearMisses = Array.Empty<Entry>();
            _loaded = true;
            return;
        }

        var chartIds = edges.Select(e => e.ChartId).Append(ChartId).ToArray();
        var charts = (await Mediator.Send(new GetChartsQuery(Mix, ChartIds: chartIds))).ToDictionary(c => c.Id);
        var analyses = await Mediator.Send(new GetChartStepAnalysesQuery(chartIds));
        var videos = (await Mediator.Send(new GetChartVideosQuery(edges.Select(e => e.ChartId))))
            .ToDictionary(v => v.ChartId, v => v.VideoUrl.ToString());
        _anchor = charts.GetValueOrDefault(ChartId);
        _anchorIntensity = _anchor == null
            ? null
            : ChartIntensityFacts.For(_anchor, analyses.GetValueOrDefault(ChartId));

        _all = edges
            .Where(e => charts.ContainsKey(e.ChartId))
            .Select(e => new Entry(e, charts[e.ChartId],
                ChartIntensityFacts.For(charts[e.ChartId], analyses.GetValueOrDefault(e.ChartId)),
                videos.GetValueOrDefault(e.ChartId)))
            .ToArray();
        await Split();
        _loaded = true;
    }

    /// <summary>
    ///     The graph hands over its whole tail; where the bar falls is ours, and so is the
    ///     order — similarity is never re-scored here.
    /// </summary>
    private async Task Split()
    {
        var ordered = await Ordered(_all);
        _matches = ordered.Where(e => e.Record.Score >= ScoreFloor).ToArray();
        _nearMisses = ordered.Where(e => e.Record.Score < ScoreFloor).Take(NearMissCount).ToArray();
    }

    /// <summary>
    ///     Easiest first. Charts we cannot place sort last rather than pretending to be
    ///     easy, and ties fall back to the match order.
    /// </summary>
    private async Task<IReadOnlyList<Entry>> Ordered(IReadOnlyList<Entry> entries)
    {
        if (_sort == ShelfSort.None || _anchor == null) return entries;

        var difficulty = await Difficulties();
        return entries
            .OrderBy(e => difficulty.TryGetValue(e.Chart.Id, out var d) ? d : double.MaxValue)
            .ThenByDescending(e => e.Record.Score)
            .ToArray();
    }

    /// <summary>
    ///     Every reachable chart's difficulty on the current lens, as an **effective level**
    ///     — one number comparable across the folders the shelf spans.
    ///     That comparability is the whole problem. A tier list ranks charts *within* one
    ///     folder, so its `Order` is 0..N per folder and its category means "hard for a D21"
    ///     rather than "hard": neither survives a shelf reaching ±2 levels. Nudging the
    ///     folder's own level by the category is what makes them commensurable — a D21 the
    ///     list calls Underrated and a D22 it calls Overrated meet in the middle, which is
    ///     precisely what those two verdicts are saying.
    ///     Community score difficulty skips all of that: the scoring level already *is* an
    ///     effective level, measured rather than voted (~87% of charts in the 17–26 range
    ///     have one; the rest sort last).
    /// </summary>
    private async Task<IReadOnlyDictionary<Guid, double>> Difficulties()
    {
        if (_sort == ShelfSort.ScoreDifficulty && !_personalized)
        {
            var levels = new Dictionary<Guid, double>();
            foreach (var entry in _all)
                if (await ScoringLevels.GetScoringLevel(entry.Chart.Id) is { } level)
                    levels[entry.Chart.Id] = level;
            return levels;
        }

        var lens = Name.From(_sort == ShelfSort.PassDifficulty ? "Pass" : "Score");
        var result = new Dictionary<Guid, double>();
        if (_anchor == null) return result;
        // A blended list covers its whole folder, so most of what comes back is not on this
        // shelf. Projecting a chart against the folder we happened to be asking about rather
        // than against its own level would misplace it by however far the two differ.
        var shelfLevels = _all.ToDictionary(e => e.Chart.Id, e => (int)e.Chart.Level);
        // The blend is computed per (type, level), so the shelf's reach costs one read per
        // folder it touches — at most five.
        foreach (var level in _all.Select(e => e.Chart.Level).Distinct())
        {
            var list = await Mediator.Send(new GetBlendedTierListQuery(_anchor.Type, level, lens,
                Personalized: _personalized && CanPersonalize));
            foreach (var entry in list.Entries.Where(e => e.Category != TierListCategory.Unrecorded))
                if (shelfLevels.TryGetValue(entry.ChartId, out var chartLevel))
                    result[entry.ChartId] = EffectiveLevel(chartLevel, entry.Category);
        }

        return result;
    }

    /// <summary>
    ///     A folder-relative verdict projected onto the absolute level scale. The spread is
    ///     deliberately under half a level: the tier list is saying a chart is misplaced
    ///     *within* its folder, never that it belongs in a different one.
    /// </summary>
    internal static double EffectiveLevel(int level, TierListCategory category) =>
        level + category switch
        {
            TierListCategory.Overrated => -0.45,
            TierListCategory.VeryEasy => -0.30,
            TierListCategory.Easy => -0.15,
            TierListCategory.Medium => 0.0,
            TierListCategory.Hard => 0.15,
            TierListCategory.VeryHard => 0.30,
            TierListCategory.Underrated => 0.45,
            _ => 0.0
        };

    private async Task SetSort(ShelfSort sort)
    {
        if (_sort == sort) return;
        _sort = sort;
        await Resort();
    }

    private async Task OnPersonalizedChanged(ChangeEventArgs e)
    {
        _personalized = e.Value is true;
        await Resort();
    }

    /// <summary>
    ///     A difficulty lens costs one tier-list read per folder the shelf reaches — up to
    ///     five round trips, and the personalized blend is the slow one. Say so and lock
    ///     the controls, rather than letting the cards sit in the old order looking like
    ///     the click missed.
    /// </summary>
    private async Task Resort()
    {
        _sorting = true;
        try
        {
            await Split();
        }
        finally
        {
            _sorting = false;
        }
    }

    private async Task ClearFilter()
    {
        _filter = null;
        _compared = null;
        await Load(await Mediator.Send(new GetSimilarChartsQuery(ChartId, Mix)));
    }

    /// <summary>
    ///     How far out the level filter offers to reach. Wider than the graph's own ±1
    ///     window on purpose: "I liked this D18, what D23s play like it" is the whole
    ///     reason the live query exists, and it is deliberately outside what gets
    ///     precalculated.
    /// </summary>
    internal const int LevelFilterReach = 5;

    internal IReadOnlyList<int> ReachableLevels
    {
        get
        {
            if (_anchor == null) return Array.Empty<int>();
            var anchor = (int)_anchor.Level;
            return Enumerable.Range(anchor - LevelFilterReach, LevelFilterReach * 2 + 1)
                .Where(l => l is >= 1 and <= 28 && l != anchor)
                .ToArray();
        }
    }

    /// <summary>
    ///     A tenth either side of the anchor's own tempo. Nominal BPM is noise as a score —
    ///     slow songs multiply, so Altale's 90 runs at 12 NPS — but as a filter it is
    ///     exactly what someone means by "at this speed".
    /// </summary>
    private (decimal Min, decimal Max)? BpmBand
    {
        get
        {
            if (_anchor?.Song.Bpm is not { } bpm) return null;
            return (Math.Round(bpm.Min * 0.9m), Math.Round(bpm.Max * 1.1m));
        }
    }

    // The chip and the reach line both read (dimension, value), so a filter carries the two
    // separately rather than a pre-baked sentence. Internal so tests can drive a filter
    // without going through MudMenu's popover, which bUnit does not host.
    internal Task FilterByArtist(Name artist) =>
        ApplyFilter(new GetFilteredSimilarChartsQuery(ChartId, Mix, StepArtist: artist),
            "Step artist", artist.ToString());

    internal Task FilterByBpm(decimal min, decimal max) =>
        ApplyFilter(new GetFilteredSimilarChartsQuery(ChartId, Mix, MinBpm: min, MaxBpm: max),
            "BPM", $"{(int)min}–{(int)max}");

    internal Task FilterByLevel(int level) =>
        ApplyFilter(new GetFilteredSimilarChartsQuery(ChartId, Mix, MinLevel: level, MaxLevel: level),
            "Level", $"{_anchor?.Type.GetShortHand()}{level}");

    /// <summary>
    ///     Narrows the target list and recomputes — never a sieve over the stored top-20.
    /// </summary>
    private async Task ApplyFilter(GetFilteredSimilarChartsQuery query, string label, string value)
    {
        _sorting = true;
        try
        {
            var result = await Mediator.Send(query);
            _filter = new ActiveFilter(label, value);
            _compared = result.ChartsCompared;
            await Load(result.Matches);
        }
        finally
        {
            _sorting = false;
        }
    }
}
