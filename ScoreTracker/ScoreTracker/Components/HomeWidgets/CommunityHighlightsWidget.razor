@using System.Globalization
@using MediatR
@using ScoreTracker.Communities.Contracts
@using ScoreTracker.Communities.Contracts.Queries
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.HomePage.Contracts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services.HomeDashboard

@* Community Highlights (docs/design/home-page-widgets.md §7): recent big wins from the
   communities you pick. Membership is the consent boundary; a row's chart opens the shared
   ChartDetailsDialog; "See more" deep-links a public player's Sessions page. *@

@if (!_loaded)
{
    <div class="dash-widget-message">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary"/>
    </div>
}
else if (!_records.Any())
{
    <div class="dash-widget-message dash-ch-empty">
        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Large"/>
        <MudText Typo="Typo.body2">@L["No big wins yet"]</MudText>
        <MudText Typo="Typo.caption" Class="dash-muted">
            @L["Rare PGs, big titles, and top scores from your communities show up here."]
        </MudText>
    </div>
}
else
{
    <div class="dash-ch-feed dash-scroll">
        @foreach (var record in _records)
        {
            <div class="dash-ch-entry">
                <MudAvatar Size="Size.Small" Class="dash-ch-avatar">
                    <MudImage Src="@record.Avatar.ToString()" Alt="@record.PlayerName"/>
                </MudAvatar>
                <div class="dash-ch-body">
                    <div class="dash-ch-head">
                        @if (record.IsPublic)
                        {
                            <MudLink Href="@SessionsLink(record)" Typo="Typo.body2" Class="dash-ch-name">@record.PlayerName</MudLink>
                        }
                        else
                        {
                            <span class="dash-ch-name">@record.PlayerName</span>
                        }
                        <span class="dash-ch-time dash-muted">@Relative(record.OccurredAt)</span>
                    </div>
                    <div class="dash-ch-wins">
                        @foreach (var win in record.Wins)
                        {
                            @if (win.ChartId is { } chartId && _charts.TryGetValue(chartId, out var chart))
                            {
                                @if (Narrow)
                                {
                                    @* 1-wide: image + bubble + score on one line, detail as a subtitle beneath. *@
                                    <div class="dash-ch-win dash-ch-win-narrow">
                                        <div class="dash-ch-line @(EditMode ? "" : "dash-clickable")"
                                             @onclick="() => OnChartClick.InvokeAsync(new ChartClickContext(chart))">
                                            <SongImage Song="chart.Song" Small="true"/>
                                            <DifficultyBubble Chart="chart" Small="true"></DifficultyBubble>
                                            @if (win.Score is { } narrowScore)
                                            {
                                                <span class="dash-ch-score dash-ch-score-right">@narrowScore.ToString("N0")</span>
                                            }
                                        </div>
                                        <div class="dash-ch-sub">@Caption(win)</div>
                                    </div>
                                }
                                else
                                {
                                    @* 2-wide+: image + bubble + name + detail, score right-aligned. *@
                                    <div class="dash-ch-win">
                                        <span class="dash-ch-chart @(EditMode ? "" : "dash-clickable")"
                                              @onclick="() => OnChartClick.InvokeAsync(new ChartClickContext(chart))">
                                            <SongImage Song="chart.Song" Small="true"/>
                                            <DifficultyBubble Chart="chart" Small="true"></DifficultyBubble>
                                            <span class="dash-ch-song">@chart.Song.Name</span>
                                        </span>
                                        <span class="dash-ch-why">@Caption(win)</span>
                                        @if (win.Score is { } wideScore)
                                        {
                                            <span class="dash-ch-score dash-ch-score-right">@wideScore.ToString("N0")</span>
                                        }
                                    </div>
                                }
                            }
                            else if (win.Kind == WinKind.FolderComplete)
                            {
                                <div class="dash-ch-win">
                                    <span class="dash-ch-why">🎉 @L["Cleared all of {0}", win.Difficulty ?? ""]</span>
                                </div>
                            }
                            else if (win.TitleName != null)
                            {
                                <div class="dash-ch-win">
                                    <span class="dash-ch-why">🏅 <b>@Bracket(win.TitleName)</b> @TitleSuffix(win)</span>
                                </div>
                            }
                            else if (win.ChartName != null)
                            {
                                <div class="dash-ch-win">
                                    <span class="dash-ch-why">@win.Difficulty @win.ChartName · @Caption(win)</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@inject IMediator Mediator
@inject ICurrentUserAccessor CurrentUser
@inject IDateTimeOffsetAccessor Clock
@inject ChartCatalogCache ChartCatalog

@code {

    [Parameter] public HomePageWidgetRecord Widget { get; set; } = null!;
    [Parameter] public MixEnum EffectiveMix { get; set; }
    [Parameter] public bool EditMode { get; set; }
    [Parameter] public EventCallback<ChartClickContext> OnChartClick { get; set; }
    // Part of the widget render contract (§2.2) — the host bumps this to force a reload.
    [Parameter] public int RefreshToken { get; set; }

    private const int FeedTake = 30;
    private static readonly MixEnum[] Supported = { MixEnum.Phoenix, MixEnum.Phoenix2 };

    // 1-wide cells stack the score over a subtitle; 2-wide+ put it on one right-aligned line.
    private bool Narrow => SizePreset.TryParse(Widget.SizePreset)?.Columns == 1;

    private bool _loaded;
    private string? _loadedFor;
    private IReadOnlyList<CommunityHighlightRecord> _records = Array.Empty<CommunityHighlightRecord>();
    private IReadOnlyDictionary<Guid, Chart> _charts = new Dictionary<Guid, Chart>();

    protected override async Task OnParametersSetAsync()
    {
        var signature = $"{Widget.Id}|{Widget.ConfigJson}|{Widget.SizePreset}|{EffectiveMix}|{RefreshToken}";
        if (signature == _loadedFor) return;
        _loadedFor = signature;
        _loaded = false;

        var config = WidgetConfigJson.Read<CommunityHighlightsConfig>(Widget.ConfigJson);
        var mix = config.Mix != null && Supported.Contains(config.Mix.Value) ? config.Mix.Value
            : Supported.Contains(EffectiveMix) ? EffectiveMix : MixEnum.Phoenix;

        // Empty config follows your non-regional crews (CH1) — World/country are opt-in.
        var communities = config.Communities.Count > 0
            ? config.Communities.Select(Name.From).ToList()
            : (await Mediator.Send(new GetMyCommunitiesQuery()))
                .Where(c => !c.IsRegional).Select(c => c.CommunityName).ToList();

        if (communities.Count == 0)
        {
            _records = Array.Empty<CommunityHighlightRecord>();
            _charts = new Dictionary<Guid, Chart>();
            _loaded = true;
            return;
        }

        _records = (await Mediator.Send(
            new GetMyCommunityHighlightsQuery(communities, mix, config.IncludeOwnWins, FeedTake))).ToList();
        _charts = await ChartCatalog.GetCharts(mix);
        _loaded = true;
    }

    private static string SessionsLink(CommunityHighlightRecord r) =>
        r.SessionId == null ? $"/Player/{r.UserId}/Sessions" : $"/Player/{r.UserId}/Sessions?session={r.SessionId}";

    private string Relative(DateTimeOffset when)
    {
        var span = Clock.Now - when;
        if (span.TotalMinutes < 1) return L["now"];
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m";
        if (span.TotalDays < 1) return $"{(int)span.TotalHours}h";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d";
        return $"{(int)(span.TotalDays / 7)}w";
    }

    private string Caption(SignificantWin win) => win.Kind switch
    {
        WinKind.NotablePg => $"💎 {L["only {0} have it", Pct(win.RarityShare)]}",
        WinKind.TopPumbility => $"👑 {L["#{0} PUMBILITY", win.Rank ?? 0]}",
        WinKind.PeerElite => $"📊 {L["top {0}% of peers", win.Rank ?? 0]}",
        WinKind.FolderFirst => $"🆕 {L["#{0} to pass this folder", win.Rank ?? 0]}",
        _ => string.Empty
    };

    private string TitleSuffix(SignificantWin win) => win.Kind == WinKind.RareTitle && win.RarityShare != null
        ? $"· {L["only {0} hold it", Pct(win.RarityShare)]}"
        : L["completed"];

    private static string Pct(double? share) =>
        share == null ? "" : (share.Value * 100).ToString("0.#", CultureInfo.InvariantCulture) + "%";

    private static string Bracket(string title) =>
        string.IsNullOrEmpty(title) ? "" : title.StartsWith('[') ? title : $"[{title}]";

}
