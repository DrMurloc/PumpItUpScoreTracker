@using ScoreTracker.Web.Shared
@inject IStringLocalizer<App> L

@* Shown once (versioned consent) the first time a user enables Remember-my-password, from the
   Import widget's configurator or the Upload page. Plain-language by default; the technical
   breakdown is one expander down. Copy mirrors docs/design/import-widget-remember-password.md. *@
<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Warning"/>
            <MudText Typo="Typo.h6">@L["Before we remember your password"]</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-3">
            @L["Turning this on is like writing your password on a sticky note you keep in your own pocket — except the note is in a code nobody can read by looking at it, not even us."]
        </MudText>
        <MudText Typo="Typo.body2" Class="mb-2">@L["Reading it takes three things at once, held in three different places:"]</MudText>
        <MudList T="string" Dense="true" Class="mb-3">
            <MudListItem T="string" Icon="@Icons.Material.Filled.PhoneAndroid">
                <b>@L["You hold the coded note"]</b> — @L["on this device only. Useless on its own."]
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Storage">
                <b>@L["We hold a sealed key"]</b> — @L["in our database, locked so it can't be opened alone."]
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Lock">
                <b>@L["We hold the master key"]</b> — @L["locked in a vault inside Microsoft Azure."]
            </MudListItem>
        </MudList>
        <MudText Typo="Typo.body2" Class="mb-3">
            @L["All three come together only for the split second you press Import — we decode it, log in for you, and immediately forget it. Your real password is never written down anywhere."]
        </MudText>

        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
            @L["Because a coded copy of your password lives on this device, please make sure your Pump It Up password is one you use only here — not the one that also opens your email or your bank."]
        </MudAlert>

        <MudExpansionPanels Elevation="0" Dense="true">
            <MudExpansionPanel Text="@L["For the technically curious — how it actually works"]">
                <MudText Typo="Typo.body2" Class="mb-2">
                    @L["Your username and password are sealed together with AES-256-GCM under a random data key. That data key is wrapped by a master key that never leaves Azure Key Vault."]
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-2">
                    @L["The ciphertext lives in your browser; the wrapped key lives in our database; the master key lives in Key Vault. Decryption needs all three — a dump of any one, or any two, yields nothing. No password is ever written to our database or logs."]
                </MudText>
                <MudText Typo="Typo.body2">
                    @L["This is not zero-knowledge: because the login runs on our server, we can technically decrypt your credential at the moment you import. We don't log or keep it — but you are trusting us with the same access we already have on every manual import."]
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Accept">@L["I understand — remember it"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private void Accept()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
