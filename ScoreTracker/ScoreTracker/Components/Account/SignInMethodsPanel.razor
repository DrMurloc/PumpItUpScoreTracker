@using System.Security.Authentication
@using MediatR
@using ScoreTracker.Domain.Records
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.Identity.Contracts
@using ScoreTracker.OfficialMirror.Contracts.Queries
@using ScoreTracker.Web.Services

<MudText Typo="Typo.body2" Class="mb-4">@L["You can sign in to your account with any connected method"]</MudText>
@if (_externalLogins.Any() && _externalLogins.All(l => l.LoginProviderName.Equals("PiuGame", StringComparison.OrdinalIgnoreCase)))
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">@L["PIUGAME logins depend on piugame.com being reachable, connect a backup sign-in method"]</MudAlert>
}
<MudGrid>
    @foreach (var provider in ConnectedProviders)
    {
        <MudItem xs="6" Style="align-content: center;">
            <MudIcon Icon="@ProviderIcon(provider)" Style="vertical-align: middle;" Class="mr-2"></MudIcon>
            <MudText Inline="true">@(provider.Equals("PiuGame", StringComparison.OrdinalIgnoreCase) ? "PIUGAME" : provider)</MudText>
        </MudItem>
        <MudItem xs="6">
            <MudTooltip Text="@(ConnectedProviders.Count == 1 ? L["This is your only sign-in method and cannot be disconnected"].Value : string.Empty)">
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           Disabled="ConnectedProviders.Count == 1"
                           OnClick="() => OpenDisconnectDialog(provider)">@L["Disconnect"]</MudButton>
            </MudTooltip>
        </MudItem>
    }
</MudGrid>
<div class="d-flex flex-wrap gap-2 mt-6">
    @foreach (var provider in ConnectableProviders.Where(p => !ConnectedProviders.Contains(p, StringComparer.OrdinalIgnoreCase)))
    {
        <MudButton Href="@($"/Login/{provider}/Link")" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@ProviderIcon(provider)">@L["Connect"] @provider</MudButton>
    }
    @if (!ConnectedProviders.Contains("PiuGame", StringComparer.OrdinalIgnoreCase))
    {
        <MudButton OnClick="OpenPiuGameDialog" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.SportsEsports">@L["Connect"] PIUGAME</MudButton>
    }
    <MudButton Href="/Account/Merge" Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.MergeType">@L["Merge another account"]</MudButton>
</div>

<MudDialog @bind-Visible="_showPiuGameDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["Connect"] PIUGAME</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-4">@L["Your username and password are sent directly to piugame.com and are never stored"]</MudAlert>
        <MudTextField T="string" Label="@L["PIUGame.com Username"].Value" Disabled="_isConnectingPiuGame" @bind-Value="_piuGameUsername"></MudTextField>
        <MudTextField T="string" InputType="InputType.Password" Label="@L["PIUGame.com Password"].Value" Disabled="_isConnectingPiuGame" @bind-Value="_piuGamePassword"></MudTextField>
    </DialogContent>
    <DialogActions>
        <MudSpacer></MudSpacer>
        <MudButton Variant="Variant.Text"
                   OnClick="() => _showPiuGameDialog = false"
                   Disabled="_isConnectingPiuGame"
                   Color="Color.Primary">@L["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   OnClick="ConnectPiuGame"
                   Disabled="@(_isConnectingPiuGame || string.IsNullOrWhiteSpace(_piuGameUsername) || string.IsNullOrWhiteSpace(_piuGamePassword))"
                   Color="Color.Primary">@L["Connect"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showDisconnectDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["Disconnect Sign-In Method"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>@L["You will no longer be able to sign in with this method"] (@(_disconnectTarget ?? ""))</MudText>
    </DialogContent>
    <DialogActions>
        <MudSpacer></MudSpacer>
        <MudButton Variant="Variant.Text"
                   OnClick="() => _showDisconnectDialog = false"
                   Disabled="_isDisconnecting"
                   Color="Color.Primary">@L["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   OnClick="ConfirmDisconnect"
                   Disabled="_isDisconnecting"
                   Color="Color.Error">@L["Confirm"]</MudButton>
    </DialogActions>
</MudDialog>

@inject ICurrentUserAccessor CurrentUser;
@inject IMediator Mediator;
@inject ISnackbar Snackbar;
@inject AccountProofService Proofs;
@code
{
    /// <summary>
    ///     Raised when a connect attempt collides with another account (with proof already
    ///     recorded) — the page hosts the merge-invitation alert above the tabs.
    /// </summary>
    [Parameter]
    public EventCallback<Guid> MergeInviteRaised { get; set; }

    private IReadOnlyList<ExternalLoginRecord> _externalLogins = Array.Empty<ExternalLoginRecord>();
    private static readonly string[] ConnectableProviders = { "Discord", "Google" };
    private bool _showDisconnectDialog = false;
    private bool _isDisconnecting = false;
    private string? _disconnectTarget;
    private bool _showPiuGameDialog = false;
    private bool _isConnectingPiuGame = false;
    private string _piuGameUsername = string.Empty;
    private string _piuGamePassword = string.Empty;

    private IReadOnlyList<string> ConnectedProviders => _externalLogins
        .Select(l => l.LoginProviderName)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private static string ProviderIcon(string provider) => provider.ToLowerInvariant() switch
    {
        "discord" => Icons.Custom.Brands.Discord,
        "google" => Icons.Custom.Brands.Google,
        "facebook" => Icons.Custom.Brands.Facebook,
        _ => Icons.Material.Filled.Login
    };

    protected override async Task OnInitializedAsync()
    {
        _externalLogins = (await Mediator.Send(new GetExternalLoginsQuery())).ToArray();
    }

    private void OpenPiuGameDialog()
    {
        _piuGameUsername = string.Empty;
        _piuGamePassword = string.Empty;
        _showPiuGameDialog = true;
    }

    private async Task ConnectPiuGame()
    {
        _isConnectingPiuGame = true;
        try
        {
            var identity = await Mediator.Send(new GetPiuGameAccountIdentityQuery(_piuGameUsername, _piuGamePassword));
            var outcome = await Mediator.Send(new LinkExternalAliasesCommand("PiuGame", identity.GetLoginAliases().ToArray()));
            switch (outcome.Result)
            {
                case ExternalLinkResult.Linked:
                    Snackbar.Add(L["Sign-in method connected"], Severity.Success);
                    break;
                case ExternalLinkResult.AlreadyLinked:
                    Snackbar.Add(L["This sign-in method is already connected to your account"], Severity.Info);
                    break;
                case ExternalLinkResult.ConflictingAccount:
                    Snackbar.Add(L["This sign-in method is connected to a different account"], Severity.Warning);
                    if (outcome.ConflictingUserId != null)
                    {
                        // The credentials they just typed are proof of the conflicting
                        // account's piugame login — the merge invitation is friction-free.
                        Proofs.RecordProof(CurrentUser.User.Id, outcome.ConflictingUserId.Value);
                        await MergeInviteRaised.InvokeAsync(outcome.ConflictingUserId.Value);
                    }

                    break;
            }

            _externalLogins = (await Mediator.Send(new GetExternalLoginsQuery())).ToArray();
            _showPiuGameDialog = false;
        }
        catch (InvalidCredentialException)
        {
            Snackbar.Add(L["Invalid username or password"], Severity.Error);
        }
        catch (HttpRequestException)
        {
            Snackbar.Add(L["Could not reach PIUGAME, try again later"], Severity.Error);
        }
        finally
        {
            _piuGamePassword = string.Empty;
            _isConnectingPiuGame = false;
        }
    }

    private void OpenDisconnectDialog(string provider)
    {
        _disconnectTarget = provider;
        _showDisconnectDialog = true;
    }

    private async Task ConfirmDisconnect()
    {
        if (_disconnectTarget == null) return;
        _isDisconnecting = true;
        try
        {
            await Mediator.Send(new DisconnectExternalProviderCommand(_disconnectTarget));
            _externalLogins = (await Mediator.Send(new GetExternalLoginsQuery())).ToArray();
            Snackbar.Add(L["Sign-in method disconnected"], Severity.Success);
            _showDisconnectDialog = false;
        }
        finally
        {
            _isDisconnecting = false;
        }
    }
}
