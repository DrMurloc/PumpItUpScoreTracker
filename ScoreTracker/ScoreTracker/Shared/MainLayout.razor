@using ScoreTracker.Domain.SecondaryPorts
@using MediatR
@using ScoreTracker.PlayerProgress.Contracts.Queries
@using ScoreTracker.Application.Commands
@using ScoreTracker.EventCompetition.Contracts.Queries
@using ScoreTracker.EventCompetition.Contracts.Commands
@using ScoreTracker.Application.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Application.Events
@using ScoreTracker.Domain.Events
@using MassTransit
@using ScoreTracker.Domain.Records
@inherits LayoutComponentBase
@inject ICurrentUserAccessor CurrentUser
@implements INotificationHandler<MatchUpdatedEvent>
@implements INotificationHandler<ImportStatusUpdatedEvent>
@implements INotificationHandler<PlayerStatsUpdatedEvent>
@implements INotificationHandler<ImportStatusErrorEvent>
<PageTitle>@L["PIU Scores"]</PageTitle>

<MudThemeProvider Theme="Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<ChartVideoDisplay></ChartVideoDisplay>
<style>
    .dense-nav .mud-nav-link {
        padding-top: 4px;
        padding-bottom: 4px;
        min-height: unset;
    }

    .dense-nav .mud-nav-link-text {
        font-size: .8125rem;
        line-height: 1.4;
    }

    .dense-nav .mud-nav-link-icon,
    .dense-nav .mud-nav-link .mud-icon-root {
        font-size: 1.125rem;
    }

    .dense-nav .nav-section {
        font-size: .6875rem;
        letter-spacing: .08em;
        line-height: 1.4;
        opacity: .65;
    }

    .appbar-search .mud-input-control {
        margin: 0;
    }

    .appbar-search .mud-input.mud-input-outlined {
        background: rgba(255, 255, 255, .15);
    }

    .appbar-search .mud-input.mud-input-outlined input,
    .appbar-search .mud-input-adornment-icon {
        color: #EDF1F5;
    }

    .appbar-search .mud-input.mud-input-outlined input::placeholder {
        color: rgba(237, 241, 245, .75);
        opacity: 1;
    }

    .appbar-search .mud-input.mud-input-outlined .mud-input-outlined-border {
        border-color: rgba(237, 241, 245, .5);
    }

    .mud-drawer {
        scrollbar-width: none;
    }

    .mud-drawer::-webkit-scrollbar {
        display: none;
    }
</style>
<MudLayout>
    @* Fixed: the drawer is viewport-pinned, so a scrolling app bar visibly detaches from it. *@
    <MudAppBar Color="Color.Primary" Fixed="true" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="() => _isOpen = !_isOpen"/>
        <MudText Typo="Typo.subtitle1" Style="font-weight: 500; white-space: nowrap;" Class="mr-6">@(_userId == null ? L["PIU Scores"].Value : $"{UserName}")</MudText>
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div class="d-flex align-center appbar-search" style="min-width: 220px; max-width: 320px;">
                <ChartSelector Mix="_currentMix" Label="" Placeholder="@L["Find a chart"].Value" Variant="Variant.Outlined" Margin="Margin.Dense" ChartIdSelected="GoToChart"></ChartSelector>
            </div>
        </MudHidden>
        <MudSpacer></MudSpacer>
        @if (CurrentUser.IsLoggedIn)
        {
            <MudHidden Breakpoint="Breakpoint.Xs">
                <MudButton Href="/UploadPhoenixScores" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Small" StartIcon="@Icons.Material.Filled.CloudDownload" Class="mr-4">@L["Import Scores"]</MudButton>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.SmAndUp">
                <MudIconButton Href="/UploadPhoenixScores" Color="Color.Inherit" Icon="@Icons.Material.Filled.CloudDownload" Class="mr-1"></MudIconButton>
            </MudHidden>
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudAvatar Size="Size.Small" Style="cursor: pointer;">
                        @* Native img with an onerror fallback: stored avatar URLs go stale when
                           piugame rehosts its images (they moved with the Phoenix 2 rollout), so
                           a broken URL degrades to the default avatar instead of a broken-image glyph. *@
                        <img src="@_profileImage" alt=""
                             onerror="this.onerror=null;this.src='https://piuimages.arroweclip.se/avatars/4f617606e7751b2dc2559d80f09c40bf.png';"
                             style="width: 100%; height: 100%; object-fit: cover;"/>
                    </MudAvatar>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Href="/Account" Icon="@Icons.Material.Filled.AccountCircle">@L["Account"]</MudMenuItem>
                    <MudMenuItem Href="/Logout" Icon="@Icons.Material.Filled.Logout">@L["Logout"]</MudMenuItem>
                </ChildContent>
            </MudMenu>
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Filled.NoAccounts" Color="Color.Inherit" Edge="Edge.Start" Href="/Login"></MudIconButton>
        }
    </MudAppBar>
    <MudDrawer @bind-Open="_isOpen" Variant="@DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" ClipMode="DrawerClipMode.Always" Width="240px" Elevation="1">
        <MudDrawerHeader Class="d-flex align-center gap-2 py-3" Style="min-height: unset;">
            <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Small"></MudIcon>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600; letter-spacing: .02em;">@L["PIU Scores"]</MudText>
        </MudDrawerHeader>
        @* flex-grow 0: the drawer content is a flex column, and the divider's full-width
           styling flex-grows — horizontal in a toolbar, but here it stretches vertically and
           swallows the space between the header and the nav. *@
        <MudDivider Style="flex-grow: 0;"></MudDivider>
        <MudNavMenu Class="dense-nav pb-4">
            <MudText Typo="Typo.overline" Class="ml-4 mt-2 d-block nav-section">@L["Play"]</MudText>
            @if (CurrentUser.IsLoggedIn)
            {
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">@L["Home"]</MudNavLink>
                <MudNavLink Href="/UploadPhoenixScores" Icon="@Icons.Material.Filled.CloudDownload">@L["Import Scores"]</MudNavLink>
            }
            else
            {
                <MudNavLink Href="/Login" Icon="@Icons.Material.Filled.NoAccounts">@L["Login"]</MudNavLink>
            }
            <MudNavLink Href="/Charts" Icon="@Icons.Material.Filled.List">@L["Charts"]</MudNavLink>
            <MudNavLink Href="/TierLists" Icon="@Icons.Material.Filled.Topic">@L["Tier Lists"]</MudNavLink>

            <MudText Typo="Typo.overline" Class="ml-4 mt-3 d-block nav-section">@L["My Progress"]</MudText>
            @if (CurrentUser.IsLoggedIn)
            {
                @* XX keeps its legacy progress page; Phoenix and Phoenix 2 share the Phoenix-style pages. *@
                <MudNavLink Href=@(_currentMix==MixEnum.XX?"/Progress":"/Phoenix/Progress") Icon="@Icons.Material.Filled.BarChart">@L["Progress Charts"]</MudNavLink>
                @if (_currentMix != MixEnum.XX)
                {
                    <MudNavLink Href="/Pumbility" Icon="@Icons.Material.Filled.Star">@L["PUMBILITY"]</MudNavLink>
                }
            }
            <MudNavLink Href="/Titles" Icon="@Icons.Material.Filled.Grade">@L["Titles"]</MudNavLink>

            <MudText Typo="Typo.overline" Class="ml-4 mt-3 d-block nav-section">@L["Compete"]</MudText>
            <MudNavLink Href="/WeeklyCharts" Icon="@Icons.Material.Filled.ViewWeek">@L["Weekly Charts"]</MudNavLink>
            <MudNavLink Href="/Tournaments/MarchOfMurlocs" Icon="@Icons.Material.Filled.Alarm">March of Murlocs</MudNavLink>
            @foreach (var tourney in _highlightedEvents)
            {
                @if (tourney.Type == TournamentType.Stamina)
                {
                    <MudNavLink Href=@($"/Tournament/Stamina/{tourney.Id}") Icon="@Icons.Material.Filled.Event">@tourney.Name</MudNavLink>
                }
                else if (tourney.LinkOverride != null)
                {
                    <MudNavLink Href="@tourney.LinkOverride.ToString()" Target="_blank" Icon="@Icons.Material.Filled.Event">@tourney.Name</MudNavLink>
                }
                else
                {
                    <MudNavLink Href=@($"/Tournament/{tourney.Id}/Qualifiers") Icon="@Icons.Material.Filled.Event">@tourney.Name</MudNavLink>
                }
            }
            <MudNavGroup Title=@L["Rankings"] Icon="@Icons.Material.Filled.Leaderboard" Expanded="false">
                @if (CurrentUser.IsLoggedIn)
                {
                    <MudNavLink Href="ScoreRankings" Icon="@Icons.Material.Filled.Stars">@L["Score Ranking"]</MudNavLink>
                }
                <MudNavLink Href="/Completion" Icon="@Icons.Material.Filled.Done">@L["Completion Leaderboards"]</MudNavLink>
                <MudNavLink Href="/UcsLeaderboards" Icon="@Icons.Material.Filled.EditNote">@L["UCS Leaderboards"]</MudNavLink>
                <MudNavLink Href="/PlayerRankings" Icon="@Icons.Material.Filled.Public">@L["World Rankings"]</MudNavLink>
                <MudNavLink Href="/OfficialLeaderboards" Icon="@Icons.Material.Filled.Score">@L["Official Leaderboard Search"]</MudNavLink>
                <MudNavLink Href="/OfficialLeaderboards/PlayerCompare" Icon="@Icons.Material.Filled.CompareArrows">@L["Leaderboard Player Compare"]</MudNavLink>
            </MudNavGroup>

            <MudText Typo="Typo.overline" Class="ml-4 mt-3 d-block nav-section">@L["Community"]</MudText>
            <MudNavLink Href="/Communities" Icon="@Icons.Material.Filled.Group">@L["Communities"]</MudNavLink>
            <MudNavLink Href="https://discord.gg/MEYvr3bFte" Target="_blank" Icon="@Icons.Custom.Brands.Discord">@L["Discord"]</MudNavLink>

            <MudDivider Class="my-2"></MudDivider>
            <MudNavGroup Title=@L["Tools"] Icon="@Icons.Material.Filled.Build" Expanded="false">
                <MudNavLink Href="/PhoenixCalculator" Icon="@Icons.Material.Filled.Calculate">@L["Phoenix Score Calculator"]</MudNavLink>
                <MudNavLink Href="/RatingCalculator" Icon="@Icons.Material.Filled.Calculate">@L["Rating Calculator"]</MudNavLink>
                <MudNavLink Href="/ChartRandomizer" Icon="@Icons.Material.Filled.QuestionMark">@L["Chart Randomizer"]</MudNavLink>
                <MudNavLink Href="/LifeCalculator" Icon="@Icons.Material.Filled.Battery4Bar">@L["Lifebar Calculator"]</MudNavLink>
                <MudNavLink Href="/StepArtists" Icon="@Icons.Material.Filled.Brush">@L["Step Artists"]</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/About" Icon="@Icons.Material.Filled.Info">@L["About"]</MudNavLink>
            <MudNavGroup Title=@(L["Mix"]+" ("+_currentMix.GetName()+")") Icon="@Icons.Material.Filled.LibraryMusic" Expanded="false">
                @foreach (var value in SelectableMixes)
                {
                    <MudNavLink OnClick="()=>SetMix(value)">@value.GetName()</MudNavLink>
                }
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer>
            @Body
            
            <MudDialog @bind-Visible="_showBite">
                <DialogContent>
                    <MudImage Src="https://piuimages.arroweclip.se/TheBigOne.png" Height="400" ObjectFit="ObjectFit.ScaleDown" Style="display:block;margin-left:auto;margin-right:auto;"></MudImage>
                    
                </DialogContent>
                <DialogActions>
                    <MudSpacer></MudSpacer>
                    <MudButton Href="https://bigone.cl/en/index.html" Target="_blank" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Link" Variant="Variant.Outlined">@L["Open"]</MudButton>
                    <MudButton Variant="Variant.Text"
                               OnClick="()=>_showBite=false"
                               Color="Color.Primary">@L["Close"]</MudButton>
                </DialogActions>
            </MudDialog>

        </MudContainer>
    </MudMainContent>
</MudLayout>
@inject IMediator Mediator;
@inject IUiSettingsAccessor UiSettings;
@inject NavigationManager NavManager;
@code
{
    // Open by default: the Responsive drawer variant keeps it as a persistent sidebar on
    // desktop widths and auto-collapses to the hamburger-toggled overlay below Md.
    private bool _isOpen = true;
    private Guid? _userId = null;

    private Task GoToChart(Chart chart)
    {
        NavManager.NavigateTo($"/Chart/{chart.Id}");
        return Task.CompletedTask;
    }
    private bool _showBite = false;
    private const string BitePopupKey = "MainLayout__BigOne2024PopupShown";
    public static readonly DateTimeOffset _cutoff = new DateTimeOffset(2024, 10, 15, 0, 0, 0, TimeSpan.FromHours(-5));
    private MixEnum _currentMix = MixEnum.Phoenix;
    // Launch order: deploy this build, then run the ChartMix seed script immediately —
    // Phoenix 2 is briefly selectable-but-empty in between (docs/design/phoenix2-implementation.md).
    private static readonly MixEnum[] SelectableMixes = { MixEnum.XX, MixEnum.Phoenix, MixEnum.Phoenix2 };
    private string _profileImage = string.Empty;
    private string _gamerTag = string.Empty;
    private IEnumerable<TournamentRecord> _highlightedEvents = Array.Empty<TournamentRecord>();
    private async Task SetMix(MixEnum mix)
    {
        await UiSettings.SetSelectedMix(mix);
        NavManager.NavigateTo(NavManager.Uri, true);
    }
    protected override async Task OnInitializedAsync()
    {
        _userId = CurrentUser.IsLoggedIn ? CurrentUser.User.Id : null;
        // Mix first: the displayed rating follows the viewer's current mix.
        _currentMix = await UiSettings.GetSelectedMix();
        _highlightedEvents = (await Mediator.Send(new GetAllTournamentsQuery()))
            .Where(e => e.IsHighlighted);

        var hasShown = await UiSettings.GetSetting(BitePopupKey);
        if (DateTimeOffset.Now<_cutoff && string.IsNullOrWhiteSpace(hasShown))
        {
            _showBite = true;
            await UiSettings.SetSetting(BitePopupKey,"true");
        }
        if (CurrentUser.IsLoggedIn)
        {
            var settings = await Mediator.Send(new GetUserUiSettingsQuery());
            _profileImage = settings.TryGetValue("ProfileImage", out var image) ? image :
                "https://piuimages.arroweclip.se/avatars/4f617606e7751b2dc2559d80f09c40bf.png";
            _gamerTag = settings.TryGetValue("GameTag", out var tag) ? tag : "";
            UserName = CurrentUser.User.Name;
            if (!string.IsNullOrWhiteSpace(_gamerTag))
        {
                UserName += $" ({_gamerTag})";
            }
            Rating = (await Mediator.Send(new GetPlayerStatsQuery(CurrentUser.User.Id, _currentMix))).SkillRating;
        }
    }

    private static readonly MudTheme Theme = new()
        {
            
            PaletteLight = new()
            {
    //77BCDC
    //466E8d
                Primary = "#80B3D4",
                Secondary = "#8FBCD8",
                Error = "#C72020",
                Success = "#6EDE7F",
                Warning = "#FFC433",
                TextPrimary = "#EDF1F5",
                TextSecondary = "#EDF1F5",
                ActionDefault = "#EDF1F5",
                ActionDisabled = "#d3d3d3",
                Background = "#18191A",
                BackgroundGray = "#3A3B3C",
                Surface = "#242526",
                TextDisabled = "#d3d3d3",
                DrawerBackground = "#283E5C",
                DrawerIcon = "#EDF1F5",
                DrawerText = "#EDF1F5"
            },
            PaletteDark = new()
            {
                //77BCDC
                //466E8d
                Primary = "#80B3D4",
                Secondary = "#8FBCD8",
                Error = "#C72020",
                Success = "#6EDE7F",
                Warning = "#FFC433",
                TextPrimary = "#EDF1F5",
                TextSecondary = "#EDF1F5",
                ActionDefault = "#EDF1F5",
                ActionDisabled = "#d3d3d3",
                Background = "#18191A",
                BackgroundGray = "#3A3B3C",
                Surface = "#242526",
                TextDisabled = "#d3d3d3",
                DrawerBackground = "#283E5C",
                DrawerIcon = "#EDF1F5",
                DrawerText = "#EDF1F5"
            }
        };

    public static event EventHandler<ImportStatusUpdatedEvent>? ImportStatusUpdatedEvent;
    public static event EventHandler<MatchUpdatedEvent>? MatchUpdated;
    public static event EventHandler<ImportStatusErrorEvent>? ImportStatusErrorEvent;
    public Task Handle(MatchUpdatedEvent notification, CancellationToken cancellationToken)
    {
        MatchUpdated?.Invoke(this, notification);
        return Task.CompletedTask;
    }
    private string UserName { get; set; }
    public int Rating { get; set; }

    public Task Handle(ImportStatusUpdatedEvent notification, CancellationToken cancellationToken)
    {
        ImportStatusUpdatedEvent?.Invoke(this, notification);
        return Task.CompletedTask;
    }

    public Task Handle(PlayerStatsUpdatedEvent notification, CancellationToken cancellationToken)
    {
        // Stats events now arrive per mix — only reflect the one the viewer is looking at.
        if (_userId != notification.UserId || notification.Mix != _currentMix)
        {
            return Task.CompletedTask;
        }
        Rating = notification.NewStats.SkillRating;
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    public Task Handle(ImportStatusErrorEvent notification, CancellationToken cancellationToken)
    {
        ImportStatusErrorEvent?.Invoke(this, notification);
        return Task.CompletedTask;
    }
}
