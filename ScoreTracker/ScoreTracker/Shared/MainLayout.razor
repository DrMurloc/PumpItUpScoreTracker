@using ScoreTracker.Domain.SecondaryPorts
@using MediatR
@using ScoreTracker.PlayerProgress.Contracts.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Web.Services.Theming
@using Microsoft.AspNetCore.Components.Routing
@inherits LayoutComponentBase
@inject ICurrentUserAccessor CurrentUser
@implements IDisposable
<PageTitle>@L["PIU Scores"]</PageTitle>

@* Shell chrome — nav, mix pill, bottom nav, More sheet — is server-rendered by _SiteLayout
   (docs/design/static-shell.md). What stays here is what only the app root can own: the Mud
   providers every page needs, the legacy-mix gate, the page dock, and the recap pointer. *@
<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<ChartVideoDisplay></ChartVideoDisplay>

@* MudLayout is MudBlazor's drawer host (it derives from MudDrawerContainer), not chrome —
   a MudDrawer anchors to it and falls into normal flow without one. It carries no app bar
   and no nav; it is here for the pages that open drawers. *@
<MudLayout>
    @* Fixed-position, so where it sits in the tree doesn't matter. Mobile only — it exists to
       put primary actions in thumb reach above the bottom nav, and desktop has neither. *@
    @if (PageDock.DockContent != null)
    {
        <div class="page-dock shell-mobile-only">@PageDock.DockContent</div>
    }

    <MudContainer>
    @if (LegacyMixGate.IsGated(_currentMix, new Uri(NavManager.Uri).AbsolutePath))
    {
        @* One render frame at most — RedirectIfGated is already navigating to
           /TierLists. The panel is the backstop, not the destination. *@
        <div class="tier-list-cta">
            <MudIcon Icon="@Icons.Material.Filled.Construction"></MudIcon>
            <MudText Typo="Typo.h5">@L["This page isn't ready for older mixes yet"]</MudText>
            <MudButton Href="/Charts" Color="Color.Primary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.QueueMusic">@L["Charts"]</MudButton>
        </div>
    }
    else
    {
        @Body
    }

    @* One-time Phoenix Recap pointer: shows once per user, only after their recap row
       exists. No expiry cutoff yet — set one when the Phoenix 2 launch date is known
       (docs/design/phoenix-season-recap.md). *@
    <MudDialog @bind-Visible="_showRecapPopup">
        <DialogContent>
            <MudText Typo="Typo.h5">@L["Your Phoenix Story is ready"]</MudText>
            <MudText Class="mt-2">@L["Three and a half years of Pump, one recap. Go see yours — and screenshot the good parts."]</MudText>
        </DialogContent>
        <DialogActions>
            <MudSpacer></MudSpacer>
            <MudButton Href=@($"/Player/{_userId}/PhoenixRecap") Color="Color.Primary" StartIcon="@Icons.Material.Filled.LocalFireDepartment" Variant="Variant.Filled" OnClick="()=>_showRecapPopup=false">@L["Open"]</MudButton>
            <MudButton Variant="Variant.Text"
                       OnClick="()=>_showRecapPopup=false"
                       Color="Color.Primary">@L["Close"]</MudButton>
            </DialogActions>
        </MudDialog>
    </MudContainer>
</MudLayout>
@inject IMediator Mediator;
@inject IUiSettingsAccessor UiSettings;
@inject NavigationManager NavManager;
@inject PageDockService PageDock;
@inject IJSRuntime JSRuntime;
@code
{
    private Guid? _userId = null;
    private bool _showRecapPopup = false;
    private bool _hasRecap = false;
    private const string RecapPopupKey = "MainLayout__PhoenixRecapPopupShown";
    // Seeded by App from the shell's root parameter, so it is known before the first render.
    private MixEnum _currentMix = MixEnum.Phoenix;
    private MixEnum _themeMix = MixEnum.Phoenix;
    private MudTheme _theme = MixThemes.ThemeFor(MixEnum.Phoenix);

    // The dock and focus-mode classes live on <html>: the chrome that reacts to them is
    // server-rendered, outside this root.
    private void OnDockChanged()
    {
        _ = JSRuntime.InvokeVoidAsync("shell.setDockState", PageDock.DockContent != null, PageDock.FocusMode);
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        RedirectIfGated();
        // Fresh page starts with the nav visible again.
        _ = JSRuntime.InvokeVoidAsync("pageDock.reset");
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    ///     Gated routes soft-redirect to the tier lists page (the one destination every
    ///     mix can render) instead of loading — pages that predate legacy mixes throw
    ///     on them, so they must never begin initializing (docs/design/legacy-mixes.md).
    /// </summary>
    private bool RedirectIfGated()
    {
        if (!LegacyMixGate.IsGated(_currentMix, new Uri(NavManager.Uri).AbsolutePath)) return false;
        NavManager.NavigateTo("/TierLists");
        return true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // nav.js starts the scroll watcher with the page, before any content exists, so its
        // idea of where the page was scrolled to predates the content. Re-sync once the
        // circuit has actually rendered something, or the first scroll is measured against a
        // page that was 48px tall and the nav flicks in and out.
        if (firstRender) await JSRuntime.InvokeVoidAsync("pageDock.reset");
    }

    public void Dispose()
    {
        // Defensive: a circuit torn down mid-render (hard refresh) can dispose the layout
        // before injection finished — observed once in the field as an NRE here.
        if (NavManager is not null) NavManager.LocationChanged -= OnLocationChanged;
        if (PageDock is not null) PageDock.Changed -= OnDockChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        NavManager.LocationChanged += OnLocationChanged;
        PageDock.Changed += OnDockChanged;
        _userId = CurrentUser.IsLoggedIn ? CurrentUser.User.Id : null;
        // Resolved from the request by the shell, so the gate can evaluate on the first render
        // — the body no longer has to be held behind a spinner waiting for it.
        _currentMix = await UiSettings.GetSelectedMix();
        RedirectIfGated();
        _themeMix = MixThemes.ResolveThemeMix(
            await UiSettings.GetSetting(MixThemes.OverrideSettingKey), _currentMix);
        _theme = MixThemes.ThemeFor(_themeMix);

        if (CurrentUser.IsLoggedIn)
        {
            // Only pester players whose recap actually exists; the flag flips on first show.
            _hasRecap = await Mediator.Send(new GetPlayerRecapQuery(CurrentUser.User.Id)) != null;
            var recapShown = await UiSettings.GetSetting(RecapPopupKey);
            if (_hasRecap && string.IsNullOrWhiteSpace(recapShown))
            {
                _showRecapPopup = true;
                await UiSettings.SetSetting(RecapPopupKey, "true");
            }
        }
    }
}
