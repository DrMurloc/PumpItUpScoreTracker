    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusAddChart && _showAddChart && _addChartSelector != null)
        {
            _focusAddChart = false;
            await _addChartSelector.FocusAsync();
        }

        if (_focusNewMatch && _showNewMatch && _newMatchNameField != null)
        {
            _focusNewMatch = false;
            await _newMatchNameField.FocusAsync();
        }
    }

    private async Task AddChart(Chart chart)
    {
        _showAddChart = false;
        if (CurrentUser.IsLoggedIn && _drawId != null)
        {
            var draw = await Mediator.Send(new AddChartToDrawCommand(_drawId.Value, chart.Id));
            var added = draw.Cards.OrderBy(c => c.Order).Last();
            _cards.Add(new CardVm { PullId = added.PullId, Chart = chart, Order = added.Order, State = added.State });
        }
        else
        {
            _cards.Add(new CardVm
                { PullId = Guid.NewGuid(), Chart = chart, Order = _cards.Count + 1, State = DrawCardState.None });
        }

        Snackbar.Add(L["{0} added to the draw", chart.Song.Name.ToString()], Severity.Success);
        // ChartSelector's callback is a plain delegate (no EventCallback auto-render),
        // and this fires from the popover's render scope — poke the page explicitly.
        StateHasChanged();
    }

