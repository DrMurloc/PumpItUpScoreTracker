@page "/ChartRandomizer"
@rendermode RenderModes.Interactive
@using MediatR
@using System.Text.Json
@using Microsoft.Extensions.Options
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.EventCompetition.Contracts
@using ScoreTracker.EventCompetition.Contracts.Commands
@using ScoreTracker.EventCompetition.Contracts.Queries
@using ScoreTracker.Identity.Contracts.Queries
@using ScoreTracker.Randomizer.Contracts
@using ScoreTracker.Randomizer.Contracts.Commands
@using ScoreTracker.Randomizer.Contracts.Events
@using ScoreTracker.Randomizer.Contracts.Queries
@using ScoreTracker.Web.Services.UiNotifications
@using ScoreTracker.Web.Shared
@using ScoreTracker.Application.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Domain.Exceptions
@using ScoreTracker.Domain.Models
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Domain.Records
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Enums
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts

@* Draw-first (docs/design/randomizer-overhaul.md): the cards are the answer and they
   render at the top; settings live behind the drawer; the dock keeps Randomize on the
   thumb. Card order is frozen — protect/veto restyle in place, Clear Vetoed is the only
   compaction. Contexts: personal (default) or a tournament the user holds a role in
   (?tournament=): draws and the settings library swap to the tournament's, and draft
   mode takes the shell over (focus mode) for the staff tablet players tap. *@
<PageTitle>@(_contextTournamentId == null ? (string)L["Chart Randomizer"] : ContextName)</PageTitle>
<HeadContent>
    <meta name="description" content="Randomize and protect/veto Pump It Up charts"/>
    <meta property="og:title" content="PIU Chart Randomizer">
    <meta property="og:description" content="Randomize and protect/veto Pump It Up charts">
</HeadContent>

@* New match panel body, shared by all three triggers (desktop header, empty state,
   dock) so the fields never duplicate — each trigger just anchors a popover around it
   (round 12). *@
@{
    RenderFragment newMatchBody =
        @<text>
            @if (_tournamentSettings.Any())
            {
                <MudTextField @ref="_newMatchNameField" T="string" @bind-Value="_newMatchName" Label="@L["Match name"]"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"></MudTextField>
                <MudSelect T="string" @bind-Value="_newMatchPreset" Label="@L["Settings preset"]"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="rand-preset-select">
                    @foreach (var preset in _tournamentSettings.Values.OrderBy(s => s.SettingsName.ToString()))
                    {
                        var name = preset.SettingsName.ToString();
                        <MudSelectItem T="string" Value="name">
                            <div class="rand-preset-item">
                                <span class="rand-preset-name">@name</span>
                                <span class="rand-preset-summary">@SettingsSummary(preset)</span>
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="_busy || string.IsNullOrWhiteSpace(_newMatchName) || string.IsNullOrWhiteSpace(_newMatchPreset)"
                           OnClick="CreateMatch">@L["Create & draw"]</MudButton>
            }
            else
            {
                @* Owner-locked (round 6): no matches without a tournament preset. *@
                <MudText Typo="Typo.body2">@L["Matches draw from a tournament preset — save one first."]</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Tune"
                           OnClick="OpenSettingsFromNewMatch">@L["Open Settings"]</MudButton>
            }
        </text>;
}

@if (_draftMode)
{
    <div class="rand-draft-head">
        <button type="button" class="rand-exit-chip" @onclick="EndDraft">
            <MudIcon Icon="@Icons.Material.Filled.FullscreenExit" Size="Size.Small"></MudIcon>@L["Exit full screen"]
        </button>
        <span class="rand-tour-pill">@ContextName@(SelectedMatchName == null ? null : $" · {SelectedMatchName}")</span>
        <span class="rand-live"><span class="rand-live-dot"></span>@L["LIVE"]</span>
        @if (_drawSlug != null)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Sensors" Size="Size.Small" Color="Color.Secondary"
                           OnClick="CopySpectateLink" aria-label="@L["Copy spectate link"]"></MudIconButton>
        }
    </div>
    <div class="rand-draft-armed">
        <ArmedActionSelector @bind-Value="_armedAction" Loud="true"></ArmedActionSelector>
    </div>
}
else
{
    <div class="rand-header">
        @if (_contextTournamentId != null)
        {
            @* The tournament IS the page while you're in it (round 8) — no switcher back
               to personal; a fresh /ChartRandomizer visit is the way out. The gear is the
               tournament's control room. *@
            <MudText Typo="Typo.h5">@ContextName</MudText>
            @if (CanOperate)
            {
                @* Phone widths carry the cog on the dock — no duplicate (round 9). *@
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Primary"
                                   OnClick="OpenManage" aria-label="@L["Manage tournament"]"></MudIconButton>
                </MudHidden>
            }
            @if (_matches.Any())
            {
                @* Match picker rides the header, right-aligned (round 9) — a full row of
                   vertical space back. New match joins it on desktop; the dock CTA covers
                   phones. *@
                <div class="rand-header-match">
                    <MudAutocomplete T="DrawDto" Value="SelectedMatch" ValueChanged="OnMatchPicked"
                                     SearchFunc="@((s, c) => SearchMatches(s))" ToStringFunc="@(m => m?.Name ?? string.Empty)"
                                     Label="@L["Match"]" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     MaxItems="50" Clearable="false" MinCharacters="0" SelectValueOnTab="true"
                                     Class="rand-match-select"></MudAutocomplete>
                    @if (CanOperate)
                    {
                        @* Desktop New match opens a popover below the top-right button (round 12). *@
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <div class="folder-picker-anchor rand-newmatch-anchor">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="ToggleNewMatch">@L["New match"]</MudButton>
                                <MudPopover Open="_showNewMatch" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                    <div class="rand-new-match-pop">@newMatchBody</div>
                                </MudPopover>
                            </div>
                        </MudHidden>
                    }
                </div>
            }
        }
        else
        {
            <MudText Typo="Typo.h5">@L["Chart Randomizer"]</MudText>
            @if (CurrentUser.IsLoggedIn && _myTournaments.Any())
            {
                <MudSelect T="string" Value="ContextValue" ValueChanged="SwitchContext" Label="@L["Running for"]"
                           Dense="true" Class="rand-context-select" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("personal")">@L["Personal"]</MudSelectItem>
                    @foreach (var tournament in _myTournaments)
                    {
                        var id = tournament.TournamentId.ToString();
                        <MudSelectItem T="string" Value="id">@tournament.TournamentName (@RoleShort(tournament.Role))</MudSelectItem>
                    }
                </MudSelect>
            }
        }
        @* Preset selection lives in the settings drawer for both contexts (owner call,
           round 6) — the header carries only identity and context. *@
    </div>
    @if (!CurrentUser.IsLoggedIn)
    {
        <MudText Typo="Typo.body2" Class="rand-anon-note">@L["Log in to keep your settings and draws — this draw only lives on this page."]</MudText>
    }

    @if (_contextTournamentId == null)
    {
        <div class="rand-chipbar">
            @* Actions only up top — the draw-settings reference strip lives below the
               cards (round 7: important to reference, not part of the live decision). *@
            @* Phone widths reach settings through the dock gear — no duplicate chip. *@
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.Tune" OnClick="() => _showSettings = true">@L["Edit settings"]</MudChip>
            </MudHidden>
            @if (CurrentUser.IsLoggedIn)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.EmojiEvents"
                         OnClick="() => _showCreateTournament = !_showCreateTournament">@L["Run as tournament"]</MudChip>
            }
        </div>
    }

    @* New match is a popover now (round 12), anchored to whichever trigger you used —
       the desktop header button, the empty-state button, or the dock. *@

    @if (_showCreateTournament)
    {
        <div class="rand-create-tournament">
            <MudTextField T="string" @bind-Value="_newTournamentName" Label="@L["Tournament name"]"
                          Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy || string.IsNullOrWhiteSpace(_newTournamentName)"
                       OnClick="CreateTournament">@L["Create"]</MudButton>
            <MudText Typo="Typo.caption" Class="rand-section-hint">@L["Unlisted — only people with a link see it. Staff you invite can run draws from their own devices."]</MudText>
        </div>
    }

    <div class="rand-countline">
        <MudSpacer></MudSpacer>
        @if (_contextTournamentId != null && CanOperate)
        {
            @* Full screen is the staff-tablet flow — no desktop meaning (round 8).
               Redraw moved into the manage drawer with the rest of match management. *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Fullscreen" OnClick="() => _draftMode = true"
                           Disabled="_selectedMatchId == null" Class="mr-2">@L["Full screen"]</MudButton>
            </MudHidden>
        }
        else if (_contextTournamentId == null)
        {
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Casino"
                           Disabled="_busy" OnClick="Randomize" Class="mr-2">@L["Randomize"]</MudButton>
            </MudHidden>
        }
        @* Phone widths carry copy on the dock — no duplicate icon (round 8). *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                <ActivatorContent>
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Primary"
                                   Disabled="@(!_cards.Any() && _drawSlug == null)" aria-label="@L["Copy"]"></MudIconButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Icon="@Icons.Material.Filled.ContentCopy" Disabled="!_cards.Any()"
                                 OnClick="CopyResults">@L["Copy draw results"]</MudMenuItem>
                    @if (_drawSlug != null)
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Sensors"
                                     OnClick="CopySpectateLink">@L["Copy spectate link"]</MudMenuItem>
                    }
                    @if (_contextTournamentId != null && CanOperate && _discordChannelId != null)
                    {
                        <MudMenuItem Icon="@Icons.Custom.Brands.Discord" Disabled="@(_drawId == null || _busy)"
                                     OnClick="PushToDiscord">@L["Push to Discord"]</MudMenuItem>
                    }
                </ChildContent>
            </MudMenu>
        </MudHidden>
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="ml-2">
            <MudIconButton Icon="@Icons.Material.Filled.ViewModule" aria-label="@L["Comfortable"]"
                           Color="@(_density == UiDensity.Comfortable ? Color.Primary : Color.Default)"
                           OnClick="() => SetDensity(UiDensity.Comfortable)"></MudIconButton>
            <MudIconButton Icon="@Icons.Material.Filled.GridOn" aria-label="@L["Compact"]"
                           Color="@(_density == UiDensity.Compact ? Color.Primary : Color.Default)"
                           OnClick="() => SetDensity(UiDensity.Compact)"></MudIconButton>
            <MudIconButton Icon="@Icons.Material.Filled.TableRows" aria-label="@L["Table"]"
                           Color="@(_density == UiDensity.Table ? Color.Primary : Color.Default)"
                           OnClick="() => SetDensity(UiDensity.Table)"></MudIconButton>
        </MudButtonGroup>
    </div>
}

@if (!_draftMode && (_cards.Any(c => c.State != DrawCardState.None) || _density == UiDensity.Compact && _cards.Any()))
{
    <div class="rand-actionbar">
        @if (_density == UiDensity.Compact)
        {
            <ArmedActionSelector @bind-Value="_armedAction"></ArmedActionSelector>
        }
        @if (_cards.Any(c => c.State == DrawCardState.Vetoed))
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.DeleteSweep" Disabled="_busy"
                       OnClick="ClearVetoed">@L["Clear vetoed"] (@_cards.Count(c => c.State == DrawCardState.Vetoed))</MudButton>
        }
    </div>
}

@if (_loading)
{
    <div class="rand-grid rand-grid-compact">
        @for (var i = 0; i < 6; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="110px" Class="tier-chart-card-skeleton"></MudSkeleton>
        }
    </div>
}
else if (!_cards.Any())
{
    <div class="rand-empty">
        <MudIcon Icon="@Icons.Material.Filled.Casino" Style="font-size:2.6rem;"></MudIcon>
        @if (_contextTournamentId != null)
        {
            <MudText Typo="Typo.h6">@L["No matches yet"]</MudText>
            @if (CanOperate)
            {
                <MudText Typo="Typo.body2">@L["A match is a named draw — create one and it fills from a tournament preset."]</MudText>
                @* Popover below on desktop; on phones the dock CTA (popover above) drives it (round 12). *@
                <div class="folder-picker-anchor rand-newmatch-anchor">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               Disabled="_busy" OnClick="ToggleNewMatch">@L["New match"]</MudButton>
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        <MudPopover Open="_showNewMatch" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                            <div class="rand-new-match-pop">@newMatchBody</div>
                        </MudPopover>
                    </MudHidden>
                </div>
            }
            else
            {
                <MudText Typo="Typo.body2">@L["Hang tight — the organizers haven't drawn anything yet."]</MudText>
            }
        }
        else
        {
            <MudText Typo="Typo.h6">@L["No draw yet"]</MudText>
            <MudText Typo="Typo.body2">@L["Set your level range in the settings, then hit Randomize."]</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Casino"
                       Disabled="_busy" OnClick="Randomize">@L["Randomize"]</MudButton>
        }
    </div>
}
else if (GridDensity == UiDensity.Table)
{
    <MudSimpleTable Dense="true" Class="rand-table">
        <tbody>
        @foreach (var card in _cards)
        {
            <tr class="@(card.State == DrawCardState.Vetoed ? "rand-row-vetoed" : card.State == DrawCardState.Protected ? "rand-row-held" : null)">
                <td class="rand-table-order">@card.Order</td>
                <td><DifficultyBubble Chart="card.Chart" Small="true"></DifficultyBubble></td>
                <td class="rand-table-name">@card.Chart.Song.Name</td>
                <td>@(card.State == DrawCardState.Protected ? L["Held"] : card.State == DrawCardState.Vetoed ? L["Vetoed"] : null)</td>
                <td class="rand-table-actions">
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Info"
                                   OnClick="() => OpenDetails(card)" aria-label="@L["Details"]"></MudIconButton>
                    @if (card.State == DrawCardState.None)
                    {
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Shield" Color="Color.Primary"
                                       OnClick="() => SetState(card, DrawCardState.Protected)" aria-label="@L["Protect"]"></MudIconButton>
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                       OnClick="() => SetState(card, DrawCardState.Vetoed)" aria-label="@L["Veto"]"></MudIconButton>
                    }
                    else
                    {
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Undo" Color="Color.Warning"
                                       OnClick="() => SetState(card, DrawCardState.None)" aria-label="@L["Undo"]"></MudIconButton>
                    }
                </td>
            </tr>
        }
        </tbody>
    </MudSimpleTable>
}
else
{
    <div class="rand-grid @(GridDensity == UiDensity.Compact ? "rand-grid-compact" : "rand-grid-comfortable")">
        @foreach (var card in _cards)
        {
            <DrawCardTile PullId="card.PullId" Chart="card.Chart" Order="card.Order" State="card.State"
                          Density="GridDensity"
                          Disabled="@(_contextTournamentId != null && !CanOperate)"
                          OnTap="_ => ApplyArmedAction(card)"
                          OnProtect="_ => SetState(card, DrawCardState.Protected)"
                          OnVeto="_ => SetState(card, DrawCardState.Vetoed)"
                          OnUndo="_ => SetState(card, DrawCardState.None)"
                          OnDetails="_ => OpenDetails(card)"></DrawCardTile>
        }
        @if (_contextTournamentId == null || CanOperate)
        {
            @* Option C (owner-picked): the popup belongs to the slot you tapped — same
               anchor/popover/click-away vocabulary as the level selector. *@
            <div class="folder-picker-anchor rand-add-anchor">
                <button type="button" class="rand-add-tile" @onclick="ToggleAddChart"
                        aria-haspopup="true" aria-expanded="@(_showAddChart ? "true" : "false")"
                        aria-label="@L["Add Chart"]">
                    <span class="rand-add-tile-plus">+</span>
                    <span class="rand-add-tile-label">@L["Add Chart"]</span>
                </button>
                @* Opens upward from the tile's top-left (round 9) — the ghost card sits at
                   the bottom of the grid, so downward would run off-screen. *@
                <MudPopover Open="_showAddChart" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.BottomLeft">
                    <div class="folder-picker-pop rand-add-pop">
                        <MudText Typo="Typo.subtitle2">@L["Add a chart to the draw"]</MudText>
                        <MudText Typo="Typo.caption" Class="rand-section-hint">@L["It lands at the end, unprotected."]</MudText>
                        <ChartSelector @ref="_addChartSelector" Mix="_mix" Label="" Placeholder="@L["Search by song name…"].Value"
                                       ChartIdSelected="AddChart"></ChartSelector>
                    </div>
                </MudPopover>
            </div>
        }
    </div>
    <MudOverlay Visible="_showAddChart" OnClick="() => _showAddChart = false" ZIndex="1199"></MudOverlay>
}

@if (!_draftMode && !_loading)
{
    @* Reference strip: what this draw was configured with — below the cards, out of
       the decision area (round 7). *@
    <div class="rand-draw-settings">
        <span class="rand-draw-settings-label">@L["Draw settings"]</span>
        @foreach (var chip in ConstraintChips)
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@chip</MudChip>
        }
    </div>
}

@* Settings drawer: panel + live-count footer. Bottom-anchored (thumb reach).
   MudLayout is the drawer's container, not chrome — each drawer brings its own. *@
<MudLayout>
<MudDrawer @bind-Open="_showSettings" Anchor="Anchor.Bottom" Variant="@DrawerVariant.Temporary"
           Height="86vh" Elevation="4" Class="rand-drawer">
    <div class="rand-drawer-body">
        @if (CurrentUser.IsLoggedIn)
        {
            <div class="rand-drawer-presets">
                @if (CurrentSettingsMap.Any())
                {
                    <MudSelect T="string" Value="_currentSettingsName" ValueChanged="SelectSavedSettings"
                               Label="@(_contextTournamentId == null ? L["Saved Settings"] : L["Tournament Settings"])"
                               Clearable="true" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var saved in CurrentSettingsMap.Values.OrderBy(s => s.SettingsName.ToString()))
                        {
                            var name = saved.SettingsName.ToString();
                            <MudSelectItem T="string" Value="name">
                                <div class="rand-preset-item">
                                    <span class="rand-preset-name">@name</span>
                                    <span class="rand-preset-summary">@SettingsSummary(saved)</span>
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>
                }
                else if (_contextTournamentId != null)
                {
                    <MudText Typo="Typo.caption" Class="rand-section-hint">@L["No tournament presets yet — tune below and Save, so your staff and matches can use them."]</MudText>
                }
            </div>
        }
        <RandomizerSettingsPanel Settings="_settings" Mix="_mix" MixChanged="OnMixChanged"
                                 SettingsChanged="OnSettingsChanged"></RandomizerSettingsPanel>
    </div>
    <div class="rand-drawer-footer">
        <div class="rand-footer-row">
            <div class="rand-drawer-count">
                <span class="rand-count-n">@(_matchCount?.ToString() ?? "–")</span>
                <span class="rand-count-label">@L["charts match"]</span>
            </div>
            <MudSpacer></MudSpacer>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => _showSettings = false">@L["Done"]</MudButton>
        </div>
        <div class="rand-footer-row">
            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.RestartAlt"
                       OnClick="ResetSettings">@L["Reset"]</MudButton>
            @* Reset is the odd one out — keep the save cluster visually away from it. *@
            <MudSpacer></MudSpacer>
            @if (CurrentUser.IsLoggedIn && _contextTournamentId == null && !string.IsNullOrWhiteSpace(_currentSettingsName))
            {
                <MudTooltip Text="@L["Share these settings"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Share" Color="Color.Primary"
                                   OnClick="ShareSettings" aria-label="@L["Share these settings"]"></MudIconButton>
                </MudTooltip>
            }
            @if (CurrentUser.IsLoggedIn && (_contextTournamentId == null || CanManageSettings))
            {
                <MudTextField T="string" @bind-Value="_saveName" Label="@L["Settings Name"]" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Class="rand-save-name"
                              Immediate="true"></MudTextField>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="_busy || string.IsNullOrWhiteSpace(_saveName)"
                           OnClick="SaveSettings">@(SaveIsNew ? L["Save as new"] : L["Save"])</MudButton>
                @if (CurrentSettingsMap.ContainsKey(_saveName ?? string.Empty))
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="_busy" OnClick="DeleteSettings">
                        @(_confirmingDelete ? L["Tap again to delete"] : L["Delete"])
                    </MudButton>
                }
            }
        </div>
    </div>
</MudDrawer>
</MudLayout>

@* Manage-tournament drawer (round 8): the tournament's control room. Match rename/
   delete/redraw for organizers (redraw for every staff role — assistants included),
   the settings hop for TOs, and the staff roster + invites for the Head TO. Same
   frame as the settings drawer, so "Edit settings" reads as switching drawers. *@
@if (_contextTournamentId != null)
{
    <MudLayout>
    <MudDrawer @bind-Open="_showManage" Anchor="Anchor.Bottom" Variant="@DrawerVariant.Temporary"
               Height="86vh" Elevation="4" Class="rand-drawer">
        <div class="rand-drawer-body">
            <div class="rand-manage-section">
                <MudText Typo="Typo.subtitle2" Class="rand-manage-heading">@L["Match"]</MudText>
                @if (_matches.Any())
                {
                    <MudSelect T="string" Value="ManageMatchValue" ValueChanged="OnManageMatchChanged"
                               Label="@L["Match"]" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var match in _matches)
                        {
                            var id = match.Id.ToString();
                            <MudSelectItem T="string" Value="id">@match.Name</MudSelectItem>
                        }
                    </MudSelect>
                    @if (CanManageSettings)
                    {
                        <div class="rand-manage-rename">
                            <MudTextField T="string" @bind-Value="_manageRenameText" Label="@L["Match name"]"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"></MudTextField>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       Disabled="@(_busy || _manageMatchId == null || string.IsNullOrWhiteSpace(_manageRenameText) || _manageRenameText.Trim() == ManagedMatchName)"
                                       OnClick="RenameManagedMatch">@L["Rename"]</MudButton>
                        </div>
                    }
                    <div class="rand-manage-actions">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Casino" Disabled="@(_busy || _manageMatchId == null)"
                                   OnClick="ManageRedraw">@(_confirmingManageRedraw ? L["Tap again"] : L["Redraw"])</MudButton>
                        @if (CanManageSettings)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Delete" Disabled="@(_busy || _manageMatchId == null)"
                                       OnClick="ManageDelete">@(_confirmingManageDelete ? L["Tap again"] : L["Delete match"])</MudButton>
                        }
                    </div>
                    <MudText Typo="Typo.caption" Class="rand-section-hint">@L["Redraw refills this match from your current settings — its spectate link never changes."]</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="rand-section-hint">@L["No matches yet — create one from the field."]</MudText>
                }
            </div>
            @if (CanManageSettings)
            {
                <div class="rand-manage-section">
                    <MudText Typo="Typo.subtitle2" Class="rand-manage-heading">@L["Settings"]</MudText>
                    <div>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Tune"
                                   OnClick="SwitchToSettings">@L["Edit settings"]</MudButton>
                    </div>
                    <MudText Typo="Typo.caption" Class="rand-section-hint">@L["Presets, level ranges, and filters — new matches draw from a preset."]</MudText>
                </div>
            }
            @if (_isHeadTo)
            {
                <div class="rand-manage-section">
                    <MudText Typo="Typo.subtitle2" Class="rand-manage-heading">@L["Staff"]</MudText>
                    @foreach (var member in _staff)
                    {
                        var m = member;
                        <div class="rand-staff-row">
                            <UserLabel User="m.User"></UserLabel>
                            <span class="rand-invite-role">@RoleShort(m.Role)</span>
                            @if (CurrentUser.IsLoggedIn && m.User.Id != CurrentUser.User.Id)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error" Disabled="_busy"
                                           OnClick="() => RemoveStaff(m.User.Id)">@(_confirmingRemoveStaffId == m.User.Id ? L["Tap again"] : L["Remove"])</MudButton>
                            }
                        </div>
                    }
                    <div class="rand-invites">
                        @foreach (var invite in _invites)
                        {
                            var token = invite.Token;
                            <div class="rand-invite-row">
                                <span class="rand-invite-role">@RoleShort(invite.Role)</span>
                                <span class="rand-invite-expiry">@(invite.ExpiresAt == null ? L["No expiry"] : L["Expires {0:d}", invite.ExpiresAt.Value])</span>
                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.ContentCopy"
                                               OnClick="() => CopyInviteLink(token)" aria-label="@L["Copy invite link"]"></MudIconButton>
                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               OnClick="() => RevokeInvite(token)" aria-label="@L["Revoke"]"></MudIconButton>
                            </div>
                        }
                        <div class="rand-invite-mint">
                            <MudSelect T="TournamentRole" @bind-Value="_inviteRole" Label="@L["Role"]" Dense="true"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="TournamentRole" Value="TournamentRole.TournamentOrganizer">@RoleShort(TournamentRole.TournamentOrganizer)</MudSelectItem>
                                <MudSelectItem T="TournamentRole" Value="TournamentRole.Assistant">@RoleShort(TournamentRole.Assistant)</MudSelectItem>
                            </MudSelect>
                            <MudSelect T="int" @bind-Value="_inviteExpiryDays" Label="@L["Expires"]" Dense="true"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="int" Value="1">@L["1 day"]</MudSelectItem>
                                <MudSelectItem T="int" Value="7">@L["7 days"]</MudSelectItem>
                                <MudSelectItem T="int" Value="0">@L["No expiry"]</MudSelectItem>
                            </MudSelect>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="_busy"
                                       StartIcon="@Icons.Material.Filled.Add" OnClick="CreateInvite">@L["Create invite"]</MudButton>
                        </div>
                    </div>
                </div>
                <div class="rand-manage-section">
                    <MudText Typo="Typo.subtitle2" Class="rand-manage-heading">@L["Discord"]</MudText>
                    <div class="rand-manage-rename">
                        <MudTextField T="string" @bind-Value="_discordChannelText" Label="@L["Channel ID"]"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                      Placeholder="@L["Right-click a channel → Copy Channel ID"].Value"></MudTextField>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="_busy"
                                   OnClick="SaveDiscordChannel">@L["Save"]</MudButton>
                    </div>
                    <MudText Typo="Typo.caption" Class="rand-section-hint">@L["When set, staff get Push to Discord in the copy menu — the draw posts to this channel. Clear the field to turn it off."]</MudText>
                </div>
            }
        </div>
        <div class="rand-drawer-footer">
            <div class="rand-footer-row">
                <MudSpacer></MudSpacer>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => _showManage = false">@L["Done"]</MudButton>
            </div>
        </div>
    </MudDrawer>
    </MudLayout>
}

@* The tier lists' chart details surface — one concept, one component. *@
<ChartDetailsDialog @bind-Visible="_detailsOpen" Chart="_detailsChart" Mix="@(_detailsChart?.Mix ?? _mix)"></ChartDetailsDialog>

@* Click-away for the New match popover (round 12) — mirrors the Add Chart overlay. *@
<MudOverlay Visible="_showNewMatch" OnClick="CloseNewMatch" ZIndex="1199"></MudOverlay>

<PageDock FocusMode="_draftMode">
    @if (_draftMode)
    {
        <MudButton Class="dock-side rand-staff-btn" Disabled="_busy || !_cards.Any(c => c.State == DrawCardState.Vetoed)"
                   StartIcon="@Icons.Material.Filled.DeleteSweep" OnClick="DraftClearVetoed">
            @(_confirmingClear ? L["Tap again"] : $"{L["Clear vetoed"]} ({_cards.Count(c => c.State == DrawCardState.Vetoed)})")
        </MudButton>
        <MudButton Class="dock-cta" Disabled="_busy" OnClick="DraftRedraw"
                   StartIcon="@(_busy ? null : Icons.Material.Filled.Casino)">
            @(_confirmingRedraw ? L["Tap again"] : L["Redraw"])
        </MudButton>
    }
    else
    {
        @if (_contextTournamentId != null)
        {
            @* Tournament gear = the manage drawer (round 8); thumb action = the next
               match. Non-staff visitors only get the copy menu. *@
            @if (CanOperate)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Class="dock-side" OnClick="OpenManage"
                               aria-label="@L["Manage tournament"]"></MudIconButton>
                @* Dock New match opens a popover above the bottom bar (round 12). *@
                <div class="folder-picker-anchor dock-cta-anchor">
                    <MudButton Class="dock-cta" Disabled="_busy" OnClick="ToggleNewMatch"
                               StartIcon="@Icons.Material.Filled.Add">@L["New match"]</MudButton>
                    <MudPopover Open="_showNewMatch" AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter">
                        <div class="rand-new-match-pop">@newMatchBody</div>
                    </MudPopover>
                </div>
            }
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Filled.Tune" Class="dock-side" OnClick="() => _showSettings = true"
                           aria-label="@L["Edit settings"]"></MudIconButton>
            <MudButton Class="dock-cta" Disabled="_busy" OnClick="Randomize"
                       StartIcon="@(_busy ? null : Icons.Material.Filled.Casino)">
                @if (_busy)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Inherit"></MudProgressCircular>
                }
                else
                {
                    @L["Randomize"]
                }
            </MudButton>
        }
        <MudMenu AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.BottomRight" Dense="true">
            <ActivatorContent>
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Class="dock-side"
                               Disabled="@(!_cards.Any() && _drawSlug == null)" aria-label="@L["Copy"]"></MudIconButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Icon="@Icons.Material.Filled.ContentCopy" Disabled="!_cards.Any()"
                             OnClick="CopyResults">@L["Copy draw results"]</MudMenuItem>
                @if (_drawSlug != null)
                {
                    <MudMenuItem Icon="@Icons.Material.Filled.Sensors"
                                 OnClick="CopySpectateLink">@L["Copy spectate link"]</MudMenuItem>
                }
                @if (_contextTournamentId != null && CanOperate && _discordChannelId != null)
                {
                    <MudMenuItem Icon="@Icons.Custom.Brands.Discord" Disabled="@(_drawId == null || _busy)"
                                 OnClick="PushToDiscord">@L["Push to Discord"]</MudMenuItem>
                }
            </ChildContent>
        </MudMenu>
    }
</PageDock>

@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject ICurrentUserAccessor CurrentUser
@inject IUiSettingsAccessor UiSettings
@inject IDateTimeOffsetAccessor Clock
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
@inject IOptions<JsonSerializerOptions> JsonOptions
@inject IUiNotificationHub UiHub
@implements IDisposable
@code {

    private const string ConfigKey = "ChartRandomizer__Config";
    private const string DensityKey = "Density__ChartRandomizer";

    private sealed class CardVm
    {
        public Guid PullId { get; init; }
        public Chart Chart { get; init; } = null!;
        public int Order { get; set; }
        public DrawCardState State { get; set; }
    }

    // Working config persisted verbatim (the old hand-copied DTO dropped Count/Ordering/
    // co-op bounds on the floor — serializing RandomSettings itself is the fix).
    private sealed class SavedWorkingConfig
    {
        public RandomSettings Settings { get; set; } = new();
        public MixEnum Mix { get; set; } = MixEnum.Phoenix;
    }

    [Parameter]
    [SupplyParameterFromQuery(Name = "tournament")]
    public Guid? TournamentQuery { get; set; }

    private RandomSettings _settings = new();
    private MixEnum _mix = MixEnum.Phoenix;
    private readonly List<CardVm> _cards = new();
    private Guid? _drawId;
    private Guid? _drawSlug;
    private IDictionary<string, SavedRandomizerSettings> _personalSettings =
        new Dictionary<string, SavedRandomizerSettings>(StringComparer.OrdinalIgnoreCase);
    private IDictionary<string, SavedRandomizerSettings> _tournamentSettings =
        new Dictionary<string, SavedRandomizerSettings>(StringComparer.OrdinalIgnoreCase);
    private string _currentSettingsName = string.Empty;
    private string? _saveName;
    private bool _confirmingDelete;
    private UiDensity _density = UiDensity.Compact;
    private ArmedAction _armedAction = ArmedAction.Protect;
    private bool _busy;
    private bool _loading = true;
    private bool _showSettings;
    private bool _showAddChart;
    private bool _focusAddChart;
    private ChartSelector? _addChartSelector;
    private bool _focusNewMatch;
    private MudTextField<string>? _newMatchNameField;
    private int? _matchCount;
    private CancellationTokenSource? _countCts;

    // Tournament context (docs/design/randomizer-overhaul.md C9).
    private bool _baseLoaded;
    private bool _contextLoaded;
    private Guid? _contextTournamentId;
    private IReadOnlyList<TournamentRoleListing> _myTournaments = Array.Empty<TournamentRoleListing>();
    private TournamentRole? _myRole;
    private bool _showCreateTournament;
    private string _newTournamentName = string.Empty;
    private IReadOnlyList<TournamentRoleInviteRecord> _invites = Array.Empty<TournamentRoleInviteRecord>();
    private TournamentRole _inviteRole = TournamentRole.Assistant;
    private int _inviteExpiryDays = 7;
    private bool _draftMode;
    private bool _confirmingClear;
    private bool _confirmingRedraw;

    // Matches (field-test round 6): a match is a named draw, many per tournament.
    private List<DrawDto> _matches = new();
    private Guid? _selectedMatchId;
    private bool _showNewMatch;
    private string _newMatchName = string.Empty;
    private string _newMatchPreset = string.Empty;

    // Manage-tournament drawer (round 8): its match selection is drawer-local state,
    // seeded from the playing field on open — a TO can re-roll match B while the
    // field displays match A.
    private bool _showManage;
    private Guid? _manageMatchId;
    private string _manageRenameText = string.Empty;
    private bool _confirmingManageRedraw;
    private bool _confirmingManageDelete;
    private Guid? _confirmingRemoveStaffId;
    private IReadOnlyList<StaffMember> _staff = Array.Empty<StaffMember>();
    private string? _contextTournamentName;

    // Push to Discord (round 10): Head TO points the tournament at a channel; any staff
    // pushes the current draw from the copy menu. Manual only, fresh message per push.
    private ulong? _discordChannelId;
    private string _discordChannelText = string.Empty;

    private sealed record StaffMember(User User, TournamentRole Role);

    private string? SelectedMatchName => _matches.FirstOrDefault(m => m.Id == _selectedMatchId)?.Name;
    private DrawDto? SelectedMatch => _matches.FirstOrDefault(m => m.Id == _selectedMatchId);
    private string? ManagedMatchName => _matches.FirstOrDefault(m => m.Id == _manageMatchId)?.Name;
    private string ManageMatchValue => _manageMatchId?.ToString() ?? string.Empty;

    // Renaming in the name field never renames the loaded preset — it saves a new one
    // (round 7: the button says so instead of surprising people).
    private bool SaveIsNew => !string.IsNullOrWhiteSpace(_saveName)
                              && !CurrentSettingsMap.ContainsKey(_saveName);

    private bool CanOperate => CurrentUser.IsLoggedInAsAdmin || _myRole != null;
    private bool CanManageSettings => CurrentUser.IsLoggedInAsAdmin ||
                                      _myRole is TournamentRole.HeadTournamentOrganizer
                                          or TournamentRole.TournamentOrganizer;
    private bool _isHeadTo => CurrentUser.IsLoggedInAsAdmin || _myRole == TournamentRole.HeadTournamentOrganizer;

    private IDictionary<string, SavedRandomizerSettings> CurrentSettingsMap =>
        _contextTournamentId == null ? _personalSettings : _tournamentSettings;

    private string ContextValue => _contextTournamentId?.ToString() ?? "personal";

    private string ContextName => _contextTournamentId == null
        ? L["Personal"]
        : _myTournaments.FirstOrDefault(t => t.TournamentId == _contextTournamentId)?.TournamentName.ToString()
          ?? _contextTournamentName
          ?? L["Tournament"];

    private UiDensity GridDensity => _draftMode ? UiDensity.Compact : _density;

    private string RoleShort(TournamentRole role)
    {
        return role switch
        {
            TournamentRole.HeadTournamentOrganizer => L["Head TO"],
            TournamentRole.TournamentOrganizer => L["TO"],
            _ => L["Assistant"]
        };
    }

    private IEnumerable<string> ConstraintChips
    {
        get
        {
            yield return _mix.GetName();
            var singles = ActiveRange(_settings.LevelWeights);
            if (singles != null) yield return $"S{singles.Value.min}–{singles.Value.max}";
            var doubles = ActiveRange(_settings.DoubleLevelWeights);
            if (doubles != null) yield return $"D{doubles.Value.min}–{doubles.Value.max}";
            var coops = _settings.PlayerCountWeights.Where(kv => kv.Value > 0).Select(kv => kv.Key).ToArray();
            if (coops.Any()) yield return $"Co-Op ×{string.Join(",×", coops)}";
            var excludedTypes = _settings.SongTypeWeights.Where(kv => kv.Value == 0).Select(kv => kv.Key).ToArray();
            if (excludedTypes.Any() && excludedTypes.Length < _settings.SongTypeWeights.Count)
                yield return L["No {0}", string.Join("/", excludedTypes.Select(t => t.ToString()))];
            yield return L["{0} cards", _settings.Count];
            if (_settings.AllowRepeats) yield return L["Repeats"];
            if (_settings.ClearStatus == false) yield return L["Not Passed"];
            if (_settings.ClearStatus == true) yield return L["Passed"];
            if (_settings.LetterGrades.Any()) yield return string.Join("/", _settings.LetterGrades.Select(g => g.GetName()));
        }
    }

    private static (int min, int max)? ActiveRange(IDictionary<int, int> weights)
    {
        var active = weights.Where(kv => kv.Value > 0).Select(kv => kv.Key).ToArray();
        return active.Length == 0 ? null : (active.Min(), active.Max());
    }

    private IDisposable? _drawSubscription;

    protected override async Task OnInitializedAsync()
    {
        _drawSubscription = UiHub.Subscribe<DrawUpdatedEvent>(UiTopics.Draws, OnDrawUpdated);
        _mix = await UiSettings.GetSelectedMix();
        var densitySetting = await UiSettings.GetSetting(DensityKey);
        if (Enum.TryParse<UiDensity>(densitySetting, out var density)) _density = density;

        if (CurrentUser.IsLoggedIn)
        {
            _personalSettings = (await Mediator.Send(new GetRandomSettingsQuery()))
                .ToDictionary(s => s.SettingsName.ToString(), s => s, StringComparer.OrdinalIgnoreCase);
            _myTournaments = (await Mediator.Send(new GetMyTournamentsQuery())).ToArray();

            var configJson = await UiSettings.GetSetting(ConfigKey);
            if (configJson != null)
                try
                {
                    var config = JsonSerializer.Deserialize<SavedWorkingConfig>(configJson, JsonOptions.Value);
                    if (config != null)
                    {
                        _settings = config.Settings;
                        _mix = config.Mix;
                    }
                }
                catch (JsonException)
                {
                    // A malformed working config never blocks the page; defaults stand in.
                }
        }

        NormalizeEmptyPool(_settings);
        _baseLoaded = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_baseLoaded) return;
        if (_contextLoaded && TournamentQuery == _contextTournamentId) return;

        await EnterContext(TournamentQuery);
    }

    private async Task EnterContext(Guid? tournamentId)
    {
        _loading = true;
        _contextLoaded = true;
        _contextTournamentId = tournamentId;
        _draftMode = false;
        _showCreateTournament = false;
        _confirmingClear = _confirmingRedraw = _confirmingDelete = false;
        _currentSettingsName = string.Empty;
        _saveName = string.Empty;
        _myRole = null;
        _cards.Clear();
        _drawId = null;
        _drawSlug = null;
        _matches = new List<DrawDto>();
        _selectedMatchId = null;
        _showNewMatch = false;
        _newMatchName = string.Empty;
        _newMatchPreset = string.Empty;
        _showManage = false;
        _manageMatchId = null;
        _manageRenameText = string.Empty;
        _confirmingManageRedraw = _confirmingManageDelete = false;
        _confirmingRemoveStaffId = null;
        _staff = Array.Empty<StaffMember>();
        _contextTournamentName = null;
        _discordChannelId = null;
        _discordChannelText = string.Empty;

        if (CurrentUser.IsLoggedIn)
        {
            if (tournamentId != null)
            {
                var roles = await Mediator.Send(new GetTournamentRolesQuery(tournamentId.Value));
                _myRole = roles.FirstOrDefault(r => r.UserId == CurrentUser.User.Id)?.Role;
                // The header carries the tournament's name (round 8); staff get it from
                // GetMyTournamentsQuery, anyone else from the tournament itself.
                if (_myTournaments.All(t => t.TournamentId != tournamentId.Value))
                    try
                    {
                        _contextTournamentName =
                            (await Mediator.Send(new GetTournamentQuery(tournamentId.Value))).Name;
                    }
                    catch (Exception)
                    {
                        // A garbage ?tournament= id never blocks the page.
                    }

                if (CanOperate)
                    _discordChannelId =
                        await Mediator.Send(new GetTournamentDiscordChannelQuery(tournamentId.Value));
                _tournamentSettings = (await Mediator.Send(new GetTournamentRandomSettingsQuery(tournamentId.Value)))
                    .ToDictionary(s => s.SettingsName.ToString(), s => s, StringComparer.OrdinalIgnoreCase);
                _matches = (await Mediator.Send(new GetTournamentDrawsQuery(tournamentId.Value))).ToList();
                var newest = _matches.FirstOrDefault();
                if (newest != null)
                {
                    _selectedMatchId = newest.Id;
                    await LoadDraw(newest);
                }
            }
            else
            {
                var draw = await Mediator.Send(new GetActiveDrawQuery(null));
                if (draw != null) await LoadDraw(draw);
            }
        }

        _loading = false;
        await RefreshMatchCount(CancellationToken.None);
    }

    private async Task SelectMatch(DrawDto match)
    {
        _selectedMatchId = match.Id;
        await LoadDraw(match);
    }

    private void OpenSettingsFromNewMatch()
    {
        _showNewMatch = false;
        _showSettings = true;
    }

    private async Task CreateMatch()
    {
        if (_contextTournamentId == null || string.IsNullOrWhiteSpace(_newMatchName)
            || !_tournamentSettings.TryGetValue(_newMatchPreset, out var preset)) return;

        _busy = true;
        try
        {
            // The preset becomes the working settings — what the match draws from is
            // what the drawer then shows.
            _settings = JsonSerializer.Deserialize<RandomSettings>(
                JsonSerializer.Serialize(preset.Settings, JsonOptions.Value), JsonOptions.Value) ?? new RandomSettings();
            NormalizeEmptyPool(_settings);
            _mix = preset.Mix;
            _currentSettingsName = preset.SettingsName.ToString();
            _saveName = _currentSettingsName;

            var charts = (await Mediator.Send(new GetRandomChartsQuery(_settings, _mix))).ToArray();
            if (!charts.Any())
            {
                Snackbar.Add(L["No charts match this preset — widen it in Settings"], Severity.Warning);
                return;
            }

            var draw = await Mediator.Send(new CreateDrawCommand(_contextTournamentId, _mix,
                charts.Select(c => c.Id).ToArray(), _newMatchName));
            _matches.Insert(0, draw);
            _selectedMatchId = draw.Id;
            await LoadDraw(draw);
            _showNewMatch = false;
            _newMatchName = string.Empty;
            await RefreshMatchCount(CancellationToken.None);
        }
        catch (RandomizerException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        catch (NotAuthorizedException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        finally
        {
            _busy = false;
        }
    }

    private Task<IEnumerable<DrawDto>> SearchMatches(string? value)
    {
        var result = string.IsNullOrWhiteSpace(value)
            ? _matches
            : _matches.Where(m => m.Name != null && m.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(result.AsEnumerable());
    }

    private async Task OnMatchPicked(DrawDto? match)
    {
        if (match == null) return;

        await SelectMatch(match);
    }

    private async Task OpenManage()
    {
        _manageMatchId = _selectedMatchId ?? _matches.FirstOrDefault()?.Id;
        _manageRenameText = ManagedMatchName ?? string.Empty;
        _confirmingManageRedraw = _confirmingManageDelete = false;
        _confirmingRemoveStaffId = null;
        _discordChannelText = _discordChannelId?.ToString() ?? string.Empty;
        _showManage = true;
        if (_isHeadTo && _contextTournamentId != null)
        {
            _invites = (await Mediator.Send(new GetTournamentRoleInvitesQuery(_contextTournamentId.Value))).ToArray();
            await LoadStaff();
        }
    }

    private async Task LoadStaff()
    {
        if (_contextTournamentId == null) return;

        var roles = await Mediator.Send(new GetTournamentRolesQuery(_contextTournamentId.Value));
        var members = new List<StaffMember>();
        // Staff lists are a handful of people; per-user lookups beat a new bulk query.
        foreach (var role in roles.OrderBy(r => r.Role))
        {
            var user = await Mediator.Send(new GetUserByIdQuery(role.UserId));
            if (user != null) members.Add(new StaffMember(user, role.Role));
        }

        _staff = members;
    }

    private void OnManageMatchChanged(string value)
    {
        _manageMatchId = Guid.TryParse(value, out var id) ? id : null;
        _manageRenameText = ManagedMatchName ?? string.Empty;
        _confirmingManageRedraw = _confirmingManageDelete = false;
    }

    private async Task RenameManagedMatch()
    {
        if (_manageMatchId == null || string.IsNullOrWhiteSpace(_manageRenameText)) return;

        _busy = true;
        try
        {
            var name = _manageRenameText.Trim();
            await Mediator.Send(new RenameDrawCommand(_manageMatchId.Value, name));
            var index = _matches.FindIndex(m => m.Id == _manageMatchId);
            if (index >= 0) _matches[index] = _matches[index] with { Name = name };
            Snackbar.Add(L["Match renamed"], Severity.Success);
        }
        catch (RandomizerException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        catch (NotAuthorizedException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ManageRedraw()
    {
        if (_manageMatchId == null) return;

        // Destructive-ish on a live match: second tap confirms (owner call, round 8).
        if (!_confirmingManageRedraw)
        {
            _confirmingManageRedraw = true;
            _confirmingManageDelete = false;
            return;
        }

        _confirmingManageRedraw = false;
        _busy = true;
        try
        {
            await SaveWorkingConfig();
            var charts = (await Mediator.Send(new GetRandomChartsQuery(_settings, _mix))).ToArray();
            if (!charts.Any())
            {
                Snackbar.Add(L["No charts match your filters — open Settings and widen the range"],
                    Severity.Warning);
                return;
            }

            if (charts.Length < _settings.Count)
                Snackbar.Add(L["Only {0} charts match your filters", charts.Length], Severity.Info);

            var draw = await Mediator.Send(new RedrawCardsCommand(_manageMatchId.Value, _mix,
                charts.Select(c => c.Id).ToArray()));
            var index = _matches.FindIndex(m => m.Id == draw.Id);
            if (index >= 0) _matches[index] = draw;
            // If the playing field shows this match, it updates in place — locally, not
            // just via the event bridge (owner call, round 8).
            if (_selectedMatchId == draw.Id) await LoadDraw(draw);
        }
        catch (RandomizerException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        catch (NotAuthorizedException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ManageDelete()
    {
        if (_manageMatchId == null) return;

        // Destructive: second tap confirms.
        if (!_confirmingManageDelete)
        {
            _confirmingManageDelete = true;
            _confirmingManageRedraw = false;
            return;
        }

        _confirmingManageDelete = false;
        _busy = true;
        try
        {
            var deletedId = _manageMatchId.Value;
            await Mediator.Send(new DeleteDrawCommand(deletedId));
            _matches.RemoveAll(m => m.Id == deletedId);
            if (_selectedMatchId == deletedId)
            {
                var newest = _matches.FirstOrDefault();
                _selectedMatchId = newest?.Id;
                if (newest != null)
                {
                    await LoadDraw(newest);
                }
                else
                {
                    _cards.Clear();
                    _drawId = null;
                    _drawSlug = null;
                }
            }

            _manageMatchId = _matches.FirstOrDefault()?.Id;
            _manageRenameText = ManagedMatchName ?? string.Empty;
        }
        catch (NotAuthorizedException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        finally
        {
            _busy = false;
        }
    }

