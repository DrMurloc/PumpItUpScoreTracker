    private void SelectSavedSettings(string name)
    {
        _currentSettingsName = name ?? string.Empty;
        _saveName = name;
        _confirmingDelete = false;
        if (string.IsNullOrWhiteSpace(name))
        {
            _settings = new RandomSettings();
            NormalizeEmptyPool(_settings);
            _ = OnSettingsChanged();
            return;
        }

        var saved = CurrentSettingsMap[name];
        // Deep copy so edits never mutate the saved snapshot until Save.
        _settings = JsonSerializer.Deserialize<RandomSettings>(
            JsonSerializer.Serialize(saved.Settings, JsonOptions.Value), JsonOptions.Value) ?? new RandomSettings();
        NormalizeEmptyPool(_settings);
        _mix = saved.Mix;
        _ = OnSettingsChanged();
    }

    private async Task SaveSettings()
    {
        if (string.IsNullOrWhiteSpace(_saveName)) return;

        _busy = true;
        try
        {
            var snapshot = JsonSerializer.Deserialize<RandomSettings>(
                JsonSerializer.Serialize(_settings, JsonOptions.Value), JsonOptions.Value) ?? new RandomSettings();
            if (_contextTournamentId == null)
                await Mediator.Send(new SaveUserRandomSettingsCommand(_saveName, _settings, _mix));
            else
                await Mediator.Send(new SaveTournamentRandomSettingsCommand(_contextTournamentId.Value, _saveName,
                    _settings, _mix));

            CurrentSettingsMap[_saveName] = new SavedRandomizerSettings(_saveName, snapshot, _mix);
            _currentSettingsName = _saveName;
            Snackbar.Add(L["{0} Saved!", _saveName], Severity.Success);
        }
        catch (NotAuthorizedException e)
        {
            Snackbar.Add(e.Message, Severity.Warning);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteSettings()
    {
        if (string.IsNullOrWhiteSpace(_saveName)) return;

        // Destructive: second tap confirms (owner-locked fix — no silent DeleteForever).
        if (!_confirmingDelete)
        {
            _confirmingDelete = true;
            return;
        }

        _busy = true;
        if (_contextTournamentId == null)
            await Mediator.Send(new DeleteRandomSettingsCommand(_saveName));
        else
            await Mediator.Send(new DeleteTournamentRandomSettingsCommand(_contextTournamentId.Value, _saveName));
        CurrentSettingsMap.Remove(_saveName);
        _saveName = string.Empty;
        _currentSettingsName = string.Empty;
        _confirmingDelete = false;
        _busy = false;
    }

    // Staff multi-device sync: another operator's action re-loads this device's match
    // list and selected match. Own actions re-fire it too — the reload agrees with
    // local state, so it's harmless.
    private Task OnDrawUpdated(DrawUpdatedEvent e)
    {
        if (_contextTournamentId == null) return Task.CompletedTask;

        return InvokeAsync(async () =>
        {
            _matches = (await Mediator.Send(new GetTournamentDrawsQuery(_contextTournamentId.Value))).ToList();
            var selected = _matches.FirstOrDefault(m => m.Id == _selectedMatchId) ?? _matches.FirstOrDefault();
            _selectedMatchId = selected?.Id;
            if (selected != null)
            {
                await LoadDraw(selected);
            }
            else
            {
                _cards.Clear();
                _drawId = null;
                _drawSlug = null;
            }

            // If another device deleted the match this drawer was managing, roll to the
            // newest sibling; an in-flight rename edit is left alone otherwise.
            if (_manageMatchId != null && _matches.All(m => m.Id != _manageMatchId))
            {
                _manageMatchId = _matches.FirstOrDefault()?.Id;
                _manageRenameText = ManagedMatchName ?? string.Empty;
                _confirmingManageRedraw = _confirmingManageDelete = false;
            }

            StateHasChanged();
        });
    }

    private string SettingsSummary(SavedRandomizerSettings preset)
    {
        var parts = new List<string> { preset.Mix.GetName() };
        var singles = ActiveRange(preset.Settings.LevelWeights);
        if (singles != null) parts.Add($"S{singles.Value.min}–{singles.Value.max}");
        var doubles = ActiveRange(preset.Settings.DoubleLevelWeights);
        if (doubles != null) parts.Add($"D{doubles.Value.min}–{doubles.Value.max}");
        var coops = preset.Settings.PlayerCountWeights.Where(kv => kv.Value > 0).Select(kv => kv.Key).ToArray();
        if (coops.Any()) parts.Add($"Co-Op ×{string.Join(",×", coops)}");
        parts.Add(L["{0} cards", preset.Settings.Count]);
        if (preset.Settings.ClearStatus == false) parts.Add(L["Not Passed"]);
        if (preset.Settings.ClearStatus == true) parts.Add(L["Passed"]);
        if (preset.Settings.AllowRepeats) parts.Add(L["Repeats"]);
        return string.Join(" · ", parts);
    }

