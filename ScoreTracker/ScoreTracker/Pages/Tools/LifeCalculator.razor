@page "/LifeCalculator"
@using ScoreTracker.Domain.Records
@using ScoreTracker.Web.Dtos
@using ScoreTracker.Domain.Enums
@using ScoreTracker.Domain.Models
@using ScoreTracker.Domain.ValueTypes

<PageTitle>@L["PIU Life Calculator"]</PageTitle>
<HeadContent>
    <meta name="description" content="Get a basic understanding of the Lifebar system in PIU, as well as calculate how many misses/bads you can get before you fail." />
    <meta property="og:title" content="PIU Life Calculator">
    <meta property="og:description" content="Get a basic understanding of the Lifebar system in PIU, as well as calculate how many misses/bads you can get before you fail.">
</HeadContent>
<MudText Color="Color.Warning">@L["Disclaimer: This data was data-mined in NX2 and Prime, it is unconfirmed how accurate it is today."]</MudText>

<MudText Typo="Typo.h4">@L["Lifebar stats"]</MudText>
<br/>
<ApexChart TItem="DataPoint"
           Title=@L["Life Bar by Level"]>
    <ApexPointSeries TItem="DataPoint"
                     Items="_startingLifePoints"
                     SeriesType="SeriesType.Bar"
                     Name=@L["Starting Life"]
                     XValue="@(e => e.X)"
                     YValue="@(e=>e.Y)"></ApexPointSeries>
    <ApexPointSeries TItem="DataPoint"
                     Items="_visibleLife"
                     SeriesType="SeriesType.Bar"
                     Name=@L["Visible Life"]
                     XValue="@(e => e.X)"
                     YValue="@(e=>e.Y)"></ApexPointSeries>
    <ApexPointSeries TItem="DataPoint"
                     Items="_maxLife"
                     SeriesType="SeriesType.Bar"
                     Name=@L["Max Life"]
                     XValue="@(e => e.X)"
                     YValue="@(e=>e.Y)"></ApexPointSeries>
</ApexChart>
<br/>
<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudNumericField T="int" Value="_level" Label=@L["Level"] Min="1" Max="DifficultyLevel.Max" ValueChanged="l=>CalculateComboToDeath(_lifeThreshold,l)"></MudNumericField>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudNumericField T="int" Value="_lifeThreshold" Label=@L["Life Threshold"] Min="0" Max="3000" ValueChanged="l=>CalculateComboToDeath(l,_level)"></MudNumericField>
    </MudItem>
</MudGrid>
<br/>
<ApexChart TItem="DataPoint"
           @ref="_comboBreakGraph"
           Title=@L["Note Count from Full Life to Death/Threshold based on Combo between Breaks"]>
    <ApexPointSeries TItem="DataPoint"
                     Items="_notesToDeadPerfect"
                     Name=@L["Perfect Combo, Miss Break"]
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.X)"
                     YValue="@(e => e.Y)"
                     OrderBy="e => e.X"/>
    <ApexPointSeries TItem="DataPoint"
                     Items="_notesToDeadGreat"
                     Name=@L["Great Combo, Miss Break"]
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.X)"
                     YValue="@(e => e.Y)"
                     OrderBy="e => e.X"/>
    <ApexPointSeries TItem="DataPoint"
                     Items="_notesToDeadBadPerfect"
                     Name=@L["Perfect Combo, Bad Break"]
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.X)"
                     YValue="@(e => e.Y)"
                     OrderBy="e => e.X"/>
    <ApexPointSeries TItem="DataPoint"
                     Items="_notesToDeadBadGreat"
                     Name=@L["Great Combo, Bad Break"]
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.X)"
                     YValue="@(e => e.Y)"
                     OrderBy="e => e.X"/>
</ApexChart>

<br/>
<ApexChart TItem="DataPoint"
           Title=@L["Notes to Full Life From Start of Song (50%)"]>
    <ApexPointSeries TItem="DataPoint"
                     Items="_perfectsToMax"
                     Name=@L["Perfects"]
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.X)"
                     YValue="@(e => e.Y)"
                     OrderBy="e => e.X" />
    <ApexPointSeries TItem="DataPoint"
                     Items="_greatsToMax"
                     Name=@L["Greats"]
                     SeriesType="SeriesType.Line"
                     XValue="@(e => e.X)"
                     YValue="@(e => e.Y)"
                     OrderBy="e => e.X" />
</ApexChart>
<br/>
<MudText Typo="Typo.h4">@L["Lifebar Description"]</MudText>
<MudText>@L["Starting life is 500, visible  Life (Rainbow life bar) is 1000."]</MudText>
<MudText>@L["Lifebar overflows exponentially by level, up to about a 2350 overflow at level 28."]</MudText>
<br/>
<MudText Typo="Typo.h4">@L["Life loss description"]</MudText>
<MudText>@L["By default, bads lose 50 health, misses lose 250 health (at ~100% health)."]</MudText>
<MudText>@L["Misses lose LESS health the further beneath 1000 health you are at (at 0 life you would lose 20 health for a miss)"]</MudText>
<br />
<MudText Typo="Typo.h4">@L["Life gain description"]</MudText>
<MudText>@L["By default at high combo, perfects gain 9.6 life, greats gain 8 life, goods gain 0 life."]</MudText>
<MudText>@L["This is modified by a multiplier that is almost entirely reset on a miss, and decreased drastically on a bad."]</MudText>
<MudText>@L["Each perfect or great you get increases the multiplier by a minor amount."]</MudText>
<MudText>@L["Effectively, this means that your life gain is heavily affected by combo, reaching maximum gain at ~40-50 combo."]</MudText>
<br />
<MudText Typo="Typo.h4">@L["Bads vs Misses Observations"]</MudText>
<MudText>@L["To recover from Bads you require 17-21 combo per Bad. Bads typically let you live for 3x as long as misses."]</MudText>
<MudText>@L["To remain alive you need to maintain 17-21 combo per Miss."]</MudText>
<MudText>@L["To remain at 50% visible life, you need 37-46 combo per Miss."]</MudText>
<MudText>@L["To remain at Rainbow Life, you 46-55 combo per Miss."]</MudText>
<MudText>@L["Bads at low health let you live for roughly 3x as long as misses, this gap increases the higher the life threshold you want to keep, up to misses punishing 6x as much when maintaining 100% visual life."]</MudText>
<MudText><b>@L["TLDR: Misses matter less at low life, but are always significantly more punishing than Bads."]</b></MudText>
<br/>
<MudText Typo="Typo.h4">@L["Recovery Observations"]</MudText>
<MudText>@L["Misses or back-to-back Bads early in a run put you in a terribly position for maintaining life, as they reset your life gain multiplier and require you to combo ~40-50 to regain it. Start runs strong for increased success rates."]</MudText>
<MudText>@L["When at 12% or lower visual life, a miss gives less life loss than a bad, but inhibits your recovery severely. This only really matters for notes at the end of a song or before guaranteed 100+ combo sections."]</MudText>
<br/>
<MudText Typo="Typo.h4">@L["TLDR"]</MudText>
<MudText>@L["Misses severely hurt your lifebar."]</MudText>
<MudText>@L["Bads mostly hurt your recovery."]</MudText>
<MudText>@L["Try to maintain 17-21 combo per bad."]</MudText>
<MudText>@L["Try to maintain 40-50 combo per miss."]</MudText>
<MudText>"@L["Lifebars are weird."]" - Zelllooo</MudText>
<br/>
<MudText Typo="Typo.h4">@L["Source"]</MudText>
<MudLink Href="https://github.com/Team-Infinitesimal/Infinitesimal/blob/lts/Modules/PIU/Gameplay.Life.lua" Target="_blank">@L["Team Infinitesimal, data-mine from NX2 + Prime"]</MudLink>
@inject ISnackbar Snackbar;
@inject ILogger<PhoenixCalculator> Logger;
@code
{

    private ApexChart<DataPoint>? _comboBreakGraph;
    //Life measures
    private IList<DataPoint> _startingLifePoints = new List<DataPoint>();
    private IList<DataPoint> _visibleLife = new List<DataPoint>();
    private IList<DataPoint> _maxLife = new List<DataPoint>();

    //Notes To Dead
    private IList<DataPoint> _notesToDeadPerfect = new List<DataPoint>();
    private IList<DataPoint> _notesToDeadGreat = new List<DataPoint>();
    private IList<DataPoint> _notesToDeadBadPerfect = new List<DataPoint>();
    private IList<DataPoint> _notesToDeadBadGreat = new List<DataPoint>();
    //Notes To Max
    private IList<DataPoint> _perfectsToMax = new List<DataPoint>();
    private IList<DataPoint> _greatsToMax = new List<DataPoint>();

    private int _lifeThreshold = 0;
    private int _level = 23;
    private async Task CalculateComboToDeath(int newThreshold, int level)
    {
        _lifeThreshold = newThreshold;
        var comboMax = 0;
        _level = level;
        _notesToDeadBadPerfect.Clear();
        _notesToDeadGreat.Clear();
        _notesToDeadPerfect.Clear();
        _notesToDeadBadGreat.Clear();
        while (true)
        {
            var next = CalculateLifeToDead(Judgment.Perfect, Judgment.Miss, comboMax,_lifeThreshold,_level);
            if (next == -1)
            {
                break;
            }
            _notesToDeadPerfect.Add(new DataPoint(comboMax,next));
            comboMax++;
        }
        comboMax = 0;
        while (true)
        {
            var next = CalculateLifeToDead(Judgment.Great, Judgment.Miss, comboMax, _lifeThreshold, _level);
            if (next == -1)
            {
                break;
            }
            _notesToDeadGreat.Add(new DataPoint(comboMax, next));
            comboMax++;
        }
        comboMax = 0;
        while (true)
        {
            var next = CalculateLifeToDead(Judgment.Perfect, Judgment.Bad, comboMax, _lifeThreshold, _level);
            if (next == -1)
            {
                break;
            }
            _notesToDeadBadPerfect.Add(new DataPoint(comboMax, next));
            comboMax++;
        }
        comboMax = 0;
        while (true)
        {
            var next = CalculateLifeToDead(Judgment.Great, Judgment.Bad, comboMax, _lifeThreshold, _level);
            if (next == -1)
            {
                break;
            }
            _notesToDeadBadGreat.Add(new DataPoint(comboMax, next));
            comboMax++;
        }
        if (_comboBreakGraph != null)
        {
            await _comboBreakGraph.UpdateSeriesAsync(true);
        }
    }
    protected override async Task OnInitializedAsync()
    {
        foreach (var level in DifficultyLevel.All)
        {
            var sim = new LifebarSimulator(level);
            _startingLifePoints.Add(new DataPoint(level, sim.CurrentLife));
            _visibleLife.Add(new DataPoint(level, 1000));
            _maxLife.Add(new DataPoint(level, sim.MaxLife));
            _perfectsToMax.Add(new DataPoint(level,CalculateNotesToMax(Judgment.Perfect,level)));
            _greatsToMax.Add(new DataPoint(level, CalculateNotesToMax(Judgment.Great, level)));

        }
        await CalculateComboToDeath(0,23);
    }
    private int CalculateNotesToMax(Judgment judgement, int level)
    {
        var sim = new LifebarSimulator(level);
        var noteCount = 0;
        while (sim.CurrentLife < sim.MaxLife)
        {
            sim.ApplyJudgment(judgement);
            noteCount++;
        }
        return noteCount;
    }
    private int CalculateLifeToDead(Judgment judgment, Judgment breakJudgment, int combo, int threshold, int level)
    {
        var sim = new LifebarSimulator(level, true);

        sim.ApplyJudgment(breakJudgment);
        var last = sim.CurrentLife;
        var lastRepeat = 0;
        var noteCount = 0;
        while (true)
        {
            for (var i = 0; i < combo; i++)
            {
                noteCount++;
                sim.ApplyJudgment(judgment);
                if (sim.CurrentLife == sim.MaxLife)
                {
                    return -1;
                }
            }
            sim.ApplyJudgment(breakJudgment);
            if (sim.CurrentLife == last)
            {
                lastRepeat++;
                if (lastRepeat == 10)
                {
                    return -1;
                }
            }
            else
            {
                last = sim.CurrentLife;
                lastRepeat = 0;
            }

            noteCount++;
            if (sim.CurrentLife <= threshold)
            {
                return noteCount;
            }
        }
    }
    private sealed record DataPoint(int X, int Y);
}
