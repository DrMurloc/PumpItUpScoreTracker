@page "/About"

<PageTitle>@L["About"]</PageTitle>

<MudPaper>
    <MudCard>

        <MudCardHeader>

            <MudText Typo="Typo.h2">@L["About The Site"]</MudText>
        </MudCardHeader>
        <MudCardContent>
            <MudButton StartIcon="@Icons.Custom.Brands.GitHub" Href="https://github.com/DrMurloc/PumpItUpScoreTracker" Target="_blank">@L["Source Code"]</MudButton>
            <br/>
            <MudButton StartIcon="@Icons.Material.Filled.PrivacyTip" Href="/Privacy" Target="_blank">@L["Privacy Policy"]</MudButton>
            <br/>
            <MudText Typo="Typo.body1">@L["Site constructed and maintained by DrMurloc"]</MudText>
            <br/>
            <MudText Typo="Typo.body1">@L["Original Concept (excel score tracking) Constructed by KyleTT"]</MudText>
            <br/>
            <MudText Typo="Typo.body1">Mix, Song, and Chart information provided by the wonderful team of <MudLink Href="https://pumpout2020.anyhowstep.com/credits" Target="_blank">Pumpout</MudLink>. An extra special thank you to <MudLink Href="https://twitter.com/pticakiwi">Haru-kaze</MudLink> and <MudLink Href="https://github.com/AnyhowStep">AnyHowStep</MudLink></MudText>
            <br/>
            <MudText Typo="Typo.body1">To request account/data management not available via website, please email <MudLink Href="mailto:sharkingbird@gmail.com">sharkingbird@gmail.com</MudLink> or message me in Discord DrMurloc@6314</MudText>
        </MudCardContent>
    </MudCard>
</MudPaper>
