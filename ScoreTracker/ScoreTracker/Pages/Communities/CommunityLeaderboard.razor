@page "/Community/Leaderboard"
@rendermode RenderModes.Interactive
@using MediatR
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.Communities.Contracts
@using ScoreTracker.Communities.Contracts.Commands
@using ScoreTracker.Communities.Contracts.Queries
@using ScoreTracker.Domain.Models
@using ScoreTracker.Domain.Records
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.PlayerProgress.Contracts.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services.Theming
@using System.Web
@using Chart = ScoreTracker.SharedKernel.Models.Chart
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType
<PageTitle>@L["Communities"]</PageTitle>

@if (_community != null)
{
    <div class="pt-4">
    <MudBreadcrumbs Items="_crumbs" Class="pa-0 mb-2"></MudBreadcrumbs>
    <div class="d-flex align-end justify-space-between flex-wrap mb-2" style="gap:12px">
        <div>
            <MudText Typo="Typo.h4">@((string)_community.Name)</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@L["{0} members", _memberCount]</MudText>
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            @if (_community.IsRegional)
            {
                <MudSwitch T="bool" Label="@L["Show Regional Guests"]" Value="_showGuests" ValueChanged="SetShowGuests" Color="Color.Primary"></MudSwitch>
            }
            @if (_myRole?.Role is CommunityRole.Creator or CommunityRole.Admin)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.ManageAccounts"
                           OnClick="GoToMembers">@L["Manage"]</MudButton>
            }
        </div>
    </div>

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2 mt-2 flex-wrap">
        <MudButtonGroup OverrideStyles="false">
            <MudButton Variant="@(_currentType == LeaderboardType.Combined ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small"
                       OnClick="@(() => SetType(LeaderboardType.Combined))">@L["Combined"]</MudButton>
            <MudButton Variant="@(_currentType == LeaderboardType.Singles ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small"
                       OnClick="@(() => SetType(LeaderboardType.Singles))">@L["Singles"]</MudButton>
            <MudButton Variant="@(_currentType == LeaderboardType.Doubles ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small"
                       OnClick="@(() => SetType(LeaderboardType.Doubles))">@L["Doubles"]</MudButton>
            <MudButton Variant="@(_currentType == LeaderboardType.CoOp ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small"
                       OnClick="@(() => SetType(LeaderboardType.CoOp))">@L["CoOp"]</MudButton>
        </MudButtonGroup>
    </MudStack>

    @{
        var pageCount = PageCount;
        var page = Math.Min(_page, pageCount);
    }
    @* Player pinned left, figures spread evenly across what's left — a right-aligned
       tail piles five values into one corner. One grid template drives every row, so
       the columns line up down the board, and the row sheds a column at a time as it
       narrows: 760 stacks competitive level over PUMBILITY, 640 drops the play count,
       500 shortens the chip. Values carry their label as a tooltip. *@
    <div class="olb-rank-cards"
         style="--olb-grid-cols:34px minmax(150px,1.6fr) 1fr 1fr 1fr 1fr 40px;--olb-grid-cols-narrow:28px minmax(110px,1fr) auto auto auto 34px;--olb-grid-cols-phone:26px minmax(96px,1fr) auto auto 32px">
        @* The figures only read as columns if something names them. The header is the row
           template with labels in it, so it sheds the same columns at the same widths. Labels
           stay short — below 760 the columns size to their content, and a spelled-out heading
           would take the width away from the player it is meant to describe. *@
        @if (_entries.Any())
        {
            <div class="olb-grid-head">
                <span>#</span>
                <span>@L["Player"]</span>
                <span>@L["Playstyle"]</span>
                <span class="olb-hide-narrow olb-grid-num" title="@L["Charts Played"]">@L["Charts"]</span>
                <span class="olb-stack">
                    @if (_currentType == LeaderboardType.CoOp)
                    {
                        <span class="olb-grid-num" title="@L["CoOp Completion"]">@L["Completion"]</span>
                    }
                    else
                    {
                        <span class="olb-grid-num">@L["Comp Lv"]</span>
                    }
                    <span class="olb-grid-num">PUMBILITY</span>
                </span>
                <span></span>
            </div>
        }
        @foreach (var entry in _entries.Skip((page - 1) * PageSize).Take(PageSize))
        {
            <div class="olb-grid-row @(IsMe(entry.UserId) ? "olb-row-me" : "")">
                <span><RankDelta Rank="entry.Place"/></span>
                <span style="display:flex;align-items:center;gap:6px;min-width:0">
                    <MudLink Style="cursor:pointer;display:flex;align-items:center;gap:8px;min-width:0" Underline="Underline.None"
                             Href="@($"/Community/Player?CommunityName={HttpUtility.UrlEncode(CommunityName)}&UserId={entry.UserId}")">
                        <MudImage Src="@entry.ProfileImage.ToString()" Height="26" ObjectFit="ObjectFit.ScaleDown"></MudImage>
                        <span class="olb-player-name" title="@((string)entry.PlayerName)">
                            <UserLabel User="_users[entry.UserId]"></UserLabel>
                        </span>
                    </MudLink>
                    @if (entry.IsPublic && _currentMix == MixEnum.Phoenix)
                    {
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.LocalFireDepartment"
                                       aria-label="@L["Phoenix Recap"]" title="@L["Phoenix Recap"]"
                                       Href=@($"/Player/{entry.UserId}/PhoenixRecap")></MudIconButton>
                    }
                </span>
                <span>
                    @if (_playerTypes.TryGetValue(entry.UserId, out var playerType))
                    {
                        <PlayerTypeChip Type="playerType"/>
                    }
                </span>
                <span class="olb-hide-narrow olb-grid-num mud-text-secondary" title="@L["Charts Played"]">
                    @(_playCounts.TryGetValue(entry.UserId, out var plays) ? plays.ToString("N0") : "—")
                </span>
                <span class="olb-stack">
                    @if (_currentType == LeaderboardType.CoOp)
                    {
                        <span class="olb-grid-num mud-text-secondary" title="@L["CoOp Completion"]">
                            @(_coOpCompletion.TryGetValue(entry.UserId, out var completion)
                                ? completion.ToString("P0")
                                : "—")
                        </span>
                    }
                    else
                    {
                        <span class="olb-grid-num mud-text-secondary" title="@L["Comp Lv"]">
                            @entry.CompetitiveLevel.ToString("0.00")
                        </span>
                    }
                    <b class="olb-grid-num" style="color:@entry.Color" title="PUMBILITY">@entry.Rating</b>
                </span>
                <span>
                    @if (_currentType != LeaderboardType.CoOp)
                    {
                        <MudIconButton Size="Size.Small" aria-label="@L["View top charts"]" title="@L["View top charts"]"
                                       Icon="@(_expandedUserId == entry.UserId ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       OnClick="() => ToggleExpand(entry.UserId, ExpandTypeFor(_currentType))"/>
                    }
                </span>
            </div>
            @if (_expandedUserId == entry.UserId)
            {
                <div class="olb-rank-expand">
                    @if (_scores == null)
                    {
                        <MudSkeleton Height="120px" SkeletonType="SkeletonType.Rectangle"/>
                    }
                    else
                    {
                        <div class="tier-card-grid pa-2">
                            @foreach (var score in _scores)
                            {
                                <TierListChartCard Chart="score.Chart"
                                                   Score="new RecordedPhoenixScore(score.Chart.Id, score.Score, score.Plate, score.IsBroken, default)"
                                                   TierLabel="@score.Rating.ToString("N0")"
                                                   ShowToDo="false"/>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
    @if (pageCount > 1)
    {
        <div class="d-flex justify-center mt-2">
            <MudPagination Count="pageCount" Selected="page" SelectedChanged="p => _page = p"/>
        </div>
    }

    @if (_noScores.Any())
    {
        <MudText Typo="Typo.overline" Class="mud-text-secondary mt-4 d-block">@L["No scores in this mix yet"]</MudText>
        <div class="d-flex flex-wrap" style="gap:6px">
            @foreach (var name in _noScores)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@((string)name)</MudChip>
            }
        </div>
    }
    </div>
}

@inject IMediator Mediator;
@inject ICurrentUserAccessor CurrentUser;
@inject NavigationManager NavManager;
@inject IUserRepository Users;
@inject ScoreTracker.Web.Services.Contracts.IUiSettingsAccessor UiSettings;
@code {
    // Community stats are Phoenix-lineage — XX viewers keep seeing Phoenix, as before.
    private MixEnum _currentMix = MixEnum.Phoenix;

    private Community? _community;
    private CommunityRoleRecord? _myRole;
    private IEnumerable<CommunityLeaderboardRecord> _leaderboard = Array.Empty<CommunityLeaderboardRecord>();
    private IEnumerable<LeaderboardEntry> _entries = Array.Empty<LeaderboardEntry>();
    private IDictionary<Guid, Chart> _charts = new Dictionary<Guid, Chart>();
    private IDictionary<Guid, User> _users = new Dictionary<Guid, User>();
    private IReadOnlyDictionary<Guid, int> _playCounts = new Dictionary<Guid, int>();
    private IReadOnlyDictionary<Guid, double> _coOpCompletion = new Dictionary<Guid, double>();
    private IReadOnlyDictionary<Guid, RecapPlayerType> _playerTypes = new Dictionary<Guid, RecapPlayerType>();
    private IReadOnlyList<Name> _noScores = Array.Empty<Name>();
    private ISet<Guid> _noScoreUserIds = new HashSet<Guid>();
    private int _memberCount;
    private bool _coOpCompletionLoaded;
    private ISet<Name> _myCommunities = new HashSet<Name>();
    private bool _showGuests = false;
    private List<BreadcrumbItem> _crumbs = new();

    // One percentile scale per rating column: a player's color reflects where they sit in
    // THIS community's distribution, on the sitewide rarity ramp.
    private ThemeScales.PopulationScale _skillScale = ThemeScales.ScaleFrom(Array.Empty<int>());
    private ThemeScales.PopulationScale _singlesScale = ThemeScales.ScaleFrom(Array.Empty<int>());
    private ThemeScales.PopulationScale _doublesScale = ThemeScales.ScaleFrom(Array.Empty<int>());
    private ThemeScales.PopulationScale _coOpScale = ThemeScales.ScaleFrom(Array.Empty<int>());

    private LeaderboardType _currentType = LeaderboardType.Combined;

    private const int PageSize = 50;
    private int _page = 1;

    private int PageCount => Math.Max(1, (int)Math.Ceiling(_entries.Count() / (double)PageSize));

    private Guid _expandedUserId = Guid.Empty;
    private ChartType? _expandedChartType;
    private ScoreEntry[]? _scores;

    [Parameter]
    [SupplyParameterFromQuery] public string CommunityName { get; set; } = string.Empty;

    private static ChartType? ExpandTypeFor(LeaderboardType type) => type switch
    {
        LeaderboardType.Singles => ChartType.Single,
        LeaderboardType.Doubles => ChartType.Double,
        _ => null
    };

    protected override async Task OnInitializedAsync()
    {
        var communityName = HttpUtility.UrlDecode(CommunityName);
        var selectedMix = await UiSettings.GetSelectedMix();
        _currentMix = selectedMix == MixEnum.XX ? MixEnum.Phoenix : selectedMix;
        var community = await Mediator.Send(new GetCommunityQuery(communityName));
        _community = community;
        _crumbs = new List<BreadcrumbItem>
        {
            new(L["Communities"].Value, "/Communities"),
            new(communityName, null, true)
        };
        _charts = (await Mediator.Send(new GetChartsQuery(_currentMix))).ToDictionary(c => c.Id);
        _myCommunities = (await Mediator.Send(new GetMyCommunitiesQuery())).Select(c => c.CommunityName).ToHashSet();
        _myRole = await Mediator.Send(new GetMyCommunityRoleQuery(communityName));
        if (community.PrivacyType == CommunityPrivacyType.Private)
        {
            if (!CurrentUser.IsLoggedIn || !_myCommunities.Contains(communityName))
            {
                NavManager.NavigateTo("/Communities");
                return;
            }
        }

        _leaderboard = (await Mediator.Send(new GetCommunityLeaderboardQuery(communityName, _currentMix))).ToArray();
        _users = (await Users.GetUsers(_leaderboard.Select(l => l.UserId).Distinct())).ToDictionary(u => u.Id);
        _playCounts = await Mediator.Send(new GetCommunityPlayCountsQuery(communityName, _currentMix));

        // Playstyle is the recap's letter-grade banding over the player's top-Pumbility
        // average — SkillScore IS that average, so every member with enough clears gets a
        // type from their own site scores (the official mirror only knows board-charting players).
        _playerTypes = _leaderboard
            .Where(l => l.ClearCount >= RecapPlayerTypeCalculator.MinimumScores && (int)l.SkillRating > 0)
            .ToDictionary(l => l.UserId, l => RecapPlayerTypeCalculator.FromAverage((int)l.SkillScore));

        // Player communities list every member; the ones without scores in this mix drop out
        // of the ranked rows and land in the roll call below the table. Regions and World are
        // population-scale — no roster pull, the board already tells the story.
        if (!community.IsRegional)
        {
            var roster = (await Mediator.Send(new GetCommunityRosterQuery(communityName)))
                .Where(m => m.Role != CommunityRole.Banned).ToArray();
            var scored = _leaderboard
                .Where(l => l.ClearCount > 0 || (int)l.SkillRating > 0 || (int)l.TotalRating > 0)
                .Select(l => l.UserId).ToHashSet();
            var noScores = roster.Where(m => !scored.Contains(m.UserId)).ToArray();
            _noScoreUserIds = noScores.Select(m => m.UserId).ToHashSet();
            _noScores = noScores.Select(m => m.Name)
                .OrderBy(n => (string)n, StringComparer.OrdinalIgnoreCase).ToArray();
            _memberCount = roster.Length;
        }
        else
        {
            _memberCount = _leaderboard.Count();
        }
        _skillScale = ThemeScales.ScaleFrom(_leaderboard.Select(l => (int)l.SkillRating));
        _singlesScale = ThemeScales.ScaleFrom(_leaderboard.Select(l => (int)l.SinglesRating));
        _doublesScale = ThemeScales.ScaleFrom(_leaderboard.Select(l => (int)l.DoublesRating));
        _coOpScale = ThemeScales.ScaleFrom(_leaderboard.Select(l => (int)l.CoOpRating));
        await SetType(LeaderboardType.Combined);
    }

    private async Task SetType(LeaderboardType type)
    {
        if (_community == null) return;
        _expandedUserId = Guid.Empty;
        _scores = null;
        _page = 1;
        if (type == LeaderboardType.CoOp && !_coOpCompletionLoaded)
        {
            _coOpCompletion = await Mediator.Send(
                new GetCommunityCoOpCompletionQuery(HttpUtility.UrlDecode(CommunityName), _currentMix));
            _coOpCompletionLoaded = true;
        }

        var entries = _leaderboard
            .Where(l => !_noScoreUserIds.Contains(l.UserId))
            .Where(l => !_community.IsRegional || _showGuests || _users[l.UserId].Country == CommunityName);
        _entries = type switch
        {
            LeaderboardType.Singles => entries.OrderByDescending(l => l.SinglesRating).Select((l, i) =>
                Entry(l, i, l.SinglesRating, l.SinglesCompetitiveLevel, _singlesScale.GetColor((int)l.SinglesRating))),
            LeaderboardType.Doubles => entries.OrderByDescending(l => l.DoublesRating).Select((l, i) =>
                Entry(l, i, l.DoublesRating, l.DoublesCompetitiveLevel, _doublesScale.GetColor((int)l.DoublesRating))),
            LeaderboardType.CoOp => entries.OrderByDescending(l => l.CoOpRating).Select((l, i) =>
                Entry(l, i, l.CoOpRating, 0, _coOpScale.GetColor((int)l.CoOpRating))),
            _ => entries.OrderByDescending(l => l.SkillRating).Select((l, i) =>
                Entry(l, i, l.SkillRating, l.CompetitiveLevel, _skillScale.GetColor((int)l.SkillRating)))
        };
        // Paging walks the list on every render — materialize once per board switch.
        _entries = _entries.ToArray();
        _currentType = type;
    }

    private LeaderboardEntry Entry(CommunityLeaderboardRecord record, int index, int rating,
        double competitiveLevel, string color) =>
        new(index + 1, record.ProfileImage, record.PlayerName, record.IsPublic, record.UserId, rating,
            competitiveLevel, color);

    private async Task SetShowGuests(bool newValue)
    {
        _showGuests = newValue;
        await SetType(_currentType);
    }

    private async Task ToggleExpand(Guid userId, ChartType? chartType)
    {
        if (_expandedUserId == userId && _expandedChartType == chartType)
        {
            _expandedUserId = Guid.Empty;
            _scores = null;
            return;
        }

        _expandedUserId = userId;
        _expandedChartType = chartType;
        _scores = null;
        var scoringConfig = ScoringConfiguration.PumbilityScoring(_currentMix, true);
        var top50 = await Mediator.Send(new GetTop50ForPlayerQuery(userId, chartType, Mix: _currentMix));
        _scores = top50.Where(s => _charts.ContainsKey(s.ChartId))
            .Select(s => new ScoreEntry(_charts[s.ChartId], s.Score ?? 0, s.Plate, s.IsBroken,
                (int)scoringConfig.GetScore(_charts[s.ChartId], s.Score ?? 0, s.Plate ?? PhoenixPlate.ExtremeGame, false),
                ScoringConfiguration.CalculateFungScore(_charts[s.ChartId].Level, s.Score ?? 0, _charts[s.ChartId].Type)))
            .ToArray();
    }

    private bool IsMe(Guid userId) => CurrentUser.IsLoggedIn && CurrentUser.User.Id == userId;

    private void GoToMembers()
    {
        NavManager.NavigateTo($"/Community/Members?CommunityName={HttpUtility.UrlEncode(CommunityName)}");
    }

    private sealed record ScoreEntry(Chart Chart, PhoenixScore Score, PhoenixPlate? Plate, bool IsBroken, int Rating, double CompetitiveLevel);

    private sealed record LeaderboardEntry(int Place, Uri ProfileImage, Name PlayerName, bool IsPublic, Guid UserId,
        int Rating, double CompetitiveLevel, string Color);

    private enum LeaderboardType
    {
        Combined,
        Singles,
        Doubles,
        CoOp
    }
}
