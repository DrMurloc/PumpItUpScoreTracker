@page "/Communities/Invite/{InviteCode:guid}"
@rendermode RenderModes.Interactive
@using MediatR
@using ScoreTracker.Communities.Contracts
@using ScoreTracker.Communities.Contracts.Commands
@using ScoreTracker.Communities.Contracts.Queries
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
<PageTitle>@L["Community Invite"]</PageTitle>

<div style="max-width:480px;margin:48px auto;text-align:center">
    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary"/>
    }
    else if (_preview == null)
    {
        <MudText Typo="Typo.h5">@L["This invite link isn't valid."]</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">@L["The code may have been revoked, or the community no longer exists."]</MudText>
        <MudButton Variant="Variant.Outlined" Href="/Communities">@L["Browse Communities"]</MudButton>
    }
    else
    {
        <MudPaper Class="pa-6">
            <MudText Typo="Typo.h4">@((string)_preview.CommunityName)</MudText>
            <div style="display:flex;gap:8px;justify-content:center;margin-top:8px" class="mb-3">
                <MudChip T="string" Size="Size.Small">@PrivacyLabel(_preview.PrivacyType)</MudChip>
                <MudChip T="string" Size="Size.Small">@L["{0} members", _preview.MemberCount]</MudChip>
            </div>

            @if (_preview.IsBanned)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@L["You've been banned from this community and can't rejoin."]</MudAlert>
                <MudButton Variant="Variant.Outlined" Href="/Communities">@L["Browse Communities"]</MudButton>
            }
            else if (_preview.IsAlreadyMember)
            {
                <MudAlert Severity="Severity.Info" Class="mb-3">@L["You're already a member of this community."]</MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToCommunity">@L["Open Community"]</MudButton>
            }
            else if (_preview.IsExpired)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-3">@L["This invite code has expired. Ask a member for a new link."]</MudAlert>
                <MudButton Variant="Variant.Outlined" Href="/Communities">@L["Browse Communities"]</MudButton>
            }
            else if (!CurrentUser.IsLoggedIn)
            {
                <MudText Typo="Typo.body1" Class="mb-3">@L["Sign in to accept this invite."]</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/Login">@L["Sign In"]</MudButton>
            }
            else
            {
                <MudText Typo="Typo.body1" Class="mb-4">@L["You've been invited to join this community."]</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="_isSaving"
                           OnClick="Accept">@L["Accept invite & join"]</MudButton>
                <MudButton Variant="Variant.Text" FullWidth="true" Class="mt-2" Href="/Communities">@L["No thanks"]</MudButton>
            }
        </MudPaper>
    }
</div>

@* Private-profile players consent to community score visibility before membership exists. *@
<MudDialog @bind-Visible="_showConsent">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-2">@L["Your scores will be visible"]</MudText>
        <MudText>@L["Your profile is private. Joining this community makes your scores visible to everyone in it — on its leaderboards, player pages, and comparisons. You'll stay hidden everywhere else."]</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showConsent = false">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_isSaving" OnClick="Join">
            @L["I understand — join"]
        </MudButton>
    </DialogActions>
</MudDialog>

@inject IMediator Mediator
@inject ICurrentUserAccessor CurrentUser
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

@code {
    [Parameter] public Guid InviteCode { get; set; }

    private bool _loading = true;
    private bool _isSaving;
    private bool _showConsent;
    private CommunityInvitePreviewRecord? _preview;

    protected override async Task OnInitializedAsync()
    {
        if (InviteCode == default)
        {
            NavManager.NavigateTo("/Communities");
            return;
        }

        _preview = await Mediator.Send(new GetCommunityInvitePreviewQuery(InviteCode));
        _loading = false;
    }

    private async Task Accept()
    {
        // The consent gate is for private-profile players only; public players join directly.
        if (!CurrentUser.User.IsPublic)
        {
            _showConsent = true;
            return;
        }

        await Join();
    }

    private async Task Join()
    {
        _showConsent = false;
        _isSaving = true;
        try
        {
            await Mediator.Send(new JoinCommunityByInviteCodeCommand(InviteCode));
            GoToCommunity();
        }
        catch (Exception)
        {
            Snackbar.Add(L["There was an error while joining the community"].Value, Severity.Error);
            _isSaving = false;
        }
    }

    private void GoToCommunity()
    {
        NavManager.NavigateTo(
            $"/Community/Leaderboard?CommunityName={Uri.EscapeDataString(_preview!.CommunityName)}");
    }

    private string PrivacyLabel(CommunityPrivacyType privacy) => privacy switch
    {
        CommunityPrivacyType.Private => L["Private"].Value,
        CommunityPrivacyType.PublicWithCode => L["Invite Required"].Value,
        _ => L["Public"].Value
    };
}
