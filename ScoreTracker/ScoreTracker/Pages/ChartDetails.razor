@page "/Record"
@page "/Chart"
@page "/Chart/{ChartId:guid}"
@rendermode RenderModes.Interactive
@using MediatR
@using ScoreTracker.Catalog.Contracts
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.ChartIntelligence.Contracts
@using ScoreTracker.ChartIntelligence.Contracts.Queries
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType

@* The chart drill-down (docs/design/chart-details-overhaul.md, mock R2): answer →
   evidence → record → onward. Rebuilt in place for the Stage-3 conversion — every
   circuit-needing section is its own child component, so islanding them is a render-mode
   line each rather than a rewrite.
   This page has no render mode of its own: it inherits the circuit from
   App.razor's `<Routes @@rendermode="Interactive">`, and a child cannot opt back out of
   one. Going static therefore waits on that attribute leaving Routes and every page
   opting in individually — see "What P3 actually costs" in the design doc. The /Record
   and bare /Chart aliases die at P3 when the 301 lattice goes live. *@
<PageTitle>@(_chart == null ? L["Chart Details"].Value : $"{_chart.Song.Name} {_chart.DifficultyString}")</PageTitle>
<HeadContent>
    @* Dead channel until Stage 3 (HeadOutlet renders in the circuit; crawlers never see
       this) — P3 moves title/meta/OG/JSON-LD into the static head for real. *@
    <meta name="description" content="@MetaDescription"/>
    <meta property="og:title" content="@(_chart == null ? "Chart Details" : $"{_chart.Song.Name} {_chart.DifficultyString}")">
    <meta property="og:image" content="@(_chart?.Song.ImagePath.ToString() ?? "")">
    <meta property="og:description" content="@MetaDescription">
</HeadContent>

@if (_initialized && _chart == null)
{
    <div class="chart-empty">
        <MudText Typo="Typo.h5">@L["Find a chart"]</MudText>
        <MudText Typo="Typo.body2" Class="chart-empty-sub">@L["Search by song name — every chart has its own page."]</MudText>
        <ChartSelector ChartIdSelected="GoToChart" Mix="_mix"></ChartSelector>
    </div>
}
@if (_chart != null)
{
    <section class="chart-hero">
        @* The jacket column: art, then your score in the nook beneath it. Keys carry the
           panel's identity alongside the chart id — Blazor's sibling key lookup compares
           key values only, so two keyed siblings sharing a chart id collide even when
           they are different component types. *@
        <div class="chart-hero-jacket-col">
            <ChartVideoPlayer Chart="_chart" @key="(_chart.Id, nameof(ChartVideoPlayer))"></ChartVideoPlayer>
            <ChartRecordPanel Chart="_chart" Mix="_mix" @key="(_chart.Id, nameof(ChartRecordPanel))"></ChartRecordPanel>
        </div>
        <div class="chart-hero-id">
            <h1 class="chart-hero-title">@_chart.Song.Name</h1>
            <div class="chart-hero-sub">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_chart.Song.Type</MudChip>
                <span>@L["song by {0}", _chart.Song.Artist]</span>
                @if (_chart.StepArtist != null && _chart.StepArtist.ToString() != "Unknown")
                {
                    <span>· @L["steps by {0}", _chart.StepArtist]</span>
                }
            </div>
            @if (_siblings.Count > 1)
            {
                <div class="chart-hero-siblings">
                    @foreach (var sibling in _siblings)
                    {
                        @if (sibling.Id == _chart.Id)
                        {
                            <span class="chart-hero-sibling-current"><DifficultyBubble Chart="sibling" Small="true"></DifficultyBubble></span>
                        }
                        else
                        {
                            <a href="@($"/Chart/{sibling.Id}")"><DifficultyBubble Chart="sibling" Small="true"></DifficultyBubble></a>
                        }
                    }
                </div>
            }
            <div class="chart-hero-facts">
                @if (_chart.Song.Bpm != null)
                {
                    <div><span class="chart-fact-value">@BpmDisplay</span><span class="chart-fact-label">@L["BPM"]</span></div>
                }
                @if (_chart.NoteCount > 0)
                {
                    <div><span class="chart-fact-value">@($"{_chart.NoteCount:N0}")</span><span class="chart-fact-label">@L["Notes"]</span></div>
                }
                @if (_analysis?.Nps != null)
                {
                    <div><span class="chart-fact-value">@_analysis.Nps.Value.ToString("0.#")</span><span class="chart-fact-label">@L["Notes per Second"]</span></div>
                }
                <div><span class="chart-fact-value">@_chart.OriginalMix.GetName()</span><span class="chart-fact-label">@L["Debuted in"]</span></div>
                @if (Population != null)
                {
                    <div><span class="chart-fact-value">@($"{Population.ScoresTracked:N0}")</span><span class="chart-fact-label">@L["Scores tracked"]</span></div>
                    <div><span class="chart-fact-value">@((int)Math.Round(Population.PassRate * 100))%</span><span class="chart-fact-label">@L["Pass rate"]</span></div>
                }
            </div>
            <ChartVerdictCard Facets="_facets"></ChartVerdictCard>
            <div class="chart-hero-actions">
                <MudLink Href="@PiuCenterUrl" Target="_blank" Typo="Typo.caption">@L["View full chart on PIU Center"]</MudLink>
            </div>
        </div>
    </section>

    <section class="chart-section">
        <div class="chart-section-head">
            <MudText Typo="Typo.h5">@L["Chart Stats"]</MudText>
        </div>
        <ChartEvidenceSection Chart="_chart" Mix="_mix" Facets="_facets" @key="_chart.Id"></ChartEvidenceSection>
    </section>

    @if (_skillChips.Any() || _analysis != null)
    {
        <section class="chart-section">
            <div class="chart-section-head">
                <MudText Typo="Typo.h5">@L["Skill fingerprint"]</MudText>
                @if (Fingerprint != null)
                {
                    <MudText Typo="Typo.caption" Class="chart-section-sub"><VerdictSentence Facet="Fingerprint"></VerdictSentence></MudText>
                }
            </div>
            <SkillCoverageBars Chips="_skillChips"></SkillCoverageBars>
            @* Intensity reads as bars beside the skills because it is the same kind of
               fact — a share of the chart — and the two together are what "what is this
               chart made of" means. Grind and spikes rather than sustain and tension:
               sustain is a subset of tension, so showing both counts the grind twice. *@
            <IntensityBars Intensity="Intensity" Duration="_chart.Song.Duration"></IntensityBars>
            <div class="chart-skill-foot">
                <span>@L["Share of the chart each pattern and demand covers"]</span>
                <span>@L["Step analysis data from PIU Center"]</span>
            </div>
        </section>
    }

    @if (History != null)
    {
        <section class="chart-section">
            <div class="chart-section-head">
                <MudText Typo="Typo.h5">@L["History"]</MudText>
                <MudText Typo="Typo.caption" Class="chart-section-sub">@L["Level changes across mixes, from the catalog record."]</MudText>
            </div>
            <ChartHistoryTimeline History="History" Type="_chart.Type"></ChartHistoryTimeline>
        </section>
    }

    <section class="chart-section">
        <div class="chart-section-head">
            <MudText Typo="Typo.h5">@L["Leaderboard"]</MudText>
        </div>
        <ChartLeaderboardSection Chart="_chart" Mix="_mix" @key="_chart.Id"></ChartLeaderboardSection>
    </section>

    <section class="chart-section">
        <div class="chart-section-head">
            <MudText Typo="Typo.h5">@L["Charts like this"]</MudText>
            <MudText Typo="Typo.caption" Class="chart-section-sub">@L["From the similarity graph — evidence-weighted, rebuilt nightly."]</MudText>
        </div>
        <SimilarChartsShelf ChartId="_chart.Id" Mix="_mix" @key="_chart.Id"></SimilarChartsShelf>
        <p class="chart-section-credit">
            @L["Chart analysis made possible by"]
            <MudLink Href="https://piucenter.com" Target="_blank" Typo="Typo.caption">PIU Center</MudLink>
        </p>
    </section>

}

@inject IMediator Mediator
@inject NavigationManager NavManager
@inject ICurrentUserAccessor CurrentUser
@inject IUiSettingsAccessor UiSettings
@code {
    [Parameter]
    public Guid? ChartId { get; set; }

    private MixEnum _mix = MixEnum.Phoenix;
    private bool _initialized;
    private Chart? _chart;
    private IReadOnlyList<ChartVerdictFacet> _facets = Array.Empty<ChartVerdictFacet>();
    private IReadOnlyList<Chart> _siblings = Array.Empty<Chart>();
    private IReadOnlyList<ChartSkillChipRecord> _skillChips = Array.Empty<ChartSkillChipRecord>();
    private ChartStepAnalysisRecord? _analysis;

    private ChartIntensityFacts? Intensity => _chart == null ? null : ChartIntensityFacts.For(_chart, _analysis);

    private PopulationVerdict? Population => _facets.OfType<PopulationVerdict>().FirstOrDefault();
    private HistoryVerdict? History => _facets.OfType<HistoryVerdict>().FirstOrDefault();
    private StyleFingerprintVerdict? Fingerprint => _facets.OfType<StyleFingerprintVerdict>().FirstOrDefault();

    // Bpm.ToString prints Min twice on ranges (pre-existing) — format locally.
    private string BpmDisplay => _chart?.Song.Bpm is not { } bpm ? "" :
        bpm.Min == bpm.Max ? bpm.Min.ToString("0.##") : $"{bpm.Min:0.##}–{bpm.Max:0.##}";

    private string MetaDescription => _chart == null
        ? "Look up statistics and leaderboards on specific PIU charts!"
        : $"Statistics and leaderboards for {_chart.Song.Name} {_chart.DifficultyString} by {_chart.Song.Artist}.";

    private string PiuCenterUrl => _analysis?.ExternalKey == null
        ? "https://www.piucenter.com"
        : $"https://www.piucenter.com/chart/{Uri.EscapeDataString(_analysis.ExternalKey)}";

    protected override async Task OnInitializedAsync()
    {
        _mix = await UiSettings.GetSelectedMix();
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // One load per chart id — the old page's init/params double-fetch is dead.
        if (ChartId == null)
        {
            _chart = null;
            return;
        }

        if (_chart?.Id == ChartId) return;
        var chart = (await Mediator.Send(new GetChartsQuery(_mix, ChartIds: new[] { ChartId.Value })))
            .FirstOrDefault();
        if (chart == null)
        {
            _chart = null;
            return;
        }

        _chart = chart;
        _facets = await Mediator.Send(new GetChartVerdictQuery(chart.Id, _mix));
        // The current chart stays in its own lineup — leaving it out makes the row read as
        // "the other ones" and hides where you are in the song's ladder.
        _siblings = (await Mediator.Send(new GetChartsBySongQuery(_mix, chart.Song.Name)))
            .OrderBy(c => c.Type)
            .ThenBy(c => (int)c.Level)
            .ToArray();
        _skillChips = (await Mediator.Send(new GetChartSkillChipsQuery(new[] { chart.Id })))
            .TryGetValue(chart.Id, out var chips)
            ? chips
            : Array.Empty<ChartSkillChipRecord>();
        _analysis = await Mediator.Send(new GetChartStepAnalysisQuery(chart.Id));
    }

    private Task GoToChart(Chart chart)
    {
        NavManager.NavigateTo($"/Chart/{chart.Id}");
        return Task.CompletedTask;
    }
}
