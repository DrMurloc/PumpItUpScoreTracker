@page "/Account"
@rendermode RenderModes.Interactive
@using System.Web
@using MediatR
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.Identity.Contracts
@using ScoreTracker.Web.Components.Account

<PageTitle>@L["Account"]</PageTitle>

<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4">@L["Account"]</MudText>
    <MudSpacer></MudSpacer>
    <MudButton Href="/Logout" StartIcon="@Icons.Material.Filled.Logout" Variant="Variant.Outlined">@L["Logout"]</MudButton>
</div>

@if (_mergeInviteUserId != null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        @L["This sign-in method belongs to another account, you can merge the two accounts"]
        <MudButton Class="ml-2" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
                   Href="@($"/Account/Merge?with={_mergeInviteUserId}")">@L["Review and merge"]</MudButton>
    </MudAlert>
}
@foreach (var merge in _activeMerges)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        @L["Merged account data is deleted on", merge.PurgeAfter.ToString("d")]
        @if (merge.SurvivorUserId == CurrentUser.User.Id)
        {
            <MudButton Class="ml-2" Variant="Variant.Outlined" Size="Size.Small" Disabled="_isUndoingMerge"
                       OnClick="() => UndoMerge(merge.Id)">@L["Undo Merge"]</MudButton>
        }
    </MudAlert>
}

<MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="@L["Profile"]" Icon="@Icons.Material.Filled.Person">
        <ProfilePanel></ProfilePanel>
    </MudTabPanel>
    <MudTabPanel Text="@L["Sign-In Methods"]" Icon="@Icons.Material.Filled.Lock">
        <SignInMethodsPanel MergeInviteRaised="OnMergeInvite"></SignInMethodsPanel>
    </MudTabPanel>
    <MudTabPanel Text="@L["API"]" Icon="@Icons.Material.Filled.Code">
        <ApiTokenPanel></ApiTokenPanel>
    </MudTabPanel>
</MudTabs>

@inject NavigationManager NavManager
@inject ICurrentUserAccessor CurrentUser;
@inject IMediator Mediator;
@inject ISnackbar Snackbar;
@code
{
    private int _activeTab = 0;
    private Guid? _mergeInviteUserId;
    private IReadOnlyList<AccountMergeRecord> _activeMerges = Array.Empty<AccountMergeRecord>();
    private bool _isUndoingMerge = false;

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUser.IsLoggedIn)
        {
            NavManager.NavigateTo("/Login");
            return;
        }

        var query = HttpUtility.ParseQueryString(new Uri(NavManager.Uri).Query);
        _activeTab = query.Get("tab")?.ToLowerInvariant() switch
        {
            "signin" => 1,
            "api" => 2,
            _ => 0
        };

        if (Guid.TryParse(query.Get("mergeWith"), out var mergeWith))
        {
            _mergeInviteUserId = mergeWith;
            _activeTab = 1;
        }

        switch (query.Get("linkResult"))
        {
            case "Linked":
                Snackbar.Add(L["Sign-in method connected"], Severity.Success);
                _activeTab = 1;
                break;
            case "AlreadyLinked":
                Snackbar.Add(L["This sign-in method is already connected to your account"], Severity.Info);
                _activeTab = 1;
                break;
            case "Conflict":
                Snackbar.Add(L["This sign-in method is connected to a different account"], Severity.Warning);
                _activeTab = 1;
                break;
        }

        _activeMerges = (await Mediator.Send(new GetActiveAccountMergesQuery())).ToArray();
    }

    private void OnMergeInvite(Guid conflictingUserId)
    {
        _mergeInviteUserId = conflictingUserId;
        StateHasChanged();
    }

    private async Task UndoMerge(Guid mergeId)
    {
        _isUndoingMerge = true;
        try
        {
            await Mediator.Send(new UndoAccountMergeCommand(mergeId));
            _activeMerges = (await Mediator.Send(new GetActiveAccountMergesQuery())).ToArray();
            Snackbar.Add(L["Merge undone"], Severity.Success);
        }
        finally
        {
            _isUndoingMerge = false;
        }
    }
}
