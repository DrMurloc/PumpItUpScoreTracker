@page "/WeeklyCharts"
@using System.Globalization
@using System.Text.Json
@using MediatR
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Communities.Contracts.Queries
@using ScoreTracker.WeeklyChallenge.Contracts
@using ScoreTracker.WeeklyChallenge.Contracts.Queries
@using ScoreTracker.Web.Components.Challenges
@using ScoreTracker.Web.Enums
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Web.Services.HomeDashboard
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType

@* The challenges hub (docs/design/weekly-charts-overhaul.md): Weekly Charts + Daily Step on one
   statically rendered page — real HTML for crawlers, one dialog-host island for the interactive
   bits. No @rendermode: under the static router a page without one renders static SSR
   (RenderModeDeclarationTests lists it as a deliberate conversion). Reads the request directly,
   so mix, user and query-string state all resolve here without a circuit. Title, description,
   OG and canonical are served by StaticHeadResolver — a static page's PageTitle/HeadContent
   would render into a HeadOutlet island it never reaches. *@

@if (_jsonLd != null)
{
    @* The JSON-LD ItemList of the week's charts. Structured data is valid anywhere in the
       document, and the body is the one place a static page can render markup. *@
    <script type="application/ld+json">@((MarkupString)_jsonLd)</script>
}

@if (_pool != null)
{
    <div class="challenge-head">
        <h1>@L["Charts Not Yet Featured"]</h1>
        <a class="challenge-btn ghost" href="/WeeklyCharts">@L["Back to Weekly Charts"]</a>
    </div>
    <ChallengePool Charts="_pool"></ChallengePool>
}
else
{
    <div class="challenge-head">
        <h1>@L["Weekly Charts"]</h1>
        @if (_isLoggedIn && _board.IsLive)
        {
            <div class="challenge-yourweek">
                <span class="challenge-chip">@L["Played"] <b>@_playedCount</b>/@_board.Charts.Count</span>
                @if (_suggestedLeft > 0)
                {
                    <span class="challenge-chip"><b>@_suggestedLeft</b> @L["suggested left"]</span>
                }
                @if (_monthlyPlace != null)
                {
                    <span class="challenge-chip">@L["Monthly"] <b>#@_monthlyPlace</b></span>
                }
            </div>
        }
        <div class="challenge-controls">
            <details class="challenge-picker">
                <summary>@L["Week"]: @(_weekStart == null ? L["current"] : WeekLabel(_weekStart.Value))</summary>
                <div class="challenge-picker-menu">
                    <a href="/WeeklyCharts" class="@(_weekStart == null ? "on" : "")">@L["Current"]</a>
                    @foreach (var date in _pastDates)
                    {
                        <a href="/WeeklyCharts?week=@date.ToString("yyyy-MM-dd")"
                           class="@(_weekStart == date ? "on" : "")">@WeekLabel(date)</a>
                    }
                </div>
            </details>
            @if (_isLoggedIn && _myCommunities.Any())
            {
                <details class="challenge-picker">
                    <summary>@L["Communities"]@(_selectedCommunities.Any() ? $": {_selectedCommunities.Count}" : "")</summary>
                    <div class="challenge-picker-menu">
                        <form method="get" action="/WeeklyCharts">
                            @if (_weekStart != null)
                            {
                                <input type="hidden" name="week" value="@Week"/>
                            }
                            @foreach (var name in _myCommunities)
                            {
                                <label>
                                    <input type="checkbox" name="communities" value="@name"
                                           checked="@_selectedCommunities.Contains(name)"/> @name
                                </label>
                            }
                            <button type="submit" class="challenge-picker-apply">@L["Apply"]</button>
                        </form>
                    </div>
                </details>
            }
        </div>
    </div>

    @* ── Daily Step (live view only) ── *@
    @if (_board.IsLive)
    {
        <section id="daily" class="challenge-section" style="margin-top:10px">
            <DailyStepStrip View="_daily" Chart="_dailyChart" ResetsIn="_dailyResetsIn"
                            IsLoggedIn="_isLoggedIn"></DailyStepStrip>
        </section>
    }

    @* ── This week's board ── *@
    <section id="weekly" class="challenge-section" style="margin-top:14px">
        <WeeklyBoardGrid Summaries="_shownSummaries" Charts="_charts" Density="_density"
                         IsLoggedIn="_isLoggedIn" ShowingSuggestedOnly="_showingSuggestedOnly"
                         SuggestionsAvailable="_board.SuggestionsAvailable" TotalCount="_board.Charts.Count"
                         ToggleHref="@_suggestedToggleHref" PoolHref="/WeeklyCharts?pool=1"
                         Rotation="@_rotationText"></WeeklyBoardGrid>
    </section>

    @* ── Monthly leaderboard ── *@
    <section id="monthly" class="challenge-section">
        <MonthlyLeaderboard View="_monthly" Charts="_charts" Type="_type" UserId="_userId"
                            Subtitle="@_monthlySubtitle" BasePath="@_monthlyBasePath"></MonthlyLeaderboard>
    </section>

    @* ── Your Daily Step history ── *@
    @if (_board.IsLive)
    {
        <section id="history" class="challenge-section">
            @if (_isLoggedIn)
            {
                <div class="challenge-sect-head">
                    <h2>@L["Your Daily Step History"]</h2>
                    <span class="sub">@L["last 14 days"]</span>
                </div>
                <DailyStepHistory Records="_history" Charts="_charts"></DailyStepHistory>
            }
            else
            {
                <div class="challenge-empty">
                    @L["Sign in to record scores, track your standings and keep your Daily Step history."]
                    <a href="/Login">@L["Sign in"]</a>
                </div>
            }
        </section>
    }

    @* ── Scoring legend ── *@
    <section id="legend" class="challenge-section">
        <div class="challenge-sect-head">
            <h2>@L["How Scoring Works"]</h2>
        </div>
        <ChallengeScoringLegend Mix="_mix"></ChallengeScoringLegend>
    </section>

    @if (_isAdmin && _board.IsLive)
    {
        <section class="challenge-section">
            <button class="challenge-btn ghost" data-challenge-rotate="true">@L["Process Weekly Charts"]</button>
        </section>
    }

    <div class="page-dock shell-mobile-only">
        <div class="challenge-dock">
            <a href="#daily">@L["Daily"]</a>
            <a href="#weekly">@L["Weekly"]</a>
            <a href="#monthly">@L["Monthly"]</a>
            @if (_dailyResetsIn != null)
            {
                <span class="reset">@L["resets in {0}", _dailyResetsIn]</span>
            }
        </div>
    </div>

    @* The one island: the static controls above reach it through challenge-board.js. The
       dialogs are the only circuit the page itself brings (§3.3). *@
    <ChallengeDialogHost @rendermode="RenderModes.Interactive" Mix="_mix"/>
}

@inject IMediator Mediator
@inject ICurrentUserAccessor CurrentUser
@inject IUiSettingsAccessor UiSettings
@inject IDateTimeOffsetAccessor Clock
@inject ChartCatalogCache ChartCatalog
@inject NavigationManager NavManager

@code {
    [SupplyParameterFromQuery] public string? Week { get; set; }
    [SupplyParameterFromQuery] public string? Type { get; set; }
    [SupplyParameterFromQuery] public string? Suggested { get; set; }
    [SupplyParameterFromQuery] public string? Pool { get; set; }
    [SupplyParameterFromQuery(Name = "communities")] public string[]? Communities { get; set; }

    private const string DensityKey = "Density__WeeklyCharts";

    private bool _isLoggedIn;
    private bool _isAdmin;
    private Guid? _userId;
    private MixEnum _mix = MixEnum.Phoenix;
    private DateTimeOffset _now;
    private IReadOnlyDictionary<Guid, Chart> _charts = new Dictionary<Guid, Chart>();

    private DateTimeOffset[] _pastDates = Array.Empty<DateTimeOffset>();
    private DateTimeOffset? _weekStart;
    private ChartType? _type;

    private string[] _myCommunities = Array.Empty<string>();
    private HashSet<string> _selectedCommunities = new();

    private WeeklyBoardView _board = new(Array.Empty<WeeklyBoardChartSummary>(), true, false);
    private MonthlyLeaderboardView _monthly = new(Array.Empty<MonthlyLeaderboardRow>(), 0, 0, null, null);
    private DailyStepBoardView? _daily;
    private Chart? _dailyChart;
    private DailyStepHistoryRecord[] _history = Array.Empty<DailyStepHistoryRecord>();
    private Chart[]? _pool;

    private UiDensity _density = UiDensity.Comfortable;
    private bool _showingSuggestedOnly;
    private IReadOnlyList<WeeklyBoardChartSummary> _shownSummaries = Array.Empty<WeeklyBoardChartSummary>();

    private int _playedCount;
    private int _suggestedLeft;
    private int? _monthlyPlace;
    private string? _dailyResetsIn;
    private string _rotationText = string.Empty;
    private string _monthlySubtitle = string.Empty;
    private string _monthlyBasePath = "/WeeklyCharts";
    private string _suggestedToggleHref = "/WeeklyCharts";

    private string? _jsonLd;

    protected override async Task OnInitializedAsync()
    {
        _isLoggedIn = CurrentUser.IsLoggedIn;
        _isAdmin = CurrentUser.IsLoggedInAsAdmin;
        _userId = _isLoggedIn ? CurrentUser.User.Id : null;
        _now = Clock.Now;

        // XX and older have no weekly board — those viewers see the Phoenix hub.
        var selected = await UiSettings.GetSelectedMix();
        _mix = selected is MixEnum.Phoenix or MixEnum.Phoenix2 ? selected : MixEnum.Phoenix;
        _charts = await ChartCatalog.GetCharts(_mix);

        _pastDates = (await Mediator.Send(new GetPastWeeklyDatesQuery(_mix)))
            .OrderByDescending(d => d).ToArray();
        if (!string.IsNullOrWhiteSpace(Week) &&
            DateTimeOffset.TryParse(Week, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var wd))
        {
            _weekStart = _pastDates.Where(d => d.Date == wd.Date).Cast<DateTimeOffset?>().FirstOrDefault();
        }

        if (Enum.TryParse<ChartType>(Type, out var t) && t is ChartType.Single or ChartType.Double or ChartType.CoOp)
        {
            _type = t;
        }

        List<Guid>? onlyUserIds = null;
        if (_isLoggedIn)
        {
            _myCommunities = (await Mediator.Send(new GetMyCommunitiesQuery()))
                .Select(c => c.CommunityName.ToString())
                .Where(n => n != "World")
                .OrderBy(n => n)
                .ToArray();
            if (Communities is { Length: > 0 })
            {
                _selectedCommunities = Communities.Where(_myCommunities.Contains).ToHashSet();
                if (_selectedCommunities.Any())
                {
                    var ids = new HashSet<Guid>();
                    foreach (var name in _selectedCommunities)
                        ids.UnionWith((await Mediator.Send(new GetCommunityQuery(Name.From(name)))).MemberIds);
                    onlyUserIds = ids.ToList();
                }
            }

            var density = await UiSettings.GetSetting(DensityKey);
            if (Enum.TryParse<UiDensity>(density, out var d)) _density = d;
        }

        // The not-yet-featured pool is its own focused view.
        if (Pool == "1")
        {
            var already = (await Mediator.Send(new GetAlreadyPlayedWeeklyChartsQuery(_mix))).ToHashSet();
            _pool = _charts.Values
                .Where(c => (c.Type == ChartType.CoOp || (int)c.Level >= 10) && !already.Contains(c.Id))
                .ToArray();
            return;
        }

        _board = await Mediator.Send(new GetWeeklyBoardQuery(_mix, _weekStart, _userId, onlyUserIds));
        _monthly = await Mediator.Send(new GetMonthlyLeaderboardQuery(_mix, _weekStart, _type, onlyUserIds));

        if (_board.IsLive)
        {
            _daily = await Mediator.Send(new GetDailyStepBoardQuery(_mix, _userId));
            if (_daily != null)
            {
                _dailyChart = _charts.GetValueOrDefault(_daily.Board.ChartId);
                _dailyResetsIn = ResetsIn(_daily.Board.ExpirationDate);
            }

            if (_userId != null)
            {
                _history = (await Mediator.Send(new GetUserDailyStepHistoryQuery(_userId.Value, _mix, 14)))
                    .ToArray();
            }
        }

        BuildDerived();
    }

    private void BuildDerived()
    {
        // Suggested-only is the default for calibrated players; the escape is ?suggested=all.
        var showAll = Suggested == "all" || !_board.SuggestionsAvailable || !_isLoggedIn;
        _showingSuggestedOnly = !showAll;
        _shownSummaries = showAll
            ? _board.Charts
            : _board.Charts.Where(c => c.IsSuggested).ToList();
        _suggestedToggleHref = BuildHref(suggestedAll: _showingSuggestedOnly);

        _playedCount = _board.Charts.Count(c => c.MyRow != null);
        _suggestedLeft = _board.Charts.Count(c => c.IsSuggested && c.MyRow == null);
        _monthlyPlace = _monthly.Rows.FirstOrDefault(r => r.Player?.Id == _userId)?.Place;

        _rotationText = _board.IsLive
            ? L["{0} charts · rotates Monday midnight ET", _board.Charts.Count]
            : L["week of {0}", WeekLabel(_weekStart!.Value)];

        _monthlyBasePath = _weekStart == null ? "/WeeklyCharts" : $"/WeeklyCharts?week={Week}";
        _monthlySubtitle = _monthly.Rows.Any()
            ? L["Week {0} — best {1} count · PUMBILITY", _monthly.WeekInMonth, _monthly.CountedPerPlayer]
            : "PUMBILITY";

        BuildJsonLd();
    }

    // A JSON-LD ItemList of the week's charts, rendered in the body (the meta/OG head lives in
    // StaticHeadResolver). Serialized with the default encoder, which escapes '<' — so a song
    // name can never break out of the <script> block.
    private void BuildJsonLd()
    {
        var pos = 1;
        var items = new List<object>();
        foreach (var summary in _board.Charts)
        {
            var chart = _charts.GetValueOrDefault(summary.ChartId);
            if (chart == null) continue;
            items.Add(new Dictionary<string, object?>
            {
                ["@type"] = "ListItem",
                ["position"] = pos++,
                ["url"] = NavManager.ToAbsoluteUri($"/Chart/{chart.Id}").ToString(),
                ["name"] = chart.Song.Name.ToString()
            });
        }

        if (items.Count > 0)
        {
            _jsonLd = JsonSerializer.Serialize(new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "ItemList",
                ["name"] = L["Weekly Charts"].Value,
                ["itemListElement"] = items
            });
        }
    }

    // Rebuilds the current URL toggling the suggested filter, preserving week + type.
    private string BuildHref(bool suggestedAll)
    {
        var q = new List<string>();
        if (_weekStart != null) q.Add($"week={Week}");
        if (_type != null) q.Add($"type={_type}");
        if (suggestedAll) q.Add("suggested=all");
        return "/WeeklyCharts" + (q.Any() ? "?" + string.Join("&", q) : "");
    }

    private string WeekLabel(DateTimeOffset rotationDate) =>
        (rotationDate - TimeSpan.FromDays(7)).ToString("MMM d");

    private string? ResetsIn(DateTimeOffset expiration)
    {
        var span = expiration - _now;
        if (span <= TimeSpan.Zero) return null;
        if (span.TotalDays >= 1) return L["{0}d {1}h", (int)span.TotalDays, span.Hours];
        if (span.TotalHours >= 1) return L["{0}h {1}m", (int)span.TotalHours, span.Minutes];
        return L["{0}m", Math.Max(1, span.Minutes)];
    }
}
