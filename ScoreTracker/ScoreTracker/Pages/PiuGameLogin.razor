@page "/PiuGameLogin"
@using System.Web
@using ScoreTracker.Domain.SecondaryPorts

<PageTitle>@L["PIUGAME Login"]</PageTitle>

<MudPaper Class="align-center" Elevation="0" MaxWidth="500px">
    <MudContainer Fixed="true">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h4" Color="Color.Primary">@L["PIUGAME Login"]</MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (_error != null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@L[_error]</MudAlert>
                }
                <MudAlert Severity="Severity.Info" Class="mb-4">@L["Your username and password are sent directly to piugame.com and are never stored"]</MudAlert>
                <form method="post" action="/Login/PiuGame">
                    <MudTextField T="string" Label="@L["PIUGame.com Username"].Value" Disabled="_isSubmitting" UserAttributes="@UsernameAttributes"></MudTextField>
                    <MudTextField T="string" InputType="InputType.Password" Label="@L["PIUGame.com Password"].Value" Disabled="_isSubmitting" UserAttributes="@PasswordAttributes"></MudTextField>
                    <input type="hidden" name="returnUrl" value="@_returnUrl"/>
                    @* OnClick only flips the working indicator — the browser's default submit
                       fires synchronously on click, before the circuit re-renders the disabled
                       state, so the POST is never blocked. *@
                    <MudButton ButtonType="ButtonType.Submit" HtmlTag="button" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" FullWidth="true"
                               Disabled="_isSubmitting" OnClick="() => _isSubmitting = true">
                        @if (_isSubmitting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"></MudProgressCircular>
                        }
                        @L["Log In"]
                    </MudButton>
                </form>
            </MudCardContent>
        </MudCard>
    </MudContainer>
</MudPaper>

@inject NavigationManager NavManager
@code {
    private string? _error;
    private string _returnUrl = "/";
    private bool _isSubmitting = false;

    private static readonly Dictionary<string, object> UsernameAttributes = new()
    {
        { "name", "username" },
        { "autocomplete", "username" }
    };

    private static readonly Dictionary<string, object> PasswordAttributes = new()
    {
        { "name", "password" },
        { "autocomplete", "current-password" }
    };

    protected override void OnInitialized()
    {
        var query = HttpUtility.ParseQueryString(new Uri(NavManager.Uri).Query);
        _error = query.Get("error") switch
        {
            "Invalid" => "Invalid username or password",
            "NoGameAccount" => "Your account is not associated with a game profile yet. Play a game on your account first, then try again.",
            "Unavailable" => "Could not reach PIUGAME, try again later",
            _ => null
        };
        _returnUrl = query.Get("returnUrl") ?? "/";
    }
}
