@page "/Dev/Populate"
@using MediatR
@using Microsoft.Extensions.Options
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Web.Configuration
@using ScoreTracker.Web.Services.Contracts

<PageTitle>Set Up Local Database</PageTitle>

@* Dev-only: gated on the same flag as the login backdoor, which only the local Aspire
   AppHost sets. In any other environment this page bounces straight to home. *@
@if (!DevAuth.Value.Enabled)
{
    return;
}

<MudPaper Class="align-center" Elevation="0" MaxWidth="640px">
    <MudContainer Fixed="true">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h5">Hey, you're on an empty database.</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-4">
                    Let's get you set up. Here's what we're about to do:
                </MudText>

                <MudList T="string" Dense="true">
                    <MudListItem Icon="@(CurrentUser.IsLoggedIn ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Circle)"
                                 IconColor="@(CurrentUser.IsLoggedIn ? Color.Success : Color.Default)">
                        <b>Sign in</b>
                        @if (!CurrentUser.IsLoggedIn)
                        {
                            <MudText Typo="Typo.body2">Use the Dev Login card to create a local user.</MudText>
                            <MudButton Href="/Login" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="mt-1">Go to Login</MudButton>
                        }
                    </MudListItem>
                    <MudListItem Icon="@(_hasToken ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Circle)"
                                 IconColor="@(_hasToken ? Color.Success : Color.Default)">
                        <b>Paste your production API token</b>
                        <MudText Typo="Typo.body2">From your Account page on the live site. Used read-only, saved in your local database.</MudText>
                        <MudTextField T="string" @bind-Value="_token" Label="Prod API token"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-1"
                                      Disabled="@(!CurrentUser.IsLoggedIn)"
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Save"
                                      OnAdornmentClick="SaveToken"/>
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Outlined.Circle">
                        <b>Populate from production</b>
                        <MudText Typo="Typo.body2">Charts and songs, then your scores, then tier lists — pulled from @ProdSync.Value.BaseUrl.</MudText>
                        <MudTooltip Text="The importer is the next piece of the dev-harness track — this button goes live when it lands.">
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Class="mt-1" Disabled="true">Populate</MudButton>
                        </MudTooltip>
                    </MudListItem>
                </MudList>
            </MudCardContent>
        </MudCard>
    </MudContainer>
</MudPaper>

@inject IMediator Mediator
@inject ICurrentUserAccessor CurrentUser
@inject IUiSettingsAccessor UiSettings
@inject IOptions<DevAuthConfiguration> DevAuth
@inject IOptions<ProdSyncConfiguration> ProdSync
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@code {
    private const string TokenSettingKey = "DevHarness__ProdApiToken";
    private string _token = string.Empty;
    private bool _hasToken;

    protected override async Task OnInitializedAsync()
    {
        if (!DevAuth.Value.Enabled)
        {
            NavManager.NavigateTo("/");
            return;
        }

        if (CurrentUser.IsLoggedIn)
        {
            _token = await UiSettings.GetSetting(TokenSettingKey) ?? string.Empty;
            _hasToken = !string.IsNullOrWhiteSpace(_token);
        }
    }

    private async Task SaveToken()
    {
        await UiSettings.SetSetting(TokenSettingKey, _token);
        _hasToken = !string.IsNullOrWhiteSpace(_token);
        Snackbar.Add(_hasToken ? "Token saved." : "Token cleared.", Severity.Success);
    }
}
