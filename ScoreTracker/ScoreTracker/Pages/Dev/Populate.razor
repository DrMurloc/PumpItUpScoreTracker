@page "/Dev/Populate"
@rendermode RenderModes.Interactive
@using MediatR
@using Microsoft.Extensions.Options
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.Domain.Models
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.Identity.Contracts.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Web.Configuration
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Data.Configuration

<PageTitle>Set Up Local Database</PageTitle>

@* Dev-only: gated on the same flag as the login backdoor, which only the local Aspire
   AppHost sets. In any other environment this page bounces straight to home. *@
@if (!DevAuth.Value.Enabled)
{
    return;
}

<MudPaper Class="align-center" Elevation="0" MaxWidth="640px">
    <MudContainer Fixed="true">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h5">Hey, you're on an empty database.</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-4">
                    Let's get you set up. Here's what we're about to do:
                </MudText>

                <MudList T="string" Dense="true">
                    <MudListItem Icon="@(CurrentUser.IsLoggedIn ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Circle)"
                                 IconColor="@(CurrentUser.IsLoggedIn ? Color.Success : Color.Default)">
                        <b>Sign in</b>
                        @if (!CurrentUser.IsLoggedIn)
                        {
                            <div class="mt-1 d-flex flex-wrap gap-2 align-center">
                                @if (_discordConfigured)
                                {
                                    <MudButton Href="/Login/Discord" StartIcon="@Icons.Custom.Brands.Discord" Size="Size.Small" Variant="Variant.Filled" Style="@($"color:{Colors.Gray.Lighten5};background:{Colors.Indigo.Default};")">Discord</MudButton>
                                }
                                @if (_googleConfigured)
                                {
                                    <MudButton Href="/Login/Google" StartIcon="@Icons.Custom.Brands.Google" Size="Size.Small" Variant="Variant.Filled" Style="@($"color:{Colors.Gray.Lighten5};background:{Colors.Orange.Darken3};")">Google</MudButton>
                                }
                                <form method="post" action="/Login/Dev/Bootstrap" style="display:inline">
                                    <MudButton ButtonType="ButtonType.Submit" Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning">
                                        Create Dev User &amp; Sign In
                                    </MudButton>
                                </form>
                            </div>
                            @if (_hasAnyUsers)
                            {
                                <form method="post" action="/Login/Dev" class="mt-2">
                                    <div class="d-flex gap-2 align-center">
                                        <MudAutocomplete T="User"
                                                         Label="…or sign in as an existing user"
                                                         SearchFunc="SearchUsers"
                                                         ToStringFunc="@(u => u?.Name.ToString() ?? "")"
                                                         Value="_selectedUser"
                                                         ValueChanged="@(u => _selectedUser = u)"
                                                         DebounceInterval="500"
                                                         ResetValueOnEmptyText="true"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"/>
                                        <input type="hidden" name="userId" value="@(_selectedUser?.Id.ToString())"/>
                                        <MudButton ButtonType="ButtonType.Submit" Disabled="@(_selectedUser == null)"
                                                   Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">
                                            Sign In
                                        </MudButton>
                                    </div>
                                </form>
                            }
                        }
                    </MudListItem>
                    <MudListItem Icon="@(HasToken ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Circle)"
                                 IconColor="@(HasToken ? Color.Success : Color.Default)">
                        <b>Paste your API token</b>
                        <MudText Typo="Typo.body2">From your <MudLink Href="@($"{ProdSync.Value.BaseUrl}/Account")" Target="_blank">Account page</MudLink> on @ProdSync.Value.BaseUrl. Used read-only; saved to your local database when you run the import.</MudText>
                        <MudTextField T="string" @bind-Value="_token" Label="API token"
                                      InputType="InputType.Password"
                                      Immediate="true"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-1"
                                      Disabled="@(!CurrentUser.IsLoggedIn)"/>
                    </MudListItem>
                    <MudListItem Icon="@(_syncComplete ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Circle)"
                                 IconColor="@(_syncComplete ? Color.Success : Color.Default)">
                        <b>Populate the database</b>
                        <MudText Typo="Typo.body2">Charts and songs, then your scores, then tier lists — pulled from @ProdSync.Value.BaseUrl.</MudText>
                        <div class="mt-1 d-flex gap-3 align-center">
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                       Disabled="@(!CurrentUser.IsLoggedIn || !HasToken || _isSyncing)"
                                       OnClick="RunSync">
                                Populate
                            </MudButton>
                            @if (_isSyncing)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary"/>
                            }
                            @if (!string.IsNullOrWhiteSpace(_progress))
                            {
                                <MudText Typo="Typo.body2">@_progress</MudText>
                            }
                        </div>
                        @if (_syncComplete)
                        {
                            <MudButton Href="/" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" Class="mt-2">You're set — go play</MudButton>
                        }
                    </MudListItem>
                </MudList>
            </MudCardContent>
        </MudCard>
    </MudContainer>
</MudPaper>

@inject IMediator Mediator
@inject ICurrentUserAccessor CurrentUser
@inject IUiSettingsAccessor UiSettings
@inject IOptions<DevAuthConfiguration> DevAuth
@inject IOptions<ProdSyncConfiguration> ProdSync
@inject IOptions<DiscordConfiguration> Discord
@inject IOptions<GoogleConfiguration> Google
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject ScoreTracker.Web.Services.DevSyncService Sync
@code {
    private const string TokenSettingKey = "DevHarness__ProdApiToken";
    private string _token = string.Empty;
    private bool _hasAnyUsers;
    private bool _discordConfigured;
    private bool _googleConfigured;
    private User? _selectedUser;
    private bool _isSyncing;
    private bool _syncComplete;
    private string _progress = string.Empty;
    private bool HasToken => !string.IsNullOrWhiteSpace(_token);

    protected override async Task OnInitializedAsync()
    {
        if (!DevAuth.Value.Enabled)
        {
            NavManager.NavigateTo("/");
            return;
        }

        _discordConfigured = !string.IsNullOrWhiteSpace(Discord.Value.ClientId);
        _googleConfigured = !string.IsNullOrWhiteSpace(Google.Value.ClientId);

        if (CurrentUser.IsLoggedIn)
        {
            _token = await UiSettings.GetSetting(TokenSettingKey) ?? string.Empty;
        }
        else
        {
            _hasAnyUsers = (await Mediator.Send(new SearchForUsersQuery("", 1, 1))).Total > 0;
        }
    }

    private async Task<IEnumerable<User>> SearchUsers(string? query, CancellationToken cancellationToken)
    {
        var results = await Mediator.Send(new SearchForUsersQuery(query ?? "", 1, 50), cancellationToken);
        return results.Results;
    }

    private async Task RunSync()
    {
        _isSyncing = true;
        _syncComplete = false;
        try
        {
            await UiSettings.SetSetting(TokenSettingKey, _token);
            await Sync.Sync(_token, CurrentUser.User.Id,
                message => InvokeAsync(() =>
                {
                    _progress = message;
                    StateHasChanged();
                }));
            _syncComplete = true;
        }
        catch (Exception e)
        {
            _progress = $"Sync failed: {e.Message}";
            Snackbar.Add("Sync failed — check the token and that the site is reachable.", Severity.Error);
        }
        finally
        {
            _isSyncing = false;
        }
    }
}
