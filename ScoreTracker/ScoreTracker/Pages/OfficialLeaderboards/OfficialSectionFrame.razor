@namespace ScoreTracker.Web.Pages.OfficialLeaderboards
@using MediatR
@using ScoreTracker.OfficialMirror.Contracts
@using ScoreTracker.OfficialMirror.Contracts.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Web.Services.Contracts
@inject IMediator Mediator
@inject IUiSettingsAccessor UiSettings

@* The Official Leaderboards section chrome, shared by every page in the section:
   title, import-health strip, the page nav, and the mix/chart context the views
   consume. Each page is its own route and circuit — the nav links are real
   document loads, which is the site's post-flip navigation model anyway. *@

<PageTitle>@L[ActiveLabel] · @L["Official Leaderboards"]</PageTitle>

<style>
    .olb-subtitle { color: var(--mix-ink-muted); }

    .olb-health {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        padding: 2px 10px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid var(--mix-surface-muted);
        color: var(--mix-ink-muted);
    }

    .olb-health.failed { color: var(--mix-accent); border-color: var(--mix-accent); }

    .olb-section-nav {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    .olb-folder-first {
        border: 1px solid var(--plate-pg);
        border-radius: 10px;
        box-shadow: 0 0 14px var(--mix-glow);
    }

    .olb-delta-up { color: var(--mix-primary); font-weight: 700; }

    .olb-delta-down { color: var(--mix-accent); font-weight: 700; }

    .olb-delta-flat { color: var(--mix-ink-muted); }

    .olb-spark polyline {
        fill: none;
        stroke: var(--mix-secondary);
        stroke-width: 1.6;
    }

    .olb-spark circle { fill: var(--mix-secondary); }

    .olb-mover-lead { background: color-mix(in srgb, var(--mix-primary) 8%, transparent); border-radius: 9px; }

    /* Rankings and chart boards render as compact card rows, never tables — a phone
       reads rank, player, and rating with zero side-scrolling (UX rule: tabular
       collections lean compact). */
    .olb-rank-card, .olb-board-row {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 8px;
        border-bottom: 1px solid color-mix(in srgb, var(--mix-ink) 12%, transparent);
        flex-wrap: wrap;
    }

    .olb-rank-rankbox { min-width: 52px; display: inline-flex; align-items: center; gap: 4px; }

    /* Mud chips ship 4px of margin — inside a row that is already budgeting every
       pixel, that reads as a misalignment rather than as spacing. */
    .olb-rank-card .mud-chip { margin: 0; }

    .olb-board-place { min-width: 40px; font-weight: 700; }

    .olb-rank-tail {
        margin-left: auto; flex: 0 0 auto;
        display: flex; align-items: center; justify-content: flex-end; gap: 8px;
    }

    .olb-rank-expand { padding: 4px 0 10px; }

    /* Board tags run long (LIKEASLAM01#8073). Lists print the human half — the digits
       identify an account, they don't name anyone — and truncate what's still too long;
       the full tag stays in the row's tooltip and on the player's own page. */
    .olb-player-name {
        max-width: 22ch;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* World firsts: the chart banner leads, the claimant closes. */
    .olb-first-row {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px;
        flex-wrap: wrap;
    }

    .olb-chartlink { display: inline-flex; align-items: center; gap: 8px; min-width: 0; }

    .olb-first-tail {
        margin-left: auto; flex: 0 0 auto;
        display: flex; align-items: center; justify-content: flex-end; gap: 8px;
    }

    /* A frozen header keeps the grade columns labelled down the full ladder. */
    .olb-tier-table thead th {
        position: sticky;
        top: 0;
        z-index: 3;
        background: var(--mix-surface);
    }

    /* The leaderboard skin for the collections that need real table semantics
       (sortable columns): same flat surface, hairlines, and row rhythm as the
       rankings cards — the section's one leaderboard look. */
    .olb-board-table.mud-table { background: transparent; }

    .olb-board-table .mud-table-cell {
        border-bottom: 1px solid color-mix(in srgb, var(--mix-ink) 12%, transparent);
        padding: 4px 8px;
    }

    .olb-board-table .mud-table-head .mud-table-cell {
        color: var(--mix-ink-muted);
        font-size: 11.5px;
        letter-spacing: .4px;
        text-transform: uppercase;
    }

    .olb-board-table .mud-table-body .mud-table-row:hover .mud-table-cell {
        background: color-mix(in srgb, var(--mix-ink) 5%, transparent);
    }

    /* Row glow: the dashboard vocabulary — you blue, your opt-in crews green. */
    .olb-row-me {
        background: color-mix(in srgb, var(--daily-you) 15%, transparent);
        box-shadow: inset 0 0 0 1.5px var(--daily-you);
        border-radius: 6px;
    }

    .olb-row-community {
        background: color-mix(in srgb, var(--daily-community) 13%, transparent);
        box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--daily-community) 60%, transparent);
        border-radius: 6px;
    }

    /* Two tiers. Narrow (≤760): the row identifier pins while the rest side-scrolls,
       optional columns and song titles step aside, names truncate. Phone (≤500): the
       row is a width budget, so padding tightens and value/context pairs stack — above
       that they stay inline, where stacking would just leave a hole. */
    @@media (max-width: 760px) {
        .olb-hide-mobile { display: none !important; }

        .olb-song-text { display: none; }

        .olb-player-name { max-width: 16ch; }

        .olb-sticky-first td:first-child, .olb-sticky-first th:first-child {
            position: sticky;
            left: 0;
            z-index: 2;
            background: var(--mix-surface);
            max-width: 200px;
            overflow: hidden;
        }

        .olb-sticky-first td:first-child .mud-typography {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .olb-pager-tight .mud-table-pagination { padding-inline: 2px; }

        .olb-pager-tight .mud-table-pagination-caption { font-size: 11px; margin: 0 4px; }
    }

    @@media (max-width: 500px) {
        .olb-rank-card, .olb-board-row { gap: 5px; padding: 3px 4px; }

        .olb-rank-rankbox { min-width: 42px; }

        .olb-rank-card .mud-chip {
            height: 20px;
            padding: 0 7px;
            font-size: 10.5px;
        }

        .olb-rank-card .mud-icon-button { padding: 2px; }

        .olb-first-tail, .olb-hero-listtail, .olb-rank-tail {
            flex-direction: column;
            align-items: flex-end;
            gap: 0;
        }
    }

</style>

<MudText Typo="Typo.h4">@L["Official Leaderboards"]</MudText>
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1 flex-wrap">
    <MudText Typo="Typo.body2" Class="olb-subtitle">
        @L["Last Updated"] · @(_lastImported?.ToLocalTime().ToString("g") ?? "—")
    </MudText>
    @if (_latestRun != null && _latestRun.CompletedAt == null && _latestRun.Error != null)
    {
        <MudTooltip Text="@_latestRun.Error">
            <span class="olb-health failed">⚠ @L["Last import failed"] · @_latestRun.Stage</span>
        </MudTooltip>
    }
</MudStack>

<nav class="olb-section-nav" aria-label="@L["Official Leaderboards"]">
    @foreach (var (key, href, label) in Links)
    {
        <MudButton Href="@href" Size="Size.Small" Color="Color.Primary"
                   Variant="@(key == Active ? Variant.Filled : Variant.Outlined)">
            @L[label]
        </MudButton>
    }
</nav>

<div class="pt-4">
    @if (_loaded)
    {
        @Body(new SectionContext(_mix, _charts))
    }
    else
    {
        <MudSkeleton Height="400px" SkeletonType="SkeletonType.Rectangle"/>
    }
</div>

@code {
    public sealed record SectionContext(MixEnum Mix, IDictionary<Guid, Chart> Charts);

    private static readonly (string Key, string Href, string Label)[] Links =
    {
        ("week", "/OfficialLeaderboards", "This Week"),
        ("rankings", "/OfficialLeaderboards/Rankings", "Rankings"),
        ("players", "/OfficialLeaderboards/Players", "Players"),
        ("popularity", "/OfficialLeaderboards/Popularity", "Popularity"),
        ("takes", "/OfficialLeaderboards/WhatItTakes", "What It Takes")
    };

    [Parameter] [EditorRequired] public string Active { get; set; } = "week";

    [Parameter] [EditorRequired] public RenderFragment<SectionContext> Body { get; set; } = null!;

    // The What It Takes view reads only rating boards — skipping the chart pull there
    // keeps that page's circuit start light.
    [Parameter] public bool RequiresCharts { get; set; } = true;

    private bool _loaded;
    private MixEnum _mix = MixEnum.Phoenix2;
    private DateTimeOffset? _lastImported;
    private ImportRunRecord? _latestRun;
    private IDictionary<Guid, Chart> _charts = new Dictionary<Guid, Chart>();

    private string ActiveLabel => Links.First(l => l.Key == Active).Label;

    protected override async Task OnInitializedAsync()
    {
        _mix = await UiSettings.GetSelectedMix();
        if (_mix == MixEnum.XX) _mix = MixEnum.Phoenix;

        _lastImported = await Mediator.Send(new GetLastLeaderboardImportTimestampQuery(_mix));
        _latestRun = (await Mediator.Send(new GetImportRunsQuery(_mix, 1))).FirstOrDefault();
        if (RequiresCharts)
            _charts = (await Mediator.Send(new ScoreTracker.Catalog.Contracts.Queries.GetChartsQuery(_mix)))
                .ToDictionary(c => c.Id);
        _loaded = true;
    }
}
