    private async Task SelectSort(ChartSearchSort sort, bool forceDefaultDirection = false)
    {
        if (sort == _sort && !forceDefaultDirection)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sort = sort;
            _sortDescending = DefaultDescending(sort);
        }

        await ApplyChange();
    }

    private bool IsDefaultSort => _sort == ChartSearchSort.Level && _sortDescending;

    private static bool DefaultDescending(ChartSearchSort sort)
    {
        return sort switch
        {
            ChartSearchSort.Name => false,
            ChartSearchSort.Duration => false,
            ChartSearchSort.DebutEra => false,
            _ => true
        };
    }

