        || _debutMixes.Count > 0 || _availableIn != null || _notAvailableIn != null
        || _reratedUp || _reratedDown || _legacySlots.Count > 0
        || _passDifficulty.Count > 0 || _scoreDifficulty.Count > 0 || _communityVote.Count > 0
        || _passRateMin != null || _scoringLevelMin != null || _scoringLevelMax != null
        || _phoenixGradeMin != null || _phoenixPlateMin != null
        || _phoenixScoreMin != null || _phoenixScoreMax != null || _legacyGradeMin != null
        || _recordedFrom != null || _recordedTo != null
