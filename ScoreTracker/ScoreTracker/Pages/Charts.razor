@page "/Charts"
@rendermode RenderModes.Interactive
@using MediatR
@using ScoreTracker.Application.Commands
@using ScoreTracker.Application.Queries
@using ScoreTracker.Catalog.Contracts
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.OfficialMirror.Contracts.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Enums
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Web.Services.Theming
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType
<PageTitle>@L["Charts"]</PageTitle>

@* The SRP page stack (docs/design/charts-srp.md): page header with the scope mode, then
   the query as one chip language, then the answer line (count + controls), then results.
   No search input — Song name contains is a drawer filter; filters live behind the funnel. *@
<div class="srp-head">
    <MudText Typo="Typo.h4" Class="srp-title">@L["Charts"]</MudText>
    <MudButtonGroup OverrideStyles="false" Class="srp-scope">
        <MudButton Variant="@(!_allMixes ? Variant.Filled : Variant.Outlined)"
                   Color="@(!_allMixes ? Color.Primary : Color.Default)"
                   OnClick="() => SetScope(false)">@_mix.GetName()</MudButton>
        <MudButton Variant="@(_allMixes ? Variant.Filled : Variant.Outlined)"
                   Color="@(_allMixes ? Color.Primary : Color.Default)"
                   OnClick="() => SetScope(true)">@L["All Mixes"]</MudButton>
    </MudButtonGroup>
</div>

<div class="srp-chip-row" role="list" aria-label="@L["Applied filters"]">
    @foreach (var chip in QueryChips)
    {
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                 Class="@(chip.IsSort ? "srp-chip srp-chip-sort" : "srp-chip")"
                 OnClose="() => chip.Remove()" CloseIcon="@Icons.Material.Filled.Close">@chip.Label</MudChip>
    }
    @if (QueryChips.Count >= 2)
    {
        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearAllFilters">@L["Clear all"]</MudButton>
    }
</div>

<div class="srp-answer">
    <MudText Typo="Typo.subtitle1" Class="srp-count">
        @if (_isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary"></MudProgressCircular>
        }
        else
        {
            @L["{0} charts", _totalCount.ToString("N0")]
        }
    </MudText>
    <MudSpacer></MudSpacer>
    <MudTooltip Text="@L["Export CSV"]">
        <MudIconButton Icon="@Icons.Material.Filled.Download" OnClick="() => _exportOpen = true"
                       aria-label="@L["Export CSV"]"></MudIconButton>
    </MudTooltip>
    <MudButtonGroup OverrideStyles="false">
        <MudTooltip Text="@L["Comfortable"]">
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.ViewComfy"
                           Color="@(_density == UiDensity.Comfortable ? Color.Primary : Color.Default)"
                           OnClick="() => SetDensity(UiDensity.Comfortable)" aria-label="@L["Comfortable"]"></MudIconButton>
        </MudTooltip>
        <MudTooltip Text="@L["Compact"]">
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.GridView"
                           Color="@(_density == UiDensity.Compact ? Color.Primary : Color.Default)"
                           OnClick="() => SetDensity(UiDensity.Compact)" aria-label="@L["Compact"]"></MudIconButton>
        </MudTooltip>
        <MudTooltip Text="@L["Table"]">
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.TableRows"
                           Color="@(_density == UiDensity.Table ? Color.Primary : Color.Default)"
                           OnClick="() => SetDensity(UiDensity.Table)" aria-label="@L["Table"]"></MudIconButton>
        </MudTooltip>
    </MudButtonGroup>
    <MudTooltip Text="@L["Sort by"]">
        <MudMenu Icon="@Icons.Material.Filled.SwapVert" Dense="true" AriaLabel="@L["Sort by"]">
            @foreach (var sort in AvailableSorts)
            {
                <MudMenuItem Icon="@(sort == _sort ? (_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward) : string.Empty)"
                             OnClick="() => SelectSort(sort)">@L[SortName(sort)]</MudMenuItem>
            }
        </MudMenu>
    </MudTooltip>
    <MudTooltip Text="@L["Filters"]">
        <MudBadge Content="ActiveFilterCount" Visible="ActiveFilterCount > 0" Color="Color.Primary" Overlap="true">
            <MudIconButton Icon="@Icons.Material.Filled.FilterList" Color="Color.Primary" Variant="Variant.Outlined"
                           OnClick="OpenFilters" aria-label="@L["Filters"]"></MudIconButton>
        </MudBadge>
    </MudTooltip>
</div>

@if (!_isLoading && _totalCount == 0)
{
    <div class="srp-empty">
        <MudText Typo="Typo.h6">@L["No charts match these filters"]</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ClearAllFilters">@L["Clear all"]</MudButton>
    </div>
}
else
{
    @if (_density == UiDensity.Compact)
    {
        @* The tier lists' own compact grid — the tiles size from the container, so reusing
           the grid classes is what makes the sticker sheet a sticker sheet. *@
        <div class="tier-card-grid tier-card-grid-compact">
            @foreach (var result in _results)
            {
                <ChartSearchSticker Result="result" LeadFact="@LeadFact(result)"
                                    IsToDo="_todoCharts.Contains(result.Chart.Id)"></ChartSearchSticker>
            }
        </div>
    }
    else if (_density == UiDensity.Table)
    {
        <div class="tier-table-wrap">
            <table class="tier-table srp-table">
                <thead>
                <tr>
                    <th class="@SortableHeaderClass(ChartSearchSort.Level)" role="button" tabindex="0"
                        @onclick="() => SelectSort(ChartSearchSort.Level)">@L["Level"]@SortMark(ChartSearchSort.Level)</th>
                    <th class="@SortableHeaderClass(ChartSearchSort.Name)" role="button" tabindex="0"
                        @onclick="() => SelectSort(ChartSearchSort.Name)">@L["Chart"]@SortMark(ChartSearchSort.Name)</th>
                    <th>@L["Song Artist"]</th>
                    <th>@L["Skills"]</th>
                    <th>@L["Tier"]</th>
                    <th class="@SortableHeaderClass(ChartSearchSort.ScoringLevel)" role="button" tabindex="0"
                        @onclick="() => SelectSort(ChartSearchSort.ScoringLevel)">@L["Scoring level"]@SortMark(ChartSearchSort.ScoringLevel)</th>
                    <th class="@SortableHeaderClass(ChartSearchSort.Nps)" role="button" tabindex="0"
                        @onclick="() => SelectSort(ChartSearchSort.Nps)">@L["NPS"]@SortMark(ChartSearchSort.Nps)</th>
                    <th class="@SortableHeaderClass(ChartSearchSort.Bpm)" role="button" tabindex="0"
                        @onclick="() => SelectSort(ChartSearchSort.Bpm)">@L["BPM"]@SortMark(ChartSearchSort.Bpm)</th>
                    <th class="@SortableHeaderClass(ChartSearchSort.PassRate)" role="button" tabindex="0"
                        @onclick="() => SelectSort(ChartSearchSort.PassRate)">@L["Pass rate"]@SortMark(ChartSearchSort.PassRate)</th>
                    <th class="@SortableHeaderClass(ChartSearchSort.Popularity)" role="button" tabindex="0"
                        @onclick="() => SelectSort(ChartSearchSort.Popularity)">@L["Scores"]@SortMark(ChartSearchSort.Popularity)</th>
                    @if (_allMixes)
                    {
                        <th>@L["Mixes"]</th>
                        <th>@L["Level change"]</th>
                    }
                    @if (CurrentUser.IsLoggedIn)
                    {
                        <th class="@SortableHeaderClass(ChartSearchSort.MyGrade)" role="button" tabindex="0"
                            @onclick="() => SelectSort(ChartSearchSort.MyGrade)">@L["My score"]@SortMark(ChartSearchSort.MyGrade)</th>
                        <th>@L["Letter Grade"]</th>
                        <th>@L["Plate"]</th>
                    }
                </tr>
                </thead>
                <tbody>
                @foreach (var result in _results)
                {
                    <tr>
                        <td>
                            <DifficultyBubble Chart="result.Chart" Small="true"></DifficultyBubble>
                        </td>
                        <td>
                            <a class="srp-table-link" href="@ChartSlugs.CanonicalPath(result.Chart)">@result.Chart.Song.Name</a>
                        </td>
                        <td class="srp-table-muted">@result.Chart.Song.Artist</td>
                        <td class="srp-table-muted">@string.Join(", ", result.Badges.Select(b => L[b.DisplayName].ToString()))</td>
                        <td>
                            @if ((result.CommunityVote ?? result.PassDifficulty) is { } tier)
                            {
                                <span style="color:@ThemeScales.DifficultyColor(tier)">@L[ChartSearchCard.CategoryName(tier)]</span>
                            }
                        </td>
                        <td class="srp-table-num">@((result.Chart.Mix.UsesLegacyScoring() ? result.CommunityVoteRating : result.ScoringLevel)?.ToString("0.0"))</td>
                        <td class="srp-table-num">@result.Nps?.ToString("0.0")</td>
                        <td class="srp-table-num">@result.Chart.Song.Bpm?.ToString()</td>
                        <td class="srp-table-num">
                            @if (result.ScoreCount >= 10)
                            {
                                @((result.PassCount * 100 / result.ScoreCount))@:%
                            }
                        </td>
                        <td class="srp-table-num">@result.ScoreCount</td>
                        @if (_allMixes)
                        {
                            <td class="srp-table-num">@result.Appearances.Count</td>
                            <td class="srp-table-num">
                                @if (result.LevelChange is not null and not 0)
                                {
                                    <span class="@(result.LevelChange > 0 ? "srp-rerate-up" : "srp-rerate-down")">@(result.LevelChange > 0 ? "+" : "")@result.LevelChange</span>
                                }
                            </td>
                        }
                        @if (CurrentUser.IsLoggedIn)
                        {
                            <td class="srp-table-num">@((result.My?.PhoenixScore ?? result.My?.LegacyScore)?.ToString("N0"))</td>
                            <td>
                                @if (result.My?.PhoenixGrade != null)
                                {
                                    <LetterGradeIcon Grade="result.My.PhoenixGrade" IsBroken="result.My.IsBroken" Height="16"></LetterGradeIcon>
                                }
                                else if (result.My?.LegacyGrade != null)
                                {
                                    @result.My.LegacyGrade@(result.My.IsBroken ? " ⨯" : "")
                                }
                            </td>
                            <td>@result.My?.PhoenixPlate?.GetShorthand()</td>
                        }
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="srp-grid">
            @foreach (var result in _results)
            {
                <ChartSearchCard Result="result" LeadFact="@LeadFact(result)"
                                 ShowMyState="CurrentUser.IsLoggedIn"
                                 ShowActions="CurrentUser.IsLoggedIn"
                                 ShowStepArtist="_showStepArtist"
                                 ShowNoteCount="_showNoteCount"
                                 IsFavorite="_favoriteCharts.Contains(result.Chart.Id)"
                                 IsToDo="_todoCharts.Contains(result.Chart.Id)"
                                 OnToggleFavorite="ToggleFavorite"
                                 OnToggleToDo="ToggleToDo"
                                 OnQuickRecord="OpenQuickRecord"
                                 OfficialPlace="OfficialPlace(result)"></ChartSearchCard>
            }
        </div>
    }
    @if (PageCount > 1)
    {
        <div class="srp-pager">
            <MudPagination Count="PageCount" Selected="_pageNumber" SelectedChanged="GoToPage"
                           Color="Color.Primary" Size="Size.Small"></MudPagination>
        </div>
    }
}

<ChartsExportDialog @bind-Visible="_exportOpen" FilterParameters="QueryParameters()" TotalCount="_totalCount"
                    Mix="_mix" AllMixes="_allMixes" SignedIn="CurrentUser.IsLoggedIn"></ChartsExportDialog>

<ChartQuickRecordDialog @bind-Visible="_quickRecordOpen" Target="_quickRecordTarget"
                        OnSaved="OnQuickRecordSaved"></ChartQuickRecordDialog>

<MudLayout>
    <MudDrawer @bind-Open="_filtersOpen" Anchor="Anchor.Right" Variant="@DrawerVariant.Temporary" Width="420px">
        <div class="srp-drawer">
            <div class="srp-drawer-head">
                <MudText Typo="Typo.h6">@L["Filters"]</MudText>
                <MudSpacer></MudSpacer>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => _filtersOpen = false"
                               aria-label="@L["Close"]"></MudIconButton>
            </div>

            @* The basics carry the everyday query — level, type, score state, a name. The long
               tail opts in below, so opening the drawer isn't a wall of chips. *@
            <MudTextField T="string" Value="_songNameContains" ValueChanged="SetSongNameContains"
                          Label="@L["Song name contains"]" Clearable="true"
                          Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>

            <div class="srp-facet">
                <div class="srp-facet-head">@L["Level"] <span class="srp-facet-value">@LevelRangeLabel</span></div>
                <MudRangeSlider T="int" Value="_levelMin ?? DifficultyLevel.Min"
                                UpperValue="_levelMax ?? DifficultyLevel.Max"
                                ValueChanged="SetLevelMin" UpperValueChanged="SetLevelMax"
                                Min="DifficultyLevel.Min" Max="DifficultyLevel.Max" Step="1"
                                Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
            </div>

            <div class="srp-facet">
                <div class="srp-facet-head">@L["Chart Type"]</div>
                <div class="srp-chipset">
                    @foreach (var type in Enum.GetValues<ChartType>())
                    {
                        var captured = type;
                        <span class="srp-facet-chip @(_types.Contains(captured) ? "srp-facet-chip-on" : "")"
                              role="button" tabindex="0" @onclick="() => ToggleType(captured)">
                            @L[TypeName(captured)]@CountSuffix(_facetCounts?.Types, captured)
                        </span>
                    }
                </div>
                @if (_types.Contains(ChartType.CoOp))
                {
                    <div class="srp-chipset srp-chipset-sub">
                        @foreach (var players in CoOpPlayerRange)
                        {
                            var captured = players;
                            <span class="srp-facet-chip @(_coOpPlayers.Contains(captured) ? "srp-facet-chip-on" : "")"
                                  role="button" tabindex="0" @onclick="() => ToggleCoOpPlayers(captured)">
                                ×@captured@CountSuffix(_facetCounts?.CoOpPlayerCounts, captured)
                            </span>
                        }
                    </div>
                }
            </div>

            @if (CurrentUser.IsLoggedIn)
            {
                <div class="srp-facet">
                    <div class="srp-facet-head">@L["Score State"]</div>
                    <div class="srp-chipset">
                        @foreach (var state in Enum.GetValues<ChartScoreStateFilter>())
                        {
                            var captured = state;
                            <span class="srp-facet-chip @(_scoreStates.Contains(captured) ? "srp-facet-chip-on" : "")"
                                  role="button" tabindex="0" @onclick="() => ToggleScoreState(captured)">
                                @L[ScoreStateName(captured)]@CountSuffix(_facetCounts?.ScoreStates, captured)
                            </span>
                        }
                    </div>
                </div>
            }

            <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
                       StartIcon="@(_moreFilters ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                       OnClick="ToggleMoreFilters">
                @(_moreFilters ? L["Fewer filters"] : L["More filters"])
            </MudButton>

            @if (_moreFilters)
            {
                <MudText Typo="Typo.overline">@L["Content"]</MudText>
                <div class="srp-facet">
                    <div class="srp-facet-head">@L["Song Type"]</div>
                    <div class="srp-chipset">
                        @foreach (var type in Enum.GetValues<SongType>())
                        {
                            var captured = type;
                            <span class="srp-facet-chip @(_songTypes.Contains(captured) ? "srp-facet-chip-on" : "")"
                                  role="button" tabindex="0" @onclick="() => ToggleSongType(captured)">
                                @L[SongTypeName(captured)]@CountSuffix(_facetCounts?.SongTypes, captured)
                            </span>
                        }
                    </div>
                </div>
                <MudAutocomplete T="string" Value="@null" ValueChanged="AddArtist" Label="@L["Song Artist"]"
                                 SearchFunc="SearchArtists" Clearable="true" CoerceText="false" CoerceValue="false"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" ResetValueOnEmptyText="true"></MudAutocomplete>
                <MudAutocomplete T="string" Value="@null" ValueChanged="AddStepArtist" Label="@L["Step Artist"]"
                                 SearchFunc="SearchStepArtists" Clearable="true" CoerceText="false" CoerceValue="false"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" ResetValueOnEmptyText="true"></MudAutocomplete>

                @if (_ranges?.BpmMin != null && _ranges.BpmMax != null && _ranges.BpmMax > _ranges.BpmMin)
                {
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["BPM"] <span class="srp-facet-value">@RangeLabel(_bpmMin, _bpmMax, _ranges.BpmMin, _ranges.BpmMax)</span></div>
                        <MudRangeSlider T="int" Value="(int)(_bpmMin ?? _ranges.BpmMin.Value)"
                                        UpperValue="(int)(_bpmMax ?? _ranges.BpmMax.Value)"
                                        ValueChanged="v => SetBpmMin(v)" UpperValueChanged="v => SetBpmMax(v)"
                                        Min="_ranges.BpmMin.Value" Max="_ranges.BpmMax.Value" Step="1"
                                        Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                    </div>
                }
                @if (_ranges?.NpsMin != null && _ranges.NpsMax != null && _ranges.NpsMax > _ranges.NpsMin)
                {
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["NPS"] <span class="srp-facet-value">@RangeLabel(_npsMin, _npsMax, _ranges.NpsMin, _ranges.NpsMax)</span></div>
                        <MudRangeSlider T="int" Value="(int)(_npsMin ?? _ranges.NpsMin.Value)"
                                        UpperValue="(int)(_npsMax ?? _ranges.NpsMax.Value)"
                                        ValueChanged="v => SetNpsMin(v)" UpperValueChanged="v => SetNpsMax(v)"
                                        Min="(int)_ranges.NpsMin.Value" Max="(int)_ranges.NpsMax.Value" Step="1"
                                        Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                    </div>
                }
                @if (_ranges?.NoteCountMin != null && _ranges.NoteCountMax != null && _ranges.NoteCountMax > _ranges.NoteCountMin)
                {
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["Note count"] <span class="srp-facet-value">@RangeLabel(_noteMin, _noteMax, _ranges.NoteCountMin, _ranges.NoteCountMax)</span></div>
                        <MudRangeSlider T="int" Value="_noteMin ?? _ranges.NoteCountMin.Value"
                                        UpperValue="_noteMax ?? _ranges.NoteCountMax.Value"
                                        ValueChanged="SetNoteMin" UpperValueChanged="SetNoteMax"
                                        Min="_ranges.NoteCountMin.Value" Max="_ranges.NoteCountMax.Value" Step="10"
                                        Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                    </div>
                }
                @if (_ranges?.DurationSecondsMin != null && _ranges.DurationSecondsMax != null
                     && _ranges.DurationSecondsMax > _ranges.DurationSecondsMin)
                {
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["Duration"] <span class="srp-facet-value">@DurationRangeLabel</span></div>
                        <MudRangeSlider T="int" Value="DurationSeconds(_durationMin) ?? _ranges.DurationSecondsMin.Value"
                                        UpperValue="DurationSeconds(_durationMax) ?? _ranges.DurationSecondsMax.Value"
                                        ValueChanged="SetDurationMin" UpperValueChanged="SetDurationMax"
                                        Min="_ranges.DurationSecondsMin.Value" Max="_ranges.DurationSecondsMax.Value" Step="5"
                                        Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                    </div>
                }

                <MudText Typo="Typo.overline">@L["Skills"] <span class="srp-drawer-sub">@L["highlighted only"]</span></MudText>
                <div class="srp-badge-cloud">
                    @foreach (var badge in _badgeVocabulary)
                    {
                        var selected = _badges.Contains(badge.Key, StringComparer.OrdinalIgnoreCase);
                        <span class="srp-badge-opt tier-chart-card-skill @(badge.Category == null ? "" : $"skillcat-{badge.Category.Value.ToString().ToLowerInvariant()}") @(selected ? "srp-badge-opt-sel" : "")"
                              role="button" tabindex="0" @onclick="() => ToggleBadge(badge.Key)">
                            @L[badge.DisplayName]@BadgeCount(badge.Key)
                        </span>
                    }
                </div>

                @if (_allMixes)
                {
                    <MudText Typo="Typo.overline">@L["Mix scope"]</MudText>
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["Debut mix"]</div>
                        @foreach (var era in MixEras)
                        {
                            <div class="srp-era">
                                <div class="srp-era-name">@L[era.Name]</div>
                                <div class="srp-chipset">
                                    @foreach (var mix in era.Mixes)
                                    {
                                        var captured = mix;
                                        <span class="srp-facet-chip @(_debutMixes.Contains(captured) ? "srp-facet-chip-on" : "")"
                                              role="button" tabindex="0" @onclick="() => ToggleDebutMix(captured)">
                                            @captured.GetName()@CountSuffix(_facetCounts?.DebutMixes, captured)
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="srp-drawer-range">
                        <MudSelect T="MixEnum?" Value="_availableIn" ValueChanged="SetAvailableIn" Label="@L["Available in"]"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var mix in AllKnownMixes)
                            {
                                <MudSelectItem T="MixEnum?" Value="@((MixEnum?)mix)">@mix.GetName()</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="MixEnum?" Value="_notAvailableIn" ValueChanged="SetNotAvailableIn" Label="@L["Not available in"]"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var mix in AllKnownMixes)
                            {
                                <MudSelectItem T="MixEnum?" Value="@((MixEnum?)mix)">@mix.GetName()</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                    <div class="srp-chipset">
                        <span class="srp-facet-chip @(_reratedUp ? "srp-facet-chip-on" : "")"
                              role="button" tabindex="0" @onclick="() => SetReratedUp(!_reratedUp)">@L["Rerated up"]</span>
                        <span class="srp-facet-chip @(_reratedDown ? "srp-facet-chip-on" : "")"
                              role="button" tabindex="0" @onclick="() => SetReratedDown(!_reratedDown)">@L["Rerated down"]</span>
                    </div>
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["Legacy Difficulty"]</div>
                        <div class="srp-chipset">
                            @foreach (var slot in Enum.GetValues<LegacySlot>())
                            {
                                var captured = slot;
                                <span class="srp-facet-chip @(_legacySlots.Contains(captured) ? "srp-facet-chip-on" : "")"
                                      role="button" tabindex="0" @onclick="() => ToggleSlot(captured)">
                                    @captured.GetName()@CountSuffix(_facetCounts?.LegacySlots, captured)
                                </span>
                            }
                        </div>
                    </div>
                }

                <MudText Typo="Typo.overline">@L["Community intelligence"]</MudText>
                <div class="srp-facet">
                    <div class="srp-facet-head">@L["Pass Difficulty"] <span class="srp-facet-value">@TierRangeLabel(_passDifficulty)</span></div>
                    <MudRangeSlider T="int" Value="TierLow(_passDifficulty)" UpperValue="TierHigh(_passDifficulty)"
                                    ValueChanged="v => SetTierLow(_passDifficulty, v, SetPassDifficulty)"
                                    UpperValueChanged="v => SetTierHigh(_passDifficulty, v, SetPassDifficulty)"
                                    Min="0" Max="@(RankedCategories.Length - 1)" Step="1"
                                    Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                </div>
                <div class="srp-facet">
                    <div class="srp-facet-head">@L["Score Difficulty"] <span class="srp-facet-value">@TierRangeLabel(_scoreDifficulty)</span></div>
                    <MudRangeSlider T="int" Value="TierLow(_scoreDifficulty)" UpperValue="TierHigh(_scoreDifficulty)"
                                    ValueChanged="v => SetTierLow(_scoreDifficulty, v, SetScoreDifficulty)"
                                    UpperValueChanged="v => SetTierHigh(_scoreDifficulty, v, SetScoreDifficulty)"
                                    Min="0" Max="@(RankedCategories.Length - 1)" Step="1"
                                    Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                </div>
                @if (LegacyInScope)
                {
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["Community Vote"] <span class="srp-facet-value">@TierRangeLabel(_communityVote)</span></div>
                        <MudRangeSlider T="int" Value="TierLow(_communityVote)" UpperValue="TierHigh(_communityVote)"
                                        ValueChanged="v => SetTierLow(_communityVote, v, SetCommunityVote)"
                                        UpperValueChanged="v => SetTierHigh(_communityVote, v, SetCommunityVote)"
                                        Min="0" Max="@(RankedCategories.Length - 1)" Step="1"
                                        Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                    </div>
                }
                <div class="srp-facet">
                    <div class="srp-facet-head">@L["Pass rate"] <span class="srp-facet-value">@(_passRateMin == null ? L["Any"].Value : $"≥ {_passRateMin}%")</span></div>
                    @* 0 is "no floor", so it clears rather than filtering to everything. *@
                    <MudSlider T="int" Value="_passRateMin ?? 0" ValueChanged="v => SetPassRateMin(v <= 0 ? null : v)"
                               Min="0" Max="100" Step="5" Color="Color.Primary" Size="Size.Small"></MudSlider>
                </div>
                @if (ModernInScope && _ranges?.ScoringLevelMin != null && _ranges.ScoringLevelMax != null
                     && _ranges.ScoringLevelMax > _ranges.ScoringLevelMin)
                {
                    <div class="srp-facet">
                        <div class="srp-facet-head">@L["Scoring level"] <span class="srp-facet-value">@RangeLabel((decimal?)_scoringLevelMin, (decimal?)_scoringLevelMax, (decimal?)_ranges.ScoringLevelMin, (decimal?)_ranges.ScoringLevelMax)</span></div>
                        <MudRangeSlider T="int" Value="(int)(_scoringLevelMin ?? _ranges.ScoringLevelMin.Value)"
                                        UpperValue="(int)(_scoringLevelMax ?? _ranges.ScoringLevelMax.Value)"
                                        ValueChanged="v => SetScoringLevelMin(v)" UpperValueChanged="v => SetScoringLevelMax(v)"
                                        Min="(int)_ranges.ScoringLevelMin.Value" Max="(int)_ranges.ScoringLevelMax.Value" Step="1"
                                        Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                    </div>
                }

                @if (CurrentUser.IsLoggedIn)
                {
                    <MudText Typo="Typo.overline">@L["My data"]</MudText>
                    <div class="srp-chipset">
                        <span class="srp-facet-chip @(_onlyFavorites ? "srp-facet-chip-on" : "")"
                              role="button" tabindex="0" @onclick="() => SetOnlyFavorites(!_onlyFavorites)">@L["Favorites"]</span>
                        <span class="srp-facet-chip @(_onlyToDo ? "srp-facet-chip-on" : "")"
                              role="button" tabindex="0" @onclick="() => SetOnlyToDo(!_onlyToDo)">@L["To Do"]</span>
                        @if (_allMixes)
                        {
                            <span class="srp-facet-chip @(_reclearGap ? "srp-facet-chip-on" : "")"
                                  role="button" tabindex="0" @onclick="() => SetReclearGap(!_reclearGap)">@L["Not yet re-cleared in {0}", NewestMix.GetName()]</span>
                        }
                    </div>
                    @if (ModernInScope)
                    {
                        <div class="srp-facet">
                            <div class="srp-facet-head">@L["Phoenix grade"] <span class="srp-facet-value">@(_phoenixGradeMin?.GetName() ?? L["Any"].Value)</span></div>
                            <MudSlider T="int" Value="GradeIndex(_phoenixGradeMin)" ValueChanged="SetPhoenixGradeIndex"
                                       Min="0" Max="@(PhoenixGrades.Length)" Step="1"
                                       Color="Color.Primary" Size="Size.Small"></MudSlider>
                        </div>
                        <div class="srp-facet">
                            <div class="srp-facet-head">@L["Phoenix plate"] <span class="srp-facet-value">@(_phoenixPlateMin?.GetShorthand() ?? L["Any"].Value)</span></div>
                            <MudSlider T="int" Value="PlateIndex(_phoenixPlateMin)" ValueChanged="SetPhoenixPlateIndex"
                                       Min="0" Max="@(PhoenixPlates.Length)" Step="1"
                                       Color="Color.Primary" Size="Size.Small"></MudSlider>
                        </div>
                        <div class="srp-facet">
                            <div class="srp-facet-head">@L["Phoenix score"] <span class="srp-facet-value">@RangeLabel(_phoenixScoreMin, _phoenixScoreMax, 0, 1000000)</span></div>
                            <MudRangeSlider T="int" Value="_phoenixScoreMin ?? 0" UpperValue="_phoenixScoreMax ?? 1000000"
                                            ValueChanged="SetPhoenixScoreMin" UpperValueChanged="SetPhoenixScoreMax"
                                            Min="0" Max="1000000" Step="5000"
                                            Color="Color.Primary" Size="Size.Small"></MudRangeSlider>
                        </div>
                    }
                    @if (LegacyInScope)
                    {
                        <div class="srp-facet">
                            <div class="srp-facet-head">@L["Legacy grade"] <span class="srp-facet-value">@(_legacyGradeMin?.ToString() ?? L["Any"].Value)</span></div>
                            <MudSlider T="int" Value="LegacyGradeIndex(_legacyGradeMin)" ValueChanged="SetLegacyGradeIndex"
                                       Min="0" Max="@(LegacyGrades.Length)" Step="1"
                                       Color="Color.Primary" Size="Size.Small"></MudSlider>
                        </div>
                    }
                    <div class="srp-drawer-range">
                        <MudDatePicker Date="_recordedFrom" DateChanged="SetRecordedFrom" Label="@L["Recorded from"]"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"></MudDatePicker>
                        <MudDatePicker Date="_recordedTo" DateChanged="SetRecordedTo" Label="@L["Recorded to"]"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"></MudDatePicker>
                    </div>
                }

                @* Display switches stay switches on purpose: they change what a card shows,
                   not which charts match, and shouldn't read as filters. *@
                <MudText Typo="Typo.overline">@L["Display"]</MudText>
                <div class="srp-drawer-switches">
                    <MudSwitch T="bool" Value="_showStepArtist" ValueChanged="SetShowStepArtist" Color="Color.Primary"
                               Label="@L["Step Artist"]"></MudSwitch>
                    <MudSwitch T="bool" Value="_showNoteCount" ValueChanged="SetShowNoteCount" Color="Color.Primary"
                               Label="@L["Note count"]"></MudSwitch>
                </div>
            }
        </div>
    </MudDrawer>
</MudLayout>

@inject IMediator Mediator
@inject NavigationManager NavManager
@inject ICurrentUserAccessor CurrentUser
@inject IUiSettingsAccessor UiSettings
@inject ISnackbar Snackbar
@inject IJSRuntime Javascript
@inject IDateTimeOffsetAccessor Clock
@code {

    private MixEnum _mix = MixEnum.Phoenix;
    private bool _allMixes;
    private bool _filtersOpen;
    private bool _exportOpen;
    private bool _isLoading = true;

