            ChartSearchSort.ScoringLevel => "Scoring level",
            ChartSearchSort.Popularity => "Popularity",
            ChartSearchSort.PassRate => "Pass rate",
            ChartSearchSort.DebutEra => "Newest content",
            ChartSearchSort.Name => "Name",
            ChartSearchSort.Bpm => "BPM",
            ChartSearchSort.Nps => "NPS",
            ChartSearchSort.Duration => "Duration",
            ChartSearchSort.MyGrade => "My grade",
            ChartSearchSort.MyRecent => "My recent",
            _ => sort.ToString()
        };
    }

    private static string ScoreStateName(ChartScoreStateFilter state)
    {
        return state switch
        {
            ChartScoreStateFilter.Unplayed => "Unplayed",
            ChartScoreStateFilter.Played => "Played",
            ChartScoreStateFilter.Passed => "Passed",
            ChartScoreStateFilter.Failed => "Failed",
            _ => state.ToString()
        };
    }

    /// <summary>The active sort's value, printed on every card — the auto-surface rule.</summary>
    private string? LeadFact(ChartSearchResult result)
    {
        return _sort switch
        {
            ChartSearchSort.ScoringLevel when result.Chart.Mix.UsesLegacyScoring() =>
                result.CommunityVoteRating == null ? null : $"{L["Community Vote"]} {result.CommunityVoteRating.Value:0.0}",
            ChartSearchSort.ScoringLevel =>
                result.ScoringLevel == null ? null : $"{L["Scoring level"]} {result.ScoringLevel.Value:0.0}",
            ChartSearchSort.DebutEra => $"{L["Debut"]}: {result.DebutMix.GetName()}",
            ChartSearchSort.MyRecent when result.My?.RecordedOn != null =>
                result.My.RecordedOn.Value.ToString("yyyy-MM-dd"),
            _ => null
        };
    }

    // ---- saved lists ----------------------------------------------------------------

    private async Task ToggleFavorite(Guid chartId)
    {
        if (_favoriteCharts.Contains(chartId))
        {
            await Mediator.Send(new RemoveChartFromListCommand(ChartListType.Favorite, chartId));
            _favoriteCharts.Remove(chartId);
            Snackbar.Add(L["Chart removed from Favorites"].Value, Severity.Success);
        }
        else
        {
            await Mediator.Send(new SaveChartToListCommand(ChartListType.Favorite, chartId));
            _favoriteCharts.Add(chartId);
            Snackbar.Add(L["Chart added to Favorites"].Value, Severity.Success);
        }
    }

    // ---- quick record ---------------------------------------------------------------

    private bool _quickRecordOpen;
    private ChartSearchResult? _quickRecordTarget;

    private void OpenQuickRecord(ChartSearchResult target)
    {
        _quickRecordTarget = target;
        _quickRecordOpen = true;
    }

    private void OnQuickRecordSaved(RecordScoreForm.Result result)
    {
        var target = _quickRecordTarget;
        if (target == null) return;

        // The card's overlay updates in place — no refetch; the search projection catches
        // up on the next load.
        var my = new ChartSearchMyState(
            result.PhoenixScore == null ? null : (int)result.PhoenixScore.Value,
            result.PhoenixGrade, result.Plate, result.LegacyGrade, result.LegacyScore, result.IsBroken,
            Clock.Now, !result.IsBroken, target.My?.PassedInAnotherScopeMix ?? false);
        _results = _results
            .Select(r => r.Chart.Id == target.Chart.Id ? r with { My = my } : r)
            .ToList();
        Snackbar.Add(L["Recorded {0}", $"{target.Chart.Song.Name} {target.Chart.DifficultyDisplay}"].Value,
            Severity.Success);
    }

