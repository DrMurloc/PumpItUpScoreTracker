    private MixEnum? _notAvailableIn;
    private bool _reratedUp;
    private bool _reratedDown;
    private List<LegacySlot> _legacySlots = new();
    private List<TierListCategory> _passDifficulty = new();
    private List<TierListCategory> _scoreDifficulty = new();
    private List<TierListCategory> _communityVote = new();
    private int? _passRateMin;
    private double? _scoringLevelMin;
    private double? _scoringLevelMax;
    private List<ChartScoreStateFilter> _scoreStates = new();
    private List<int> _coOpPlayers = new();
    private TimeSpan? _durationMin;
    private TimeSpan? _durationMax;
    private bool _moreFilters;
    private ChartSearchRanges? _ranges;
    private const string MoreFiltersKey = "Charts__MoreFilters";
    private PhoenixLetterGrade? _phoenixGradeMin;
    private PhoenixPlate? _phoenixPlateMin;
    private int? _phoenixScoreMin;
    private int? _phoenixScoreMax;
    private XXLetterGrade? _legacyGradeMin;
    private DateTime? _recordedFrom;
    private DateTime? _recordedTo;
    private bool _onlyFavorites;
    private bool _onlyToDo;
    private bool _reclearGap;
    private ChartSearchSort _sort = ChartSearchSort.Level;
    private bool _sortDescending = true;
    private int _pageNumber = 1;
    private const int PageSize = 24;

    private bool _showStepArtist;
    private bool _showNoteCount;
    private const string StepArtistDisplayKey = "Charts__Display__StepArtist";
    private const string NoteCountDisplayKey = "Charts__Display__NoteCount";

    private UiDensity _density = UiDensity.Comfortable;
    private const string DensitySettingKey = "Density__Charts";

    private IReadOnlyList<ChartSearchResult> _results = Array.Empty<ChartSearchResult>();
    private int _totalCount;
    private ChartSearchFacetCounts? _facetCounts;
    private ISet<Guid> _favoriteCharts = new HashSet<Guid>();
    private ISet<Guid> _todoCharts = new HashSet<Guid>();

    private IReadOnlyList<ChartBadge> _badgeVocabulary = Array.Empty<ChartBadge>();
    private IReadOnlyList<string> _artistVocabulary = Array.Empty<string>();
    private IReadOnlyList<string> _stepArtistVocabulary = Array.Empty<string>();
    private bool _vocabularyLoaded;

    private int PageCount => (int)Math.Ceiling(_totalCount / (double)PageSize);

    private bool LegacyInScope => _allMixes || _mix.UsesLegacyScoring();
    private bool ModernInScope => _allMixes || !_mix.UsesLegacyScoring();

    private static readonly MixEnum NewestMix = MixThemes.ThemedMixes.OrderBy(m => m.DisplayOrder()).Last();

    private static readonly MixEnum[] AllKnownMixes =
        Enum.GetValues<MixEnum>().OrderBy(m => m.DisplayOrder()).ToArray();

    /// <summary>
    ///     The debut-mix facet grouped into eras — twenty-nine loose chips is a wall. Pro,
    ///     Pro 2 and Infinity are their own line (owner, 2026-07-20), which is why they sit
    ///     apart from the main timeline rather than interleaved by release order.
    /// </summary>
    internal sealed record MixEra(string Name, MixEnum[] Mixes);

    internal static readonly MixEra[] MixEras =
    {
        new("Modern", new[] { MixEnum.Phoenix2, MixEnum.Phoenix, MixEnum.XX }),
        new("Prime", new[] { MixEnum.Prime2, MixEnum.Prime }),
        new("Pro & Infinity", new[] { MixEnum.Infinity, MixEnum.Pro2, MixEnum.Pro }),
        new("Fiesta", new[] { MixEnum.Fiesta2, MixEnum.FiestaEx, MixEnum.Fiesta }),
        new("Exceed & NX", new[]
        {
            MixEnum.NxAbsolute, MixEnum.Nx2, MixEnum.Nx, MixEnum.Zero, MixEnum.Exceed2, MixEnum.Exceed
        }),
        new("Classic", new[]
        {
            MixEnum.Prex3, MixEnum.Premiere3, MixEnum.Prex2, MixEnum.Premiere2, MixEnum.Rebirth, MixEnum.Prex,
            MixEnum.Premiere, MixEnum.Extra, MixEnum.PerfectCollection, MixEnum.Collection,
            MixEnum.ObgSeasonEvolution, MixEnum.ThirdObg, MixEnum.SecondUltimateRemix, MixEnum.FirstDanceFloor
        })
    };

    /// <summary>Filter labels spell the type out; the shorthand belongs on bubbles, not chips.</summary>
    internal static string TypeName(ChartType type)
    {
        return type switch
        {
            ChartType.Single => "Single",
            ChartType.Double => "Double",
            ChartType.SinglePerformance => "Single Performance",
            ChartType.DoublePerformance => "Double Performance",
            ChartType.CoOp => "Co-Op",
            ChartType.HalfDouble => "Half-Double",
            _ => type.ToString()
        };
    }

    internal static string SongTypeName(SongType type)
    {
        return type switch
        {
            SongType.Arcade => "Arcade",
            SongType.ShortCut => "Short Cut",
            SongType.FullSong => "Full Song",
            SongType.Remix => "Remix",
            _ => type.ToString()
        };
    }

    private static List<int> ParseCsvInts(string? csv)
    {
        return csv?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(v => int.TryParse(v, out var parsed) ? parsed : (int?)null)
            .Where(v => v != null)
            .Select(v => v!.Value)
            .Distinct()
            .ToList() ?? new List<int>();
    }

    private static readonly TierListCategory[] RankedCategories =
    {
        TierListCategory.Overrated, TierListCategory.VeryEasy, TierListCategory.Easy, TierListCategory.Medium,
        TierListCategory.Hard, TierListCategory.VeryHard, TierListCategory.Underrated
    };

    private static readonly ChartSearchSort[] SortOrder =
    {
        ChartSearchSort.Level, ChartSearchSort.ScoringLevel, ChartSearchSort.Popularity, ChartSearchSort.PassRate,
        ChartSearchSort.DebutEra, ChartSearchSort.Name, ChartSearchSort.Bpm, ChartSearchSort.Nps,
        ChartSearchSort.Duration, ChartSearchSort.MyGrade, ChartSearchSort.MyRecent
    };

    private IEnumerable<ChartSearchSort> AvailableSorts => CurrentUser.IsLoggedIn
        ? SortOrder
        : SortOrder.Where(s => s is not (ChartSearchSort.MyGrade or ChartSearchSort.MyRecent));

    // ---- query-string contract ------------------------------------------------------

    [Parameter] [SupplyParameterFromQuery(Name = "Song")] public string? SongParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "LevelMin")] public int? LevelMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "LevelMax")] public int? LevelMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Type")] public string? TypeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SongType")] public string? SongTypeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Artist")] public string? ArtistParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "StepArtist")] public string? StepArtistParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "BpmMin")] public decimal? BpmMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "BpmMax")] public decimal? BpmMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "NpsMin")] public decimal? NpsMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "NpsMax")] public decimal? NpsMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "NoteMin")] public int? NoteMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "NoteMax")] public int? NoteMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Badges")] public string? BadgesParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "DebutMix")] public string? DebutMixParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "In")] public string? AvailableInParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "NotIn")] public string? NotAvailableInParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "RUp")] public bool RUpParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "RDown")] public bool RDownParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Slots")] public string? SlotsParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "PassDiff")] public string? PassDiffParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "ScoreDiff")] public string? ScoreDiffParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Vote")] public string? VoteParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "PassRateMin")] public int? PassRateMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SlMin")] public double? SlMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SlMax")] public double? SlMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "PhxGrade")] public string? PhxGradeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "PhxPlate")] public string? PhxPlateParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "PhxMin")] public int? PhxMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "PhxMax")] public int? PhxMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "LegGrade")] public string? LegGradeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "RecFrom")] public string? RecFromParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "RecTo")] public string? RecToParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Saved")] public string? SavedParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Reclear")] public bool ReclearParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "State")] public string? StateParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "CoOp")] public string? CoOpParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "DurMin")] public int? DurMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "DurMax")] public int? DurMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Sort")] public string? SortParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Dir")] public string? DirParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Scope")] public string? ScopeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Page")] public int? PageParam { get; set; }

    // The old page's parameter names, honored as read-time aliases so shared links keep
    // working. SongName was an exact match; it maps onto the contains filter.
    [Parameter] [SupplyParameterFromQuery(Name = "Difficulty")] public int? LegacyDifficultyParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "ChartType")] public string? LegacyChartTypeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SongName")] public string? LegacySongNameParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SongArtist")] public string? LegacySongArtistParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "ScoreState")] public string? LegacyScoreStateParam { get; set; }

    private void ParseQuery()
    {
        _songNameContains = SongParam ?? LegacySongNameParam;
        _levelMin = LevelMinParam ?? LegacyDifficultyParam;
        _levelMax = LevelMaxParam ?? LegacyDifficultyParam;
        _types = ParseCsvEnum<ChartType>(TypeParam ?? LegacyChartTypeParam);
        _songTypes = ParseCsvEnum<SongType>(SongTypeParam);
        _artists = ParseCsv(ArtistParam ?? LegacySongArtistParam);
        _stepArtists = ParseCsv(StepArtistParam);
        _bpmMin = BpmMinParam;
        _bpmMax = BpmMaxParam;
        _npsMin = NpsMinParam;
        _npsMax = NpsMaxParam;
        _noteMin = NoteMinParam;
        _noteMax = NoteMaxParam;
        _badges = ParseCsv(BadgesParam);
        _debutMixes = ParseCsvEnum<MixEnum>(DebutMixParam);
        _availableIn = Enum.TryParse<MixEnum>(AvailableInParam, true, out var aIn) ? aIn : null;
        _notAvailableIn = Enum.TryParse<MixEnum>(NotAvailableInParam, true, out var nIn) ? nIn : null;
        _reratedUp = RUpParam;
        _reratedDown = RDownParam;
        _legacySlots = ParseCsvEnum<LegacySlot>(SlotsParam);
        _passDifficulty = ParseCsvEnum<TierListCategory>(PassDiffParam);
        _scoreDifficulty = ParseCsvEnum<TierListCategory>(ScoreDiffParam);
        _communityVote = ParseCsvEnum<TierListCategory>(VoteParam);
        _passRateMin = PassRateMinParam;
        _scoringLevelMin = SlMinParam;
        _scoringLevelMax = SlMaxParam;
        _phoenixGradeMin = Enum.TryParse<PhoenixLetterGrade>(PhxGradeParam, true, out var pg) ? pg : null;
        _phoenixPlateMin = Enum.TryParse<PhoenixPlate>(PhxPlateParam, true, out var pp) ? pp : null;
        _phoenixScoreMin = PhxMinParam;
        _phoenixScoreMax = PhxMaxParam;
        _legacyGradeMin = Enum.TryParse<XXLetterGrade>(LegGradeParam, true, out var lg) ? lg : null;
        _recordedFrom = DateTime.TryParse(RecFromParam, out var from) ? from : null;
        _recordedTo = DateTime.TryParse(RecToParam, out var to) ? to : null;
        var saved = ParseCsv(SavedParam);
        _onlyFavorites = saved.Contains("Favorites", StringComparer.OrdinalIgnoreCase);
        _onlyToDo = saved.Contains("ToDo", StringComparer.OrdinalIgnoreCase);
        _reclearGap = ReclearParam;
        _scoreStates = ParseCsvEnum<ChartScoreStateFilter>(StateParam);
        if (_scoreStates.Count == 0)
        {
            var legacyState = LegacyScoreStateParam?.ToLowerInvariant() switch
            {
                "passed" => ChartScoreStateFilter.Passed,
                "broken" or "notpassed" => ChartScoreStateFilter.Failed,
                "ungraded" => ChartScoreStateFilter.Unplayed,
                _ => (ChartScoreStateFilter?)null
            };
            if (legacyState != null) _scoreStates.Add(legacyState.Value);
        }

        _coOpPlayers = ParseCsvInts(CoOpParam);
        _durationMin = DurMinParam == null ? null : TimeSpan.FromSeconds(DurMinParam.Value);
        _durationMax = DurMaxParam == null ? null : TimeSpan.FromSeconds(DurMaxParam.Value);
        _sort = Enum.TryParse<ChartSearchSort>(SortParam, true, out var sort) ? sort : ChartSearchSort.Level;
        _sortDescending = DirParam?.ToLowerInvariant() != "asc" &&
                          (DirParam?.ToLowerInvariant() == "desc" || DefaultDescending(_sort));
        _allMixes = string.Equals(ScopeParam, "all", StringComparison.OrdinalIgnoreCase);
        _pageNumber = Math.Max(1, PageParam ?? 1);
    }

    private static List<string> ParseCsv(string? csv)
    {
        return csv?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList()
               ?? new List<string>();
    }

    private static List<T> ParseCsvEnum<T>(string? csv) where T : struct, Enum
    {
        return csv?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(v => Enum.TryParse<T>(v, true, out var parsed) ? parsed : (T?)null)
            .Where(v => v != null)
            .Select(v => v!.Value)
            .Distinct()
            .ToList() ?? new List<T>();
    }

    private async Task PushUrl()
    {
        var url = NavManager.GetUriWithQueryParameters("/Charts", QueryParameters());
        await Javascript.InvokeVoidAsync("history.pushState", null, "", url);
    }

    /// <summary>The page's query-string contract — also handed to the export dialog verbatim.</summary>
    private Dictionary<string, object?> QueryParameters()
    {
        return new Dictionary<string, object?>
        {
            ["Song"] = string.IsNullOrWhiteSpace(_songNameContains) ? null : _songNameContains,
            ["LevelMin"] = _levelMin,
            ["LevelMax"] = _levelMax,
            ["Type"] = Csv(_types),
            ["SongType"] = Csv(_songTypes),
            ["Artist"] = _artists.Count == 0 ? null : string.Join(',', _artists),
            ["StepArtist"] = _stepArtists.Count == 0 ? null : string.Join(',', _stepArtists),
            ["BpmMin"] = _bpmMin,
            ["BpmMax"] = _bpmMax,
            ["NpsMin"] = _npsMin,
            ["NpsMax"] = _npsMax,
            ["NoteMin"] = _noteMin,
            ["NoteMax"] = _noteMax,
            ["Badges"] = _badges.Count == 0 ? null : string.Join(',', _badges),
            ["DebutMix"] = Csv(_debutMixes),
            ["In"] = _availableIn?.ToString(),
            ["NotIn"] = _notAvailableIn?.ToString(),
            ["RUp"] = _reratedUp ? true : null,
            ["RDown"] = _reratedDown ? true : null,
            ["Slots"] = Csv(_legacySlots),
            ["PassDiff"] = Csv(_passDifficulty),
            ["ScoreDiff"] = Csv(_scoreDifficulty),
            ["Vote"] = Csv(_communityVote),
            ["PassRateMin"] = _passRateMin,
            ["SlMin"] = _scoringLevelMin,
            ["SlMax"] = _scoringLevelMax,
            ["PhxGrade"] = _phoenixGradeMin?.ToString(),
            ["PhxPlate"] = _phoenixPlateMin?.ToString(),
            ["PhxMin"] = _phoenixScoreMin,
            ["PhxMax"] = _phoenixScoreMax,
            ["LegGrade"] = _legacyGradeMin?.ToString(),
            ["RecFrom"] = _recordedFrom?.ToString("yyyy-MM-dd"),
            ["RecTo"] = _recordedTo?.ToString("yyyy-MM-dd"),
            ["Saved"] = SavedCsv,
            ["Reclear"] = _reclearGap ? true : null,
            ["State"] = Csv(_scoreStates),
            ["CoOp"] = _coOpPlayers.Count == 0 ? null : string.Join(',', _coOpPlayers),
            ["DurMin"] = DurationSeconds(_durationMin),
            ["DurMax"] = DurationSeconds(_durationMax),
            ["Sort"] = IsDefaultSort ? null : _sort.ToString(),
            ["Dir"] = IsDefaultSort || _sortDescending == DefaultDescending(_sort)
                ? null
                : _sortDescending ? "desc" : "asc",
            ["Scope"] = _allMixes ? "all" : null,
            ["Page"] = _pageNumber <= 1 ? null : _pageNumber
        };
    }

    private static string? Csv<T>(IReadOnlyCollection<T> values)
    {
        return values.Count == 0 ? null : string.Join(',', values);
    }

    private string? SavedCsv => _onlyFavorites || _onlyToDo
        ? string.Join(',', new[] { _onlyFavorites ? "Favorites" : null, _onlyToDo ? "ToDo" : null }.Where(v => v != null))
        : null;

    // ---- loading --------------------------------------------------------------------

    protected override async Task OnInitializedAsync()
    {
        _mix = await UiSettings.GetSelectedMix();
        ParseQuery();
        if (CurrentUser.IsLoggedIn)
        {
            var saves = (await Mediator.Send(new GetSavedChartsQuery())).ToArray();
            _favoriteCharts = saves.Where(s => s.ListType == ChartListType.Favorite).Select(s => s.ChartId).ToHashSet();
            _todoCharts = saves.Where(s => s.ListType == ChartListType.ToDo).Select(s => s.ChartId).ToHashSet();
        }

        _showStepArtist = await UiSettings.GetSetting(StepArtistDisplayKey) == true.ToString();
        _showNoteCount = await UiSettings.GetSetting(NoteCountDisplayKey) == true.ToString();
        // An advanced filter arriving by URL opens its own section — otherwise the chip is
        // visible but the control that set it is hidden.
        _moreFilters = await UiSettings.GetSetting(MoreFiltersKey) == true.ToString() || HasAdvancedFilter;
        if (Enum.TryParse<UiDensity>(await UiSettings.GetSetting(DensitySettingKey), out var density))
            _density = density;

        await LoadPage();
    }

    private async Task SetDensity(UiDensity density)
    {
        _density = density;
        await UiSettings.SetSetting(DensitySettingKey, density.ToString());
    }

    private string SortableHeaderClass(ChartSearchSort sort)
    {
        return _sort == sort ? "srp-th-sortable srp-th-sorted" : "srp-th-sortable";
    }

    private string SortMark(ChartSearchSort sort)
    {
        return _sort == sort ? _sortDescending ? " ↓" : " ↑" : string.Empty;
    }

    private SearchChartsQuery BuildQuery()
    {
        var restrictTo = _onlyFavorites || _onlyToDo
            ? (_onlyFavorites ? _favoriteCharts : Enumerable.Empty<Guid>())
            .Concat(_onlyToDo ? _todoCharts : Enumerable.Empty<Guid>())
            .Distinct().ToArray()
            : null;

        return new SearchChartsQuery
        {
            Mix = _mix,
            AllMixes = _allMixes,
            UserId = CurrentUser.IsLoggedIn ? CurrentUser.User.Id : null,
            SongNameContains = _songNameContains,
            LevelMin = _levelMin,
            LevelMax = _levelMax,
            Types = _types.Count == 0 ? null : _types,
            SongTypes = _songTypes.Count == 0 ? null : _songTypes,
            Artists = _artists.Count == 0 ? null : _artists,
            StepArtists = _stepArtists.Count == 0 ? null : _stepArtists,
            BpmMin = _bpmMin,
            BpmMax = _bpmMax,
            NpsMin = _npsMin,
            NpsMax = _npsMax,
            NoteCountMin = _noteMin,
            NoteCountMax = _noteMax,
            Badges = _badges.Count == 0 ? null : _badges,
            DebutMixes = _debutMixes.Count == 0 ? null : _debutMixes,
            AvailableIn = _allMixes ? _availableIn : null,
            NotAvailableIn = _allMixes ? _notAvailableIn : null,
            ReratedUp = _allMixes && _reratedUp,
            ReratedDown = _allMixes && _reratedDown,
            LegacySlots = _legacySlots.Count == 0 ? null : _legacySlots,
            PassDifficulty = _passDifficulty.Count == 0 ? null : _passDifficulty,
            ScoreDifficulty = _scoreDifficulty.Count == 0 ? null : _scoreDifficulty,
            CommunityVote = _communityVote.Count == 0 ? null : _communityVote,
            PassRateMin = _passRateMin == null ? null : _passRateMin.Value / 100.0,
            ScoringLevelMin = _scoringLevelMin,
            ScoringLevelMax = _scoringLevelMax,
            ScoreStates = CurrentUser.IsLoggedIn && _scoreStates.Count > 0 ? _scoreStates : null,
            CoOpPlayerCounts = _coOpPlayers.Count == 0 ? null : _coOpPlayers,
            DurationMin = _durationMin,
            DurationMax = _durationMax,
            PhoenixGradeMin = _phoenixGradeMin,
            PhoenixPlateMin = _phoenixPlateMin,
            PhoenixScoreMin = _phoenixScoreMin,
            PhoenixScoreMax = _phoenixScoreMax,
            LegacyGradeMin = _legacyGradeMin,
            RecordedFrom = _recordedFrom == null ? null : new DateTimeOffset(_recordedFrom.Value, TimeSpan.Zero),
            RecordedTo = _recordedTo == null ? null : new DateTimeOffset(_recordedTo.Value.AddDays(1).AddTicks(-1), TimeSpan.Zero),
            NotReclearedIn = _allMixes && _reclearGap && CurrentUser.IsLoggedIn ? NewestMix : null,
            RestrictToChartIds = restrictTo,
            Sort = _sort,
            SortDescending = _sortDescending,
            Page = _pageNumber,
            PageSize = PageSize,
            IncludeFacetCounts = true
        };
    }

    private async Task LoadPage()
    {
        _isLoading = true;
        var page = await Mediator.Send(BuildQuery());
        _results = page.Results;
        _totalCount = page.TotalCount;
        _facetCounts = page.FacetCounts;
        // Landing past the tail (a stale shared link) snaps back to the last real page.
        if (_pageNumber > 1 && _results.Count == 0 && _totalCount > 0)
        {
            _pageNumber = Math.Max(1, PageCount);
            page = await Mediator.Send(BuildQuery());
            _results = page.Results;
            _totalCount = page.TotalCount;
            _facetCounts = page.FacetCounts;
        }

        _isLoading = false;
        await LoadOfficialPlaces();
    }

    // The official mirror's popularity places — display-only badges, fetched per modern
    // mix once per circuit and never a filter (docs/design/charts-srp.md §2 Popularity).
    private readonly Dictionary<MixEnum, IReadOnlyDictionary<Guid, int>> _officialPlaces = new();

    private async Task LoadOfficialPlaces()
    {
        foreach (var mix in _results.Select(r => r.Chart.Mix).Distinct().Where(m => !m.UsesLegacyScoring()))
        {
            if (_officialPlaces.ContainsKey(mix)) continue;
            _officialPlaces[mix] = (await Mediator.Send(new GetOfficialPopularityQuery(mix)))
                .ToDictionary(p => p.ChartId, p => p.Place);
        }
    }

    private int? OfficialPlace(ChartSearchResult result)
    {
        return _officialPlaces.TryGetValue(result.Chart.Mix, out var places) &&
               places.TryGetValue(result.Chart.Id, out var place)
            ? place
            : null;
    }

    private async Task ApplyChange(bool resetPage = true)
    {
        if (resetPage) _pageNumber = 1;
        await PushUrl();
        await LoadPage();
    }

    private async Task OpenFilters()
    {
        _filtersOpen = true;
        if (_moreFilters) await LoadDrawerVocabulary();
    }

    /// <summary>
    ///     The advanced facets' dictionaries and slider extents — fetched when the long tail
    ///     is actually on screen, so the everyday open costs nothing.
    /// </summary>
    private async Task LoadDrawerVocabulary()
    {
        if (_vocabularyLoaded) return;
        _vocabularyLoaded = true;
        _badgeVocabulary = await Mediator.Send(new GetSearchBadgesQuery());
        _artistVocabulary = await Mediator.Send(new GetSearchArtistsQuery(_mix, _allMixes));
        _stepArtistVocabulary = await Mediator.Send(new GetSearchStepArtistsQuery(_mix, _allMixes));
        _ranges = await Mediator.Send(new GetSearchRangesQuery(_mix, _allMixes));
    }

    // ---- chips ----------------------------------------------------------------------

    private sealed record QueryChip(string Label, bool IsSort, Func<Task> Remove);

    private IReadOnlyList<QueryChip> QueryChips
    {
        get
        {
            var chips = new List<QueryChip>();
            // In Table density the sorted column header carries the sort — the chip retires.
            if (!IsDefaultSort && _density != UiDensity.Table)
                chips.Add(new QueryChip($"⇅ {L[SortName(_sort)]} {(_sortDescending ? "↓" : "↑")}", true,
                    () => SelectSort(ChartSearchSort.Level, true)));
            if (!string.IsNullOrWhiteSpace(_songNameContains))
                chips.Add(new QueryChip($"{L["Song name"]}: “{_songNameContains}”", false,
                    () => SetSongNameContains(null)));
            if (_levelMin != null || _levelMax != null)
                chips.Add(new QueryChip(LevelChipLabel, false, async () =>
                {
                    _levelMin = null;
                    _levelMax = null;
                    await ApplyChange();
                }));
            AddListChips(chips, _types, t => L[TypeName(t)].Value);
            AddListChips(chips, _coOpPlayers, p => $"{L["Co-Op"]} ×{p}");
            if (_durationMin != null || _durationMax != null)
                chips.Add(RangeChip(L["Duration"], FormatDuration(_durationMin), FormatDuration(_durationMax),
                    async () =>
                    {
                        _durationMin = null;
                        _durationMax = null;
                        await ApplyChange();
                    }));
            AddListChips(chips, _songTypes, t => L[SongTypeName(t)].Value);
            AddListChips(chips, _artists, a => a);
            AddListChips(chips, _stepArtists, a => $"{L["Step Artist"]}: {a}");
            if (_bpmMin != null || _bpmMax != null)
                chips.Add(RangeChip("BPM", _bpmMin?.ToString("0"), _bpmMax?.ToString("0"), async () =>
                {
                    _bpmMin = null;
                    _bpmMax = null;
                    await ApplyChange();
                }));
            if (_npsMin != null || _npsMax != null)
                chips.Add(RangeChip("NPS", _npsMin?.ToString("0.#"), _npsMax?.ToString("0.#"), async () =>
                {
                    _npsMin = null;
                    _npsMax = null;
                    await ApplyChange();
                }));
            if (_noteMin != null || _noteMax != null)
                chips.Add(RangeChip(L["Notes"], _noteMin?.ToString(), _noteMax?.ToString(), async () =>
                {
                    _noteMin = null;
                    _noteMax = null;
                    await ApplyChange();
                }));
            AddListChips(chips, _badges, b => BadgeDisplay(b));
            AddListChips(chips, _debutMixes, m => $"{L["Debut"]}: {m.GetName()}");
            if (_availableIn != null)
                chips.Add(new QueryChip($"{L["In"]}: {_availableIn.Value.GetName()}", false, () => SetAvailableIn(null)));
            if (_notAvailableIn != null)
                chips.Add(new QueryChip($"{L["Not in"]}: {_notAvailableIn.Value.GetName()}", false,
                    () => SetNotAvailableIn(null)));
            if (_reratedUp)
                chips.Add(new QueryChip(L["Rerated up"], false, () => SetReratedUp(false)));
            if (_reratedDown)
                chips.Add(new QueryChip(L["Rerated down"], false, () => SetReratedDown(false)));
            AddListChips(chips, _legacySlots, s => s.GetName());
            AddListChips(chips, _passDifficulty, c => $"{L["Pass"]}: {L[ChartSearchCard.CategoryName(c)]}");
            AddListChips(chips, _scoreDifficulty, c => $"{L["Score"]}: {L[ChartSearchCard.CategoryName(c)]}");
            AddListChips(chips, _communityVote, c => $"{L["Community Vote"]}: {L[ChartSearchCard.CategoryName(c)]}");
            if (_passRateMin != null)
                chips.Add(new QueryChip($"{L["Pass rate"]} ≥ {_passRateMin}%", false, () => SetPassRateMin(null)));
            if (_scoringLevelMin != null || _scoringLevelMax != null)
                chips.Add(RangeChip(L["Scoring level"], _scoringLevelMin?.ToString("0.#"),
                    _scoringLevelMax?.ToString("0.#"), async () =>
                    {
                        _scoringLevelMin = null;
                        _scoringLevelMax = null;
                        await ApplyChange();
                    }));
            if (CurrentUser.IsLoggedIn)
            {
                AddListChips(chips, _scoreStates, s => L[ScoreStateName(s)].Value);
                if (_phoenixGradeMin != null)
                    chips.Add(new QueryChip($"{L["Grade"]} ≥ {_phoenixGradeMin.Value.GetName()}", false,
                        () => SetPhoenixGradeMin(null)));
                if (_phoenixPlateMin != null)
                    chips.Add(new QueryChip($"{L["Plate"]} ≥ {_phoenixPlateMin.Value.GetShorthand()}", false,
                        () => SetPhoenixPlateMin(null)));
                if (_phoenixScoreMin != null || _phoenixScoreMax != null)
                    chips.Add(RangeChip(L["Score"], _phoenixScoreMin?.ToString("N0"), _phoenixScoreMax?.ToString("N0"),
                        async () =>
                        {
                            _phoenixScoreMin = null;
                            _phoenixScoreMax = null;
                            await ApplyChange();
                        }));
                if (_legacyGradeMin != null)
                    chips.Add(new QueryChip($"{L["Legacy grade"]} ≥ {_legacyGradeMin}", false,
                        () => SetLegacyGradeMin(null)));
                if (_recordedFrom != null || _recordedTo != null)
                    chips.Add(RangeChip(L["Recorded"], _recordedFrom?.ToString("yyyy-MM-dd"),
                        _recordedTo?.ToString("yyyy-MM-dd"), async () =>
                        {
                            _recordedFrom = null;
                            _recordedTo = null;
                            await ApplyChange();
                        }));
                if (_onlyFavorites)
                    chips.Add(new QueryChip(L["Favorites"], false, () => SetOnlyFavorites(false)));
                if (_onlyToDo)
                    chips.Add(new QueryChip(L["To Do"], false, () => SetOnlyToDo(false)));
                if (_reclearGap && _allMixes)
                    chips.Add(new QueryChip(L["Not yet re-cleared in {0}", NewestMix.GetName()], false,
                        () => SetReclearGap(false)));
            }

            return chips;
        }
    }

    private void AddListChips<T>(List<QueryChip> chips, List<T> list, Func<T, string> label)
    {
        foreach (var item in list)
        {
            var captured = item;
            chips.Add(new QueryChip(label(captured), false, async () =>
            {
                list.Remove(captured);
                await ApplyChange();
            }));
        }
    }

    private static QueryChip RangeChip(string label, string? from, string? to, Func<Task> remove)
    {
        var range = from != null && to != null ? $"{from}–{to}" : from != null ? $"≥ {from}" : $"≤ {to}";
        return new QueryChip($"{label} {range}", false, remove);
    }

