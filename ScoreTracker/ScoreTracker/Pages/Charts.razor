            _todoCharts.Remove(chartId);
            Snackbar.Add(L["Chart removed from To Do list"].Value, Severity.Success);
        }
        else
        {
            await Mediator.Send(new SaveChartToListCommand(ChartListType.ToDo, chartId));
            _todoCharts.Add(chartId);
            Snackbar.Add(L["Chart added to To Do list"].Value, Severity.Success);
        }
    }
