    // Tier sliders travel the ordered ranked scale; an untouched full-width range means no
    // filter, so Unranked charts (which sit on no rung at all) aren't quietly excluded.
    private static int TierLow(List<TierListCategory> selected) =>
        selected.Count == 0 ? 0 : RankedCategories.Select((c, i) => (c, i))
            .Where(x => selected.Contains(x.c)).Min(x => x.i);

    private static int TierHigh(List<TierListCategory> selected) =>
        selected.Count == 0
            ? RankedCategories.Length - 1
            : RankedCategories.Select((c, i) => (c, i)).Where(x => selected.Contains(x.c)).Max(x => x.i);

    private Task SetTierLow(List<TierListCategory> selected, int low, Func<List<TierListCategory>, Task> apply)
    {
        return apply(TierSpan(low, TierHigh(selected)));
    }

    private Task SetTierHigh(List<TierListCategory> selected, int high, Func<List<TierListCategory>, Task> apply)
    {
        return apply(TierSpan(TierLow(selected), high));
    }

    private static List<TierListCategory> TierSpan(int low, int high)
    {
        if (low <= 0 && high >= RankedCategories.Length - 1) return new List<TierListCategory>();
        return RankedCategories.Skip(low).Take(Math.Max(0, high - low + 1)).ToList();
    }

