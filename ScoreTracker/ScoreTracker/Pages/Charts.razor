    private async Task ToggleFavorite(Guid chartId)
    {
        if (_favoriteCharts.Contains(chartId))
        {
            await Mediator.Send(new RemoveChartFromListCommand(ChartListType.Favorite, chartId));
            _favoriteCharts.Remove(chartId);
            Snackbar.Add(L["Chart removed from Favorites"].Value, Severity.Success);
        }
        else
        {
            await Mediator.Send(new SaveChartToListCommand(ChartListType.Favorite, chartId));
            _favoriteCharts.Add(chartId);
            Snackbar.Add(L["Chart added to Favorites"].Value, Severity.Success);
        }
    }

    // ---- quick record ---------------------------------------------------------------

    private bool _quickRecordOpen;
    private ChartSearchResult? _quickRecordTarget;

    private void OpenQuickRecord(ChartSearchResult target)
    {
        _quickRecordTarget = target;
        _quickRecordOpen = true;
    }

    private void OnQuickRecordSaved(RecordScoreForm.Result result)
    {
        var target = _quickRecordTarget;
        if (target == null) return;

        // The card's overlay updates in place — no refetch; the search projection catches
        // up on the next load.
        var my = new ChartSearchMyState(
            result.PhoenixScore == null ? null : (int)result.PhoenixScore.Value,
            result.PhoenixGrade, result.Plate, result.LegacyGrade, result.LegacyScore, result.IsBroken,
            Clock.Now, !result.IsBroken, target.My?.PassedInAnotherScopeMix ?? false);
        _results = _results
            .Select(r => r.Chart.Id == target.Chart.Id ? r with { My = my } : r)
            .ToList();
        Snackbar.Add(L["Recorded {0}", $"{target.Chart.Song.Name} {target.Chart.DifficultyDisplay}"].Value,
            Severity.Success);
    }

