    private static string ScoreStateName(ChartScoreStateFilter state)
    {
        return state switch
        {
            ChartScoreStateFilter.Unplayed => "Unplayed",
            ChartScoreStateFilter.Played => "Played",
            ChartScoreStateFilter.Passed => "Passed",
            ChartScoreStateFilter.Failed => "Failed",
            _ => state.ToString()
        };
    }

    /// <summary>The active sort's value, printed on every card — the auto-surface rule.</summary>
    private string? LeadFact(ChartSearchResult result)
    {
        return _sort switch
        {
            ChartSearchSort.ScoringLevel when result.Chart.Mix.UsesLegacyScoring() =>
                result.CommunityVoteRating == null ? null : $"{L["Community Vote"]} {result.CommunityVoteRating.Value:0.0}",
            ChartSearchSort.ScoringLevel =>
                result.ScoringLevel == null ? null : $"{L["Scoring level"]} {result.ScoringLevel.Value:0.0}",
            ChartSearchSort.DebutEra => $"{L["Debut"]}: {result.DebutMix.GetName()}",
            ChartSearchSort.MyRecent when result.My?.RecordedOn != null =>
                result.My.RecordedOn.Value.ToString("yyyy-MM-dd"),
            _ => null
        };
    }

