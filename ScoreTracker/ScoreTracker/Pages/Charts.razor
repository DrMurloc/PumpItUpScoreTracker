    private string TierRangeLabel(List<TierListCategory> selected)
    {
        if (selected.Count == 0) return L["Any"];
        var low = L[ChartSearchCard.CategoryName(RankedCategories[TierLow(selected)])].Value;
        var high = L[ChartSearchCard.CategoryName(RankedCategories[TierHigh(selected)])].Value;
        return low == high ? low : $"{low} – {high}";
    }

    private string LevelRangeLabel => _levelMin == null && _levelMax == null
        ? L["Any"]
        : $"{_levelMin ?? DifficultyLevel.Min}–{_levelMax ?? DifficultyLevel.Max}";

    private string DurationRangeLabel => _durationMin == null && _durationMax == null
        ? L["Any"]
        : $"{FormatDuration(_durationMin) ?? "0:00"}–{FormatDuration(_durationMax) ?? "∞"}";

    private string RangeLabel(decimal? from, decimal? to, decimal? floor, decimal? ceiling)
    {
        if (from == null && to == null) return L["Any"];
        return $"{from ?? floor ?? 0:0.#}–{to ?? ceiling ?? 0:0.#}";
    }

    private string RangeLabel(int? from, int? to, int? floor, int? ceiling)
    {
        return RangeLabel((decimal?)from, (decimal?)to, (decimal?)floor, (decimal?)ceiling);
    }

