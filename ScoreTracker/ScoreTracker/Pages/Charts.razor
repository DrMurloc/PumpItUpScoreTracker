@page "/Charts"
@rendermode RenderModes.Interactive
@using MediatR
@using ScoreTracker.Application.Commands
@using ScoreTracker.Application.Queries
@using ScoreTracker.Catalog.Contracts
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services.Contracts
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType
<PageTitle>@L["Charts"]</PageTitle>

@* The SRP page stack (docs/design/charts-srp.md): page header with the scope mode, then
   the query as one chip language, then the answer line (count + controls), then results.
   No search input — Song name contains is a drawer filter; filters live behind the funnel. *@
<div class="srp-head">
    <MudText Typo="Typo.h4" Class="srp-title">@L["Charts"]</MudText>
    <MudButtonGroup OverrideStyles="false" Class="srp-scope">
        <MudButton Variant="@(!_allMixes ? Variant.Filled : Variant.Outlined)"
                   Color="@(!_allMixes ? Color.Primary : Color.Default)"
                   OnClick="() => SetScope(false)">@_mix.GetName()</MudButton>
        <MudButton Variant="@(_allMixes ? Variant.Filled : Variant.Outlined)"
                   Color="@(_allMixes ? Color.Primary : Color.Default)"
                   OnClick="() => SetScope(true)">@L["All Mixes"]</MudButton>
    </MudButtonGroup>
</div>

<div class="srp-chip-row" role="list" aria-label="@L["Applied filters"]">
    @foreach (var chip in QueryChips)
    {
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                 Class="@(chip.IsSort ? "srp-chip srp-chip-sort" : "srp-chip")"
                 OnClose="() => chip.Remove()" CloseIcon="@Icons.Material.Filled.Close">@chip.Label</MudChip>
    }
    @if (QueryChips.Count >= 2)
    {
        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearAllFilters">@L["Clear all"]</MudButton>
    }
</div>

<div class="srp-answer">
    <MudText Typo="Typo.subtitle1" Class="srp-count">
        @if (_isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary"></MudProgressCircular>
        }
        else
        {
            @L["{0} charts", _totalCount.ToString("N0")]
        }
    </MudText>
    <MudSpacer></MudSpacer>
    <MudTooltip Text="@L["Sort by"]">
        <MudMenu Icon="@Icons.Material.Filled.SwapVert" Dense="true" AriaLabel="@L["Sort by"]">
            @foreach (var sort in AvailableSorts)
            {
                <MudMenuItem Icon="@(sort == _sort ? (_sortDescending ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward) : string.Empty)"
                             OnClick="() => SelectSort(sort)">@L[SortName(sort)]</MudMenuItem>
            }
        </MudMenu>
    </MudTooltip>
    <MudTooltip Text="@L["Filters"]">
        <MudBadge Content="ActiveFilterCount" Visible="ActiveFilterCount > 0" Color="Color.Primary" Overlap="true">
            <MudIconButton Icon="@Icons.Material.Filled.FilterList" Color="Color.Primary" Variant="Variant.Outlined"
                           OnClick="() => _filtersOpen = true" aria-label="@L["Filters"]"></MudIconButton>
        </MudBadge>
    </MudTooltip>
</div>

@if (!_isLoading && _totalCount == 0)
{
    <div class="srp-empty">
        <MudText Typo="Typo.h6">@L["No charts match these filters"]</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ClearAllFilters">@L["Clear all"]</MudButton>
    </div>
}
else
{
    <div class="srp-grid">
        @foreach (var result in _results)
        {
            <ChartSearchCard Result="result" LeadFact="@LeadFact(result)"
                             ShowMyState="CurrentUser.IsLoggedIn"
                             ShowActions="CurrentUser.IsLoggedIn"
                             IsFavorite="_favoriteCharts.Contains(result.Chart.Id)"
                             IsToDo="_todoCharts.Contains(result.Chart.Id)"
                             OnToggleFavorite="ToggleFavorite"
                             OnToggleToDo="ToggleToDo"></ChartSearchCard>
        }
    </div>
    @if (PageCount > 1)
    {
        <div class="srp-pager">
            <MudPagination Count="PageCount" Selected="_pageNumber" SelectedChanged="GoToPage"
                           Color="Color.Primary" Size="Size.Small"></MudPagination>
        </div>
    }
}

<MudLayout>
    <MudDrawer @bind-Open="_filtersOpen" Anchor="Anchor.Right" Variant="@DrawerVariant.Temporary" Width="340px">
        <div class="srp-drawer">
            <div class="srp-drawer-head">
                <MudText Typo="Typo.h6">@L["Filters"]</MudText>
                <MudSpacer></MudSpacer>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => _filtersOpen = false"
                               aria-label="@L["Close"]"></MudIconButton>
            </div>
            <MudTextField T="string" Value="_songNameContains" ValueChanged="SetSongNameContains"
                          Label="@L["Song name contains"]" Clearable="true"
                          Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
            <div class="srp-drawer-range">
                <MudNumericField T="int?" Value="_levelMin" ValueChanged="SetLevelMin" Label="@L["Level from"]"
                                 Min="DifficultyLevel.Min" Max="DifficultyLevel.Max" Variant="Variant.Outlined"
                                 Margin="Margin.Dense" Clearable="true"></MudNumericField>
                <MudNumericField T="int?" Value="_levelMax" ValueChanged="SetLevelMax" Label="@L["Level to"]"
                                 Min="DifficultyLevel.Min" Max="DifficultyLevel.Max" Variant="Variant.Outlined"
                                 Margin="Margin.Dense" Clearable="true"></MudNumericField>
            </div>
            <MudSelect T="string" MultiSelection="true" SelectedValues="_types.Select(t => t.ToString())"
                       SelectedValuesChanged="SetTypes" Label="@L["Chart Type"]" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Clearable="true">
                @foreach (var type in Enum.GetValues<ChartType>())
                {
                    <MudSelectItem T="string" Value="@type.ToString()">@type.GetShortHand()</MudSelectItem>
                }
            </MudSelect>
            @if (CurrentUser.IsLoggedIn)
            {
                <MudSelect T="ChartScoreStateFilter?" Value="_scoreState" ValueChanged="SetScoreState"
                           Label="@L["Score State"]" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    <MudSelectItem T="ChartScoreStateFilter?" Value="ChartScoreStateFilter.Unplayed">@L["Unplayed"]</MudSelectItem>
                    <MudSelectItem T="ChartScoreStateFilter?" Value="ChartScoreStateFilter.Played">@L["Played"]</MudSelectItem>
                    <MudSelectItem T="ChartScoreStateFilter?" Value="ChartScoreStateFilter.Passed">@L["Passed"]</MudSelectItem>
                    <MudSelectItem T="ChartScoreStateFilter?" Value="ChartScoreStateFilter.Failed">@L["Failed"]</MudSelectItem>
                </MudSelect>
            }
        </div>
    </MudDrawer>
</MudLayout>

@inject IMediator Mediator
@inject NavigationManager NavManager
@inject ICurrentUserAccessor CurrentUser
@inject IUiSettingsAccessor UiSettings
@inject ISnackbar Snackbar
@inject IJSRuntime Javascript
@code {

    private MixEnum _mix = MixEnum.Phoenix;
    private bool _allMixes;
    private bool _filtersOpen;
    private bool _isLoading = true;
    private bool _initialized;

    private string? _songNameContains;
    private int? _levelMin;
    private int? _levelMax;
    private List<ChartType> _types = new();
    private List<SongType> _songTypes = new();
    private List<string> _artists = new();
    private ChartScoreStateFilter? _scoreState;
    private ChartSearchSort _sort = ChartSearchSort.Level;
    private bool _sortDescending = true;
    private int _pageNumber = 1;
    private const int PageSize = 24;

    private IReadOnlyList<ChartSearchResult> _results = Array.Empty<ChartSearchResult>();
    private int _totalCount;
    private ISet<Guid> _favoriteCharts = new HashSet<Guid>();
    private ISet<Guid> _todoCharts = new HashSet<Guid>();

    private int PageCount => (int)Math.Ceiling(_totalCount / (double)PageSize);

    private static readonly ChartSearchSort[] SortOrder =
    {
        ChartSearchSort.Level, ChartSearchSort.ScoringLevel, ChartSearchSort.Popularity, ChartSearchSort.PassRate,
        ChartSearchSort.DebutEra, ChartSearchSort.Name, ChartSearchSort.Bpm, ChartSearchSort.Nps,
        ChartSearchSort.Duration, ChartSearchSort.MyGrade, ChartSearchSort.MyRecent
    };

    private IEnumerable<ChartSearchSort> AvailableSorts => CurrentUser.IsLoggedIn
        ? SortOrder
        : SortOrder.Where(s => s is not (ChartSearchSort.MyGrade or ChartSearchSort.MyRecent));

    // ---- query-string contract ------------------------------------------------------

    [Parameter] [SupplyParameterFromQuery(Name = "Song")] public string? SongParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "LevelMin")] public int? LevelMinParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "LevelMax")] public int? LevelMaxParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Type")] public string? TypeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SongType")] public string? SongTypeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Artist")] public string? ArtistParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "State")] public string? StateParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Sort")] public string? SortParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Dir")] public string? DirParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Scope")] public string? ScopeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "Page")] public int? PageParam { get; set; }

    // The old page's parameter names, honored as read-time aliases so shared links keep
    // working. SongName was an exact match; it maps onto the contains filter.
    [Parameter] [SupplyParameterFromQuery(Name = "Difficulty")] public int? LegacyDifficultyParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "ChartType")] public string? LegacyChartTypeParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SongName")] public string? LegacySongNameParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "SongArtist")] public string? LegacySongArtistParam { get; set; }
    [Parameter] [SupplyParameterFromQuery(Name = "ScoreState")] public string? LegacyScoreStateParam { get; set; }

    private void ParseQuery()
    {
        _songNameContains = SongParam ?? LegacySongNameParam;
        _levelMin = LevelMinParam ?? LegacyDifficultyParam;
        _levelMax = LevelMaxParam ?? LegacyDifficultyParam;
        _types = ParseCsvEnum<ChartType>(TypeParam ?? LegacyChartTypeParam);
        _songTypes = ParseCsvEnum<SongType>(SongTypeParam);
        _artists = (ArtistParam ?? LegacySongArtistParam)?
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList() ?? new List<string>();
        _scoreState = Enum.TryParse<ChartScoreStateFilter>(StateParam, true, out var state)
            ? state
            : LegacyScoreStateParam?.ToLowerInvariant() switch
            {
                "passed" => ChartScoreStateFilter.Passed,
                "broken" or "notpassed" => ChartScoreStateFilter.Failed,
                "ungraded" => ChartScoreStateFilter.Unplayed,
                _ => null
            };
        _sort = Enum.TryParse<ChartSearchSort>(SortParam, true, out var sort) ? sort : ChartSearchSort.Level;
        _sortDescending = DirParam?.ToLowerInvariant() != "asc" &&
                          (DirParam?.ToLowerInvariant() == "desc" || DefaultDescending(_sort));
        _allMixes = string.Equals(ScopeParam, "all", StringComparison.OrdinalIgnoreCase);
        _pageNumber = Math.Max(1, PageParam ?? 1);
    }

    private static List<T> ParseCsvEnum<T>(string? csv) where T : struct, Enum
    {
        return csv?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(v => Enum.TryParse<T>(v, true, out var parsed) ? parsed : (T?)null)
            .Where(v => v != null)
            .Select(v => v!.Value)
            .Distinct()
            .ToList() ?? new List<T>();
    }

    private async Task PushUrl(bool replace = false)
    {
        var url = NavManager.GetUriWithQueryParameters("/Charts", new Dictionary<string, object?>
        {
            ["Song"] = string.IsNullOrWhiteSpace(_songNameContains) ? null : _songNameContains,
            ["LevelMin"] = _levelMin,
            ["LevelMax"] = _levelMax,
            ["Type"] = _types.Count == 0 ? null : string.Join(',', _types),
            ["SongType"] = _songTypes.Count == 0 ? null : string.Join(',', _songTypes),
            ["Artist"] = _artists.Count == 0 ? null : string.Join(',', _artists),
            ["State"] = _scoreState?.ToString(),
            ["Sort"] = IsDefaultSort ? null : _sort.ToString(),
            ["Dir"] = IsDefaultSort || _sortDescending == DefaultDescending(_sort)
                ? null
                : _sortDescending ? "desc" : "asc",
            ["Scope"] = _allMixes ? "all" : null,
            ["Page"] = _pageNumber <= 1 ? null : _pageNumber
        });
        await Javascript.InvokeVoidAsync(replace ? "history.replaceState" : "history.pushState", null, "", url);
    }

    // ---- loading --------------------------------------------------------------------

    protected override async Task OnInitializedAsync()
    {
        _mix = await UiSettings.GetSelectedMix();
        ParseQuery();
        if (CurrentUser.IsLoggedIn)
        {
            var saves = (await Mediator.Send(new GetSavedChartsQuery())).ToArray();
            _favoriteCharts = saves.Where(s => s.ListType == ChartListType.Favorite).Select(s => s.ChartId).ToHashSet();
            _todoCharts = saves.Where(s => s.ListType == ChartListType.ToDo).Select(s => s.ChartId).ToHashSet();
        }

        await LoadPage();
        _initialized = true;
    }

    private SearchChartsQuery BuildQuery()
    {
        return new SearchChartsQuery
        {
            Mix = _mix,
            AllMixes = _allMixes,
            UserId = CurrentUser.IsLoggedIn ? CurrentUser.User.Id : null,
            SongNameContains = _songNameContains,
            LevelMin = _levelMin,
            LevelMax = _levelMax,
            Types = _types.Count == 0 ? null : _types,
            SongTypes = _songTypes.Count == 0 ? null : _songTypes,
            Artists = _artists.Count == 0 ? null : _artists,
            ScoreState = CurrentUser.IsLoggedIn ? _scoreState : null,
            Sort = _sort,
            SortDescending = _sortDescending,
            Page = _pageNumber,
            PageSize = PageSize
        };
    }

    private async Task LoadPage()
    {
        _isLoading = true;
        var page = await Mediator.Send(BuildQuery());
        _results = page.Results;
        _totalCount = page.TotalCount;
        // Landing past the tail (a stale shared link) snaps back to the last real page.
        if (_pageNumber > 1 && _results.Count == 0 && _totalCount > 0)
        {
            _pageNumber = Math.Max(1, PageCount);
            page = await Mediator.Send(BuildQuery());
            _results = page.Results;
            _totalCount = page.TotalCount;
        }

        _isLoading = false;
    }

    private async Task ApplyChange(bool resetPage = true)
    {
        if (resetPage) _pageNumber = 1;
        await PushUrl();
        await LoadPage();
    }

    // ---- chips ----------------------------------------------------------------------

    private sealed record QueryChip(string Label, bool IsSort, Func<Task> Remove);

    private IReadOnlyList<QueryChip> QueryChips
    {
        get
        {
            var chips = new List<QueryChip>();
            if (!IsDefaultSort)
                chips.Add(new QueryChip($"⇅ {L[SortName(_sort)]} {(_sortDescending ? "↓" : "↑")}", true,
                    () => SelectSort(ChartSearchSort.Level, true)));
            if (!string.IsNullOrWhiteSpace(_songNameContains))
                chips.Add(new QueryChip($"{L["Song name"]}: “{_songNameContains}”", false,
                    () => SetSongNameContains(null)));
            if (_levelMin != null || _levelMax != null)
                chips.Add(new QueryChip(LevelChipLabel, false, async () =>
                {
                    _levelMin = null;
                    _levelMax = null;
                    await ApplyChange();
                }));
            foreach (var type in _types)
            {
                var captured = type;
                chips.Add(new QueryChip(captured.GetShortHand(), false, async () =>
                {
                    _types.Remove(captured);
                    await ApplyChange();
                }));
            }

            foreach (var songType in _songTypes)
            {
                var captured = songType;
                chips.Add(new QueryChip(captured.ToString(), false, async () =>
                {
                    _songTypes.Remove(captured);
                    await ApplyChange();
                }));
            }

            foreach (var artist in _artists)
            {
                var captured = artist;
                chips.Add(new QueryChip(captured, false, async () =>
                {
                    _artists.Remove(captured);
                    await ApplyChange();
                }));
            }

            if (_scoreState != null && CurrentUser.IsLoggedIn)
                chips.Add(new QueryChip(L[ScoreStateName(_scoreState.Value)], false, () => SetScoreState(null)));
            return chips;
        }
    }

    private string LevelChipLabel => _levelMin == _levelMax
        ? $"{L["Level"]} {_levelMin}"
        : $"{L["Level"]} {_levelMin?.ToString() ?? DifficultyLevel.Min.ToString()}–{_levelMax?.ToString() ?? DifficultyLevel.Max.ToString()}";

    private int ActiveFilterCount => QueryChips.Count(c => !c.IsSort);

    private async Task ClearAllFilters()
    {
        _songNameContains = null;
        _levelMin = null;
        _levelMax = null;
        _types.Clear();
        _songTypes.Clear();
        _artists.Clear();
        _scoreState = null;
        _sort = ChartSearchSort.Level;
        _sortDescending = true;
        await ApplyChange();
    }

    // ---- control handlers -----------------------------------------------------------

    private async Task SetScope(bool allMixes)
    {
        if (_allMixes == allMixes) return;
        _allMixes = allMixes;
        await ApplyChange();
    }

    private async Task SetSongNameContains(string? value)
    {
        _songNameContains = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        await ApplyChange();
    }

    private async Task SetLevelMin(int? value)
    {
        _levelMin = value;
        await ApplyChange();
    }

    private async Task SetLevelMax(int? value)
    {
        _levelMax = value;
        await ApplyChange();
    }

    private async Task SetTypes(IEnumerable<string>? values)
    {
        _types = ParseCsvEnum<ChartType>(values == null ? null : string.Join(',', values));
        await ApplyChange();
    }

    private async Task SetScoreState(ChartScoreStateFilter? value)
    {
        _scoreState = value;
        await ApplyChange();
    }

    private async Task SelectSort(ChartSearchSort sort, bool forceDefaultDirection = false)
    {
        if (sort == _sort && !forceDefaultDirection)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sort = sort;
            _sortDescending = DefaultDescending(sort);
        }

        await ApplyChange();
    }

    private bool IsDefaultSort => _sort == ChartSearchSort.Level && _sortDescending;

    private static bool DefaultDescending(ChartSearchSort sort)
    {
        return sort switch
        {
            ChartSearchSort.Name => false,
            ChartSearchSort.Duration => false,
            ChartSearchSort.DebutEra => false,
            _ => true
        };
    }

    private async Task GoToPage(int page)
    {
        _pageNumber = page;
        await ApplyChange(resetPage: false);
    }

    // ---- display helpers ------------------------------------------------------------

    internal static string SortName(ChartSearchSort sort)
    {
        return sort switch
        {
            ChartSearchSort.Level => "Level",
            ChartSearchSort.ScoringLevel => "Scoring level",
            ChartSearchSort.Popularity => "Popularity",
            ChartSearchSort.PassRate => "Pass rate",
            ChartSearchSort.DebutEra => "Newest content",
            ChartSearchSort.Name => "Name",
            ChartSearchSort.Bpm => "BPM",
            ChartSearchSort.Nps => "NPS",
            ChartSearchSort.Duration => "Duration",
            ChartSearchSort.MyGrade => "My grade",
            ChartSearchSort.MyRecent => "My recent",
            _ => sort.ToString()
        };
    }

    private static string ScoreStateName(ChartScoreStateFilter state)
    {
        return state switch
        {
            ChartScoreStateFilter.Unplayed => "Unplayed",
            ChartScoreStateFilter.Played => "Played",
            ChartScoreStateFilter.Passed => "Passed",
            ChartScoreStateFilter.Failed => "Failed",
            _ => state.ToString()
        };
    }

    /// <summary>The active sort's value, printed on every card — the auto-surface rule.</summary>
    private string? LeadFact(ChartSearchResult result)
    {
        return _sort switch
        {
            ChartSearchSort.ScoringLevel when result.Chart.Mix.UsesLegacyScoring() =>
                result.CommunityVoteRating == null ? null : $"{L["Community Vote"]} {result.CommunityVoteRating.Value:0.0}",
            ChartSearchSort.ScoringLevel =>
                result.ScoringLevel == null ? null : $"{L["Scoring level"]} {result.ScoringLevel.Value:0.0}",
            ChartSearchSort.DebutEra => $"{L["Debut"]}: {result.DebutMix.GetName()}",
            ChartSearchSort.MyRecent when result.My?.RecordedOn != null =>
                result.My.RecordedOn.Value.ToString("yyyy-MM-dd"),
            _ => null
        };
    }

    // ---- saved lists ----------------------------------------------------------------

    private async Task ToggleFavorite(Guid chartId)
    {
        if (_favoriteCharts.Contains(chartId))
        {
            await Mediator.Send(new RemoveChartFromListCommand(ChartListType.Favorite, chartId));
            _favoriteCharts.Remove(chartId);
            Snackbar.Add(L["Chart removed from Favorites"].Value, Severity.Success);
        }
        else
        {
            await Mediator.Send(new SaveChartToListCommand(ChartListType.Favorite, chartId));
            _favoriteCharts.Add(chartId);
            Snackbar.Add(L["Chart added to Favorites"].Value, Severity.Success);
        }
    }

    private async Task ToggleToDo(Guid chartId)
    {
        if (_todoCharts.Contains(chartId))
        {
            await Mediator.Send(new RemoveChartFromListCommand(ChartListType.ToDo, chartId));
            _todoCharts.Remove(chartId);
            Snackbar.Add(L["Chart removed from To Do list"].Value, Severity.Success);
        }
        else
        {
            await Mediator.Send(new SaveChartToListCommand(ChartListType.ToDo, chartId));
            _todoCharts.Add(chartId);
            Snackbar.Add(L["Chart added to To Do list"].Value, Severity.Success);
        }
    }
}
