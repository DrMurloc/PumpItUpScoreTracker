@page "/UploadPhoenixScores"
@rendermode RenderModes.Interactive
@using ScoreTracker.ScoreLedger.Contracts.Queries
@using ScoreTracker.PlayerProgress.Contracts.Queries
@using ScoreTracker.PlayerProgress.Contracts.Commands
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.ScoreLedger.Contracts.Commands
@using ScoreTracker.OfficialMirror.Contracts
@using ScoreTracker.OfficialMirror.Contracts.Commands
@using ScoreTracker.OfficialMirror.Contracts.Queries
@using ScoreTracker.Identity.Contracts.Commands
@using ScoreTracker.Domain.Models
@using ScoreTracker.SharedKernel.Models
@using MediatR
@using CsvHelper
@using System.Globalization
@using System.Security.Authentication
@using ScoreTracker.Application.Commands
@using ScoreTracker.Application.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Domain.Events
@using ScoreTracker.Domain.Records
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Dtos
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Web.Services.UiNotifications
@using ScoreTracker.Web.Shared
@implements IDisposable
<PageTitle>@L["Import Scores"]</PageTitle>

@* The form is the page (design doc D1/D2): credentials, options and Import sit above the fold;
   the script/CSV flow lives in the manual-import expander below. *@
<MudCard Class="mt-4">
    <MudCardHeader><h2>@L["Import Scores"]</h2></MudCardHeader>
    <MudCardContent>
        <MudText Typo="Typo.body2" Class="mb-4">@L["Import Lede"]</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                @if (_hasStoredCredential)
                {
                    @* Saved credential replaces the username/password fields — the rest of the
                       import (options, game card) proceeds normally against it. *@
                    <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.Lock" Dense="true">
                        <div class="d-flex align-center flex-wrap" style="gap:.5rem">
                            <span>@L["Saved on this device"]</span>
                            <MudButton Size="Size.Small" Disabled="_isImporting"
                                       OnClick="ForgetSavedCredentials">@L["Forget here"]</MudButton>
                        </div>
                    </MudAlert>
                }
                else
                {
                    <MudTextField Label="@L["PIUGame.com Username"]" Disabled="_isImporting" @bind-Value="_username"></MudTextField>
                    <MudTextField InputType="InputType.Password" Disabled="_isImporting" Label="@L["PIUGame.com Password"]"
                                  HelperText="@L["Import Password Helper"]" @bind-Value="_password"></MudTextField>
                }
                @if (_cards.Any())
                {
                    <MudSelect T="string" Value="_selectedId" ValueChanged="SelectId" Label="@L["Game Card"]">
                        @foreach (var gameCard in _cards)
                        {
                            <MudSelectItem T="string" Value="@gameCard.Id">@gameCard.GameTag</MudSelectItem>
                        }
                    </MudSelect>
                }
                else if (!string.IsNullOrWhiteSpace(_selectedId))
                {
                    <MudTooltip Text="@_selectedGameTag">
                        <MudText Typo="Typo.body2" Class="mt-2">
                            @L["Game Card"]: @_selectedGameTag
                        </MudText>
                    </MudTooltip>
                }
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudCheckBox T="bool" Label="@L["Include Broken Scores"]" @bind-Value="_includeBroken" Disabled="_isImporting"></MudCheckBox>
                <MudText Typo="Typo.caption" Class="ml-10 d-block">@L["Import Broken Helper"]</MudText>
                @* A saved credential already says so in the alert — the checkbox only offers
                   the choice while there is a typed password to remember. *@
                @if (!_hasStoredCredential)
                {
                    <MudCheckBox T="bool" Value="_rememberPassword" ValueChanged="OnRememberChanged" Disabled="_isImporting"
                                 Label="@L["Remember my password on this device"]"></MudCheckBox>
                }
                <MudCheckBox T="bool" Label="@L["Also send scores to piutracker.app"]" Disabled="_isImporting"
                             Value="_alsoImportPiuTracker" ValueChanged="d=>SetPiuTrackerImport(d)"></MudCheckBox>
                @if (_alsoImportPiuTracker && !_isPublic)
                {
                    <MudText Typo="Typo.caption" Class="ml-10 d-block" Color="Color.Warning">@L["PIU Tracker is fully public — scores you send there are public even if your profile isn't."]</MudText>
                }
            </MudItem>
            @if (_mergeInviteUserId != null)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info">
                        @L["An account with game tag {0} already exists, is that you?", _mergeInviteTag]
                        <MudButton Class="ml-2" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small"
                                   Href="@($"/Account/Merge?with={_mergeInviteUserId}&returnUrl={System.Web.HttpUtility.UrlEncode("/UploadPhoenixScores")}")">@L["Review and merge"]</MudButton>
                    </MudAlert>
                </MudItem>
            }
            @if (_isImporting)
            {
                <MudItem xs="12">
                    @if (!_scores.Any())
                    {
                        <MudText>@_importStatus</MudText>
                    }
                    <MudText Typo="Typo.caption">@L["You can leave this page."]</MudText>
                </MudItem>
            }
            @if (_importCompleted && CurrentUser.User.IsPublic)
            {
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Timeline"
                               Href="@($"/Player/{CurrentUser.User.Id}/Sessions")"
                               data-testid="view-session-link">
                        @L["View your session"]
                    </MudButton>
                </MudItem>
            }
            @if (_errors.Any())
            {
                <MudItem xs="12">
                    @foreach (var error in _errors)
                    {
                        <MudText Color="Color.Error">@error</MudText>
                    }
                </MudItem>
            }
            @if (_isImporting && !_scores.Any())
            {
                @* The incoming results, shaped before they arrive (UX rule 9) — named, so the
                   empty shimmer reads as "results pending", not a broken render. *@
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="d-block mb-1">@L["Imported scores will appear here as they come in."]</MudText>
                    @for (var i = 0; i < 3; i++)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="48px" Class="mb-2 rounded"></MudSkeleton>
                    }
                </MudItem>
            }
            @if (_scores.Any())
            {
                <MudItem xs="12">
                    <MudTable T="RecordedPhoenixScore" Items="_scores">
                        <ToolBarContent>
                            <MudText>@_importStatus</MudText>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>@L["Song"]</MudTh>
                            <MudTh>@L["Difficulty"]</MudTh>
                            <MudTh>@L["Score"]</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <SongImage Song="_charts[context.ChartId].Song"></SongImage>
                            </MudTd>
                            <MudTd>
                                <DifficultyBubble Chart="_charts[context.ChartId]"></DifficultyBubble>
                            </MudTd>
                            <MudTd>
                                <ScoreBreakdown Score="context.Score" Plate="context.Plate" ShowScore="true" OneLine="true"
                                                Ranking="_rankings.TryGetValue(context.ChartId, out var r) ? r : null"></ScoreBreakdown>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager></MudTablePager>
                        </PagerContent>
                    </MudTable>
                </MudItem>
            }
        </MudGrid>
    </MudCardContent>
    <MudCardActions>
        <MudSpacer></MudSpacer>
        @* Card switching needs the typed password (a saved credential stays sealed), so it's
           only offered on the typed path. *@
        @if (!_cards.Any() && !string.IsNullOrWhiteSpace(_selectedId) && !_hasStoredCredential)
        {
            <MudButton Variant="Variant.Outlined"
                       Disabled="_isImporting || string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password)"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ChangeCircle"
                       OnClick="LoadCards">@L["Change Card"]</MudButton>
        }
        @* The phone-width Import lives in the page dock; this is its desktop seat. *@
        <MudButton Variant="Variant.Filled"
                   Class="shell-desktop-only"
                   Disabled="@ImportDisabled"
                   Color="Color.Primary"
                   StartIcon="@(_isImporting ? null : Icons.Material.Filled.ImportExport)"
                   OnClick="ImportScores">
            @if (_isImporting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
            }
            @L["Import"]
        </MudButton>
    </MudCardActions>
</MudCard>

@* The technical fallback (design doc D3): everything the script/CSV flow could do, collapsed. *@
<MudExpansionPanels Class="mt-4">
    <MudExpansionPanel Text="@L["Manual import — console script + CSV"]">
        <MudText Typo="Typo.caption" Class="d-block mb-3">@L["For re-importing older scores"]</MudText>
        @switch (_csvStep)
        {
            case CsvStep.Idle:
                @* Page range comes first — the copied script embeds it, so copying before
                   picking pages would hand out a stale script. *@
                <ol class="import-manual-steps">
                    <li>
                        <MudText Typo="Typo.body2">@L["Import Manual Step 1"]</MudText>
                        <MudGrid Spacing="2" Class="mt-0">
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="int" Min="1" Label="@L["From page"]" @bind-Value="_startPage"></MudNumericField>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="int?" Min="1" Label="@L["To page"]" @bind-Value="_endPage" Clearable="true"></MudNumericField>
                            </MudItem>
                        </MudGrid>
                    </li>
                    <li>
                        <MudText Typo="Typo.body2">@L["Import Manual Step 2"]</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mt-1"
                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                   OnClick="CopyPIUGameScript">@L["Copy Script"]</MudButton>
                    </li>
                    <li>
                        <MudText Typo="Typo.body2">@L["Import Manual Step 3"]</MudText>
                    </li>
                    <li>
                        <MudText Typo="Typo.body2">@L["Import Manual Step 4"]</MudText>
                        <MudButton HtmlTag="label"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Class="mt-1"
                                   StartIcon="@Icons.Material.Filled.UploadFile"
                                   for="uploadInput">@L["Upload CSV"]</MudButton>
                    </li>
                </ol>
                break;
            case CsvStep.Uploading:
                <MudText Typo="Typo.body2" Class="mb-2">@L["Phoenix Import Uploading"]</MudText>
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Size="Size.Large"></MudProgressLinear>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-2"
                           StartIcon="@Icons.Material.Filled.Cancel" OnClick="Cancel">@L["Cancel"]</MudButton>
                break;
            case CsvStep.Confirming:
                <MudText Typo="Typo.body2">
                    <b>@L["Scores Parsed"]:</b> @_spreadSheetScores.Count
                    <br/>
                    <b>@L["Parse Failures"]:</b> @_failedUploads.Count
                </MudText>
                <MudText Typo="Typo.body2" Class="mt-2 mb-2">@L["Import Confirming"]</MudText>
                <div class="d-flex flex-wrap" style="gap:.5rem">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save" OnClick="SaveScores">@L["Save Scores"]</MudButton>
                    @if (_failedUploads.Any())
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.FileDownload" OnClick="DownloadFailures">@L["Download Failures"]</MudButton>
                    }
                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Cancel" OnClick="Cancel">@L["Cancel"]</MudButton>
                </div>
                break;
            case CsvStep.Saving:
                <MudText Typo="Typo.body2" Class="mb-2">@L["Import Saving"]</MudText>
                <span>
                    @L["Phoenix Import Saving Progress", _currentSaved, _maxSaving, RemainingTimeString, _failedUploads.Count]
                </span>
                <MudProgressLinear Color="Color.Primary" Size="Size.Large" Value="_currentSaved" Min="1" Max="_maxSaving"/>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-2"
                           StartIcon="@Icons.Material.Filled.Cancel" OnClick="Cancel">@L["Cancel"]</MudButton>
                break;
            case CsvStep.Finished:
                <MudText Typo="Typo.body2" Class="mb-2">
                    @(_failedUploads.Any() ? L["Import Failures"] : L["Phoenix Import Saving Success"])
                </MudText>
                <div class="d-flex flex-wrap" style="gap:.5rem">
                    @if (_failedUploads.Any())
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.FileDownload" OnClick="DownloadFailures">@L["Download Failures"]</MudButton>
                    }
                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="@(_ => _csvStep = CsvStep.Idle)">@L["Restart"]</MudButton>
                </div>
                break;
        }
    </MudExpansionPanel>
</MudExpansionPanels>

<PageDock>
    <MudButton Class="dock-cta"
               Disabled="@ImportDisabled"
               StartIcon="@(_isImporting ? null : Icons.Material.Filled.ImportExport)"
               OnClick="ImportScores">
        @if (_isImporting)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
        }
        @L["Import"]
    </MudButton>
</PageDock>
<InputFile id="uploadInput" OnChange="@UploadFile" hidden accept=".csv,.xlsx"/>

@inject NavigationManager NavManager
@inject ICurrentUserAccessor CurrentUser;
@inject IUiSettingsAccessor UiSettings;
@inject IMediator Mediator;
@inject ISnackbar Snackbar;
@inject IPhoenixScoreFileExtractor Extractor;
@inject IJSRuntime JSRuntime;
@inject ILogger<UploadPhoenixScores> Logger;
@inject IImportCredentialClientStore ClientStore;
@inject IDialogService DialogService;
@inject IUiNotificationHub UiHub;
@code
{
    // The spreadsheet pipeline's own states — the password form is not a step, it is the page.
    private enum CsvStep
    {
        Idle,
        Uploading,
        Confirming,
        Saving,
        Finished
    }

    private CsvStep _csvStep = CsvStep.Idle;
    private MixEnum _currentMix = MixEnum.Phoenix;
    private int _maxSaving = 0;
    private int _currentSaved = 0;
    private int _startPage = 1;
    private bool _isPublic = false;
    private string _username = "";
    private string _password = "";
    private bool _includeBroken = false;
    private bool _rememberPassword = false;
    private bool _hasStoredCredential = false;
    private const string RememberConsentKey = "RememberPasswordConsent";
    private const string RememberConsentVersion = "1";

    private bool ImportDisabled =>
        _isImporting || (!_hasStoredCredential && (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password)));

    // Import using the credential saved on this device — the Import button routes here when one is
    // stored. Reuses the background path (StoredCredentialSource), so the password is never re-typed
    // and never leaves the encrypted blob. Options (broken scores, PIU Tracker, game card) apply.
    private async Task ImportWithSavedCredentials()
    {
        var blob = await ClientStore.Read();
        if (blob == null)
        {
            _hasStoredCredential = false;
            _isImporting = false;
            return;
        }

        _isImporting = true;
        _errors.Clear();
        _scores.Clear();
        _importCompleted = false;
        _importStatus = L["Starting Import..."].Value;
        var result = await Mediator.Send(new StartOfficialImportCommand(
            new StoredCredentialSource(blob.KeyId, blob.Ciphertext), _currentMix, _selectedId, _selectedGameTag,
            _includeBroken, _alsoImportPiuTracker));
        switch (result.Outcome)
        {
            case ImportStartOutcome.Started:
                // Status and completion arrive over the hub (StatusUpdate).
                break;
            case ImportStartOutcome.CredentialUnlockFailed:
                _hasStoredCredential = false;
                _isImporting = false;
                _importStatus = L["Invalid Username/Password"].Value;
                Snackbar.Add(L["Couldn't unlock your saved password. Enter it to import."].Value, Severity.Warning);
                break;
            case ImportStartOutcome.InvalidCredentials:
                _isImporting = false;
                _importStatus = L["Invalid Username/Password"].Value;
                Snackbar.Add(L["Saved Password Incorrect"].Value, Severity.Error);
                break;
            case ImportStartOutcome.AlreadyRunning:
                _isImporting = false;
                Snackbar.Add(L["An import is already running"].Value, Severity.Info);
                break;
        }
    }

    private async Task ForgetSavedCredentials()
    {
        await ClientStore.Clear();
        _hasStoredCredential = false;
        _rememberPassword = false;
    }

    private async Task OnRememberChanged(bool value)
    {
        if (!value)
        {
            _rememberPassword = false;
            return;
        }

        var consent = await UiSettings.GetSetting(RememberConsentKey);
        if (consent != RememberConsentVersion)
        {
            var dialog = await DialogService.ShowAsync<RememberPasswordDisclaimerDialog>(
                L["Before we remember your password"].Value);
            var result = await dialog.Result;
            if (result is null || result.Canceled)
            {
                _rememberPassword = false;
                return;
            }

            await UiSettings.SetSetting(RememberConsentKey, RememberConsentVersion);
        }

        _rememberPassword = true;
    }
    private bool _alsoImportPiuTracker  = false;
    private const string PiuTrackerKey = "UploadPhoenixScores__ImportPiuTracker";
    public async Task SetPiuTrackerImport(bool newValue)
    {
        _alsoImportPiuTracker = newValue;
        await UiSettings.SetSetting(PiuTrackerKey, newValue.ToString());
    }
    private string _selectedGameTag = "";
    private string _selectedId = "";
    private IEnumerable<GameCardRecord> _cards = Array.Empty<GameCardRecord>();

    private async Task SelectId(string id)
    {
        _selectedGameTag = _cards.First(c => c.Id == id).GameTag;
        _selectedId = id;
        await CheckMergeInvite();
    }

    private Guid? _mergeInviteUserId;
    private string _mergeInviteTag = "";

    // Requirement: an import that surfaces a game tag another account already carries offers
    // a merge. Invitation only — the wizard's prove step is the security gate.
    private async Task CheckMergeInvite()
    {
        _mergeInviteUserId = null;
        if (string.IsNullOrWhiteSpace(_selectedGameTag)) return;
        var match = (await Mediator.Send(new GetUsersByGameTagQuery(_selectedGameTag)))
            .FirstOrDefault(u => u.Id != CurrentUser.User.Id);
        if (match == null) return;
        _mergeInviteUserId = match.Id;
        _mergeInviteTag = _selectedGameTag;
    }

    private async Task LoadCards()
    {
        _isImporting = true;

        try
        {
            _cards = (await Mediator.Send(new GetGameCardsQuery(_username, _password))).ToArray();
        }
        catch (InvalidCredentialException)
        {
            _importStatus = L["Invalid Username/Password"].Value;
            Snackbar.Add(L["Password Incorrect"].Value, Severity.Error);
        }
        catch (Exception e)
        {
            _importStatus = L["The import ran into an error."].Value;
            Logger.LogError(e, "There was an error while importing scores");
            Snackbar.Add(L["Import Error Notify"].Value, Severity.Error);
        }
        _isImporting = false;
    }
    private async Task ImportScores()
    {
        if (_isImporting) return;
        // Flip to importing and render before the slow sign-in so the button disables and shows a
        // spinner immediately, instead of looking inert and staying spammable while SignIn runs.
        _isImporting = true;
        _errors.Clear();
        StateHasChanged();

        // A saved credential takes the sealed-blob path; typing takes the credential path below.
        if (_hasStoredCredential)
        {
            await ImportWithSavedCredentials();
            return;
        }

        try
        {
            if (string.IsNullOrWhiteSpace(_selectedId))
            {
                _cards = (await Mediator.Send(new GetGameCardsQuery(_username, _password))).ToArray();
                if (_cards.Count() > 1)
                {
                    _selectedId = _cards.First(c => c.IsActive).Id;
                    _selectedGameTag = _cards.First(c => c.IsActive).GameTag;
                    await CheckMergeInvite();
                    Snackbar.Add(L["Choose a game card, then press Import again."].Value, Severity.Info);
                    _isImporting = false;
                    return;
                }
                _selectedId = _cards.First().Id;
                _selectedGameTag = _cards.First().GameTag;
                await CheckMergeInvite();
            }
            await UiSettings.SetSetting($"PhoenixScoreUpload__LastGameId", _selectedId);
            await UiSettings.SetSetting($"PhoenixScoreUpload__LastGameTag", _selectedGameTag);

            _scores.Clear();
            _importCompleted = false;
            _importStatus = L["Starting Import..."].Value;
            // Hand the scrape to the background job: SignIn runs now (a bad password is caught
            // immediately), then status + completion arrive over the hub while the page stays
            // usable — the user can leave. Terminal state is flipped by StatusUpdate/ImportError.
            var result = await Mediator.Send(new StartOfficialImportCommand(
                new TypedCredentialSource(_username, _password), _currentMix, _selectedId, _selectedGameTag,
                _includeBroken, _alsoImportPiuTracker));
            switch (result.Outcome)
            {
                case ImportStartOutcome.Started:
                    // SignIn succeeded, so the credentials authenticated — safe to remember now.
                    // A storage failure is isolated so it can't read as an import failure.
                    if (_rememberPassword)
                    {
                        try
                        {
                            var stored = await Mediator.Send(new StoreImportCredentialCommand(_username, _password));
                            await ClientStore.Write(new StoredCredentialBlob(stored.KeyId, stored.Ciphertext, 0));
                            _hasStoredCredential = true;
                        }
                        catch (Exception e)
                        {
                            Logger.LogError(e, "Import started but storing the remembered credential failed");
                            Snackbar.Add(L["Could not save your password"].Value, Severity.Error);
                        }
                    }
                    break;
                case ImportStartOutcome.InvalidCredentials:
                case ImportStartOutcome.CredentialUnlockFailed:
                    _isImporting = false;
                    _importStatus = L["Invalid Username/Password"].Value;
                    Snackbar.Add(L["Password Incorrect"].Value, Severity.Error);
                    break;
                case ImportStartOutcome.AlreadyRunning:
                    _isImporting = false;
                    Snackbar.Add(L["An import is already running"].Value, Severity.Info);
                    break;
            }
        }
        catch (InvalidCredentialException)
        {
            _isImporting = false;
            _importStatus = L["Invalid Username/Password"].Value;
            Snackbar.Add(L["Password Incorrect"].Value, Severity.Error);
        }
        catch (Exception e)
        {
            _isImporting = false;
            _importStatus = L["The import ran into an error."].Value;
            Logger.LogError(e, "There was an error while importing scores");
            Snackbar.Add(L["Import Error Notify"].Value, Severity.Error);
        }
    }
    private bool _isImporting = false;
    private bool _importCompleted = false;
    private int? _endPage = null;
    private TimeSpan _remainingTime = TimeSpan.Zero;
    // No estimate until at least one save has landed.
    private string RemainingTimeString => _currentSaved > 0 ? _remainingTime.ToString(@"m\:ss") : "-:--";
    private IDictionary<Guid,Chart> _charts = new Dictionary<Guid, Chart>();
    private readonly ICollection<RecordedPhoenixScore>_scores = new List<RecordedPhoenixScore>();
    private List<SpreadsheetScoreErrorDto> _failedUploads = new List<SpreadsheetScoreErrorDto>();
    private List<RecordedPhoenixScore> _spreadSheetScores = new List<RecordedPhoenixScore>();
    private CancellationTokenSource _currentCancellation = new CancellationTokenSource();
    private string _importStatus = string.Empty;
    private Guid _userId;
    private readonly List<IDisposable> _subscriptions = new();
    protected override async Task OnInitializedAsync()
    {
        _currentMix = await UiSettings.GetSelectedMix();
        _charts = (await Mediator.Send(new GetChartsQuery(_currentMix))).ToDictionary(c => c.Id);
        if (!CurrentUser.IsLoggedIn)
        {
            NavManager.NavigateTo("/Login");
            return;
        }
        _isPublic = CurrentUser.User.IsPublic;
        _userId = CurrentUser.User.Id;
        // This user's import feed, routed by user topic (no cross-user status/culture leak).
        _subscriptions.Add(UiHub.Subscribe<ImportStatusUpdatedEvent>(UiTopics.User(_userId), StatusUpdate));
        _subscriptions.Add(UiHub.Subscribe<ImportStatusErrorEvent>(UiTopics.User(_userId), ImportError));
        _selectedId = await UiSettings.GetSetting("PhoenixScoreUpload__LastGameId") ?? "";
        _selectedGameTag = await UiSettings.GetSetting("PhoenixScoreUpload__LastGameTag") ?? "";
        _alsoImportPiuTracker = bool.TryParse(await UiSettings.GetSetting(PiuTrackerKey), out var v) && v;
        // Detect a credential already saved on this device so we can offer a one-click import
        // instead of asking for the password again; the checkbox reflects the saved state.
        _hasStoredCredential = await ClientStore.Read() != null;
        _rememberPassword = _hasStoredCredential;
    }

    private List<string> _errors = new List<string>();
    // The hub already routed by user; only mix labelling remains. Marshal onto the circuit.
    private Task ImportError(ImportStatusErrorEvent e)
    {
        return InvokeAsync(() =>
        {
            // Events arrive per mix now — name the mix when it isn't the Phoenix default.
            _errors.Add(e.Mix != MixEnum.Phoenix ? $"[{e.Mix.GetName()}] {e.Error}" : e.Error);
            // A background (saved-credential) import reports failure here, not through a return
            // value — release the importing state so the page is usable again.
            _isImporting = false;
            StateHasChanged();
        });
    }
    private Task StatusUpdate(ImportStatusUpdatedEvent e)
    {
        return InvokeAsync(async () =>
        {
            foreach (var score in e.Scores)
            {
                _scores.Add(score);
            }
            _importStatus = e.Mix != MixEnum.Phoenix ? $"[{e.Mix.GetName()}] {e.Status}" : e.Status;
            // Terminal status for a background (saved-credential) import — the synchronous typed
            // path already flips these itself, so setting them again is harmless.
            if (e.Status == "Charts finished saving")
            {
                _isImporting = false;
                _importCompleted = true;
            }
            await GetRatings();
        });
    }

    private IDictionary<Guid, ScoreRankingRecord> _rankings = new Dictionary<Guid, ScoreRankingRecord>();
    private async Task GetRatings()
    {
        _rankings = await Mediator.Send(new GetChartScoreRankingsQuery(_scores.Select(s => s.ChartId), _currentMix));
        StateHasChanged();
    }
    private void Cancel()
    {
        _csvStep = CsvStep.Idle;
        _currentCancellation?.Cancel();
    }


    private async Task DownloadFailures()
    {

        var stream = new MemoryStream();
        await using var writer = new StreamWriter(stream);
        await using var csv = new CsvWriter(writer, CultureInfo.InvariantCulture);
        await csv.WriteRecordsAsync(_failedUploads);
        await writer.FlushAsync();
        await csv.FlushAsync();
        const string fileName = "failedUploads.csv";

        using var streamRef = new DotNetStreamReference(stream: stream);
        stream.Seek(0, SeekOrigin.Begin);

        var module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/helpers.js");
        await module.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);

    }

    private async Task SaveScores()
    {
        _csvStep = CsvStep.Saving;
        _currentCancellation = new CancellationTokenSource();
        var cancellationToken = _currentCancellation.Token;
        _currentSaved = 0;
        var startTime = DateTimeOffset.Now;
        // One upload = one session.
        var uploadSessionId = Guid.NewGuid();
        var myScores = (await Mediator.Send(new GetPhoenixRecordsQuery(_userId, _currentMix), cancellationToken)).ToDictionary(s => s.ChartId);
        // Same improvement guard as the official import: a stale or re-uploaded file must
        // never regress records, and unchanged rows must not reach the ledger at all.
        var toSaveScores = _spreadSheetScores
            .Where(s => !myScores.TryGetValue(s.ChartId, out var existing)
                        || existing.IsBroken
                        || existing.Plate < s.Plate
                        || existing.Score < s.Score).ToArray();

        _maxSaving = toSaveScores.Length;
        foreach (var best in toSaveScores)
        {

            if (_currentCancellation.IsCancellationRequested)
            {
                return;
            }

            StateHasChanged();
            _currentSaved++;
            _remainingTime = (DateTimeOffset.Now - startTime) * (((double)_maxSaving - (double)_currentSaved) / (double)_currentSaved);
            try
            {
                await Mediator.Send(new UpdatePhoenixBestAttemptCommand(best.ChartId, false, best.Score, best.Plate,
                    Source: ScoreJournalEntry.CsvSource, Mix: _currentMix, SessionId: uploadSessionId),
                    cancellationToken);
            }
            catch (OperationCanceledException)
            {
                return;
            }
        }
        _csvStep = CsvStep.Finished;
    }
    private async Task UploadFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > XXScoreFile.MaxByteCount)
        {
            Snackbar.Add(L["File cannot be larger than 10 MB"].Value, Severity.Error);
            return;
        }
        _csvStep = CsvStep.Uploading;
        _currentCancellation = new CancellationTokenSource();

        try
        {
            var result = await Extractor.GetScores(file, _currentMix, _currentCancellation.Token);
            _spreadSheetScores = result.Scores.ToList();
            _failedUploads = result.Errors.ToList();
            _csvStep = CsvStep.Confirming;
        }
        catch (ScoreFileParseException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _csvStep = CsvStep.Idle;
            return;
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception)
        {
            Snackbar.Add(L["There was an unknown error while parsing the file"].Value, Severity.Error);
            _csvStep = CsvStep.Idle;
            return;
        }
    }
    private async Task CopyPIUGameScript()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _piuGameScript());
        Snackbar.Add(L["Copied to clipboard!"].Value, Severity.Success);
    }

    private string _pageLimitString() => _endPage == null ? "" : $"pageIndex>{_endPage}||";
    // The paste-into-console scraper. Downloads a Blob through a temporary <a download> —
    // top-frame data: navigation has been blocked by browsers for years, and popup blockers
    // ate window.open. The BOM keeps Excel from garbling CJK song names; song names travel
    // verbatim (the old #→Num mangling existed only to survive a data: URI).
    private string _piuGameScript() => $@"
var rows=""Song,Difficulty,Score,LetterGrade,Plate\r\n"";
var pageIndex={_startPage};
var pageCount=0, scoreCount=0, failedRows=0;
while(true) {{
    var pageHtml = await $.get(""https://phoenix.piugame.com/my_page/my_best_score.php?page=""+pageIndex);
    var page=$(pageHtml);
    var found=$(""ul.my_best_scoreList>li>div.in"",page);
    if(found.length==0 && pageCount==0) {{
        alert(""No scores found - sign in on https://phoenix.piugame.com first, then run this again."");
        break;
    }}
    found.each(function(){{
        try {{
            var songName = $("".song_name p"",this).first().text().replaceAll('""','""""');
            var typeMatch = ($("".stepBall_img_wrap .imG img"",this).first().attr(""src"")||"""").match(/\/full\/([a-z]+)_num_/i);
            var chartType = typeMatch ? typeMatch[1] : ""?"";
            var level = $("".stepBall_img_wrap .imG img"",this).map(function(i,el){{var m=$(el).attr(""src"").match(/_num_([0-9])\.png/);return m?m[1]:"""";}}).get().join("""");
            var score = $("".etc_con span.num"",this).first().text().replaceAll("","","""");
            var letterMatch = ($("".etc_con img[src*='/grade/']"",this).attr(""src"")||"""").match(/\/grade\/([a-z_]+)\.png/i);
            var letter = (letterMatch?letterMatch[1]:""?"").replace(""_p"",""+"");
            var plateMatch = ($("".etc_con img[src*='/plate/']"",this).attr(""src"")||"""").match(/\/plate\/([a-z]+)\.png/i);
            var plate = plateMatch?plateMatch[1]:""?"";
            rows+='""'+songName+'"",'+chartType+level+"",""+score+"",""+letter+"",""+plate+""\r\n"";
            scoreCount++;
        }} catch(e) {{
            failedRows++;
            console.error(""Skipped a row on page ""+pageIndex, e);
        }}
    }});
    console.log(""Page ""+pageIndex+"" done"");
    pageCount++;
    pageIndex++;
    if({_pageLimitString()}$("".xi.last"",page).length==0){{
        break;
    }}
}}
if(scoreCount>0) {{
    var blobUrl = URL.createObjectURL(new Blob([""\uFEFF""+rows], {{type:""text/csv;charset=utf-8""}}));
    var link = document.createElement(""a"");
    link.href = blobUrl;
    link.download = ""piu-scores.csv"";
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(blobUrl);
    console.log(""Done - ""+scoreCount+"" scores across ""+pageCount+"" pages""+(failedRows>0?"", ""+failedRows+"" rows skipped (see errors above)"":"""")+"". Saved as piu-scores.csv"");
}}";

    public void Dispose()
    {
        foreach (var subscription in _subscriptions) subscription.Dispose();
    }
}
