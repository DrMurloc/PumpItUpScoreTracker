</style>
@inject ICurrentUserAccessor CurrentUser;
@inject IMediator Mediator;
@inject NavigationManager NavManager;
@inject IUiSettingsAccessor UiSettings;
@code {

    [Parameter] public string? ChartTypeRoute { get; set; }

    [Parameter] public int? LevelRoute { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "Lens")]
    public string? LensParam { get; set; }

    private static readonly string[] ValidLenses = { "Pass", "Score" };

    private MixEnum _currentMix = MixEnum.Phoenix;
    private ChartType _chartType = ChartType.Double;
    private int _level = 18;
    private string _lens = "Pass";
    private bool _isLoading = true;

    private PersonalizedTierListBreakdown? _breakdown;
    private IDictionary<Guid, Chart> _charts = new Dictionary<Guid, Chart>();
    private IDictionary<Guid, Chart> _allCharts = new Dictionary<Guid, Chart>();
    private IDictionary<Guid, RecordedPhoenixScore> _scores = new Dictionary<Guid, RecordedPhoenixScore>();
    private IReadOnlyDictionary<Guid, IReadOnlyList<ChartSkillChipRecord>> _skillChips =
        new Dictionary<Guid, IReadOnlyList<ChartSkillChipRecord>>();
    private IDictionary<Guid, ScoreRankingRecord> _scoreRankings = new Dictionary<Guid, ScoreRankingRecord>();

    private string TierListUrl => $"/TierLists/{_chartType}/{_level}?TierListType={_lens}";

    // --- Verdict + movers buckets --------------------------------------------------------

    // A chart with no recorded vote from either personal source cannot move — that's
    // the honest "not enough data" bucket, distinct from "agrees with the community".
    private IReadOnlyList<BreakdownChartRecord> NoDataCharts => _breakdown == null
        ? Array.Empty<BreakdownChartRecord>()
        : _breakdown.Charts.Where(c => c.SkillCategory == TierListCategory.Unrecorded &&
                                       c.SimilarPlayersCategory == TierListCategory.Unrecorded).ToArray();

    private IReadOnlyList<BreakdownChartRecord> HarderMovers => MoversWhere(c => c.PersonalizedCategory > c.CommunityCategory);

    private IReadOnlyList<BreakdownChartRecord> EasierMovers => MoversWhere(c => c.PersonalizedCategory < c.CommunityCategory);

    private IReadOnlyList<BreakdownChartRecord> MoversWhere(Func<BreakdownChartRecord, bool> direction)
    {
        return _breakdown == null
            ? Array.Empty<BreakdownChartRecord>()
            : _breakdown.Charts
                .Where(c => c.CommunityCategory != TierListCategory.Unrecorded &&
                            c.PersonalizedCategory != TierListCategory.Unrecorded)
                .Where(direction)
                .OrderByDescending(c => Math.Abs(c.PersonalizedCategory - c.CommunityCategory))
                .ThenBy(c => _charts.TryGetValue(c.ChartId, out var chart) ? chart.Song.Name.ToString() : "")
                .ToArray();
    }

    private int MovedCount => HarderMovers.Count + EasierMovers.Count;

    private int UnchangedCount => _breakdown == null
        ? 0
        : _breakdown.Charts.Count - MovedCount - NoDataCharts.Count;

    private int CommunityRatedCount => _breakdown == null
        ? 0
        : _breakdown.Charts.Count(c => c.CommunityCategory != TierListCategory.Unrecorded);

    // --- Skill profile ---------------------------------------------------------------------

    private sealed record SkillRow(Skill Skill, double Deviation, double Evidence, bool Usable,
        double? PeerPercentile);

    // Usable skills weakest-first (the actionable order); below-evidence skills sink
    // to the bottom, greyed, so "not enough data" never masquerades as "average".
    private IReadOnlyList<SkillRow> SkillRows => _breakdown == null
        ? Array.Empty<SkillRow>()
        : _breakdown.Skills
            .Select(s => new SkillRow(s.Skill, s.Deviation, s.Evidence, s.Usable, PeerPercentileFor(s.Skill)))
            .OrderBy(s => s.Usable ? 0 : 1)
            .ThenBy(s => s.Usable ? s.Deviation : 0)
            .ThenByDescending(s => s.Evidence)
            .ThenBy(s => s.Skill.GetName())
            .ToArray();

    private double MaxAbsDeviation => Math.Max(0.0001, _breakdown == null
        ? 1
        : _breakdown.Skills.Where(s => s.Usable).Select(s => Math.Abs(s.Deviation)).DefaultIfEmpty(1).Max());

    // Vs. Peers: the coverage-weighted average of your per-chart "Better Than %"
    // (players within ±0.5 competitive level — the tier page's Better Than column)
    // across this folder's charts featuring the skill. Only scored charts have a
    // percentile, so thin skills aggregate over few charts — the evidence column
    // beside it keeps that honest. No new cohort SQL (owner, post-incident).
    private double? PeerPercentileFor(Skill skill)
    {
        var weightTotal = 0.0;
        var weighted = 0.0;
        foreach (var chart in _charts.Values)
        {
            if (!_scoreRankings.TryGetValue(chart.Id, out var rank)) continue;
            double? weight = _skillChips.TryGetValue(chart.Id, out var chips) && chips.Count > 0
                ? chips.Where(c => c.Skill == skill)
                    .Select(c => (double?)((double?)c.SegmentFraction ?? 1.0))
                    .FirstOrDefault()
                : chart.Skills.Contains(skill)
                    ? 1.0
                    : null;
            if (weight is not > 0) continue;
            weightTotal += weight.Value;
            weighted += weight.Value * rank.Ranking;
        }

        return weightTotal <= 0 ? null : weighted / weightTotal;
    }

    // --- Movers ------------------------------------------------------------------------

    private const int InitialMoversShown = 8;
    private readonly HashSet<Guid> _expandedCharts = new();
    private readonly HashSet<string> _showAllGroups = new();
    private bool _showNoData;

    // Friendly tier names — raw enum names never render; the unlocalized string is
    // the key, L[...] localizes at render (same table as the tier list page).
    private static readonly IDictionary<TierListCategory, string> TierNames = new Dictionary<TierListCategory, string>
    {
        { TierListCategory.Overrated, "1+ Level Easier" },
        { TierListCategory.VeryEasy, "Very Easy" },
        { TierListCategory.Easy, "Easy" },
        { TierListCategory.Medium, "Medium" },
        { TierListCategory.Hard, "Hard" },
        { TierListCategory.VeryHard, "Very Hard" },
        { TierListCategory.Underrated, "1+ Level Harder" },
        { TierListCategory.Unrecorded, "Not Rated" }
    };

    private static string TierNameFor(TierListCategory category)
    {
        return TierNames[category];
    }

    private RenderFragment? SourceSegment(string label, double weight, TierListCategory category)
    {
        if (category == TierListCategory.Unrecorded) return null;
        return @<span class="bd-src">@label <span class="bd-src-w">×@weight</span>
            <span style="color:@ThemeScales.DifficultyColor(category)">@L[TierNameFor(category)]</span></span>;
    }

    private IReadOnlyList<(string Key, string Title, string CssClass, IReadOnlyList<BreakdownChartRecord> Movers)> MoverGroups => new[]
    {
        ("Harder", (string)L["Harder for you"], "bd-count-harder", HarderMovers),
        ("Easier", (string)L["Easier for you"], "bd-count-easier", EasierMovers)
    };

    private void ToggleExpanded(Guid chartId)
    {
        if (!_expandedCharts.Add(chartId))
        {
            _expandedCharts.Remove(chartId);
        }
    }

    private void ToggleShowAll(string groupKey)
    {
        if (!_showAllGroups.Add(groupKey))
        {
            _showAllGroups.Remove(groupKey);
        }
    }

    private IReadOnlyList<string> NoDataChartNames => NoDataCharts
        .Select(c => _charts.TryGetValue(c.ChartId, out var chart) ? chart.Song.Name.ToString() : null)
        .Where(n => n != null)
        .Select(n => n!)
        .OrderBy(n => n)
        .ToArray();

    // --- Contribution chips ---------------------------------------------------------------

    private sealed record ContributionChip(Skill Skill, double? Coverage, double Deviation);

    private IReadOnlyDictionary<Skill, double> UsableDeviations => _breakdown == null
        ? new Dictionary<Skill, double>()
        : _breakdown.Skills.Where(s => s.Usable).ToDictionary(s => s.Skill, s => s.Deviation);

    // Which of the chart's skills pushed it: influence = coverage × |your deviation|,
    // matching the blend's own weighting. Pre-crawl fallback tags have no coverage to
    // print and weigh like the blend's default.
    private IReadOnlyList<ContributionChip> ContributionChipsFor(Guid chartId)
    {
        if (!_charts.TryGetValue(chartId, out var chart)) return Array.Empty<ContributionChip>();
        var deviations = UsableDeviations;
        var pairs = _skillChips.TryGetValue(chartId, out var chips) && chips.Count > 0
            ? chips.Select(c => (c.Skill, Coverage: (double?)c.SegmentFraction, Weight: (double?)c.SegmentFraction ?? 0.5))
            : chart.Skills.Select(s => (Skill: s, Coverage: (double?)null, Weight: 0.5));
        return pairs
            .Where(p => deviations.ContainsKey(p.Skill))
            .Select(p => new ContributionChip(p.Skill, p.Coverage, deviations[p.Skill]))
            .OrderByDescending(p => (p.Coverage ?? 0.5) * Math.Abs(p.Deviation))
            .ToArray();
    }

    private static string FormatDeviation(double deviation)
    {
        return (deviation >= 0 ? "+" : "−") + Math.Abs(deviation * 100).ToString("0.0") + "%";
    }

    // The verdict's "mostly X, Y": the skills with the most total influence over a
    // mover group, counting only deviations pointing the group's way.
    private string TopDrivers(IReadOnlyList<BreakdownChartRecord> movers, bool weaker)
    {
        var totals = new Dictionary<Skill, double>();
        foreach (var mover in movers)
        foreach (var chip in ContributionChipsFor(mover.ChartId))
        {
            if (weaker ? chip.Deviation >= 0 : chip.Deviation <= 0) continue;
            totals[chip.Skill] = totals.GetValueOrDefault(chip.Skill) +
                                 (chip.Coverage ?? 0.5) * Math.Abs(chip.Deviation);
        }

        return string.Join(", ", totals.OrderByDescending(kv => kv.Value).Take(2).Select(kv => kv.Key.GetName()));
    }

    // --- Navigation ----------------------------------------------------------------------

    private async Task ChangeFolder((ChartType Type, int Level) folder)
    {
        // CoOp doesn't personalize — hand the folder back to the tier list page.
        if (folder.Type == ChartType.CoOp)
        {
            NavManager.NavigateTo($"/TierLists/{folder.Type}/{folder.Level}");
            return;
        }

        _chartType = folder.Type;
        _level = folder.Level;
        SetQueryString();
        await LoadFolder();
    }

    private async Task ChangeLens(string lens)
    {
        _lens = lens;
        SetQueryString();
        ResetMoverViewState();
        // Only the blend depends on the lens — charts, scores, chips, and rankings
        // are folder-scoped and stay.
        _isLoading = true;
        StateHasChanged();
        _breakdown = await Mediator.Send(new GetPersonalizedTierListBreakdownQuery(_chartType, _level, _lens, Mix: _currentMix));
        _isLoading = false;
        StateHasChanged();
    }

    private void SetQueryString()
    {
        NavManager.NavigateTo(NavManager.GetUriWithQueryParameters(
            $"/TierLists/{_chartType}/{_level}/Breakdown",
            new Dictionary<string, object?> { { "Lens", _lens } }));
    }

    // --- Load ----------------------------------------------------------------------------

    protected override async Task OnInitializedAsync()
    {
        _currentMix = await UiSettings.GetSelectedMix();
        // The lenses that personalize don't exist for legacy mixes; CoOp never
        // personalizes. Soft-land those on the tier list instead of a dead page.
        if (_currentMix.UsesLegacyScoring())
        {
            NavManager.NavigateTo("/TierLists");
            return;
        }

        _chartType = Enum.TryParse<ChartType>(ChartTypeRoute, true, out var routeType) ? routeType : ChartType.Double;
        if (LevelRoute is >= 1 and <= 29)
        {
            _level = LevelRoute.Value;
        }

        if (_chartType == ChartType.CoOp)
        {
            NavManager.NavigateTo($"/TierLists/{_chartType}/{_level}");
            return;
        }

        _lens = ValidLenses.FirstOrDefault(l => string.Equals(l, LensParam, StringComparison.OrdinalIgnoreCase)) ?? "Pass";

        if (!CurrentUser.IsLoggedIn)
        {
            _isLoading = false;
            return;
        }

        var chartsTask = Mediator.Send(new GetChartsQuery(_currentMix));
        var scoresTask = Mediator.Send(new GetPhoenixRecordsQuery(CurrentUser.User.Id, _currentMix));
        _allCharts = (await chartsTask).ToDictionary(c => c.Id);
        _scores = (await scoresTask).ToDictionary(s => s.ChartId);

        await LoadFolder();
    }

    private void ResetMoverViewState()
    {
        _expandedCharts.Clear();
        _showAllGroups.Clear();
        _showNoData = false;
    }

    private async Task LoadFolder()
    {
        _isLoading = true;
        ResetMoverViewState();
        StateHasChanged();

        _charts = _allCharts.Values
            .Where(c => c.Level == _level && c.Type == _chartType)
            .ToDictionary(c => c.Id);

        var breakdownTask = Mediator.Send(new GetPersonalizedTierListBreakdownQuery(_chartType, _level, _lens, Mix: _currentMix));
        var chipsTask = Mediator.Send(new GetChartSkillChipsQuery(_charts.Keys.ToArray()));
        var rankingsTask = Mediator.Send(new GetPlayerScoreQualityQuery(_level, _chartType, _currentMix));
        _breakdown = await breakdownTask;
        _skillChips = await chipsTask;
        _scoreRankings = await rankingsTask;

        _isLoading = false;
        StateHasChanged();
    }
}
