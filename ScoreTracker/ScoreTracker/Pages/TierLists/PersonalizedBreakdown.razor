@page "/TierLists/{ChartTypeRoute}/{LevelRoute:int}/Breakdown"
@using MediatR
@using ScoreTracker.Catalog.Contracts
@using ScoreTracker.Catalog.Contracts.Queries
@using ScoreTracker.ChartIntelligence.Contracts
@using ScoreTracker.ChartIntelligence.Contracts.Queries
@using ScoreTracker.Domain.Models
@using ScoreTracker.Domain.Records
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.PlayerProgress.Contracts.Queries
@using ScoreTracker.ScoreLedger.Contracts.Queries
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Components
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Web.Services.Theming
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType

<PageTitle>@L["Personalized Breakdown"]</PageTitle>
<HeadContent>
    <meta name="description" content="How your personalized PIU tier list is computed for this folder."/>
</HeadContent>

@if (!CurrentUser.IsLoggedIn)
{
    <div class="tier-list-cta">
        <MudText Typo="Typo.h6">@L["Import your scores to light this folder up"]</MudText>
        <div class="tier-list-cta-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/Login">@L["Login"]</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/UploadPhoenixScores">@L["Import Scores"]</MudButton>
        </div>
    </div>
}
else
{
    <div class="bd-page">
        @* Header: where you are (folder + lens) and the way back. The folder picker and
           lens select stay live so folder-hopping doesn't bounce through the tier list. *@
        <div class="bd-toolbar">
            <MudLink Href="@TierListUrl" Typo="Typo.caption">← @L["Back to Tier List"]</MudLink>
            <div class="bd-toolbar-row">
                <MudText Typo="Typo.h4" Class="bd-title">@L["Personalized Breakdown"]</MudText>
                <FolderPicker Type="_chartType" Level="_level" Disabled="_isLoading" FolderChanged="ChangeFolder"></FolderPicker>
                <MudSelect T="string" Class="bd-lens-select" Label="@L["Ranked by"]" Disabled="_isLoading" Value="_lens" ValueChanged="ChangeLens">
                    <MudSelectItem T="string" Value="@("Pass")">@L["Pass Difficulty"]</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Score")">@L["Score Difficulty"]</MudSelectItem>
                </MudSelect>
                <MudSpacer></MudSpacer>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.Bolt">@L["Personalized for {0}", CurrentUser.User.GameTag ?? CurrentUser.User.Name]</MudChip>
            </div>
        </div>

        @if (_isLoading)
        {
            <TierListSkeleton></TierListSkeleton>
        }
        else if (_breakdown == null)
        {
            <div class="tier-list-cta">
                <MudText>@L["No charts match your filters"]</MudText>
            </div>
        }
        else
        {
            @* The verdict: what personalization actually did to this folder, in numbers
               that always print (rule 8). *@
            <div class="bd-verdict">
                <span>@L["Your personalized list moves {0} of {1} charts away from the community's.", MovedCount, _breakdown.Charts.Count]</span>
                <span class="bd-verdict-detail">
                    @{
                        var harderDrivers = TopDrivers(HarderMovers, weaker: true);
                        var easierDrivers = TopDrivers(EasierMovers, weaker: false);
                    }
                    <span class="bd-harder-text">@(harderDrivers.Length > 0 ? L["{0} harder for you — mostly {1}", HarderMovers.Count, harderDrivers] : L["{0} harder for you", HarderMovers.Count])</span>
                    <span class="bd-dot">·</span>
                    <span class="bd-easier-text">@(easierDrivers.Length > 0 ? L["{0} easier for you — mostly {1}", EasierMovers.Count, easierDrivers] : L["{0} easier for you", EasierMovers.Count])</span>
                    <span class="bd-dot">·</span>
                    <span>@L["{0} match the community tier", UnchangedCount]</span>
                    @if (NoDataCharts.Any())
                    {
                        <span class="bd-dot">·</span>
                        <span>@L["{0} don't have enough data to move", NoDataCharts.Count]</span>
                    }
                </span>
                <MudText Typo="Typo.caption" Class="bd-caption">@L["Recalculated every few hours"]</MudText>
            </div>

            @* The recipe: the three sources, their weights, and their status for YOU in
               this folder — a silent source is a diagnostic, not a mystery. *@
            <section class="bd-block">
                <MudText Typo="Typo.h5">@L["What goes into your list"]</MudText>
                <MudText Typo="Typo.caption" Class="bd-caption">@L["Three sources vote on every chart. Sources with more weight move charts further."]</MudText>
                <div class="bd-weightbar" aria-hidden="true">
                    <span class="bd-w-community" style="flex:@_breakdown.CommunityWeight"></span>
                    <span class="bd-w-skill" style="flex:@_breakdown.SkillWeight"></span>
                    <span class="bd-w-similar" style="flex:@_breakdown.SimilarPlayersWeight"></span>
                </div>
                <div class="bd-recipe-cards">
                    <div class="bd-card">
                        <div class="bd-card-head">
                            <MudText Typo="Typo.subtitle1">@L["Community Tier List"]</MudText>
                            <span class="bd-weight bd-w-community">×@_breakdown.CommunityWeight</span>
                        </div>
                        <MudText Typo="Typo.body2" Class="bd-caption">@L["The shared tier list for this folder, built from everyone's data."]</MudText>
                        <div class="bd-status">
                            <span class="bd-status-ok">●</span>
                            <span>@L["{0} / {1} charts rated", CommunityRatedCount, _breakdown.Charts.Count]</span>
                        </div>
                    </div>
                    <div class="bd-card">
                        <div class="bd-card-head">
                            <MudText Typo="Typo.subtitle1">@L["Your Skill Estimate"]</MudText>
                            <span class="bd-weight bd-w-skill">×@_breakdown.SkillWeight</span>
                        </div>
                        <MudText Typo="Typo.body2" Class="bd-caption">@L["Every chart you've scored within 3 folders votes on your skills — closer folders and bigger skill coverage count more."]</MudText>
                        @if (_breakdown.SkillSourceActive)
                        {
                            <div class="bd-status">
                                <span class="bd-status-ok">●</span>
                                <span>@L["Active — {0} scores nearby, {1} skills have enough evidence", _breakdown.ScoredChartCount, _breakdown.UsableSkillCount]</span>
                            </div>
                        }
                        else
                        {
                            <div class="bd-status">
                                <span class="bd-status-off">●</span>
                                <span>@L["Silent — only {0} skills have enough evidence. Your list currently matches the community's. Score more charts near this folder to turn this on.", _breakdown.UsableSkillCount]</span>
                            </div>
                        }
                        @* Card-level disclaimer, deliberately not per-row (owner): the age
                           weighting is context, not data. Counts the actual outliers the
                           algorithm diminished, not a fixed calendar cutoff. *@
                        @if (_breakdown.OutdatedScoreCount > 0)
                        {
                            <div class="bd-status bd-age-note">
                                <MudIcon Icon="@Icons.Material.Filled.History" Class="bd-age-icon"></MudIcon>
                                <span>@L["Older scores count for less — {0} of your nearby scores are much older than the rest of your record.", _breakdown.OutdatedScoreCount]</span>
                            </div>
                        }
                    </div>
                    <div class="bd-card">
                        <div class="bd-card-head">
                            <MudText Typo="Typo.subtitle1">@L["Players Like You"]</MudText>
                            <span class="bd-weight bd-w-similar">×@_breakdown.SimilarPlayersWeight</span>
                        </div>
                        <MudText Typo="Typo.body2" Class="bd-caption">@L["Players within one competitive level of you — closer players count more, and so do those whose folder ratings agree with yours."]</MudText>
                        @if (_breakdown.SimilarPlayerCount > 0)
                        {
                            <div class="bd-status">
                                <span class="bd-status-ok">●</span>
                                <span>@L["{0} players found", _breakdown.SimilarPlayerCount]</span>
                            </div>
                        }
                        else
                        {
                            <div class="bd-status">
                                <span class="bd-status-off">●</span>
                                <span>@L["Silent — no players found in your competitive range yet."]</span>
                            </div>
                        }
                    </div>
                </div>
            </section>

            @* Your skill profile — the same skills through two questions. Left: the
               cross-folder deviations the blend actually uses (owner: users should
               come out going "oh, that's what all that meant"). Right: the Folder
               Stats view of this folder, restated so the two connect. *@
            <section class="bd-block">
                <MudText Typo="Typo.h5">@L["Your skill profile"]</MudText>
                <MudText Typo="Typo.caption" Class="bd-caption">@L["Two views of the same skills. The left one feeds the blend above; the right one is this folder as Folder Stats shows it."]</MudText>
                <div class="bd-skills-grid">
                    <div class="bd-card">
                        <MudText Typo="Typo.subtitle1">@L["Across everything you've scored nearby"]</MudText>
                        <MudText Typo="Typo.caption" Class="bd-caption">@L["How each skill runs against your own average"]</MudText>
                        <div class="bd-dev-head">
                            <span>@L["Skill"]</span>
                            <span>← @L["weaker"] · @L["stronger"] →</span>
                            <span>@L["You"]</span>
                            <span>@L["Evidence"]</span>
                            <span>@L["Vs. Peers"]</span>
                        </div>
                        @foreach (var row in SkillRows)
                        {
                            var widthPercent = row.Usable ? Math.Max(2, (int)Math.Round(48.0 * Math.Abs(row.Deviation) / MaxAbsDeviation)) : 0;
                            <div class="bd-dev-row skillcat-@(row.Skill.GetPrimaryCategory().ToString().ToLowerInvariant()) @(row.Usable ? "" : "bd-dim")">
                                <span class="bd-dev-label">@row.Skill.GetName()</span>
                                <span class="bd-dev-track">
                                    @if (row.Usable)
                                    {
                                        <span class="bd-dev-fill" style="@(row.Deviation < 0 ? $"right:50%;width:{widthPercent}%" : $"left:50%;width:{widthPercent}%")"></span>
                                    }
                                </span>
                                <span class="bd-dev-val">@(row.Usable ? (row.Deviation >= 0 ? "+" : "−") + Math.Abs(row.Deviation * 100).ToString("0.0") + "%" : "—")</span>
                                <span class="bd-dev-ev">@row.Evidence.ToString("0.0")</span>
                                <span class="bd-dev-peer">
                                    @if (row.PeerPercentile != null)
                                    {
                                        <span class="@ThemeScales.RarityClass(ThemeScales.BandFor(row.PeerPercentile.Value))" style="@ThemeScales.RarityStyle(row.PeerPercentile.Value)">@((100 * row.PeerPercentile.Value).ToString("N0"))%</span>
                                    }
                                    else
                                    {
                                        <span class="bd-caption">—</span>
                                    }
                                </span>
                            </div>
                        }
                        <MudText Typo="Typo.caption" Class="bd-caption bd-footnote">@L["Vs. Peers: how your scores rank against players of similar competitive level, averaged over this folder's charts featuring the skill. Greyed skills don't have enough evidence to vote yet."] @L["Evidence already includes score age — older scores count for less."]</MudText>
                    </div>
                    <div class="bd-card">
                        <MudText Typo="Typo.subtitle1">@L["In this folder"]</MudText>
                        <MudText Typo="Typo.caption" Class="bd-caption">@L["Your ability on the charts you've played here — the same numbers as Folder Stats"]</MudText>
                        <FolderSkillList Charts="_charts.Values" SkillChips="_skillChips" Scores="_scores"></FolderSkillList>
                        <div class="bd-bridge">@L["Same skills, two questions: this folder view asks how the charts you've played here actually go — the blend view asks which skills run hot or cold across everything you've scored nearby. A skill can look fine here and still move charts."]</div>
                    </div>
                </div>
                <MudText Typo="Typo.caption" Class="bd-attribution">@L["Skill data: PIU Center — maintained by aesthete"]</MudText>
            </section>

            @* Charts that moved — the reason this page exists. Simple rows (jacket,
               movement in ramp-colored words, top contribution chips); tapping a row
               expands the full source strip (owner: simple view, tap for more data). *@
            <section class="bd-block">
                <MudText Typo="Typo.h5">@L["Charts that moved"]</MudText>
                <MudText Typo="Typo.caption" Class="bd-caption">@L["Where your list disagrees with the community's, and the skills that pushed it. Tap a chart for its full source breakdown."]</MudText>
                @if (!HarderMovers.Any() && !EasierMovers.Any())
                {
                    <div class="bd-quiet">@L["Your list currently matches the community's on every rated chart."]</div>
                }
                @foreach (var group in MoverGroups)
                {
                    if (!group.Movers.Any())
                    {
                        continue;
                    }
                    var shown = _showAllGroups.Contains(group.Key)
                        ? group.Movers
                        : group.Movers.Take(InitialMoversShown).ToArray();
                    <div class="bd-mover-group">
                        <div class="bd-group-head">
                            <MudText Typo="Typo.subtitle1">@group.Title</MudText>
                            <span class="bd-count @group.CssClass">@group.Movers.Count</span>
                        </div>
                        @foreach (var mover in shown)
                        {
                            if (!_charts.TryGetValue(mover.ChartId, out var chart))
                            {
                                continue;
                            }
                            var expanded = _expandedCharts.Contains(mover.ChartId);
                            <div class="bd-mover" role="button" tabindex="0" @onclick="() => ToggleExpanded(mover.ChartId)">
                                <span class="bd-jacket" style="background-image:url('@chart.Song.ImagePath')"></span>
                                <span class="bd-mover-song">
                                    <DifficultyBubble Chart="chart"></DifficultyBubble>
                                    <span class="bd-mover-name">@chart.Song.Name</span>
                                </span>
                                <span class="bd-move">
                                    <span style="color:@ThemeScales.DifficultyColor(mover.CommunityCategory)">@L[TierNameFor(mover.CommunityCategory)]</span>
                                    <span class="bd-move-arrow">→</span>
                                    <span style="color:@ThemeScales.DifficultyColor(mover.PersonalizedCategory)">@L[TierNameFor(mover.PersonalizedCategory)]</span>
                                </span>
                                <span class="bd-mover-chips">
                                    @foreach (var chip in ContributionChipsFor(mover.ChartId).Take(2))
                                    {
                                        <span class="tier-chart-card-skill skillcat-@(chip.Skill.GetPrimaryCategory().ToString().ToLowerInvariant())">
                                            @chip.Skill.GetName()@(chip.Coverage == null ? null : $" {(int)Math.Round(100 * chip.Coverage.Value)}%")
                                            <span class="bd-chip-dev">@FormatDeviation(chip.Deviation)</span>
                                        </span>
                                    }
                                </span>
                                @if (expanded)
                                {
                                    @* Sources with no vote don't render at all (a dangling "—"
                                       read as a stray dash — owner field-test), and the final
                                       flows inline instead of floating right. *@
                                    <div class="bd-source-strip">
                                        @SourceSegment(L["Community"], _breakdown.CommunityWeight, mover.CommunityCategory)
                                        @SourceSegment(L["Players like you"], _breakdown.SimilarPlayersWeight, mover.SimilarPlayersCategory)
                                        @SourceSegment(L["Your skills"], _breakdown.SkillWeight, mover.SkillCategory)
                                        <span class="bd-src-final">= <span style="color:@ThemeScales.DifficultyColor(mover.PersonalizedCategory)">@L[TierNameFor(mover.PersonalizedCategory)]</span></span>
                                    </div>
                                }
                            </div>
                        }
                        @if (group.Movers.Count > InitialMoversShown)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       OnClick="() => ToggleShowAll(group.Key)">
                                @(_showAllGroups.Contains(group.Key) ? L["Show fewer"] : L["Show all {0}", group.Movers.Count])
                            </MudButton>
                        }
                    </div>
                }
                <div class="bd-quiet">
                    <span>@L["{0} charts match the community tier", UnchangedCount]</span>
                    @if (NoDataCharts.Any())
                    {
                        <span class="bd-dot">·</span>
                        <span>@L["{0} don't have enough skill data to move:", NoDataCharts.Count]</span>
                        <span class="bd-nodata-names">@string.Join(" · ", NoDataChartNames.Take(_showNoData ? NoDataCharts.Count : 3))</span>
                        @if (NoDataCharts.Count > 3)
                        {
                            <MudLink Typo="Typo.caption" OnClick="() => _showNoData = !_showNoData">@(_showNoData ? L["Show fewer"] : L["+{0} more", NoDataCharts.Count - 3])</MudLink>
                        }
                    }
                </div>
            </section>
        }
    </div>
}
<style>
    .bd-page {
        max-width: 1240px;
        margin: 0 auto;
        padding-bottom: 24px;
    }

    .bd-toolbar {
        margin-top: 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .bd-toolbar-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
    }

    .bd-title {
        margin-right: 4px;
    }

    .bd-lens-select {
        max-width: 190px;
    }

    .bd-caption {
        color: var(--mud-palette-text-secondary);
        display: block;
    }

    .bd-verdict {
        margin: 16px 0 4px;
        padding: 12px 16px;
        border-left: 3px solid var(--mud-palette-primary);
        background: var(--mud-palette-surface);
        border-radius: 0 8px 8px 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .bd-verdict-detail {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        font-size: .85rem;
        color: var(--mud-palette-text-secondary);
    }

    .bd-harder-text {
        color: var(--diff-veryhard);
    }

    .bd-easier-text {
        color: var(--diff-veryeasy);
    }

    .bd-dot {
        opacity: .6;
    }

    .bd-block {
        margin-top: 28px;
    }

    .bd-weightbar {
        display: flex;
        height: 8px;
        border-radius: 4px;
        overflow: hidden;
        max-width: 520px;
        margin: 10px 0 14px;
    }

    .bd-weightbar span {
        display: block;
    }

    .bd-w-community {
        background: var(--mud-palette-text-secondary);
    }

    .bd-w-skill {
        background: var(--mud-palette-primary);
    }

    .bd-w-similar {
        background: var(--mix-secondary);
    }

    span.bd-weight {
        font-size: .68rem;
        letter-spacing: .1em;
        border-radius: 4px;
        padding: 1px 6px;
        font-weight: 700;
        background: transparent;
    }

    .bd-weight.bd-w-community {
        background: color-mix(in srgb, var(--mud-palette-text-secondary) 25%, transparent);
        color: var(--mud-palette-text-primary);
    }

    .bd-weight.bd-w-skill {
        background: color-mix(in srgb, var(--mud-palette-primary) 25%, transparent);
        color: var(--mud-palette-primary);
    }

    .bd-weight.bd-w-similar {
        background: color-mix(in srgb, var(--mix-secondary) 25%, transparent);
        color: var(--mix-secondary);
    }

    .bd-recipe-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 12px;
    }

    .bd-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 10px;
        padding: 14px 16px;
    }

    .bd-card-head {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: space-between;
    }

    .bd-status {
        margin-top: 8px;
        display: flex;
        gap: 6px;
        align-items: baseline;
        font-size: .82rem;
    }

    .bd-status-ok {
        color: var(--mud-palette-success);
    }

    .bd-status-off {
        color: var(--mud-palette-warning);
    }

    .bd-status.bd-age-note {
        color: var(--mud-palette-text-secondary);
        margin-top: 4px;
        align-items: center;
    }

    .bd-age-icon {
        font-size: 1rem;
    }

    .bd-skills-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-top: 12px;
    }

    @@media (min-width: 900px) {
        .bd-skills-grid {
            grid-template-columns: 7fr 5fr;
        }
    }

    .bd-dev-head, .bd-dev-row {
        display: grid;
        grid-template-columns: minmax(88px, 110px) 1fr 56px 62px 74px;
        gap: 10px;
        align-items: center;
    }

    .bd-dev-head {
        font-size: .64rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--mud-palette-text-secondary);
        margin: 10px 0 6px;
    }

    .bd-dev-row {
        font-size: .82rem;
        padding: 3px 0;
    }

    .bd-dev-row.bd-dim {
        opacity: .45;
    }

    .bd-dev-label {
        color: color-mix(in srgb, var(--skill-chip) 60%, var(--mix-ink));
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .bd-dev-track {
        position: relative;
        height: 8px;
        border-radius: 4px;
        background: color-mix(in srgb, var(--mud-palette-text-secondary) 16%, transparent);
    }

    .bd-dev-track::before {
        content: "";
        position: absolute;
        left: 50%;
        top: -2px;
        bottom: -2px;
        width: 1px;
        background: var(--mud-palette-lines-default);
    }

    .bd-dev-fill {
        position: absolute;
        top: 0;
        bottom: 0;
        border-radius: 4px;
        background: var(--skill-chip);
    }

    .bd-dev-val, .bd-dev-ev, .bd-dev-peer {
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .bd-dev-val {
        font-weight: 600;
    }

    .bd-dev-ev {
        color: var(--mud-palette-text-secondary);
    }

    .bd-footnote {
        margin-top: 8px;
        max-width: 70ch;
    }

    .bd-bridge {
        margin-top: 12px;
        padding: 10px 12px;
        background: var(--mix-surface-muted);
        border-radius: 8px;
        font-size: .8rem;
        color: var(--mud-palette-text-secondary);
    }

    .bd-attribution {
        color: var(--mud-palette-text-secondary);
        display: block;
        margin-top: 6px;
    }

    .bd-mover-group {
        margin-top: 16px;
    }

    .bd-group-head {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .bd-count {
        font-size: .72rem;
        border-radius: 999px;
        padding: 1px 8px;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
    }

    .bd-count-harder {
        background: color-mix(in srgb, var(--diff-veryhard) 22%, transparent);
        color: var(--diff-veryhard);
    }

    .bd-count-easier {
        background: color-mix(in srgb, var(--diff-veryeasy) 22%, transparent);
        color: var(--diff-veryeasy);
    }

    .bd-mover {
        display: grid;
        grid-template-columns: 40px minmax(150px, 240px) minmax(200px, 260px) 1fr;
        gap: 12px;
        align-items: center;
        padding: 8px 12px;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 10px;
        margin-bottom: 6px;
        background: var(--mud-palette-surface);
        cursor: pointer;
    }

    .bd-mover:focus-visible {
        outline: 2px solid var(--mud-palette-primary);
    }

    .bd-jacket {
        width: 40px;
        height: 40px;
        border-radius: 6px;
        background-size: cover;
        background-position: center;
    }

    .bd-mover-song {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
    }

    .bd-mover-name {
