    // --- Reload pipeline: coalesced + cancel-previous ---------------------------------------

    private async Task Recalculate()
    {
        _reloadCts?.Cancel();
        _reloadCts = new CancellationTokenSource();
        var cancellationToken = _reloadCts.Token;
        try
        {
            await LoadFolder(cancellationToken);
        }
        catch (OperationCanceledException)
        {
            // A newer folder/lens selection superseded this load.
        }
    }

    public void Dispose()
    {
        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
    }

    private async Task LoadFolder(CancellationToken cancellationToken)
    {
        _isLoading = true;
        StateHasChanged();

        await UiSettings.SetSetting("TierLists__Level", _level.ToString(), cancellationToken);
        await UiSettings.SetSetting("TierLists__ChartType", _chartType.ToString(), cancellationToken);
        await UiSettings.SetSetting("TierLists__ListType", _tierListType, cancellationToken);
        await UiSettings.SetSetting("TierLists__UsePersonalized", _usePersonalizedData.ToString(), cancellationToken);
        await UiSettings.SetSetting("TierLists__GroupBy", _groupBy, cancellationToken);

        _charts = _allCharts.Values
            .Where(c => c.Level == _level && c.Type == _chartType)
            .ToDictionary(c => c.Id);
        _folderScores = _scores.Where(kv => _charts.ContainsKey(kv.Key)).ToDictionary(kv => kv.Key, kv => kv.Value);

        // Population phase — works logged-out, renders as soon as it lands.
        var blendTask = Mediator.Send(new GetBlendedTierListQuery(_chartType, _level, _tierListType,
            PersonalizedActive, Mix: _currentMix), cancellationToken);
        var popularityTask = Mediator.Send(new GetTierListWithFallbackQuery("Popularity", _currentMix), cancellationToken);
        var blended = await blendTask;
        var popularityResult = await popularityTask;
        cancellationToken.ThrowIfCancellationRequested();

        // The blank-page guard is dead (rule 9): render every chart we can resolve and
        // silently drop entries whose chart no longer exists.
        _finalEntries = blended.Entries.Where(e => _charts.ContainsKey(e.ChartId)).ToArray();
        _isProvisionalFallback = blended.IsProvisionalFallback || popularityResult.IsProvisionalFallback;
        _chartDifficulties = _finalEntries.ToDictionary(e => e.ChartId, e => e.Category);
        var popularity = popularityResult.Entries.GroupBy(e => e.ChartId).ToDictionary(g => g.Key, g => g.First());
        _popularCharts = popularity.Where(kv => kv.Value.Category == TierListCategory.Overrated).Select(kv => kv.Key).ToHashSet();
        _unPopularCharts = popularity.Where(kv => kv.Value.Category == TierListCategory.Underrated).Select(kv => kv.Key).ToHashSet();

        var charts = _finalEntries.Select(e => _charts[e.ChartId]).ToArray();
        _lowestBpm = charts.Any(c => c.Song.Bpm != null) ? charts.Where(c => c.Song.Bpm != null).Min(c => c.Song.Bpm!.Value.Min) : 0;
        _settings.MinBpm = null;
        _highestBpm = charts.Any(c => c.Song.Bpm != null) ? charts.Where(c => c.Song.Bpm != null).Max(c => c.Song.Bpm!.Value.Max) : 0;
        _settings.MaxBpm = null;
        _lowestNoteCount = charts.Any(c => c.NoteCount != null) ? charts.Where(c => c.NoteCount != null).Min(c => c.NoteCount!.Value) : 0;
        _settings.MinNoteCount = null;
        _highestNoteCount = charts.Any(c => c.NoteCount != null) ? charts.Where(c => c.NoteCount != null).Max(c => c.NoteCount!.Value) : 0;
        _settings.MaxNoteCount = null;
        _availableStepArtists = charts.Select(c => c.StepArtist ?? "Unknown").Distinct().OrderBy(s => s).ToArray();
        _availableSongArtists = charts.Select(c => c.Song.Artist).Distinct().OrderBy(s => s).ToArray();

        RegroupEntries();
        _isLoading = false;
        StateHasChanged();

        if (!CurrentUser.IsLoggedIn)
        {
            return;
        }

        // Personal phase — the overlay streams in after the population paint.
        var rankingsTask = Mediator.Send(new GetPlayerScoreQualityQuery(_level, _chartType, _currentMix), cancellationToken);
        var crossMixTask = Mediator.Send(new GetCrossMixPassesQuery(_currentMix), cancellationToken);
        var competitiveTask = Mediator.Send(new GetCompetitivePlayersQuery(_chartType, _currentMix), cancellationToken);
        // Round 7: pass standing among similar players, from the folder's materialized
        // cohort histograms. CoOp has no cohort data (the rebuild covers S/D only).
        var cohortTask = _chartType == ChartType.CoOp
            ? Task.FromResult<FolderCohortSummaryRecord?>(null)
            : Mediator.Send(new GetFolderCohortStatsQuery(_currentMix, _chartType, _level,
                _chartType == ChartType.Single ? _singlesCompetitive : _doublesCompetitive, PassedCount),
                cancellationToken);
        _scoreRankings = await rankingsTask;
        _otherMixPasses = await crossMixTask;
        _competitivePlayerCount = (await competitiveTask).Count();
        _cohortSummary = await cohortTask;
        cancellationToken.ThrowIfCancellationRequested();

        var baseRating = DifficultyLevel.From(_level).BaseRating;
        if (_chartType == ChartType.CoOp)
        {
            baseRating = 2000;
        }
        _averageRating = _folderScores.Any(kv => !kv.Value.IsBroken && kv.Value.Score > 0)
            ? (int)_folderScores.Where(kv => !kv.Value.IsBroken && kv.Value.Score > 0).Average(s => s.Value.Score!.Value.LetterGrade.GetModifier() * baseRating)
            : baseRating;

        BuildLamps();
        StateHasChanged();
    }

    private void BuildLamps()
    {
        var lamps = new List<LampStrip.Lamp>
        {
            new("Pass", _charts.Count(kv => _scores.TryGetValue(kv.Key, out var b) && !b.IsBroken))
        };
        for (var grade = PhoenixLetterGrade.AA; grade <= PhoenixLetterGrade.SSSPlus; grade++)
        {
            var lampGrade = grade;
            lamps.Add(new LampStrip.Lamp(lampGrade.GetName(),
                _charts.Count(kv => _scores.TryGetValue(kv.Key, out var s) && s.Score?.LetterGrade >= lampGrade)));
        }
        lamps.Add(new LampStrip.Lamp("PG", _charts.Count(kv => _scores.TryGetValue(kv.Key, out var s) && s.Score == PhoenixScore.Max)));
        _lamps = lamps;
    }

    // --- Grouping: pure in-memory --------------------------------------------------------

    private const string NeutralSectionColor = "var(--mud-palette-text-secondary)";

    // Friendly tier names — raw enum names never render (design doc §3). The unlocalized
    // string is the stable collapse key; L[...] localizes at group build.
    private static readonly IDictionary<TierListCategory, string> _tierNames = new Dictionary<TierListCategory, string>()
    {
        { TierListCategory.Overrated, "1+ Level Easier" },
        { TierListCategory.VeryEasy, "Very Easy" },
        { TierListCategory.Easy, "Easy" },
        { TierListCategory.Medium, "Medium" },
        { TierListCategory.Hard, "Hard" },
        { TierListCategory.VeryHard, "Very Hard" },
        { TierListCategory.Underrated, "1+ Level Harder" },
        { TierListCategory.Unrecorded, "Not Rated" }
    };
    private static readonly IDictionary<TierListCategory, string> _scoreNames = new Dictionary<TierListCategory, string>()
    {
        { TierListCategory.Overrated, "Amazing" },
        { TierListCategory.VeryEasy, "Very Good" },
        { TierListCategory.Easy, "Good" },
        { TierListCategory.Medium, "Average" },
        { TierListCategory.Hard, "Low" },
        { TierListCategory.VeryHard, "Very Low" },
        { TierListCategory.Underrated, "Why Don't You Get Up and Dance, Man?" },
        { TierListCategory.Unrecorded, "Not Recorded" }
    };
    private static readonly IDictionary<TierListCategory, string> _ageNames = new Dictionary<TierListCategory, string>()
    {
        { TierListCategory.Overrated, "Ancient" },
        { TierListCategory.VeryEasy, "Very Old" },
        { TierListCategory.Easy, "Old" },
        { TierListCategory.Medium, "Average" },
        { TierListCategory.Hard, "New" },
        { TierListCategory.VeryHard, "Very New" },
        { TierListCategory.Underrated, "Most Recent" },
        { TierListCategory.Unrecorded, "Not Recorded" }
    };
    private static readonly IDictionary<TierListCategory, string> _popularityNames = new Dictionary<TierListCategory, string>()
    {
        { TierListCategory.Unrecorded, "Unknown" },
        { TierListCategory.Overrated, "Ultra Popular" },
        { TierListCategory.VeryEasy, "Very Popular" },
        { TierListCategory.Easy, "Popular" },
        { TierListCategory.Medium, "Average" },
        { TierListCategory.Hard, "Unpopular" },
        { TierListCategory.VeryHard, "Very Unpopular" },
        { TierListCategory.Underrated, "Ultra Unpopular" }
    };

    private void RegroupEntries()
    {
        _groups = _groupBy switch
        {
            "Score" => GroupByScore(),
            "Age" => GroupByAge(),
            "Score Ranking" => GroupByScoreRanking(),
            "Scoring Level" => GroupByScoringLevel(),
            "Skill" => GroupBySkill(),
            _ => GroupByTier()
        };
    }

    private string TierName(TierListCategory category) =>
        _tierListType == "Popularity" ? _popularityNames[category] :
        _tierListType == "Chabala" && category == TierListCategory.Unrecorded ? "Subjective" :
        _tierNames[category];

    // Round 7: the lens always orders cards within a section, in every view — hardest
    // first (most-popular first under the Popularity lens), scoring level as the
    // tiebreaker, blend order as the final stabilizer. Unrecorded sinks to the bottom.
    private IEnumerable<SongTierListEntry> LensOrdered(IEnumerable<SongTierListEntry> entries)
    {
        var byCategory = _tierListType == "Popularity"
            ? entries.OrderBy(e => e.Category == TierListCategory.Unrecorded ? int.MaxValue : (int)e.Category)
            : entries.OrderByDescending(e => e.Category == TierListCategory.Unrecorded ? int.MinValue : (int)e.Category);
        return byCategory
            .ThenByDescending(e => _scoringLevels.TryGetValue(e.ChartId, out var sl) ? sl : 0)
            .ThenBy(e => e.Order);
    }

    private IReadOnlyList<TierGroup> GroupByTier()
    {
        var groups = LensOrdered(_finalEntries)
            .GroupBy(e => e.Category);
        // Hardest-first is the community-image convention; the popularity lens reads
        // most-popular first. Not Rated always sinks to the bottom.
        var ordered = _tierListType == "Popularity"
            ? groups.OrderBy(g => g.Key == TierListCategory.Unrecorded ? int.MaxValue : (int)g.Key)
            : groups.OrderByDescending(g => g.Key == TierListCategory.Unrecorded ? int.MinValue : (int)g.Key);
        return ordered
            .Select(g =>
            {
                var name = TierName(g.Key);
                return new TierGroup(name, L[name], ThemeScales.DifficultyColor(g.Key),
                    MixThemes.DifficultyHex(g.Key), g.ToArray());
            })
            .ToArray();
    }

    private TierGroup ToNeutralGroup(IGrouping<string, SongTierListEntry> group) =>
        new(group.Key, L[group.Key], NeutralSectionColor, MixThemes.PaletteFor(_currentMix).InkMuted, group.ToArray());

    private IReadOnlyList<TierGroup> GroupByScore()
    {
        var tierList = TierListProcessor
            .ProcessIntoTierList("Score", _folderScores.Where(kv => kv.Value.Score != null).ToDictionary(kv => kv.Key, kv => (int)kv.Value.Score!.Value))
            .ToDictionary(e => e.ChartId);
        return LensOrdered(_finalEntries)
            .GroupBy(e => _scoreNames[tierList.TryGetValue(e.ChartId, out var t) ? t.Category : TierListCategory.Unrecorded])
            .Select(ToNeutralGroup)
            .ToArray();
    }

    private IReadOnlyList<TierGroup> GroupByAge()
    {
        if (_folderScores.Values.Select(s => s.RecordedDate).Distinct().Count() < 5)
        {
            return LensOrdered(_finalEntries)
                .GroupBy(_ => _ageNames[TierListCategory.Unrecorded])
                .Select(ToNeutralGroup)
                .ToArray();
        }
        var tierList = TierListProcessor
            .ProcessIntoTierList("Score", _folderScores.Where(kv => kv.Value.Score != null).ToDictionary(kv => kv.Key, kv => (_now - kv.Value.RecordedDate).TotalDays))
            .ToDictionary(e => e.ChartId);
        return LensOrdered(_finalEntries)
            .GroupBy(e => _scores.ContainsKey(e.ChartId)
                ? _ageNames[tierList.TryGetValue(e.ChartId, out var t) ? t.Category : TierListCategory.Unrecorded]
                : _ageNames[TierListCategory.Unrecorded])
            .Select(ToNeutralGroup)
            .ToArray();
    }

    private IReadOnlyList<TierGroup> GroupByScoreRanking()
    {
        return LensOrdered(_finalEntries)
            .GroupBy(e => _scoreRankings.TryGetValue(e.ChartId, out var r) ?
                (r.Ranking <= 0.01 ?
                    "Last Place" :
                    r.Ranking <= 0.10 ?
                        "0 -> 10%" :
                        r.Ranking <= 0.25 ?
                            "10% -> 25%" :
                            r.Ranking <= .5 ?
                                "25% -> 50%" :
                                r.Ranking <= .75 ?
                                    "50% -> 75%" :
                                    r.Ranking <= .9 ?
                                        "75% -> 90%" :
                                        r.Ranking > .99 ?
                                            "The Best" :
                                        "90% -> 99.9%"
                    )
                : "Not Recorded")
            .Select(ToNeutralGroup)
            .ToArray();
    }

    private IReadOnlyList<TierGroup> GroupByScoringLevel()
    {
        return LensOrdered(_finalEntries)
            .GroupBy(e => _scoringLevels.TryGetValue(e.ChartId, out var sl) ? sl.ToString("0.0") : "Not Enough Data")
            .OrderBy(g => double.TryParse(g.Key, out var d) ? d : 10000)
            .Select(g => new TierGroup(g.Key, double.TryParse(g.Key, out _) ? g.Key : L[g.Key], NeutralSectionColor,
                MixThemes.PaletteFor(_currentMix).InkMuted, g.ToArray()))
            .ToArray();
    }

    // --- By-Skill view (round 4: the radar charts' information, placed where it's
    // actionable — one section per skill, sorted weakest-first) ---------------------------

    private IReadOnlyList<TierGroup> GroupBySkill()
    {
        var entryByChart = _finalEntries.ToDictionary(e => e.ChartId);
        var skillGroups = _charts.Values
            .SelectMany(c => c.Skills.Select(s => (Skill: s, Chart: c)))
            .GroupBy(p => p.Skill)
            .Select(g =>
            {
                var entries = LensOrdered(g.Where(p => entryByChart.ContainsKey(p.Chart.Id))
                        .Select(p => entryByChart[p.Chart.Id]))
                    .ToArray();
                var scored = entries
                    .Where(e => _scores.TryGetValue(e.ChartId, out var s) && s is { Score: not null, IsBroken: false })
                    .Select(e => (int)_scores[e.ChartId].Score!.Value)
                    .ToArray();
                var passRate = entries.Length == 0 ? 0.0 : (double)entries.Count(e => Passed(e.ChartId)) / entries.Length;
                return (g.Key, Entries: entries, PassRate: passRate,
                    Average: scored.Any() ? (int?)scored.Average() : null);
            })
            .Where(g => g.Entries.Length > 0)
            .OrderBy(g => CurrentUser.IsLoggedIn ? g.PassRate : 0)
            .ThenBy(g => g.Average ?? int.MaxValue)
            .ThenBy(g => g.Key.GetName())
            .Select(g =>
            {
                var heat = SkillHeatCategory(g.PassRate);
                return new TierGroup($"Skill:{g.Key}", g.Key.GetName(),
                    heat == null ? NeutralSectionColor : ThemeScales.DifficultyColor(heat.Value),
                    heat == null ? MixThemes.PaletteFor(_currentMix).InkMuted : MixThemes.DifficultyHex(heat.Value),
                    g.Entries);
            })
            .ToList();

        var untagged = _finalEntries
            .Where(e => _charts.TryGetValue(e.ChartId, out var c) && !c.Skills.Any())
            .OrderBy(e => e.Order)
            .ToArray();
        if (untagged.Any())
        {
            skillGroups.Add(new TierGroup("Skill:None", L["Not Tagged"], NeutralSectionColor,
                MixThemes.PaletteFor(_currentMix).InkMuted, untagged));
        }

        return skillGroups;
    }

    private TierListCategory? SkillHeatCategory(double passRate)
    {
        return !CurrentUser.IsLoggedIn ? null :
            passRate < .4 ? TierListCategory.VeryHard :
            passRate < .65 ? TierListCategory.Hard :
            passRate < .85 ? TierListCategory.Medium :
            TierListCategory.VeryEasy;
    }

    private IDictionary<(ChartType,DifficultyLevel), string> _chabalaLinks = new Dictionary<(ChartType, DifficultyLevel), string>()
    {
        { (ChartType.Single,19), "https://drive.google.com/file/d/1A5D6tlFVU2HMwzNO34TQLOx1ie78XwTx/view?usp=drive_link" },
        { (ChartType.Single,20), "https://drive.google.com/file/d/1dOxTW1wkdozZMmlOO2yUMy2JggA6Mhej/view?usp=drive_link" },
