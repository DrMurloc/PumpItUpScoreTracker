    protected override async Task OnInitializedAsync()
    {
        _currentMix = await UiSettings.GetSelectedMix();
        if (_currentMix == MixEnum.XX)
        {
            // Round 5: XX and older render the coming-soon state and load nothing.
            _isLoading = false;
            return;
        }

        // Kick off every independent async fetch in parallel — wall clock is bounded by
        // the slowest single query, not the sum.
        var chartsTask = Mediator.Send(new GetChartsQuery(_currentMix));
        var scoringLevelsTask = Mediator.Send(new GetChartScoringLevelsQuery(_currentMix));
        var titleProgressTask = Mediator.Send(new GetTitleProgressQuery(_currentMix));
        var userSettingsTask = UiSettings.GetSetting(UserSettingsKey);
        var showAgeSettingTask = UiSettings.GetSetting("TierLists__ShowAge");
        var levelSettingTask = UiSettings.GetSetting("TierLists__Level");
        var chartTypeSettingTask = UiSettings.GetSetting("TierLists__ChartType");
        var listTypeSettingTask = UiSettings.GetSetting("TierLists__ListType");
        var personalizedSettingTask = UiSettings.GetSetting("TierLists__UsePersonalized");
        var groupBySettingTask = UiSettings.GetSetting("TierLists__GroupBy");
        var densitySettingTask = UiSettings.GetSetting(DensitySettingKey);
        var legacyTextViewTask = UiSettings.GetSetting("TierLists__TextView");
        var titlesCollapsedSettingTask = UiSettings.GetSetting("TierLists__TitlesCollapsed");
        var collapsedTiersSettingTask = UiSettings.GetSetting("TierLists__CollapsedTiers");

        if (CurrentUser.IsLoggedIn)
        {
            var userId = CurrentUser.User.Id;
            var scoresTask = Mediator.Send(new GetPhoenixRecordsQuery(userId, _currentMix));
            var statsTask = Mediator.Send(new GetPlayerStatsQuery(userId, _currentMix));
            var todosTask = Mediator.Send(new GetSavedChartsQuery());

            _scores = (await scoresTask).ToDictionary(c => c.ChartId);
            var stats = await statsTask;
            _singlesCompetitive = stats.SinglesCompetitiveLevel;
            _doublesCompetitive = stats.DoublesCompetitiveLevel;
            if (stats.DoublesCompetitiveLevel > 1)
            {
                _level = (int)Math.Round(stats.DoublesCompetitiveLevel);
            }
            if (stats.SinglesCompetitiveLevel > 1 && stats.SinglesCompetitiveLevel > stats.DoublesCompetitiveLevel)
            {
                _chartType = ChartType.Single;
                _level = (int)Math.Round(stats.SinglesCompetitiveLevel);
            }
            _todos = (await todosTask).Where(c => c.ListType == ChartListType.ToDo).Select(c => c.ChartId).Distinct().ToHashSet();
        }

        _allCharts = (await chartsTask).ToDictionary(c => c.Id);
        _scoringLevels = await scoringLevelsTask;
        _titleProgress = (await titleProgressTask).ToArray();

        var settingsString = await userSettingsTask;
        if (!string.IsNullOrWhiteSpace(settingsString))
        {
            _settings = JsonSerializer.Deserialize<FilterSettings>(settingsString) ?? new FilterSettings();
        }

        _showAge = bool.TryParse(await showAgeSettingTask, out var showAge) && showAge;
        // One-time migration: Text View retires into its successor, the Table density.
        _density = Enum.TryParse<UiDensity>(await densitySettingTask, out var density) ? density :
            bool.TryParse(await legacyTextViewTask, out var legacyTextView) && legacyTextView
                ? UiDensity.Table
                : UiDensity.Comfortable;
        // Unset (or unparseable) means collapsed — the round-6 default.
        _titlesCollapsed = !bool.TryParse(await titlesCollapsedSettingTask, out var titlesCollapsed) || titlesCollapsed;
        var collapsedTiersJson = await collapsedTiersSettingTask;
        if (!string.IsNullOrWhiteSpace(collapsedTiersJson))
        {
            try
            {
                _collapsedTiers = JsonSerializer.Deserialize<HashSet<string>>(collapsedTiersJson) ?? new HashSet<string>();
            }
            catch (JsonException)
            {
                _collapsedTiers = new HashSet<string>();
            }
        }

        // Saved settings refine the competitive-level smart default; when unset they fall
        // through to the stats-derived folder instead of clobbering it with 18/Double.
        _level = int.TryParse(await levelSettingTask, out var savedLevel) ? savedLevel : _level;
        _chartType = Enum.TryParse<ChartType>(await chartTypeSettingTask, out var savedType) ? savedType : _chartType;
        var savedLens = await listTypeSettingTask;
        _tierListType = LensKeys.FirstOrDefault(k => string.Equals(k, savedLens, StringComparison.OrdinalIgnoreCase)) ?? "Pass";
        _usePersonalizedData = (await personalizedSettingTask ?? true.ToString()) == true.ToString();
        _groupBy = await groupBySettingTask ?? "Difficulty";

        // Legacy query params, then the canonical C3 path route, win over saved state.
        if (DifficultyFilter is >= 1 and <= 29)
        {
            _level = DifficultyFilter.Value;
        }
        if (Enum.TryParse<ChartType>(ChartTypeFilter, out var chartTypeParam))
        {
            _chartType = chartTypeParam;
        }
        if (Enum.TryParse<ChartType>(ChartTypeRoute, true, out var routeType))
        {
            _chartType = routeType;
        }
        if (LevelRoute is >= 1 and <= 29)
        {
            _level = LevelRoute.Value;
        }
        var queryLens = TierListType == null
            ? null
            : LensKeys.FirstOrDefault(k => string.Equals(k, TierListType, StringComparison.OrdinalIgnoreCase));
        if (queryLens != null)
        {
            _tierListType = queryLens;
        }

        // Guards: CoOp folders are 2-5 players; folders without Chabala data fall back to
        // the default lens; retired ("Skill") or login-gated groupings fall back to the
        // tier-list view.
        if (_chartType == ChartType.CoOp && _level is < 2 or > 5)
        {
            _level = 2;
        }
        if (_tierListType == "Chabala" && !ChabalaAvailable)
        {
            _tierListType = "Pass";
        }
        if (!ValidGroupings.Contains(_groupBy) || (!CurrentUser.IsLoggedIn && _groupBy is "Score" or "Age" or "Score Ranking")
            || (_groupBy == "Skill" && !_currentMix.HasSkillData()))
        {
            _groupBy = "Difficulty";
        }

        SetQueryString();
        await Recalculate();
    }
