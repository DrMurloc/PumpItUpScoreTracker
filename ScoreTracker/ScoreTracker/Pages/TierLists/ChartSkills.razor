    private async Task ChangeFolder((ChartType Type, int Level) folder)
    {
        _chartType = folder.Type;
        _level = folder.Level;
        if (_chartType == ChartType.CoOp && _level is < 2 or > 5)
        {
            _level = 2;
        }
        if (_tierListType == "Chabala" && !ChabalaAvailable)
        {
            _tierListType = "Pass";
        }
        SetQueryString();
        await Recalculate();
    }

