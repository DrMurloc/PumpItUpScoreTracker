@page "/TierLists"
@page "/TierLists/{ChartTypeRoute}/{LevelRoute:int}"
@using MediatR
@using ScoreTracker.Web.Enums
@using ScoreTracker.ScoreLedger.Contracts.Queries
@using ScoreTracker.PlayerProgress.Contracts.Queries
@using ScoreTracker.ChartIntelligence.Contracts
@using ScoreTracker.ChartIntelligence.Contracts.Queries
@using ScoreTracker.Domain.Services
@using ScoreTracker.Application.Commands
@using ScoreTracker.Application.Queries
@using ScoreTracker.Domain.SecondaryPorts
@using ScoreTracker.SharedKernel.Enums
@using ScoreTracker.Domain.Models
@using ScoreTracker.SharedKernel.Models
@using ScoreTracker.Domain.Models.Titles
@using ScoreTracker.Domain.Models.Titles.Phoenix
@using ScoreTracker.SharedKernel.ValueTypes
@using ScoreTracker.Web.Components
@using ChartType = ScoreTracker.SharedKernel.Enums.ChartType
@using ScoreTracker.Domain.Records
@using ScoreTracker.Web.Services
@using ScoreTracker.Web.Services.Contracts
@using ScoreTracker.Web.Services.Theming
@using ScoreTracker.Application.Queries
@using System.Text.Json
@implements IDisposable
@inject ChartVideoDisplayer VideoDisplayer
<PageTitle>@L["PIU Tier List"]</PageTitle>
<HeadContent>
    <meta name="description" content="PIU Charts organized by difficulty with optional personalization based on individual skill."/>
    <meta property="og:title" content="PIU Tier List">
    <meta property="og:description" content="PIU Charts organized by difficulty with optional personalization based on individual skill." >
    @if (!_currentMix.UsesLegacyScoring())
    {
        @* C9: the unfurl of a folder link IS the community tier list — the image is
           regenerated daily by the refresh-folder-share-cards job. *@
        <meta property="og:url" content="@($"https://piuscores.arroweclip.se/TierLists/{_chartType}/{_level}")">
        <meta property="og:image" content="@($"https://piuimages.arroweclip.se/tier-lists/{_currentMix}/{_chartType.GetShortHand().ToLower()}{_level}.png")">
    }
</HeadContent>
@if (_currentMix.UsesLegacyScoring())
{
    @* Round-5 decision: XX and older mixes get a whole-page coming-soon state — the old
       silent Phoenix-data masquerade (ListMix) is retired for this page. The condition
       predates the legacy-mix enum values; UsesLegacyScoring is that "XX and older"
       intent (docs/design/legacy-mixes.md keeps legacy tier lists out of scope). *@
    <div class="tier-list-cta">
        <MudIcon Icon="@Icons.Material.Filled.Construction"></MudIcon>
        <MudText Typo="Typo.h5">@L["Tier lists for XX and older coming soon"]</MudText>
    </div>
}
else
{
    @* Round 9: the lens controls render in the desktop content bar AND the compact
       Advanced drawer — one fragment so they can't drift. *@
    RenderFragment lensControls = @<text>
        <MudSelect T="string" Class="tier-toolbar-select" Label="@L["Ranked by"]" Disabled="_isLoading" Value="_tierListType" ValueChanged="ChangeLens">
            <MudSelectItem T="string" Value="@("Pass")">@L["Pass Difficulty"]</MudSelectItem>
            <MudSelectItem T="string" Value="@("Score")">@L["Score Difficulty"]</MudSelectItem>
            <MudSelectItem T="string" Value="@("Popularity")">@L["Popularity"]</MudSelectItem>
            @if (ChabalaAvailable)
            {
                <MudSelectItem T="string" Value="@("Chabala")">Chabala</MudSelectItem>
            }
            <MudSelectItem T="string" Value="@("PG")">PG</MudSelectItem>
        </MudSelect>
        @if (IsMyProgress)
        {
            <MudSelect T="string" Class="tier-toolbar-select" Label="@L["Grouped by"]" Value="_groupBy" ValueChanged="ChangeGrouping">
                @if (CurrentUser.IsLoggedIn)
                {
                    <MudSelectItem T="string" Value="@("Score")">@L["Score"]</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Age")">@L["Age"]</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Score Ranking")">@L["Score Ranking"]</MudSelectItem>
                }
                <MudSelectItem T="string" Value="@("Scoring Level")">@L["Scoring Level"]</MudSelectItem>
            </MudSelect>
        }
    </text>;
    <div class="tier-page">
    @* 1 — sticky toolbar. Desktop: one line — folder → view → personalized → Download.
       Round 9 compact (<960): one clean row of Folder → view → Advanced; the Advanced
       drawer holds Personalized, Ranked-by, Grouped-by, Download, and the whole filter
       panel (replacing round 8's bottom action bar, which fought the shell's bottom
       nav). Below 600 the Advanced button slots before the view group and everything
       centers, so the wrap is deliberate instead of ragged. *@
    <div class="tier-toolbar">
        <div class="tier-toolbar-row">
            <FolderPicker Type="_chartType" Level="_level" Disabled="_isLoading" FolderChanged="ChangeFolder"></FolderPicker>
            <MudButtonGroup OverrideStyles="false" Class="tier-views-group">
                <MudButton Variant="@(_groupBy == "Difficulty" ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small" OnClick="@(() => ChangeGrouping("Difficulty"))">@L["Tier List"]</MudButton>
                <MudButton Variant="@(IsMyProgress ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small" OnClick="@(() => ChangeGrouping(CurrentUser.IsLoggedIn ? "Score" : "Scoring Level"))">@L["My Progress"]</MudButton>
                @if (_currentMix.HasSkillData())
                {
                    <MudButton Variant="@(IsSkillView ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Size="Size.Small" OnClick="@(() => ChangeGrouping("Skill"))">@L["By Skill"]</MudButton>
                }
            </MudButtonGroup>
            <MudButton Class="tier-compact-only tier-advanced-btn" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Tune" OnClick="() => _advancedOpen = true">@L["Advanced"]</MudButton>
        </div>
        <div class="tier-toolbar-row tier-desktop-only">
            @if (CurrentUser.IsLoggedIn && _chartType != ChartType.CoOp && _tierListType is "Pass" or "Score")
            {
                <MudSwitch T="bool" Color="Color.Primary" Value="_usePersonalizedData" ValueChanged="SetUsePersonalized" Label="@L["Personalized"]"></MudSwitch>
            }
            <MudSpacer></MudSpacer>
            <MudButton OnClick="DownloadImage" Color="Color.Primary" Variant="Variant.Outlined"
                       StartIcon="@(_isBuildingImage ? null : Icons.Material.Filled.FileDownload)"
                       Disabled="_isBuildingImage || _isLoading">
                @if (_isBuildingImage)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2"></MudProgressCircular>
                    @L["Generating"]
                }
                else
                {
                    @L["Download"]
                }
            </MudButton>
        </div>
    </div>
    @if (_isProvisionalFallback || PersonalizedActive)
    {
        <div class="tier-badges">
            @if (_isProvisionalFallback)
            {
                <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.Construction">@L["Provisional — based on Phoenix data"]</MudChip>
            }
            @if (PersonalizedActive)
            {
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.Bolt">@L["Personalized for {0}", CurrentUser.User.GameTag ?? CurrentUser.User.Name]</MudChip>
            }
        </div>
    }
    @* 3 — progress strip (logged in) or the rule-9 import CTA (anonymous). Round 8:
       below 960px the whole strip + legend live behind the Folder Stats drawer —
       mobile's fold belongs to the tier sections (rule 1). The stats markup is one
       shared fragment so the inline strip and the drawer can't drift apart. *@
    @if (CurrentUser.IsLoggedIn)
    {
        RenderFragment folderStatsCore = @<text>
            <div class="tier-progress-strip-summary">
                <MudText Typo="Typo.subtitle1">@L["Folder Progress"]</MudText>
                <MudText Typo="Typo.caption">@L["{0} / {1} passed", PassedCount, _charts.Count]</MudText>
            </div>
            <LampStrip Lamps="_lamps" Total="_charts.Count"></LampStrip>
            @* Round 7: cohort standing as labeled bars — fill + hue from the rarity ramp,
               with the percentage always printed beside it (rule 8). *@
            @if (_competitivePlayerCount > 0 && _finalEntries.Any(e => _scoreRankings.ContainsKey(e.ChartId)))
            {
                var rating = _finalEntries.Where(e => _scoreRankings.ContainsKey(e.ChartId)).Average(e => _scoreRankings[e.ChartId].Ranking);
                <div class="tier-cohort-bar">
                    <span class="tier-cohort-bar-label">@L["Score in Folder"]</span>
                    <span class="tier-cohort-bar-meter">
                        <span class="tier-cohort-bar-fill" style="width:@((100.0 * rating).ToString("0"))%;background:@ThemeScales.CssVar(ThemeScales.BandFor(rating))"></span>
                    </span>
                    <span class="tier-cohort-bar-value @ThemeScales.RarityClass(ThemeScales.BandFor(rating))" style="@ThemeScales.RarityStyle(rating)">@((100.0 * rating).ToString("N1"))%</span>
                    <span class="tier-cohort-bar-note">@L["of {0} similar players in this folder", _competitivePlayerCount]</span>
                </div>
            }
            @if (_cohortSummary != null)
            {
                <div class="tier-cohort-bar">
                    <span class="tier-cohort-bar-label">@L["Passes in Folder"]</span>
                    <span class="tier-cohort-bar-meter">
                        <span class="tier-cohort-bar-fill" style="width:@((100.0 * _cohortSummary.PassPercentile).ToString("0"))%;background:@ThemeScales.CssVar(ThemeScales.BandFor(_cohortSummary.PassPercentile))"></span>
                    </span>
                    <span class="tier-cohort-bar-value @ThemeScales.RarityClass(ThemeScales.BandFor(_cohortSummary.PassPercentile))" style="@ThemeScales.RarityStyle(_cohortSummary.PassPercentile)">@((100.0 * _cohortSummary.PassPercentile).ToString("N0"))%</span>
                    <span class="tier-cohort-bar-note">@L["You: {0} · similar players average {1}", PassedCount, _cohortSummary.AveragePasses.ToString("N1")]</span>
                </div>
            }
            @if (_unpassedTodos.Any())
            {
                <MudText Typo="Typo.caption">@L.GetString("Unpassed ToDos", _unpassedTodos.Count(), _level)</MudText>
            }
        </text>;

        <div class="tier-progress-strip tier-desktop-only">
            @folderStatsCore
            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@(_titlesCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)"
                       OnClick="ToggleTitles" aria-expanded="@(_titlesCollapsed ? "false" : "true")">@L["Folder Levels"]</MudButton>
            @if (!_titlesCollapsed)
            {
                <MudGrid>
                    <TitleProgressBar AverageRating="_averageRating" Titles="_titleProgress.Where(t => (t.Title is PhoenixDifficultyTitle pdt && pdt.Level == _level) || (_chartType == ChartType.CoOp && t.Title is PhoenixCoOpTitle))"></TitleProgressBar>
                </MudGrid>
            }
        </div>
        @* 4 — the border language, printed (rule 8). *@
        <div class="tier-desktop-only">
            <BorderLegend></BorderLegend>
        </div>
        <MudDrawer @bind-Open="_statsOpen" Anchor="Anchor.Right" Variant="@DrawerVariant.Temporary" Width="320px">
            <div class="tier-filter-drawer">
                <div class="tier-drawer-head">
                    <MudText Typo="Typo.h6">@L["Folder Stats"]</MudText>
                    <MudSpacer></MudSpacer>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => _statsOpen = false"
                                   aria-label="@L["Close"]"></MudIconButton>
                </div>
                @folderStatsCore
                <BorderLegend></BorderLegend>
                <MudText Typo="Typo.overline">@L["Folder Levels"]</MudText>
                <MudGrid>
                    <TitleProgressBar AverageRating="_averageRating" Titles="_titleProgress.Where(t => (t.Title is PhoenixDifficultyTitle pdt && pdt.Level == _level) || (_chartType == ChartType.CoOp && t.Title is PhoenixCoOpTitle))"></TitleProgressBar>
                </MudGrid>
            </div>
        </MudDrawer>
    }
    else
    {
        <div class="tier-list-cta">
            <MudText Typo="Typo.h6">@L["Import your scores to light this folder up"]</MudText>
            <div class="tier-list-cta-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/Login">@L["Login"]</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/UploadPhoenixScores">@L["Import Scores"]</MudButton>
            </div>
        </div>
    }
    @if (_tierListType == "Chabala" && ChabalaAvailable)
    {
        <MudLink Href="@_chabalaLinks[(_chartType, _level)]" Target="_blank">@L["Original Chabala Tier List"]</MudLink>
    }
    @if (_groupBy == "Score Ranking")
    {
        <MudText Typo="Typo.body2">@L["Score Ranking: What percent of players of comparable (+/- .5 competitive level) your score is on a chart."]</MudText>
    }
    @if (IsSkillView)
    {
        @* Skill sections sort weakest-first — the radar charts' information, placed
           where it's actionable (round 4). Attribution per the round-3 agreement. *@
        <MudText Typo="Typo.caption" Class="tier-attribution">@L["Skill data: PIU Center — maintained by aesthete"]</MudText>
    }
    @* 2 — content bar: how the list PRESENTS (lens ordering, grouping, density,
       Download, Filters). Sits with the list it affects, not in the sticky toolbar. *@
    <div class="tier-content-bar">
        @if (CurrentUser.IsLoggedIn)
        {
            @* Round 9: on compact, Folder Stats takes the Ranked-by slot (the lens
               controls live in the Advanced drawer there). *@
            <MudButton Class="tier-compact-only" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.QueryStats" OnClick="() => _statsOpen = true">@L["Folder Stats"]</MudButton>
        }
        <div class="tier-flat tier-desktop-only">
            @lensControls
        </div>
        <MudSpacer></MudSpacer>
        <MudButtonGroup OverrideStyles="false">
            <MudTooltip Text=@L["Comfortable"]>
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.ViewComfy"
                               Color="@(_density == UiDensity.Comfortable ? Color.Primary : Color.Default)"
                               OnClick="() => SetDensity(UiDensity.Comfortable)" aria-label="@L["Comfortable"]"></MudIconButton>
            </MudTooltip>
            <MudTooltip Text=@L["Compact"]>
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.GridView"
                               Color="@(_density == UiDensity.Compact ? Color.Primary : Color.Default)"
                               OnClick="() => SetDensity(UiDensity.Compact)" aria-label="@L["Compact"]"></MudIconButton>
            </MudTooltip>
            <MudTooltip Text=@L["Table"]>
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.TableRows"
                               Color="@(_density == UiDensity.Table ? Color.Primary : Color.Default)"
                               OnClick="() => SetDensity(UiDensity.Table)" aria-label="@L["Table"]"></MudIconButton>
            </MudTooltip>
        </MudButtonGroup>
        @* The Filters icon + drawer are width-independent (round 9 refinement) —
           filtering always lives here, never inside Advanced. *@
        <MudTooltip Text=@L["Filters and Columns"]>
            <MudBadge Content="ActiveFilterCount" Visible="HasActiveFilters" Color="Color.Primary" Overlap="true">
                <MudIconButton Icon="@Icons.Material.Filled.FilterList" Color="Color.Primary" Variant="Variant.Outlined"
                               OnClick="() => _filtersOpen = true" aria-label="@L["Filters and Columns"]"></MudIconButton>
            </MudBadge>
        </MudTooltip>
    </div>
    @* Active-filter chips: labeled so it's obvious what the chips are (round 6). *@
    @if (HasActiveFilters)
    {
        <div class="tier-filter-chips">
            <span class="tier-filter-chips-label">@L["Applied Filters"]:</span>
            @if (!string.IsNullOrWhiteSpace(_songFilter))
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearSongNameFilter">@L["Song Name"]: @_songFilter</MudChip>
            }
            @if (_settings.SongTypes.Any())
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearSongTypeFilter">@L["Song Type"]: @string.Join(", ", _settings.SongTypes)</MudChip>
            }
            @if (_settings.ToDo != null)
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearToDoFilter">@L["To Do"]</MudChip>
            }
            @if (_settings.Completion != null)
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearCompletionFilter">@L["Stage Pass"]</MudChip>
            }
            @if (_settings.MinLetterGrade != null || _settings.MaxLetterGrade != null)
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearLetterGradeFilter">@L["Letter Grade"]</MudChip>
            }
            @if (_settings.MinBpm != null || _settings.MaxBpm != null)
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearBpmFilter">@L["BPM"]</MudChip>
            }
            @if (_settings.MinNoteCount != null || _settings.MaxNoteCount != null)
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearNoteCountFilter">@L["Note Count"]</MudChip>
            }
            @if (_settings.StepArtists.Any())
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearStepArtistFilter">@L["Step Artist"]</MudChip>
            }
            @if (_settings.SongArtists.Any())
            {
                <MudChip T="string" Size="Size.Small" OnClose="ClearSongArtistFilter">@L["Song Artist"]</MudChip>
            }
        </div>
    }
    @* 5/6/7 — the answer: tier sections, skeleton while loading, honest empty state. *@
    @if (_isLoading)
    {
        <TierListSkeleton></TierListSkeleton>
    }
    else if (_groups.All(g => !g.Entries.Any(ShouldChartShow)))
    {
        <div class="tier-list-cta">
            <MudText>@L["No charts match your filters"]</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClearFilters">@L["Clear Filters"]</MudButton>
        </div>
    }
    else
    {
        @foreach (var group in _groups)
        {
            var visible = group.Entries.Where(ShouldChartShow).ToArray();
            if (visible.Length == 0)
            {
                continue;
            }
            <TierSection Name="@group.Name" Color="@group.Color" Count="visible.Length" Stat="@GroupStat(visible)"
                         Collapsed="_collapsedTiers.Contains(group.Key)" CollapsedChanged="c => SetTierCollapsed(group.Key, c)">
                @if (_density == UiDensity.Table)
                {
                    <div class="tier-table-wrap">
                        <table class="tier-table">
                            <thead>
                            <tr>
                                <th class="tier-table-jacket-cell"></th>
                                <th>@L["Song Name"]</th>
                                <th>@L["Chart"]</th>
                                @if (ShowLensAnnotation)
                                {
                                    <th>@LensDisplayName(_tierListType)</th>
                                }
                                @if (_settings.ShowStepArtist)
                                {
                                    <th>@L["Step Artist"]</th>
                                }
                                @if (_settings.ShowSkills)
                                {
                                    <th>@L["Skills"]</th>
                                }
                                @if (CurrentUser.IsLoggedIn)
                                {
                                    @if (_showAge)
                                    {
                                        <th>@L["Age"]</th>
                                    }
                                    <th>@L["My Score"]</th>
                                    <th>@L["Better Than"]</th>
                                    <th></th>
                                }
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var entry in visible)
                            {
                                var chart = _charts[entry.ChartId];
                                var score = _scores.TryGetValue(chart.Id, out var rowScore) ? rowScore : null;
                                <tr class="@RowClass(chart.Id, score)">
                                    <td class="tier-table-jacket-cell">
                                        <div class="tier-table-jacket" role="button" tabindex="0"
                                             @onclick="() => OpenDetails(chart.Id)"
                                             style="background-image:url('@chart.Song.ImagePath')"></div>
                                    </td>
                                    <td>@chart.Song.Name</td>
                                    <td>@chart.DifficultyString</td>
                                    @if (ShowLensAnnotation)
                                    {
                                        <td><span style="color:@ThemeScales.DifficultyColor(entry.Category)">@L[TierName(entry.Category)]</span></td>
                                    }
                                    @if (_settings.ShowStepArtist)
                                    {
                                        <td>@chart.StepArtist</td>
                                    }
                                    @if (_settings.ShowSkills)
                                    {
                                        <td class="tier-table-skills">@string.Join(", ", chart.Skills)</td>
                                    }
                                    @if (CurrentUser.IsLoggedIn)
                                    {
                                        @if (_showAge)
                                        {
                                            <td>
                                                @if (score != null)
                                                {
                                                    @L["{0} days ago", (int)(_now - score.RecordedDate).TotalDays]
                                                }
                                            </td>
                                        }
                                        <td>
                                            @if (score?.Score != null)
                                            {
                                                <ScoreBreakdown Score="score.Score.Value" IsBroken="score.IsBroken" OneLine="true" ShowScore="true" Plate="score.Plate"></ScoreBreakdown>
                                            }
                                        </td>
                                        <td>
                                            @if (_scoreRankings.TryGetValue(chart.Id, out var rowRank))
                                            {
                                                <span style="@ThemeScales.RarityStyle(rowRank.Ranking)">@((100.0 * rowRank.Ranking).ToString("N1"))%</span>
                                            }
                                        </td>
                                        <td>
                                            <MudIconButton Size="Size.Small"
                                                           Icon="@(_todos.Contains(chart.Id) ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)"
                                                           Color="@(_todos.Contains(chart.Id) ? Color.Info : Color.Default)"
                                                           OnClick="() => ToggleToDo(chart.Id)" aria-label="@L["To Do"]"></MudIconButton>
                                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Info"
                                                           OnClick="() => OpenDetails(chart.Id)" aria-label="@L["Details"]"></MudIconButton>
                                        </td>
                                    }
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="@(_density == UiDensity.Compact ? "tier-card-grid tier-card-grid-compact" : "tier-card-grid")">
                        @foreach (var entry in visible)
                        {
                            var chart = _charts[entry.ChartId];
                            var score = _scores.TryGetValue(chart.Id, out var scr) ? scr : null;
                            <TierListChartCard Chart="chart"
                                               Score="score"
                                               Ranking="_scoreRankings.TryGetValue(chart.Id, out var rank) ? rank : null"
                                               Passed="score is { IsBroken: false }"
                                               IsToDo="_todos.Contains(chart.Id)"
                                               PassedInAnotherMix="_otherMixPasses.Contains(chart.Id)"
                                               ShowName="_settings.ShowSongName"
                                               ShowToDo="CurrentUser.IsLoggedIn"
                                               Density="_density"
                                               TierLabel="@(ShowLensAnnotation ? (string)L[TierName(entry.Category)] : null)"
                                               TierColor="@(ShowLensAnnotation ? ThemeScales.DifficultyColor(entry.Category) : null)"
                                               StepArtist="@(_settings.ShowStepArtist ? chart.StepArtist?.ToString() : null)"
                                               Skills="@(_settings.ShowSkills && !IsSkillView ? chart.Skills.Select(s => s.ToString()).ToArray() : null)"
                                               AgeDays="@(_showAge && score != null ? (int)(_now - score.RecordedDate).TotalDays : null)"
                                               OnToDo="ToggleToDo"
                                               OnOpen="OpenDetails"></TierListChartCard>
                        }
                    </div>
                }
            </TierSection>
        }
    }
    @* Filters drawer — the full panel (rule 6). Round 9: the panel is one shared
       fragment so the desktop Filters drawer and the compact Advanced drawer can't
       drift apart. *@
    @{
        RenderFragment filterPanel = @<text>
        <MudAutocomplete T="string" Label=@L["Song Name"] AdornmentIcon="@Icons.Material.Filled.Search" @bind-Value="_songFilter" SearchFunc="(s,c)=>FilterSongName(s)" CoerceText="false" CoerceValue="true"></MudAutocomplete>
            <MudSelect T="SongType" Clearable="true" MultiSelection="true" SelectedValues="_settings.SongTypes" SelectedValuesChanged="SetSongTypeFilter" Label=@L["Song Type"]>
                @foreach (var type in Enum.GetValues<SongType>())
                {
                    <MudSelectItem T="SongType" Value="type">@type</MudSelectItem>
                }
            </MudSelect>
            @if (CurrentUser.IsLoggedIn)
            {
                <MudCheckBox T="bool?" Value="_settings.ToDo" ValueChanged="SetTodoFilter" TriState="true" Label=@L["To Do"]></MudCheckBox>
                <MudCheckBox T="bool?" TriState="true" Value="_settings.Completion" ValueChanged="SetCompletionFilter" Label=@L["Stage Pass"]></MudCheckBox>
                <MudSelect T="PhoenixLetterGrade?" Label=@L["Min Letter Grade"] Value="_settings.MinLetterGrade" ValueChanged="SetMinLetterGrade" Clearable="true">
                    @foreach (var letterGrade in Enum.GetValues<PhoenixLetterGrade>().Reverse())
                    {
                        <MudSelectItem T="PhoenixLetterGrade?" Value="letterGrade">@letterGrade.GetName()</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="PhoenixLetterGrade?" Label=@L["Max Letter Grade"] Value="_settings.MaxLetterGrade" ValueChanged="SetMaxLetterGrade" Clearable="true">
                    @foreach (var letterGrade in Enum.GetValues<PhoenixLetterGrade>().Reverse())
                    {
                        <MudSelectItem T="PhoenixLetterGrade?" Value="letterGrade">@letterGrade.GetName()</MudSelectItem>
                    }
                </MudSelect>
            }
            @if (_lowestBpm != _highestBpm)
            {
                <MudNumericField T="decimal?" Clearable="true" Value="_settings.MinBpm" ValueChanged="SetSelectedMinBpm" Label=@L["Min BPM"] Min="_lowestBpm" Max="_highestBpm" HelperText="Not All BPMS Labeled Yet" HideSpinButtons="true"></MudNumericField>
                <MudNumericField T="decimal?" Clearable="true" Value="_settings.MaxBpm" ValueChanged="SetSelectedMaxBpm" Label=@L["Max BPM"] Min="_lowestBpm" Max="_highestBpm" HelperText="Not All BPMS Labeled Yet" HideSpinButtons="true"></MudNumericField>
            }
            @if (_lowestNoteCount != _highestNoteCount)
            {
                <MudNumericField T="int?" Clearable="true" Value="_settings.MinNoteCount" ValueChanged="SetMinNoteCount" Label=@L["Min Note Count"] Min="_lowestNoteCount" Max="_highestNoteCount" HelperText="Not All Note Counts Labeled Yet" HideSpinButtons="true"></MudNumericField>
                <MudNumericField T="int?" Clearable="true" Value="_settings.MaxNoteCount" ValueChanged="SetMaxNoteCount" Label=@L["Max Note Count"] Min="_lowestNoteCount" Max="_highestNoteCount" HelperText="Not All Note Counts Labeled Yet" HideSpinButtons="true"></MudNumericField>
            }
            <MudSelect T="string" SelectedValues="_settings.StepArtists" SelectedValuesChanged="SetSelectedStepArtists" Label=@L["Step Artist"] HelperText="Not All Step Artists Labeled Yet" MultiSelection="true" Clearable="true">
                @foreach (var artist in _availableStepArtists)
                {
                    <MudSelectItem T="string" Value="@artist">@artist</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" SelectedValues="_settings.SongArtists" SelectedValuesChanged="SetSelectedSongArtists" Label=@L["Song Artist"] MultiSelection="true" Clearable="true">
                @foreach (var artist in _availableSongArtists)
                {
                    <MudSelectItem T="string" Value="@artist">@artist</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">@L["Clear Filters"]</MudButton>
            <MudDivider></MudDivider>
            @* Columns: extra info on Comfortable cards / as Table columns. Compact is the
               jacket sticker sheet — nothing fits, so the switches disable there (round 7).
               "Show Difficulty" retired: the lens annotation is always on since round 6. *@
            <MudText Typo="Typo.subtitle1">@L["Display"]</MudText>
            @if (_density == UiDensity.Compact)
            {
                <MudText Typo="Typo.caption">@L["Not available in Compact view"]</MudText>
            }
            <MudSwitch T="bool" Color="Color.Primary" Value="_settings.ShowSongName" ValueChanged="SetShowName"
                       Disabled="_density != UiDensity.Comfortable" Label=@L["Show Song Name"]></MudSwitch>
            <MudSwitch T="bool" Color="Color.Primary" Value="_settings.ShowStepArtist" ValueChanged="SetShowStepArtist"
                       Disabled="_density == UiDensity.Compact" Label=@L["Show Step Artist"]></MudSwitch>
            <MudSwitch T="bool" Color="Color.Primary" Value="_settings.ShowSkills" ValueChanged="SetShowSkills"
                       Disabled="_density == UiDensity.Compact" Label=@L["Show Skills"]></MudSwitch>
            @if (CurrentUser.IsLoggedIn)
            {
                <MudSwitch T="bool" Color="Color.Primary" Value="_showAge" ValueChanged="SetShowAge"
                           Disabled="_density == UiDensity.Compact" Label=@L["Show Age"]></MudSwitch>
            }
        </text>;
    }
    <MudDrawer @bind-Open="_filtersOpen" Anchor="Anchor.Right" Variant="@DrawerVariant.Temporary" Width="320px">
        <div class="tier-filter-drawer">
            <div class="tier-drawer-head">
                <MudText Typo="Typo.h6">@L["Filters"]</MudText>
                <MudSpacer></MudSpacer>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => _filtersOpen = false"
                               aria-label="@L["Close"]"></MudIconButton>
            </div>
            @filterPanel
        </div>
    </MudDrawer>
    @* Round 9: the compact Advanced drawer replaces the bottom action bar (which
       stacked awkwardly on the shell's bottom nav). Owner-specced order: Ranked-by →
       Grouped-by → Personalized → Download. Filtering deliberately is NOT here —
       the Filters icon + drawer are the same at every width. *@
    <MudDrawer @bind-Open="_advancedOpen" Anchor="Anchor.Right" Variant="@DrawerVariant.Temporary" Width="320px">
        <div class="tier-filter-drawer">
            <div class="tier-drawer-head">
                <MudText Typo="Typo.h6">@L["Advanced"]</MudText>
                <MudSpacer></MudSpacer>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => _advancedOpen = false"
                               aria-label="@L["Close"]"></MudIconButton>
            </div>
            @lensControls
            @if (CurrentUser.IsLoggedIn && _chartType != ChartType.CoOp && _tierListType is "Pass" or "Score")
            {
                <MudSwitch T="bool" Color="Color.Primary" Value="_usePersonalizedData" ValueChanged="SetUsePersonalized" Label="@L["Personalized"]"></MudSwitch>
            }
            <MudButton OnClick="DownloadImage" Color="Color.Primary" Variant="Variant.Outlined"
                       StartIcon="@(_isBuildingImage ? null : Icons.Material.Filled.FileDownload)"
                       Disabled="_isBuildingImage || _isLoading">
                @if (_isBuildingImage)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2"></MudProgressCircular>
                    @L["Generating"]
                }
                else
                {
                    @L["Download"]
                }
            </MudButton>
        </div>
    </MudDrawer>
    <ChartDetailsDialog @bind-Visible="_detailsOpen" Chart="_detailsChart" Mix="_currentMix"
                        Score="_detailsChart != null && _scores.TryGetValue(_detailsChart.Id, out var detailsScore) ? detailsScore : null"
                        Ranking="_detailsChart != null && _scoreRankings.TryGetValue(_detailsChart.Id, out var detailsRank) ? detailsRank : null"
                        IsToDo="_detailsChart != null && _todos.Contains(_detailsChart.Id)"
                        ScoreAgeDays="@(_detailsChart != null && _scores.TryGetValue(_detailsChart.Id, out var detailsAge) ? (int)(_now - detailsAge.RecordedDate).TotalDays : null)"
                        OnToDo="ToggleToDo" OnScoreRecorded="RefreshScores"></ChartDetailsDialog>
    </div>
}
<style>
    /* Round 8: one clamp for 4K, one 960px breakpoint (matches the shell's bottom
       nav). Below it: two explicit toolbar rows, the bottom action bar takes over
       Download/Filters, and the strip + legend live behind the Folder Stats drawer. */
    .tier-page {
        max-width: 1680px;
        margin: 0 auto;
    }

    .tier-toolbar {
        position: sticky;
        top: 0;
        z-index: 20;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        margin-top: 12px;
        padding: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    /* Desktop: the rows (and the tier-flat wrappers around shared fragments)
       flatten away so the toolbar and content bar read as single lines. */
    .tier-toolbar-row,
    .tier-flat {
        display: contents;
    }

    .tier-compact-only {
        display: none;
    }

    @@media (max-width: 959.98px) {
        .tier-desktop-only {
            display: none;
        }

        .tier-compact-only {
            display: inline-flex;
        }

        .tier-toolbar {
            display: block;
        }

        .tier-toolbar-row {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

        /* The desktop-only second row (Personalized + Download) hides wholesale —
           the Advanced drawer carries both on compact. Two classes beat the
           display:flex row rule above. */
        .tier-toolbar-row.tier-desktop-only {
            display: none;
        }
    }

    /* Round 9: under 600px the Advanced button slots between the folder and the view
       group and the row centers, so the wrap lands as folder+Advanced / views instead
       of a ragged break. */
    @@media (max-width: 599.98px) {
        .tier-toolbar-row {
            justify-content: center;
        }

        .tier-advanced-btn {
            order: 1;
        }

        .tier-views-group {
            order: 2;
        }
    }

    .tier-toolbar-select {
        max-width: 190px;
    }

    .tier-content-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        margin: 8px 0 4px;
    }

    .tier-filter-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        align-items: center;
        margin-bottom: 4px;
    }

    .tier-filter-chips-label {
        font-size: .75rem;
        color: var(--mud-palette-text-secondary);
    }

    .tier-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin: 8px 0;
    }

    .tier-progress-strip {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        padding: 8px 12px;
        margin: 8px 0;
    }

    .tier-progress-strip-summary {
        display: flex;
        align-items: baseline;
        gap: 8px;
    }

    .tier-cohort-bar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin: 6px 0;
    }

    .tier-cohort-bar-label {
        font-size: .8rem;
        color: var(--mud-palette-text-secondary);
        min-width: 220px;
    }

    .tier-cohort-bar-meter {
        width: 160px;
        height: 6px;
        background: var(--mud-palette-lines-default);
        border-radius: 3px;
        overflow: hidden;
        display: inline-block;
    }

    .tier-cohort-bar-fill {
        display: block;
        height: 100%;
    }

    .tier-cohort-bar-value {
        font-size: .85rem;
        font-weight: 600;
    }

    .tier-cohort-bar-note {
        font-size: .75rem;
        color: var(--mud-palette-text-secondary);
    }

    @* Section / card / lamp / legend / folder-picker styles live in wwwroot/css/site.css —
       they belong to the shared components, not this page. *@
    .tier-table-wrap {
        overflow-x: auto;
    }

    .tier-table {
        width: 100%;
        border-collapse: collapse;
    }

    .tier-table th {
        text-align: left;
        color: var(--mud-palette-text-secondary);
        font-size: .75rem;
        padding: 4px 8px;
        border-bottom: 1px solid var(--mud-palette-lines-default);
    }

    .tier-table td {
        padding: 4px 8px;
        border-bottom: 1px solid var(--mud-palette-lines-default);
    }

    .tier-table-jacket-cell {
        width: 36px;
    }

    .tier-table-jacket {
        width: 32px;
        height: 32px;
        border-radius: 4px;
        background-size: cover;
        background-position: center;
        cursor: pointer;
    }

    .tier-table-skills {
        font-size: .8rem;
        color: var(--mud-palette-text-secondary);
    }

    .tier-row-pass td:first-child {
        border-left: 3px solid var(--mud-palette-success);
    }

    .tier-row-todo td:first-child {
        border-left: 3px dashed var(--mud-palette-info);
    }

    .tier-row-other-mix td:first-child {
        border-left: 3px dashed var(--mud-palette-success);
    }

    .tier-list-cta {
        border: 1px dashed var(--mud-palette-lines-default);
        border-radius: 8px;
        padding: 16px;
        margin: 12px 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-start;
    }

    .tier-list-cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .tier-filter-drawer {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    /* Round 12: every drawer gets an explicit close — the click-away overlay is
       unreliable on mobile. */
    .tier-drawer-head {
        display: flex;
        align-items: center;
    }

    .tier-attribution {
        color: var(--mud-palette-text-secondary);
        display: block;
        margin: 4px 0;
    }
</style>
@inject ICurrentUserAccessor CurrentUser;
@inject IMediator Mediator;
@inject NavigationManager NavManager;
@inject IUiSettingsAccessor UiSettings;
@inject ISnackbar Snackbar;
@inject IJSRuntime JSRuntime;
@code
{

    [Parameter]
    [SupplyParameterFromQuery(Name = "Difficulty")]
    public int? DifficultyFilter { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "ChartType")]
    public string? ChartTypeFilter { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "TierListType")]
    public string? TierListType { get; set; } = string.Empty;

    [Parameter] public string? ChartTypeRoute { get; set; }

    [Parameter] public int? LevelRoute { get; set; }

    private DateTimeOffset _now = DateTimeOffset.Now;

    private IDictionary<Guid, RecordedPhoenixScore> _scores = new Dictionary<Guid, RecordedPhoenixScore>();
    private IDictionary<Guid, RecordedPhoenixScore> _folderScores = new Dictionary<Guid, RecordedPhoenixScore>();
    private IDictionary<Guid, Chart> _charts = new Dictionary<Guid, Chart>();
    private IDictionary<Guid, double> _scoringLevels = new Dictionary<Guid, double>();
    private IDictionary<Guid, Chart> _allCharts = new Dictionary<Guid, Chart>();
    private ISet<Guid> _unPopularCharts = new HashSet<Guid>();
    private ISet<Guid> _popularCharts = new HashSet<Guid>();
    private IReadOnlySet<Guid> _otherMixPasses = new HashSet<Guid>();
    private bool _isBuildingImage = false;
    private FilterSettings _settings = new FilterSettings();
    private const string UserSettingsKey = @"ChartSkills__Settings";

    private async Task SaveSettings()
    {
        await UiSettings.SetSetting(UserSettingsKey, JsonSerializer.Serialize(_settings));
    }

    private sealed class FilterSettings
    {
        public HashSet<SongType> SongTypes { get; set; } = new HashSet<SongType>();
        public bool? ToDo { get; set; }
        public bool? Completion { get; set; }
        public PhoenixLetterGrade? MinLetterGrade { get; set; }
        public PhoenixLetterGrade? MaxLetterGrade { get; set; }
        public decimal? MinBpm { get; set; }
        public decimal? MaxBpm { get; set; }
        public bool ShowStepArtist { get; set; }
        public bool ShowSongName { get; set; } = true;
        public bool ShowSkills { get; set; } = true;
        public int? MinNoteCount { get; set; }
        public int? MaxNoteCount { get; set; }
        public HashSet<string> StepArtists { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        public HashSet<string> SongArtists { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    }
    // Color is the on-screen CSS token reference; ShareHex is the same hue resolved to a
    // raw hex for the share-card renderer (which can't read CSS custom properties).
    private sealed record TierGroup(string Key, string Name, string Color, string ShareHex, IReadOnlyList<SongTierListEntry> Entries);

    private IEnumerable<TitleProgress> _titleProgress = Array.Empty<TitleProgress>();
    private IEnumerable<Guid> _unpassedTodos => _finalEntries.Select(e => e.ChartId).Where(chartId => _scores.ContainsKey(chartId) && _scores[chartId].IsBroken && _todos.Contains(chartId));
    private IDictionary<Guid, TierListCategory> _chartDifficulties = new Dictionary<Guid, TierListCategory>();
    private Name[] _availableStepArtists = Array.Empty<Name>();
    private Name[] _availableSongArtists = Array.Empty<Name>();
    private int _lowestNoteCount = 0;
    private int _highestNoteCount = 0;
    private decimal _lowestBpm = 0;
    private decimal _highestBpm = 0;
    private ChartType _chartType = ChartType.Double;
    // Round-2 decision: density persists PER PAGE ("you use different ones based on
    // your current task"), never a site-wide Universal__ key.
    private const string DensitySettingKey = "Density__TierLists";
    private UiDensity _density = UiDensity.Comfortable;
    private bool _isLoading = true;
    private bool _showAge = false;
    private bool _filtersOpen = false;
    // Title bars default collapsed (round-6 field test); general progress always shows.
    private bool _titlesCollapsed = true;
    private HashSet<string> _collapsedTiers = new HashSet<string>();

    private ISet<Guid> _todos = new HashSet<Guid>();

    private IReadOnlyList<LampStrip.Lamp> _lamps = Array.Empty<LampStrip.Lamp>();
    private Task<IEnumerable<string>> FilterSongName(string search) => Task.FromResult(_finalEntries.Select(c => _charts[c.ChartId].Song.Name.ToString()).Distinct().Where(
        n => string.IsNullOrWhiteSpace(search) || n.Contains(search, StringComparison.OrdinalIgnoreCase)).OrderBy(n => n == search ? 0 : 1).AsEnumerable());

    private async Task SetSongTypeFilter(IEnumerable<SongType> s)
    {
        _settings.SongTypes = s.Distinct().ToHashSet();
        await SaveSettings();
    }

    private async Task SetTodoFilter(bool? newValue)
    {
        _settings.ToDo = newValue;
        await SaveSettings();
    }

    private async Task SetSelectedSongArtists(IEnumerable<string> artists)
    {
        _settings.SongArtists = artists.Distinct(StringComparer.OrdinalIgnoreCase).ToHashSet(StringComparer.OrdinalIgnoreCase);
        await SaveSettings();
    }

    private async Task SetSelectedStepArtists(IEnumerable<string> artists)
    {
        _settings.StepArtists = artists.Distinct(StringComparer.OrdinalIgnoreCase).ToHashSet(StringComparer.OrdinalIgnoreCase);
        await SaveSettings();
    }

    private async Task SetSelectedMinBpm(decimal? bpm)
    {
        _settings.MinBpm = bpm;
        await SaveSettings();
    }
    private async Task SetSelectedMaxBpm(decimal? bpm)
    {
        _settings.MaxBpm = bpm;
        await SaveSettings();
    }

    private async Task SetMinNoteCount(int? noteCount)
    {
        _settings.MinNoteCount = noteCount;
        await SaveSettings();
    }
    private async Task SetMaxNoteCount(int? noteCount)
    {
        _settings.MaxNoteCount = noteCount;
        await SaveSettings();
    }

    private async Task SetCompletionFilter(bool? completion)
    {
        _settings.Completion = completion;
        await SaveSettings();
    }

    private async Task SetMinLetterGrade(PhoenixLetterGrade? grade)
    {
        _settings.MinLetterGrade = grade;
        await SaveSettings();
    }
    private async Task SetMaxLetterGrade(PhoenixLetterGrade? grade)
    {
        _settings.MaxLetterGrade = grade;
        await SaveSettings();
    }

    private async Task SetShowSkills(bool show)
    {
        _settings.ShowSkills = show;
        await SaveSettings();
    }

    private async Task SetShowStepArtist(bool show)
    {
        _settings.ShowStepArtist = show;
        await SaveSettings();
    }
    private async Task SetShowName(bool show)
    {
        _settings.ShowSongName = show;
        await SaveSettings();
    }

    private async Task SetDensity(UiDensity density)
    {
        _density = density;
        await UiSettings.SetSetting(DensitySettingKey, density.ToString());
    }

    private bool _detailsOpen = false;
    private Chart? _detailsChart;

    private void OpenDetails(Guid chartId)
    {
        if (!_charts.TryGetValue(chartId, out var chart)) return;
        _detailsChart = chart;
        _detailsOpen = true;
    }

    private async Task RefreshScores()
    {
        if (!CurrentUser.IsLoggedIn) return;
        _scores = (await Mediator.Send(new GetPhoenixRecordsQuery(CurrentUser.User.Id, _currentMix)))
            .ToDictionary(c => c.ChartId);
        await Recalculate();
    }

    private string RowClass(Guid chartId, RecordedPhoenixScore? score)
    {
        return score is { IsBroken: false } ? "tier-row-pass" :
            _todos.Contains(chartId) ? "tier-row-todo" :
            _otherMixPasses.Contains(chartId) ? "tier-row-other-mix" : string.Empty;
    }

    private async Task SetShowAge(bool newSetting)
    {
        _showAge = newSetting;
        await UiSettings.SetSetting("TierLists__ShowAge", newSetting.ToString());
    }

    // --- Active-filter chips ---------------------------------------------------------

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_songFilter) || _settings.SongTypes.Any() || _settings.ToDo != null ||
        _settings.Completion != null || _settings.MinLetterGrade != null || _settings.MaxLetterGrade != null ||
        _settings.MinBpm != null || _settings.MaxBpm != null || _settings.MinNoteCount != null ||
        _settings.MaxNoteCount != null || _settings.StepArtists.Any() || _settings.SongArtists.Any();

    // Counts one per chip, matching the chips row exactly (min/max pairs are one chip).
    private int ActiveFilterCount =>
        (string.IsNullOrWhiteSpace(_songFilter) ? 0 : 1) +
        (_settings.SongTypes.Any() ? 1 : 0) +
        (_settings.ToDo != null ? 1 : 0) +
        (_settings.Completion != null ? 1 : 0) +
        (_settings.MinLetterGrade != null || _settings.MaxLetterGrade != null ? 1 : 0) +
        (_settings.MinBpm != null || _settings.MaxBpm != null ? 1 : 0) +
        (_settings.MinNoteCount != null || _settings.MaxNoteCount != null ? 1 : 0) +
        (_settings.StepArtists.Any() ? 1 : 0) +
        (_settings.SongArtists.Any() ? 1 : 0);

    private Task ClearSongNameFilter()
    {
        _songFilter = null;
        return Task.CompletedTask;
    }

    private async Task ClearSongTypeFilter()
    {
        _settings.SongTypes.Clear();
        await SaveSettings();
    }

    private async Task ClearToDoFilter()
    {
        _settings.ToDo = null;
        await SaveSettings();
    }

    private async Task ClearCompletionFilter()
    {
        _settings.Completion = null;
        await SaveSettings();
    }

    private async Task ClearLetterGradeFilter()
    {
        _settings.MinLetterGrade = null;
        _settings.MaxLetterGrade = null;
        await SaveSettings();
    }

    private async Task ClearBpmFilter()
    {
        _settings.MinBpm = null;
        _settings.MaxBpm = null;
        await SaveSettings();
    }

    private async Task ClearNoteCountFilter()
    {
        _settings.MinNoteCount = null;
        _settings.MaxNoteCount = null;
        await SaveSettings();
    }

    private async Task ClearStepArtistFilter()
    {
        _settings.StepArtists.Clear();
        await SaveSettings();
    }

    private async Task ClearSongArtistFilter()
    {
        _settings.SongArtists.Clear();
        await SaveSettings();
    }

    private async Task ClearFilters()
    {
        _songFilter = null;
        _settings.SongTypes.Clear();
        _settings.ToDo = null;
        _settings.Completion = null;
        _settings.MinLetterGrade = null;
        _settings.MaxLetterGrade = null;
        _settings.MinBpm = null;
        _settings.MaxBpm = null;
        _settings.MinNoteCount = null;
        _settings.MaxNoteCount = null;
        _settings.StepArtists.Clear();
        _settings.SongArtists.Clear();
        await SaveSettings();
    }

    // --- Share image (SkiaSharp renderer via IShareCardRenderer, C8) --------------------

    public string DifficultyBubblePath(ChartType chartType, DifficultyLevel level) => $"https://piuimages.arroweclip.se/difficulty/{_currentMix}/{chartType.GetShortHand().ToLower()}{level}.png";
    private string LetterGradeImage(PhoenixLetterGrade letterGrade, bool isBroken) =>
        $"https://piuimages.arroweclip.se/letters/{letterGrade.ToString().ToLower()}{(isBroken ? "_broken" : "")}.png";

    private string PlateImage(PhoenixPlate plate) => $"https://piuimages.arroweclip.se/plates/{plate.GetShorthand().ToLower()}.png";

    private string LensDisplayName(string lens) => lens switch
    {
        "Pass" => L["Pass Difficulty"],
        "Score" => L["Score Difficulty"],
        "Popularity" => L["Popularity"],
        _ => lens
    };

    private async Task DownloadImage()
    {
        _isBuildingImage = true;
        try
        {
            var palette = MixThemes.PaletteFor(_currentMix);
            var rows = _groups
                .Select(g => (Group: g,
                    Entries: g.Entries.Where(ShouldChartShow).Where(e => _charts.ContainsKey(e.ChartId)).ToArray()))
                .Where(g => g.Entries.Any())
                .Select(g => new TierListShareCard.Row(g.Group.Name, g.Group.ShareHex, g.Entries
                    .Select(e =>
                    {
                        var chart = _charts[e.ChartId];
                        var score = _scores.TryGetValue(chart.Id, out var s) ? s : null;
                        return new TierListShareCard.Tile(
                            chart.Song.ImagePath.ToString(),
                            score?.Score != null
                                ? LetterGradeImage(score.Score.Value.LetterGrade, score.IsBroken)
                                : null,
                            score?.Plate != null ? PlateImage(score.Plate.Value) : null,
                            score is { IsBroken: false } ? MixPalette.Success :
                            _todos.Contains(chart.Id) ? MixPalette.Info : null);
                    })
                    .ToArray()))
                .ToArray();
            var title = _chartType == ChartType.CoOp
                ? $"{L["CoOp"]} ×{_level}"
                : $"{L[_chartType == ChartType.Single ? "Singles" : "Doubles"]} {_level}";
            var stamp = PersonalizedActive
                ? L["Personalized for {0}", CurrentUser.User.GameTag ?? CurrentUser.User.Name].ToString()
                : L["Community"].ToString();
            var linkUrl = $"https://piuscores.arroweclip.se/TierLists/{_chartType}/{_level}";
            var card = new TierListShareCard(
                title,
                $"{LensDisplayName(_tierListType)} · {_currentMix} · {_now:yyyy-MM-dd}",
                stamp,
                palette.Primary,
                palette.Background,
                palette.Surface,
                palette.Ink,
                palette.InkMuted,
                linkUrl,
                DifficultyBubblePath(_chartType, _level),
                rows);

            var bytes = await Mediator.Send(new GetTierListShareCardQuery(card));
            using var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            var module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/helpers.js");
            await module.InvokeVoidAsync("downloadFileFromStream",
                $"TierList_{_chartType}{_level}_{_now:yyyy-MM-dd}.png", streamRef);
        }
        finally
        {
            _isBuildingImage = false;
        }
    }

    // --- Filtering ---------------------------------------------------------------------

    private bool ShouldChartShow(SongTierListEntry entry)
    {
        var score = _scores.TryGetValue(entry.ChartId, out var scr) ? scr : null;
        if (_settings.MinLetterGrade != null && (score?.Score == null || score.Score.Value.LetterGrade < _settings.MinLetterGrade))
        {
            return false;
        }
        if (_settings.MaxLetterGrade != null && (score?.Score == null || score.Score.Value.LetterGrade > _settings.MaxLetterGrade))
        {
            return false;
        }
        if (_settings.Completion != null && _settings.Completion != (_scores.TryGetValue(entry.ChartId, out var s) && !s.IsBroken))
        {
            return false;
        }
        if (_settings.ToDo != null && _settings.ToDo != _todos.Contains(entry.ChartId))
        {
            return false;
        }
        var chart = _charts[entry.ChartId];
        if (_settings.SongTypes.Any() && !_settings.SongTypes.Contains(chart.Song.Type))
        {
            return false;
        }
        if (!string.IsNullOrWhiteSpace(_songFilter) && !chart.Song.Name.ToString().Contains(_songFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }
        if (_settings.MaxBpm != null && (chart.Song.Bpm == null || chart.Song.Bpm.Value.Max > _settings.MaxBpm))
        {
            return false;
        }
        if (_settings.MinBpm != null && (chart.Song.Bpm == null || chart.Song.Bpm.Value.Min < _settings.MinBpm))
        {
            return false;
        }
        if (_settings.StepArtists.Any() && !_settings.StepArtists.Contains(chart.StepArtist?.ToString() ?? "Unknown"))
        {
            return false;
        }
        if (_settings.SongArtists.Any() && !_settings.SongArtists.Contains(chart.Song.Artist.ToString()))
        {
            return false;
        }
        if (_settings.MinNoteCount != null && (chart.NoteCount == null || chart.NoteCount < _settings.MinNoteCount))
        {
            return false;
        }
        if (_settings.MaxNoteCount != null && (chart.NoteCount == null || chart.NoteCount > _settings.MaxNoteCount))
        {
            return false;
        }
        return true;
    }

